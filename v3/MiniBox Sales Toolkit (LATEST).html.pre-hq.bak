      #tab-pulmo .plp-cpt:last-child { border-bottom:none; }
      #tab-pulmo .plp-cpt-code { font-family:'DM Mono','SF Mono',monospace; font-weight:600; font-size:16px; color:var(--plt); min-width:58px; }
      #tab-pulmo .plp-cpt-desc { font-size:13px; color:var(--plsoft); }
