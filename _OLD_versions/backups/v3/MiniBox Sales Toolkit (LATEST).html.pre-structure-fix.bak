                  <div class="rh-diag-drug">&#8595; On cyclophosphamide &rarr; up to 4x/yr</div>
                </div></td>
                <td><div class="cell"><span class="rh-icd-pill">M33.11</span><span class="rh-icd-pill">M33.21</span></div></td>
                <td><div class="cell"><span class="rh-code-pill">94010</span><span class="rh-code-pill">94726</span><span class="rh-code-pill">94729</span></div></td>
