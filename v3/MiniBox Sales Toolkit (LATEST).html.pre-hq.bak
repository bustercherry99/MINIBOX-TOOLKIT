/* ============ v3.0 MATERIALS REGISTRY ============ */
var MATERIALS = [
  {id:'brochure',    file:'MiniBox-Plus-Brochure.pdf',            title:'MiniBox+ Product Brochure',           sub:'Specs, workflow overview, connectivity, EHR integration', cat:'send',     kb:196,  blurb:'MiniBox+ Product Brochure — specs, workflow overview, connectivity options, and EHR integration details.'},
  {id:'why',         file:'Why-MiniBox.pdf',                      title:'“Why MiniBox+” Overview',   sub:'The one-pager that makes the case',                       cat:'send',     kb:373,  blurb:'“Why MiniBox+” Overview — a one-page summary of what sets the device apart.'},
  {id:'samplereport',file:'Sample-PFT-Report.pdf',                title:'Sample PFT Report',                   sub:'What the doctor sees after each test',                    cat:'send',     kb:149,  blurb:'Sample PFT Report — the report your team and referring physicians will see after each test.'},
  {id:'comparison',  file:'MiniBox-Competitive-Comparison.pdf',   title:'Competitive Comparison',              sub:'MiniBox+ vs. body boxes & competitors',                   cat:'send',     kb:400,  blurb:'Competitive Comparison — how the MiniBox+ stacks up against conventional body boxes and competing systems.'},
  {id:'eolletter',   file:'MiniBox-End-of-Life-Letter.pdf',       title:'MiniBox End-of-Life Letter (Official)', sub:'Signed CEO notice — early MiniBox units EOL July 1, 2026; opens the upgrade conversation', cat:'send', kb:173, blurb:'Official End-of-Life Notification for early-generation MiniBox systems (signed by CEO Avi Lazar, Oct 8, 2025) — units sold through 2016 reach End-of-Life on July 1, 2026, after which parts and updates are subject to availability. The letter that opens the MiniBox+ upgrade / trade-in conversation.'},
  {id:'aging-concerns',file:'MiniBox-Plus-Aging-Unit-Concerns.pdf', title:'Aging Unit Concerns (MiniBox+)',   sub:'The failure patterns to expect as a unit passes its 10-year lifetime', cat:'send', kb:5, blurb:'MiniBox+ Aging Unit Concerns — a short reference on the failure patterns that surface as an early MiniBox unit approaches and passes its rated 10-year lifetime (DLCO gas system, occluder valve, tablet / battery). The companion to the End-of-Life Letter for opening the upgrade / trade-in conversation.'},
  {id:'chestsum',    file:'CHEST-2021-Study-Summary.pdf',         title:'CHEST 2021 Study — Summary',     sub:'The validation study at a glance',                        cat:'clinical', kb:201,  blurb:'CHEST 2021 Study Summary — the validation study at a glance (700+ patients across 11 medical centers).'},
  {id:'chestfull',   file:'CHEST-2021-Full-Article.pdf',          title:'CHEST 2021 Study — Full Article',sub:'Complete peer-reviewed validation paper',                 cat:'clinical', kb:1434, blurb:'CHEST 2021 Full Article — the complete peer-reviewed validation paper.'},
  {id:'verona',      file:'Verona-Study.pdf',                     title:'Verona Study',                        sub:'Additional published clinical evidence',                  cat:'clinical', kb:85,   blurb:'Verona Study — additional published clinical evidence.'},
  {id:'coaching',    file:'PFT-Coaching-Sheet.pdf',               title:'MiniBox+ PFT Coaching Sheet (2-sided)', sub:'Front: how to set up &amp; coach FVC, LVM, DLCO. Back: the in-progress screens and what to check', cat:'training', kb:916,  blurb:'MiniBox+ PFT Coaching Sheet — the two-sided chairside sheet a tech keeps next to the device. Front side: setup and word-for-word coaching for FVC (Forced Vital Capacity), LVM (Lung Volume Measurement) and DLCO (Diffusion Capacity). Back side: the real in-progress test screens with the quality checks to look for — did the patient pause at the top of inhalation, did the wheel turn green, were the tidal breaths under one liter, did they reach the green dotted line, did they hold the breath long enough. Print it double-sided and leave it in the room.'},
  {id:'dlco',        file:'DLCO-Gas-Requirements.pdf',            title:'DLCO Gas Requirements',               sub:'What’s needed on-site for DLCO',                     cat:'tech',     kb:181,  blurb:'DLCO Gas Requirements — what’s needed on-site for DLCO testing.'},
  {id:'hl7',         file:'HL7-Conformance-Statement-2025.pdf',   title:'HL7 Conformance Statement (2025)',    sub:'For the practice’s IT / EHR team',                   cat:'tech',     kb:561,  blurb:'HL7 Conformance Statement (2025) — integration documentation for your IT/EHR team.'},
  {id:'mds2',        file:'MDS2-Cybersecurity-Statement.pdf',     title:'MDS2 Cybersecurity Statement',        sub:'Security documentation for IT review',                    cat:'tech',     kb:271,  blurb:'MDS2 Cybersecurity Statement — security documentation for your IT review.'},
  {id:'manual',      file:'MiniBox-User-Manual-Rev20.pdf',        title:'User Manual (Rev 20)',                sub:'Full manual — too large to email, view/download only', cat:'tech',    kb:8559, noembed:true, blurb:''},
  {id:'certificate', file:'Manufacturer-Certificate.pdf',         title:'Manufacturer Certificate',            sub:'Official MiniBox+ certification',                         cat:'closing',  kb:356,  blurb:'Manufacturer Certificate — official certification for the MiniBox+.'},
  {id:'financing',   file:'Financing-Quick-Application-2025.pdf', title:'Financing Quick Application (2025)',  sub:'GFS application — 12/24/36-month structures',        cat:'closing',  kb:1211, blurb:'Financing Quick Application — flexible 12, 24, and 36-month structures sized to keep the monthly cost below the revenue the device generates.'},
