      #tab-pulmo .plsub-nav { display:flex; flex-wrap:wrap; gap:8px; margin:4px 0 18px; }
      #tab-pulmo .plsub-btn { font-size:13px; font-weight:700; border:1.5px solid var(--gray-300); color:var(--gray-600); background:#fff; border-radius:999px; padding:8px 18px; cursor:pointer; transition:all .12s; }
      #tab-pulmo .plsub-btn:hover { border-color:#185fa5; color:#0f4a85; }
      #tab-pulmo .plsub-btn.on { border-color:#185fa5; background:#eff6ff; color:#0f4a85; }
      #tab-pulmo .plp-files-cta { display:flex; flex-wrap:wrap; gap:14px; align-items:center; justify-content:space-between; background:linear-gradient(180deg,#f5f9ff,#eff6ff); border:1.5px solid var(--plt-line); border-left:5px solid var(--plt); border-radius:12px; padding:15px 18px; margin:0 0 16px; }
      #tab-pulmo .plp-files-cta-h { font-size:15px; font-weight:800; color:var(--plink); }
      #tab-pulmo .plp-files-cta-s { font-size:12.5px; color:var(--plsoft); margin-top:3px; line-height:1.5; }
      #tab-pulmo .plp-files-cta-btns { display:flex; gap:8px; flex-wrap:wrap; }
      #tab-pulmo .plp-files-cta-btns button { font-size:13px; font-weight:700; border:none; border-radius:999px; padding:10px 18px; cursor:pointer; background:var(--plt); color:#fff; }
