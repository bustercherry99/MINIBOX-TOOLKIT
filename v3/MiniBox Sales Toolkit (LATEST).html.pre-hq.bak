      <div class="card"><div class="card-title">HR / People</div><div class="card-body">&rarr; Manager &rarr; HRBP<br>[contact]</div></div>
      <div class="card"><div class="card-title">IT / Security</div><div class="card-body">&rarr; IT Helpdesk (24/7 security)<br>[contact]</div></div>
      <div class="card"><div class="card-title">Finance / Expense</div><div class="card-body">&rarr; Manager &rarr; AP / Finance<br>[contact]</div></div>
