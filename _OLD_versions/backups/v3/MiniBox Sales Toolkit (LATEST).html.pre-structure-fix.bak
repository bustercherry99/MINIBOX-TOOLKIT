<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>MiniBox+ Master Reference Toolkit</title>
<!-- v3.6: RMA form placeholders simplified to "Type here", date auto-fills to today; manual entry, on-screen signature, PDF+share send; auto-fill deferred -->
<!-- v3.7: Added NewLane Financing tab (customer-facing) — enter price, shows 12/24/36-mo monthly payments @ 1.99/2.99/3.99% APR; PulmOne discount not displayed by design -->
<!-- v3.9: Repositioned/padded PulmOne logo in Installation Completion Form header so it is no longer clipped by the header border -->
<!-- v3.8: Added Installation Completion Form (DHR008 Rev 4.0) embedded in Forms tab — tap Yes/No, cursive signatures, auto-resize iframe, Save as PDF -->
<!-- v3.10: Removed all placeholder hint text (e.g. "Dr. Jane Smith", "30000.00", schedule dates) from the scheduled-payment ACH Authorization Form so printed/DocuSign copy carries zero on-line text — matches the blank Full-Payment ACH form -->
<!-- v3.9: ACH Authorization Form opens fully BLANK for clean DocuSign overlays — removed Date auto-fill (today), # of Payments default (6), and Balance "$0.00"; all placeholders already hidden in print -->
<!-- v3.11: RMA form upgraded to v1.5 — signature now uses Pointer Events (mouse + finger + stylus/pen all work), added Draw/Type cursive signature toggle, and photo attach that embeds downscaled photos as pages inside the sent PDF; iframe height raised to 2050px -->
<!-- v3.12: SINGLE-SIGNATURE FIX for Outlook Web sends — OWA injects the account's auto-signature at the top of link-composed emails (no way to suppress via URL), which doubled up with the toolkit's signature. Outlook Web buttons now open compose with To/Subject only, strip the toolkit signature, and put the body on the clipboard for a Ctrl+V paste ABOVE the auto-signature → exactly one signature, at the bottom. Desktop mailto + .eml drafts keep the toolkit signature (those paths don't auto-insert one). -->
<!-- v3.14: ONE SEND BUTTON — team is 100% PulmOne Microsoft 365 Outlook, so both email modes now show a single green "Send with Outlook" button (the proven compose+paste+drag flow) plus a small Copy fallback. Removed: Outlook Draft .eml (unopenable in web/New Outlook), Outlook Desktop mailto (wrong-account/body-wipe bug), Copy & Open Blank Outlook (redundant), purple zip button (zipping is automatic). Send-help is now one uniform 3-step note; welcome wizard no longer asks which Outlook; practice run rehearses the real flow instead of downloading an .eml. Old send functions remain defined but unreferenced. -->
<!-- v3.13: AUTO-ZIP multi-file sends — the Outlook Web / Outlook Desktop "+ files" buttons downloaded each PDF loose, and browsers set to "always open PDFs" launched Adobe Acrobat for every one (looked like Acrobat was "blocking attachments"). Now 2+ selected materials auto-bundle into ONE .zip (single material still downloads as a plain PDF); zips never trigger Acrobat and it's one drag into the email. Same proven workflow as the purple zip button, now automatic. -->
<!-- v2.27: installable web-app + full-screen on iPad (Add to Home Screen). Hosting required for true PWA install. -->
<!-- v3.15: Cardiology tab now has a Rheum-style sub-nav — The Playbook (full interactive MiniBox Cardiology Playbook embedded via srcdoc iframe with auto-height: Rep Playbook view + "Show the Doctor" view with live ROI dials) and Evidence & Billing (the existing sourced evidence, billing table, and files, unchanged) -->
<!-- v3.17: NEW My Day tab (row 3) framework. Stop list with Maps links, arrive/depart visit stamps, per leg mileage with IRS rate math, expense log, copy ready end of day prose report. Map, GPS geofence auto arrival, auto drive miles, and receipt photos are marked Coming. Also repaired v3.16 file truncation by splicing tail from pre-specialties-menu backup. -->
<meta name="theme-color" content="#0a3d6b">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="MiniBox+ Toolkit">
<meta name="description" content="MiniBox+ field sales toolkit — ROI, CPT codes, clinical proof, competitive positioning, forms, and email center.">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%230a3d6b'/%3E%3Ctext x='32' y='44' font-size='34' font-family='Arial,sans-serif' font-weight='700' fill='%23ffffff' text-anchor='middle'%3EM%2B%3C/text%3E%3C/svg%3E">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap');

  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --blue-dark: #0a3d6b;
    --blue-mid: #0c5299;
    --blue-brand: #0e6abf;
    --blue-light: #d6eaf8;
    --teal: #0e9e8e;
    --teal-light: #d4f5f1;
    --amber: #e67e22;
    --amber-light: #fef3e2;
    --red: #c0392b;
    --red-light: #fde8e6;
    --green: #27ae60;
    --green-light: #e8f8f0;
    --gray-100: #f4f6f9;
    --gray-200: #e8ecf0;
    --gray-300: #c8d0d8;
    --gray-600: #5a6a7a;
    --gray-800: #1e2d3d;
    --text: #1a2733;
  }

  body {
    font-family: 'Inter', sans-serif;
    background: #eef2f7;
    color: var(--text);
    min-height: 100vh;
  }

  /* HEADER */
  .site-header {
    background: var(--blue-dark);
    padding: 0;
  }
  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 28px 32px 0;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .header-brand { font-size: 11px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: #7ab6e0; margin-bottom: 5px; }
  .header-title { font-size: 28px; font-weight: 700; color: #fff; line-height: 1.15; }
  .header-sub { font-size: 13px; color: #a8d0ee; margin-top: 5px; }
  .header-badges { display: flex; gap: 8px; flex-wrap: wrap; padding-bottom: 4px; }
  .hbadge { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.18); border-radius: 5px; padding: 4px 12px; font-size: 11px; font-weight: 500; color: #cce4f7; white-space: nowrap; }

  /* TABS — TWO-ROW LAYOUT, EVENLY DISTRIBUTED */
  .tab-bar {
    background: var(--blue-mid);
    border-bottom: none;
  }
  .tab-bar-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .tab-row {
    display: flex;
    width: 100%;
    gap: 0;
  }
  .tab-row:first-child {
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .tab-btn {
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    padding: 13px 6px;
    font-family: 'Inter', sans-serif;
    font-size: 11.5px;
    font-weight: 500;
    color: rgba(255,255,255,0.6);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    flex: 1 1 0;
    min-width: 0;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tab-btn:hover { color: rgba(255,255,255,0.95); background: rgba(255,255,255,0.05); }
  .tab-btn.active { color: #fff; border-bottom-color: #5bc8f5; background: rgba(255,255,255,0.06); }

  /* SPECIALTIES DROPDOWN — hover opens on desktop, tap toggles on touch */
  .tab-dd { position: relative; flex: 1 1 0; min-width: 0; display: flex; }
  .tab-dd .tab-dd-parent { width: 100%; }
  .tab-dd .tab-dd-caret { font-size: 8px; opacity: .7; margin-left: 3px; }
  .tab-dd-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: 215px;
    background: var(--blue-mid);
    border: 1px solid rgba(255,255,255,0.16);
    border-top: none;
    border-radius: 0 0 12px 12px;
    box-shadow: 0 14px 30px rgba(0,0,0,0.38);
    padding: 6px;
    z-index: 400;
  }
  .tab-dd:hover .tab-dd-menu, .tab-dd.open .tab-dd-menu { display: block; }
  .tab-dd-menu .tab-btn {
    display: block;
    width: 100%;
    flex: none;
    text-align: left;
    border-bottom: none;
    border-left: 3px solid transparent;
    border-radius: 8px;
    padding: 11px 13px;
    font-size: 12.5px;
    font-weight: 700;
  }
  .tab-dd-menu .tab-btn.active { border-left-color: #5bc8f5; border-bottom-color: transparent; }
  @media (max-width: 720px) {
    .tab-btn { font-size: 10.5px; padding: 11px 4px; }
    .tab-bar-inner { padding: 0 10px; }
    .tab-dd-menu { left: auto; right: 0; transform: none; }
  }

  /* CONTENT */
  .content-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 32px 32px 60px;
  }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* SECTION TITLE */
  .section-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }
  .section-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }
  .icon-blue { background: var(--blue-light); }
  .icon-teal { background: var(--teal-light); }
  .icon-amber { background: var(--amber-light); }
  .icon-green { background: var(--green-light); }
  .section-title { font-size: 22px; font-weight: 700; color: var(--blue-dark); }
  .section-sub { font-size: 13px; color: var(--gray-600); margin-top: 2px; }

  /* CARD GRID */
  .card-grid { display: grid; gap: 16px; }
  .grid-2 { grid-template-columns: repeat(2, 1fr); }
  .grid-3 { grid-template-columns: repeat(3, 1fr); }
  .grid-4 { grid-template-columns: repeat(4, 1fr); }

  .card {
    background: #fff;
    border-radius: 10px;
    border: 1px solid var(--gray-200);
    padding: 20px 22px;
  }
  .card-title { font-size: 13px; font-weight: 600; color: var(--blue-dark); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.06em; }
  .card-body { font-size: 13.5px; color: #374151; line-height: 1.65; }
  .card-body strong { font-weight: 600; color: var(--blue-dark); }

  /* STAT CARDS */
  .stat-card {
    background: #fff;
    border-radius: 10px;
    border: 1px solid var(--gray-200);
    padding: 18px 20px;
    text-align: center;
  }
  .stat-num { font-size: 32px; font-weight: 700; color: var(--blue-brand); line-height: 1; margin-bottom: 6px; }
  .stat-label { font-size: 12px; font-weight: 600; color: var(--gray-600); text-transform: uppercase; letter-spacing: 0.08em; line-height: 1.4; }
  .stat-sub { font-size: 11.5px; color: var(--gray-600); margin-top: 4px; }

  /* COMPARISON TABLE */
  .comp-table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 10px; overflow: hidden; border: 1px solid var(--gray-200); }
  .comp-table th { padding: 14px 16px; font-size: 12px; font-weight: 700; text-align: center; text-transform: uppercase; letter-spacing: 0.08em; }
  .comp-table th.row-label { text-align: left; background: var(--gray-100); color: var(--gray-600); }
  .comp-table th.col-mini { background: var(--blue-dark); color: #fff; }
  .comp-table th.col-other { background: var(--gray-600); color: #fff; }
  .comp-table td { padding: 12px 16px; font-size: 13px; border-top: 1px solid var(--gray-200); }
  .comp-table td.row-label { font-weight: 600; color: var(--gray-800); background: var(--gray-100); font-size: 12.5px; }
  .comp-table td.col-mini { text-align: center; color: #14532d; background: #f0fdf4; font-weight: 500; }
  .comp-table td.col-other { text-align: center; color: #7f1d1d; background: #fff5f5; }
  .check { color: var(--green); font-weight: 700; }
  .cross { color: var(--red); }

  /* CPT TABLE */
  .cpt-table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 10px; overflow: hidden; border: 1px solid var(--gray-200); }
  .cpt-table th { background: var(--blue-dark); color: #fff; padding: 12px 16px; font-size: 12px; font-weight: 600; text-align: left; letter-spacing: 0.06em; text-transform: uppercase; }
  .cpt-table td { padding: 13px 16px; font-size: 13.5px; border-top: 1px solid var(--gray-200); }
  .cpt-table tr:nth-child(even) td { background: var(--gray-100); }
  .cpt-code { font-family: 'DM Mono', monospace; font-size: 13px; font-weight: 500; color: var(--blue-brand); background: var(--blue-light); padding: 3px 8px; border-radius: 4px; }
  .cpt-rate { font-weight: 600; color: var(--green); }

  /* COACHING CARDS */
  .coaching-card {
    background: #fff;
    border-radius: 10px;
    border: 1px solid var(--gray-200);
    overflow: hidden;
    margin-bottom: 16px;
  }
  .coaching-header {
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .coaching-tag {
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    padding: 5px 14px;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .tag-fvc { background: #dbeafe; color: #1e40af; }
  .tag-lvm { background: #fef3c7; color: #92400e; }
  .tag-dlco { background: #ede9fe; color: #6d28d9; }
  .coaching-name { font-size: 16px; font-weight: 700; color: var(--blue-dark); }
  .coaching-desc { font-size: 12px; color: var(--gray-600); margin-top: 1px; }
  .coaching-body { padding: 0 20px 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .coaching-col-title { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--blue-brand); margin-bottom: 8px; }
  .coaching-list { list-style: none; display: flex; flex-direction: column; gap: 7px; }
  .coaching-list li { display: flex; gap: 9px; align-items: flex-start; font-size: 13px; color: #374151; line-height: 1.5; }
  .cli-num { background: var(--blue-brand); color: #fff; font-size: 9px; font-weight: 700; width: 17px; height: 17px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
  .cli-dot { color: var(--blue-brand); font-size: 18px; line-height: 1; flex-shrink: 0; }
  .highlight { font-weight: 600; color: var(--blue-dark); }

  /* STUDY CARDS */
  .study-card {
    background: #fff;
    border-radius: 10px;
    border: 1px solid var(--gray-200);
    padding: 20px 22px;
    border-left: 4px solid var(--blue-brand);
  }
  .study-journal { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue-brand); margin-bottom: 6px; }
  .study-title { font-size: 15px; font-weight: 700; color: var(--blue-dark); margin-bottom: 8px; line-height: 1.3; }
  .study-authors { font-size: 12px; color: var(--gray-600); margin-bottom: 10px; }
  .study-finding { font-size: 13.5px; color: #374151; line-height: 1.65; }
  .study-finding strong { font-weight: 600; color: var(--green); }

  /* NSD TABLE */
  .nsd-table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 10px; overflow: hidden; border: 1px solid var(--gray-200); margin-top: 16px; }
  .nsd-table th { background: var(--blue-dark); color: #fff; padding: 11px 14px; font-size: 11.5px; font-weight: 600; text-align: center; }
  .nsd-table td { padding: 11px 14px; font-size: 13px; border-top: 1px solid var(--gray-200); text-align: center; }
  .nsd-best { background: #f0fdf4; font-weight: 700; color: var(--green); font-size: 15px; }
  .nsd-other { color: var(--red); font-weight: 500; }

  /* INTERP STEPS */
  .interp-step {
    display: flex;
    gap: 14px;
    padding: 16px 20px;
    background: #fff;
    border-radius: 8px;
    border: 1px solid var(--gray-200);
    margin-bottom: 10px;
    align-items: flex-start;
  }
  .step-num-big {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: var(--blue-dark);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .interp-text { font-size: 13.5px; color: #374151; line-height: 1.65; }
  .interp-text strong { font-weight: 600; color: var(--blue-dark); }

  /* REVENUE TABLE */
  .rev-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
  .rev-card { background: #fff; border-radius: 10px; border: 1px solid var(--gray-200); padding: 16px; text-align: center; }
  .rev-period { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gray-600); margin-bottom: 6px; }
  .rev-num { font-size: 22px; font-weight: 700; color: var(--green); }

  /* ALERT BOX */
  .alert-box {
    border-radius: 8px;
    padding: 14px 18px;
    display: flex;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 16px;
    font-size: 13.5px;
    line-height: 1.6;
  }
  .alert-blue { background: var(--blue-light); color: var(--blue-dark); border: 1px solid #a8d0ee; }
  .alert-green { background: var(--green-light); color: #14532d; border: 1px solid #86efac; }
  .alert-amber { background: var(--amber-light); color: #713f12; border: 1px solid #fcd34d; }
  .alert-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }

  /* DIVIDER */
  .divider { height: 1px; background: var(--gray-200); margin: 24px 0; }

  /* FOOTER */
  .toolkit-footer {
    max-width: 1100px;
    margin: 0 auto 40px;
    padding: 0 32px;
  }
  .footer-bar {
    background: var(--blue-dark);
    border-radius: 10px;
    padding: 18px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .fl { }
  .fl-label { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #7ab6e0; margin-bottom: 3px; }
  .fl-val { font-size: 13px; font-weight: 500; color: #fff; }
  .fdiv { width: 1px; background: rgba(255,255,255,0.18); align-self: stretch; min-height: 32px; }

  .pill { display: inline-flex; align-items: center; padding: 2px 9px; border-radius: 20px; font-size: 11px; font-weight: 600; }
  .pill-green { background: var(--green-light); color: #14532d; }
  .pill-blue { background: var(--blue-light); color: var(--blue-dark); }
  .pill-amber { background: var(--amber-light); color: #92400e; }

  @media (max-width: 700px) {
    .header-inner { padding: 20px 18px 0; }
    .tab-bar-inner { padding: 0 12px; }
    .content-wrap { padding: 20px 16px 40px; }
    .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
    .coaching-body { grid-template-columns: 1fr; }
    .rev-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-bar { flex-direction: column; }
    .fdiv { display: none; }
  }

  /* COMPETITIVE TAB — EXPANDED */
  .player-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin-bottom: 20px; }
  .player-card { background: #fff; border-radius: 11px; border: 1px solid var(--gray-200); overflow: hidden; }
  .player-hdr { padding: 13px 18px; display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .ph-ndd  { background: linear-gradient(135deg,#1d4ed8,#1e40af); }
  .ph-jaeger{ background: linear-gradient(135deg,#0f766e,#0d5c58); }
  .ph-mgc  { background: linear-gradient(135deg,#7e22ce,#6b21a8); }
  .ph-morgan{ background: linear-gradient(135deg,#b45309,#92400e); }
  .player-name { font-size: 13.5px; font-weight: 700; color: #fff; }
  .player-sub  { font-size: 10px; color: rgba(255,255,255,0.65); margin-top: 1px; }
  .player-tech { font-size: 9px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; padding: 3px 9px; border-radius: 20px; background: rgba(255,255,255,0.18); color: #fff; white-space: nowrap; }
  .player-body { padding: 13px 17px; }
  .player-products { display: flex; flex-direction: column; gap: 7px; margin-bottom: 11px; }
  .player-product { background: var(--gray-100); border-radius: 7px; padding: 8px 10px; border: 1px solid var(--gray-200); }
  .pp-name { font-size: 11.5px; font-weight: 700; color: var(--blue-dark); margin-bottom: 3px; }
  .pp-caps { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 3px; }
  .pcap { font-size: 9px; font-weight: 600; padding: 2px 7px; border-radius: 10px; }
  .pcap-sp { background: #dbeafe; color: #1e40af; }
  .pcap-dl { background: #ede9fe; color: #6d28d9; }
  .pcap-pl { background: var(--green-light); color: #14532d; }
  .pcap-n2 { background: var(--amber-light); color: #92400e; }
  .pcap-eol{ background: var(--red-light); color: var(--red); }
  .pp-price { font-size: 12px; font-weight: 700; color: var(--gray-800); }
  .pp-pnote { font-size: 10px; color: var(--gray-600); font-weight: 400; }
  .player-costs { display: grid; grid-template-columns: 1fr 1fr; gap: 7px; }
  .pc-block { background: var(--gray-100); border-radius: 7px; padding: 8px 10px; border: 1px solid var(--gray-200); }
  .pc-lbl { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--gray-600); margin-bottom: 5px; }
  .pc-item { font-size: 11px; color: var(--gray-800); display: flex; justify-content: space-between; gap: 5px; padding: 2px 0; }
  .pc-bad { color: var(--red); font-weight: 600; }

  .master-comp-table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 11px; overflow: hidden; border: 1px solid var(--gray-200); font-size: 11.5px; }
  .mct th { padding: 9px 12px; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; text-align: center; }
  .mct th.rh { text-align: left; background: var(--gray-100); color: var(--gray-600); min-width: 155px; }
  .mct th.cm { background: var(--blue-dark); color: #fff; }
  .mct th.cn { background: #1d4ed8; color: #fff; }
  .mct th.cj { background: #0f766e; color: #fff; }
  .mct th.cg { background: #7e22ce; color: #fff; }
  .mct th.cmo{ background: #b45309; color: #fff; }
  .mct td { padding: 8px 12px; border-top: 1px solid var(--gray-200); vertical-align: middle; }
  .mct td.rh { font-weight: 600; color: var(--gray-800); background: var(--gray-100); font-size: 11px; }
  .mct td.cm { background: var(--green-light); text-align: center; }
  .mct td.cn,.mct td.cj,.mct td.cg,.mct td.cmo { text-align: center; }
  .mct-best { font-weight: 800; color: var(--green); }
  .mct-bad  { font-weight: 600; color: var(--red); }
  .mct-warn { font-weight: 600; color: var(--amber); }

  .rev-impact-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 20px; }
  .ric { background: #fff; border-radius: 10px; border: 1px solid var(--gray-200); padding: 16px; }
  .ric-vs    { font-size: 9px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--gray-600); margin-bottom: 4px; }
  .ric-title { font-size: 12.5px; font-weight: 700; color: var(--blue-dark); margin-bottom: 10px; line-height: 1.3; }
  .ric-row   { display: flex; justify-content: space-between; align-items: center; padding: 3px 0; border-bottom: 1px solid var(--gray-200); font-size: 11.5px; color: var(--gray-800); }
  .ric-row:last-of-type { border-bottom: none; }
  .ric-good { font-weight: 700; color: var(--green); }
  .ric-bad  { font-weight: 600; color: var(--red); }
  .ric-annual { margin-top: 9px; background: var(--green-light); border-radius: 7px; padding: 8px 10px; text-align: center; }
  .ric-a-lbl { font-size: 9px; font-weight: 700; color: #14532d; text-transform: uppercase; letter-spacing: .08em; }
  .ric-a-num { font-size: 18px; font-weight: 800; color: #14532d; }
  .ric-a-sub { font-size: 9px; color: #166534; }

  .disp-table-wrap { width: 100%; border-collapse: collapse; background: #fff; border-radius: 11px; overflow: hidden; border: 1px solid var(--gray-200); font-size: 11.5px; }
  .disp-table-wrap th { background: var(--blue-dark); color: #fff; padding: 9px 13px; font-size: 9.5px; font-weight: 600; text-transform: uppercase; letter-spacing: .07em; }
  .disp-table-wrap th:not(:first-child) { text-align: center; }
  .disp-table-wrap td { padding: 9px 13px; border-top: 1px solid var(--gray-200); }
  .disp-table-wrap td:not(:first-child) { text-align: center; }
  .disp-table-wrap tr:nth-child(even) td { background: var(--gray-100); }
  .disp-hl { background: var(--green-light) !important; font-weight: 700; color: var(--green); }
  .disp-rl { font-weight: 600; color: var(--gray-800); }

  .swot-player-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .swot-player { background: #fff; border-radius: 10px; border: 1px solid var(--gray-200); overflow: hidden; }
  .swot-phdr { padding: 11px 15px; font-size: 11.5px; font-weight: 700; color: #fff; }
  .swot-ndd { background: #1d4ed8; } .swot-jae { background: #0f766e; } .swot-mgc { background: #7e22ce; }
  .swot-pbody { padding: 12px 15px; display: grid; grid-template-columns: 1fr 1fr; gap: 9px; }
  .swot-qlbl { font-size: 8.5px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; margin-bottom: 4px; }
  .swot-s { color: var(--green); } .swot-w { color: var(--red); } .swot-o { color: var(--blue-brand); } .swot-t { color: var(--amber); }
  .swot-qi { font-size: 10.5px; color: var(--gray-800); display: flex; gap: 4px; line-height: 1.4; margin-bottom: 2px; }

  .emerging-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 11px; }
  .emerging-card { background: #fff; border-radius: 10px; border: 1.5px dashed var(--gray-300); padding: 14px 16px; }
  .emerging-badge { display: inline-flex; align-items: center; gap: 4px; background: var(--amber-light); border-radius: 20px; padding: 2px 8px; font-size: 9px; font-weight: 700; color: #92400e; margin-bottom: 6px; }
  .emerging-name { font-size: 13.5px; font-weight: 700; color: var(--blue-dark); margin-bottom: 2px; }
  .emerging-prod { font-size: 11px; color: var(--gray-600); margin-bottom: 7px; }
  .emerging-note { font-size: 11px; color: var(--gray-800); line-height: 1.55; background: var(--gray-100); border-radius: 6px; padding: 7px 9px; }

  .tp-grid-comp { display: grid; grid-template-columns: repeat(2, 1fr); gap: 11px; }
  .tp-comp-card { background: #fff; border-radius: 10px; border: 1px solid var(--gray-200); padding: 15px 17px; }
  .tp-comp-lbl { font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 6px; }
  .tp-comp-text { font-size: 12.5px; color: #374151; line-height: 1.7; }

  @media (max-width: 700px) {
    .player-grid, .rev-impact-grid, .swot-player-grid, .emerging-grid, .tp-grid-comp { grid-template-columns: 1fr; }
    .player-costs { grid-template-columns: 1fr; }
  }

  /* FORMS TAB */
  .form-card {
    background: #fff;
    border-radius: 12px;
    border: 1px solid var(--gray-200);
    padding: 0;
    overflow: hidden;
    margin-bottom: 28px;
  }
  .form-card-header {
    background: var(--blue-dark);
    padding: 18px 28px;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
  }
  .form-card-title { font-size: 16px; font-weight: 700; color: #fff; }
  .form-card-sub { font-size: 12px; color: #a8d0ee; margin-top: 2px; }
  .form-body { padding: 28px; }
  .form-row { display: grid; gap: 16px; margin-bottom: 18px; }
  .form-row-2 { grid-template-columns: 1fr 1fr; }
  .form-row-3 { grid-template-columns: 1fr 1fr 1fr; }
  .form-field { display: flex; flex-direction: column; gap: 6px; }
  .form-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.09em; color: var(--gray-600); }
  .form-input {
    border: 1.5px solid var(--gray-300);
    border-radius: 7px;
    padding: 10px 14px;
    font-size: 14px;
    font-family: 'Inter', sans-serif;
    color: var(--text);
    background: #fff;
    outline: none;
    transition: border-color 0.15s;
  }
  .form-input:focus { border-color: var(--blue-brand); box-shadow: 0 0 0 3px rgba(14,106,191,0.1); }
  .form-input[readonly] { background: var(--gray-100); color: var(--gray-600); cursor: default; }
  .form-divider { height: 1px; background: var(--gray-200); margin: 22px 0; }
  .form-section-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--blue-brand); margin-bottom: 14px; }

  /* ACH Payment Table */
  .ach-table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
  .ach-table th { background: var(--blue-dark); color: #fff; padding: 10px 12px; font-size: 11px; font-weight: 600; text-align: left; text-transform: uppercase; letter-spacing: 0.06em; }
  .ach-table th:last-child { text-align: center; width: 48px; }
  .ach-table td { padding: 6px 6px; border-bottom: 1px solid var(--gray-200); vertical-align: middle; }
  .ach-table td input { border: 1.5px solid var(--gray-300); border-radius: 5px; padding: 7px 10px; font-size: 13px; font-family: 'Inter', sans-serif; width: 100%; outline: none; }
  .ach-table td input:focus { border-color: var(--blue-brand); }
  .ach-table .td-num { text-align: center; font-size: 13px; font-weight: 700; color: var(--gray-600); width: 36px; }
  .ach-table .td-del { text-align: center; }
  .ach-del-btn { background: var(--red-light); border: none; border-radius: 5px; color: var(--red); cursor: pointer; font-size: 15px; width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center; }
  .ach-del-btn:hover { background: #fca5a5; }
  .ach-add-btn { background: var(--blue-light); border: 1.5px solid #a8d0ee; color: var(--blue-dark); border-radius: 7px; padding: 8px 16px; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; cursor: pointer; }
  .ach-add-btn:hover { background: #c3ddf5; }
  .ach-total-row { display: flex; align-items: center; justify-content: flex-end; gap: 14px; padding: 12px 0; }
  .ach-total-label { font-size: 14px; font-weight: 700; color: var(--blue-dark); }
  .ach-total-val { font-size: 22px; font-weight: 800; color: var(--green); min-width: 120px; text-align: right; }

  /* Print buttons */
  .print-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--green); color: #fff;
    border: none; border-radius: 8px; padding: 11px 20px;
    font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600;
    cursor: pointer; transition: background 0.15s;
  }
  .print-btn:hover { background: #229954; }
  .clear-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--gray-100); color: var(--gray-600);
    border: 1.5px solid var(--gray-300); border-radius: 8px; padding: 10px 18px;
    font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600;
    cursor: pointer; transition: background 0.15s;
  }
  .clear-btn:hover { background: var(--gray-200); }

  /* DAILY HUB TAB */
  .hub-section { margin-bottom: 28px; }
  .hub-section-title { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gray-600); margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
  .hub-section-title::after { content: ''; flex: 1; height: 1px; background: var(--gray-200); }
  .launcher-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }
  .launcher-btn {
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;
    padding: 20px 16px;
    border-radius: 12px; border: 1.5px solid var(--gray-200);
    background: #fff; cursor: pointer; text-decoration: none;
    transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s;
    text-align: center;
  }
  .launcher-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.08); }
  .launcher-icon { font-size: 30px; }
  .launcher-name { font-size: 13px; font-weight: 700; color: var(--blue-dark); }
  .launcher-desc { font-size: 11px; color: var(--gray-600); }
  .lb-outlook { border-color: #0078d4; }
  .lb-outlook:hover { border-color: #0078d4; background: #f0f7ff; }
  .lb-docusign { border-color: #ffb800; }
  .lb-docusign:hover { border-color: #ffb800; background: #fffbf0; }
  .lb-salesforce { border-color: #00a1e0; }
  .lb-salesforce:hover { border-color: #00a1e0; background: #f0faff; }
  .lb-phone { border-color: var(--green); }
  .lb-phone:hover { border-color: var(--green); background: var(--green-light); }
  .lb-calendar { border-color: var(--teal); }
  .lb-calendar:hover { border-color: var(--teal); background: var(--teal-light); }
  .lb-maps { border-color: var(--red); }
  .lb-maps:hover { border-color: var(--red); background: var(--red-light); }

  /* Quick Email Composer */
  .email-template-btns { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
  .etpl-btn { background: var(--blue-light); border: 1px solid #a8d0ee; border-radius: 20px; padding: 6px 14px; font-size: 12px; font-weight: 600; color: var(--blue-dark); cursor: pointer; transition: background 0.15s; }
  .etpl-btn:hover { background: #c3ddf5; }
  .email-composer { display: grid; gap: 10px; }
  .email-input { border: 1.5px solid var(--gray-300); border-radius: 7px; padding: 10px 14px; font-size: 13px; font-family: 'Inter', sans-serif; color: var(--text); outline: none; width: 100%; }
  .email-input:focus { border-color: var(--blue-brand); }
  .email-body-input { resize: vertical; min-height: 100px; }
  .email-send-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: #0078d4; color: #fff; border: none; border-radius: 8px;
    padding: 11px 20px; font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600;
    cursor: pointer; transition: background 0.15s;
  }
  .email-send-btn:hover { background: #006abe; }

  /* Notes Pad */
  .notes-pad { width: 100%; min-height: 140px; border: 1.5px solid var(--gray-300); border-radius: 9px; padding: 14px; font-family: 'Inter', sans-serif; font-size: 13.5px; color: var(--text); resize: vertical; outline: none; background: #fffef5; }
  .notes-pad:focus { border-color: var(--blue-brand); }
  .notes-actions { display: flex; gap: 10px; margin-top: 10px; flex-wrap: wrap; align-items: center; }
  .notes-save-btn { background: var(--blue-dark); color: #fff; border: none; border-radius: 7px; padding: 9px 18px; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; cursor: pointer; }
  .notes-save-btn:hover { background: var(--blue-mid); }
  .notes-clear-btn { background: none; border: 1.5px solid var(--gray-300); border-radius: 7px; padding: 8px 16px; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 500; color: var(--gray-600); cursor: pointer; }
  .notes-saved-msg { font-size: 12px; color: var(--green); font-weight: 600; display: none; }

  /* Contact quick-dial grid */
  .contact-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
  .contact-tile { background: #fff; border-radius: 10px; border: 1px solid var(--gray-200); padding: 14px 16px; }
  .ct-name { font-size: 13px; font-weight: 700; color: var(--blue-dark); margin-bottom: 4px; }
  .ct-role { font-size: 11px; color: var(--gray-600); margin-bottom: 10px; }
  .ct-actions { display: flex; gap: 6px; }
  .ct-btn { flex: 1; text-align: center; border-radius: 6px; padding: 6px 4px; font-size: 11px; font-weight: 600; text-decoration: none; cursor: pointer; border: none; font-family: 'Inter', sans-serif; }
  .ct-call { background: var(--green-light); color: #14532d; }
  .ct-call:hover { background: #bbf7d0; }
  .ct-email { background: var(--blue-light); color: var(--blue-dark); }
  .ct-email:hover { background: #c3ddf5; }
  /* My References add-form + delete */
  .ref-add-form { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; align-items: start; }
  .ref-add-form .notes-save-btn { grid-column: 1 / -1; justify-self: start; }
  @media (max-width: 700px) { .ref-add-form { grid-template-columns: 1fr; } }
  .ct-del { background: none; border: 1px solid var(--gray-300); color: var(--gray-600); flex: 0 0 auto; padding: 6px 8px; }
  .ct-del:hover { background: #fee2e2; border-color: #fca5a5; color: #b91c1c; }

  @media print {
    body { background: white; }
    .site-header, .tab-bar, .toolkit-footer, #roi-fullscreen,
    .print-btn, .clear-btn, .ach-add-btn, .ach-del-btn,
    .tab-panel:not(.print-target) { display: none !important; }
    .print-target { display: block !important; }
    .form-card-header { background: #0a3d6b !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .ach-table th { background: #0a3d6b !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    @page { margin: 0.6in; }
  
  /* v2.10 / v1.4: hide input placeholders + date-format helpers in print so DocuSign can overlay cleanly */
  input::placeholder,
  input::-webkit-input-placeholder,
  input::-moz-placeholder,
  input:-ms-input-placeholder,
  input:-moz-placeholder,
  textarea::placeholder { color: transparent !important; opacity: 0 !important; }
  input[type="date"]:invalid::-webkit-datetime-edit,
  input[type="date"]:not([value])::-webkit-datetime-edit { color: transparent !important; }
  input[type="date"]::-webkit-calendar-picker-indicator { display: none !important; }
}

  @media (max-width: 700px) {
    .form-row-2, .form-row-3 { grid-template-columns: 1fr; }
    .launcher-grid { grid-template-columns: repeat(2, 1fr); }
    .contact-grid { grid-template-columns: 1fr; }
  }

  /* ROI CALCULATOR */
  .roi-calc-wrap { background: #fff; border-radius: 12px; border: 1px solid var(--gray-200); padding: 24px; margin-bottom: 0; }
  .roi-ctrl-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray-600); margin-bottom: 8px; }
  .roi-stepper { display: flex; align-items: center; border: 1.5px solid var(--gray-300); border-radius: 8px; overflow: hidden; width: fit-content; }
  .roi-stepper button { width: 40px; height: 48px; background: var(--gray-100); border: none; font-size: 22px; cursor: pointer; color: var(--text); font-family: 'Inter', sans-serif; transition: background 0.15s; }
  .roi-stepper button:hover { background: var(--gray-200); }
  .roi-stepper-val { min-width: 56px; text-align: center; font-size: 26px; font-weight: 700; color: var(--blue-dark); padding: 0 4px; }
  .roi-bar-col { flex: 1; border-radius: 5px 5px 0 0; display: flex; align-items: flex-start; justify-content: center; padding-top: 5px; transition: height 0.3s ease; }
  .roi-bar-col span { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.9); }
  .roi-bar-label { flex: 1; text-align: center; font-size: 11px; color: var(--gray-600); font-weight: 500; }
  .roi-breakeven-card { background: #fff; border-radius: 10px; border: 1px solid var(--gray-200); padding: 16px; text-align: center; }
  .roi-cpt-card { background: var(--gray-100); border-radius: 8px; padding: 10px 14px; }

  /* PRESENT BUTTON */
  .roi-present-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--blue-dark); color: #fff;
    border: none; border-radius: 8px;
    padding: 11px 20px;
    font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600;
    cursor: pointer; white-space: nowrap;
    transition: background 0.15s, transform 0.1s;
    box-shadow: 0 2px 8px rgba(10,61,107,0.25);
  }
  .roi-present-btn:hover { background: var(--blue-mid); }
  .roi-present-btn:active { transform: scale(0.98); }

  /* FULLSCREEN OVERLAY */
  #roi-fullscreen {
    display: none;
    position: fixed; inset: 0; z-index: 9999;
    background: #0a3d6b;
    overflow-y: auto;
  }
  #roi-fullscreen.open { display: flex; flex-direction: column; }
  .fs-header {
    background: rgba(0,0,0,0.2);
    padding: 18px 40px;
    display: flex; align-items: center; justify-content: space-between;
    flex-shrink: 0;
  }
  .fs-logo { font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #7ab6e0; }
  .fs-title { font-size: 15px; font-weight: 600; color: #fff; }
  .fs-close {
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
    color: #fff; border-radius: 7px; padding: 8px 16px;
    font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: background 0.15s;
  }
  .fs-close:hover { background: rgba(255,255,255,0.2); }
  .fs-body { flex: 1; padding: 32px 48px 48px; max-width: 1000px; margin: 0 auto; width: 100%; }
  .fs-hero { text-align: center; margin-bottom: 36px; }
  .fs-hero-label { font-size: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #7ab6e0; margin-bottom: 10px; }
  .fs-hero-num { font-size: 72px; font-weight: 800; color: #fff; line-height: 1; letter-spacing: -0.02em; }
  .fs-hero-sub { font-size: 16px; color: #a8d0ee; margin-top: 8px; }
  .fs-cards { display: grid; grid-template-columns: repeat(5,1fr); gap: 12px; margin-bottom: 24px; }
  .fs-card { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); border-radius: 10px; padding: 16px; text-align: center; }
  .fs-card-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #7ab6e0; margin-bottom: 6px; }
  .fs-card-num { font-size: 20px; font-weight: 700; color: #fff; }
  .fs-breakeven { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 28px; }
  .fs-bcard { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); border-radius: 10px; padding: 18px; text-align: center; }
  .fs-bcard-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #7ab6e0; margin-bottom: 6px; }
  .fs-bcard-num { font-size: 26px; font-weight: 700; color: #fff; }
  .fs-bcard-sub { font-size: 11px; color: #a8d0ee; margin-top: 4px; }
  .fs-controls { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 28px; align-items: center; }
  .fs-ctrl-label { font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #7ab6e0; margin-bottom: 8px; }
  .fs-stepper { display: flex; align-items: center; gap: 0; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 9px; overflow: hidden; width: fit-content; }
  .fs-stepper button { width: 48px; height: 54px; background: rgba(255,255,255,0.08); border: none; font-size: 24px; cursor: pointer; color: #fff; font-family: 'Inter',sans-serif; transition: background 0.15s; }
  .fs-stepper button:hover { background: rgba(255,255,255,0.18); }
  .fs-stepper-val { min-width: 72px; text-align: center; font-size: 30px; font-weight: 700; color: #fff; }
  .fs-cost-input { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 9px; padding: 12px 16px; font-size: 26px; font-weight: 700; font-family: 'Inter',sans-serif; color: #fff; width: 100%; }
  .fs-cost-input::placeholder { color: rgba(255,255,255,0.3); }
  .fs-bars-wrap { margin-bottom: 16px; }
  .fs-bar-col { flex:1; border-radius: 5px 5px 0 0; display: flex; align-items: flex-start; justify-content: center; padding-top: 6px; }
  .fs-bar-col span { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.9); }
  .fs-bar-label { flex:1; text-align:center; font-size:12px; color:#7ab6e0; font-weight:500; }
  .fs-disclaimer { font-size: 11px; color: rgba(168,208,238,0.6); text-align: center; margin-top: 16px; }
  @media (max-width: 700px) {
    .fs-body { padding: 20px 18px 32px; }
    .fs-hero-num { font-size: 48px; }
    .fs-cards { grid-template-columns: repeat(2,1fr); }
    .fs-breakeven { grid-template-columns: 1fr; }
    .fs-controls { grid-template-columns: 1fr; }
    .roi-ctrl-row { grid-template-columns: 1fr !important; }
  }

  /* ========== EMAIL LIBRARY TAB ========== */
  .hbadge-profile {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff; cursor: pointer;
    font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600;
    padding: 5px 13px; border-radius: 5px;
    transition: background 0.15s, border-color 0.15s;
    display: inline-flex; align-items: center; gap: 5px;
  }
  .hbadge-profile:hover { background: rgba(255,255,255,0.25); border-color: rgba(255,255,255,0.5); }
  .hbadge-profile.set { background: var(--green); border-color: var(--green); }


  /* EMAIL ASSEMBLY STATION v2.17 */
  .eas-wrap { background: linear-gradient(135deg, #0a3d6b 0%, #0c5299 100%); border-radius: 14px; padding: 24px 26px; margin-bottom: 24px; color: #fff; }
  .eas-header { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
  .eas-icon { font-size: 28px; }
  .eas-title { font-size: 18px; font-weight: 700; }
  .eas-sub { font-size: 12px; color: #a8d0ee; margin-top: 2px; }
  .eas-body { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  @media (max-width: 800px) { .eas-body { grid-template-columns: 1fr; } }
  .eas-col-label { font-size: 10px; font-weight: 700; letter-spacing: 0.13em; text-transform: uppercase; color: #7ab6e0; margin-bottom: 10px; }
  .eas-field { margin-bottom: 10px; }
  .eas-field label { display: block; font-size: 11.5px; color: #cce4f7; margin-bottom: 4px; font-weight: 500; }
  .eas-field input { width: 100%; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.22); border-radius: 7px; padding: 8px 12px; color: #fff; font-family: "Inter", sans-serif; font-size: 13px; outline: none; }
  .eas-field input::placeholder { color: rgba(255,255,255,0.4); }
  .eas-field input:focus { border-color: #5bc8f5; background: rgba(255,255,255,0.14); }
  .eas-items-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .eas-toggle { display: flex; align-items: flex-start; gap: 9px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.14); border-radius: 9px; padding: 10px 12px; cursor: pointer; transition: background 0.15s, border-color 0.15s; user-select: none; }
  .eas-toggle:hover { background: rgba(255,255,255,0.16); }
  .eas-toggle.on { background: rgba(91,200,245,0.22); border-color: #5bc8f5; }
  .eas-toggle-dot { width: 18px; height: 18px; min-width: 18px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.4); margin-top: 1px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; transition: background 0.15s, border-color 0.15s; }
  .eas-toggle.on .eas-toggle-dot { background: #5bc8f5; border-color: #5bc8f5; color: #0a3d6b; }
  .eas-toggle-text { font-size: 12.5px; font-weight: 600; color: #e0f0ff; line-height: 1.3; }
  .eas-toggle-sub { font-size: 11px; color: #7ab6e0; margin-top: 2px; font-weight: 400; }
  .eas-studies-panel { margin-top: 8px; background: rgba(0,0,0,0.2); border-radius: 8px; padding: 10px 12px; display: none; }
  .eas-studies-panel.open { display: block; }
  .eas-study-row { display: flex; align-items: center; gap: 8px; padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,0.07); cursor: pointer; }
  .eas-study-row:last-child { border-bottom: none; }
  .eas-study-row input[type=checkbox] { accent-color: #5bc8f5; width: 14px; height: 14px; cursor: pointer; flex-shrink: 0; }
  .eas-study-row label { font-size: 12px; color: #cce4f7; cursor: pointer; line-height: 1.4; }
  .eas-email-type { display: flex; gap: 7px; flex-wrap: wrap; margin-top: 4px; }
  .eas-type-btn { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18); border-radius: 7px; padding: 7px 13px; font-size: 12px; font-weight: 500; color: #cce4f7; cursor: pointer; transition: all 0.15s; }
  .eas-type-btn:hover { background: rgba(255,255,255,0.16); }
  .eas-type-btn.active { background: rgba(91,200,245,0.25); border-color: #5bc8f5; color: #fff; font-weight: 600; }
  .eas-generate-btn { margin-top: 18px; width: 100%; background: #5bc8f5; color: #0a3d6b; border: none; border-radius: 9px; padding: 13px; font-size: 14px; font-weight: 700; cursor: pointer; letter-spacing: 0.03em; transition: background 0.15s; }
  .eas-generate-btn:hover { background: #3ab0e0; }
  .eas-output { margin-top: 20px; display: none; }
  .eas-output.show { display: block; }
  .eas-checklist { background: #fffbeb; border: 1px solid #f59e0b; border-radius: 10px; padding: 14px 18px; margin-bottom: 14px; }
  .eas-checklist-title { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #92400e; margin-bottom: 8px; }
  .eas-checklist ul { list-style: none; padding: 0; margin: 0; }
  .eas-checklist ul li { font-size: 12.5px; color: #78350f; padding: 3px 0; display: flex; align-items: flex-start; gap: 7px; }
  .eas-checklist ul li::before { content: "\2610"; font-size: 14px; margin-top: -1px; flex-shrink: 0; }
  .eas-email-card { background: #fff; border-radius: 12px; padding: 20px 22px; color: #1a2733; }
  .eas-out-label { font-size: 10px; font-weight: 700; letter-spacing: 0.13em; text-transform: uppercase; color: #0c5299; margin-bottom: 6px; }
  .eas-out-subject { font-size: 14px; font-weight: 700; color: #0a3d6b; background: #d6eaf8; border-radius: 7px; padding: 10px 14px; margin-bottom: 14px; }
  .eas-out-body { font-size: 13px; line-height: 1.8; color: #1a2733; white-space: pre-wrap; border: 1px solid #e8ecf0; border-radius: 8px; padding: 14px 16px; background: #fafbfc; max-height: 400px; overflow-y: auto; }
  .eas-action-row { display: flex; gap: 10px; margin-top: 14px; flex-wrap: wrap; }
  .eas-copy-btn { background: #0c5299; color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-size: 13px; font-weight: 600; cursor: pointer; transition: background 0.15s; }
  .eas-copy-btn:hover { background: #0a3d6b; }
  .eas-web-btn { background: #27ae60; color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-size: 13px; font-weight: 600; cursor: pointer; transition: background 0.15s; }
  .eas-web-btn:hover { background: #1e8449; }

  .el-intro { display: grid; grid-template-columns: 2fr 1fr; gap: 14px; margin-bottom: 22px; }
  @media (max-width: 900px) { .el-intro { grid-template-columns: 1fr; } }
  .el-intro-card { background: #fff; border: 1px solid var(--gray-200); border-radius: 10px; padding: 16px 20px; }
  .el-intro-card strong { color: var(--blue-dark); }
  .el-profile-card { background: linear-gradient(135deg, var(--blue-dark), var(--blue-brand)); color: #fff; border-radius: 10px; padding: 16px 20px; }
  .el-profile-card .el-p-lbl { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #a8d0ee; margin-bottom: 4px; }
  .el-profile-card .el-p-name { font-size: 17px; font-weight: 700; }
  .el-profile-card .el-p-title { font-size: 12px; color: #cce4f7; margin-top: 2px; }
  .el-profile-card .el-p-contact { font-size: 11.5px; color: #a8d0ee; margin-top: 8px; line-height: 1.5; }
  .el-profile-card button { margin-top: 10px; background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.3); color: #fff; border-radius: 6px; padding: 6px 14px; font-family: 'Inter', sans-serif; font-size: 11.5px; font-weight: 600; cursor: pointer; }
  .el-profile-card button:hover { background: rgba(255,255,255,0.28); }

  .email-grid { display: grid; grid-template-columns: 300px 1fr; gap: 14px; }
  @media (max-width: 900px) { .email-grid { grid-template-columns: 1fr; } }
  .email-list { display: flex; flex-direction: column; gap: 6px; background: #fff; border: 1px solid var(--gray-200); border-radius: 10px; padding: 10px; max-height: 740px; overflow-y: auto; }
  .email-item { padding: 11px 13px; border-radius: 7px; cursor: pointer; border: 1px solid transparent; transition: background 0.15s, border-color 0.15s; }
  .email-item:hover { background: var(--gray-100); }
  .email-item.active { background: var(--blue-light); border-color: #a8d0ee; }
  .email-item-cat { font-size: 9.5px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue-brand); margin-bottom: 2px; }
  .email-item-title { font-size: 13px; font-weight: 600; color: var(--blue-dark); line-height: 1.35; }
  .email-item-sub { font-size: 11px; color: var(--gray-600); margin-top: 3px; }
  .email-preview { background: #fff; border: 1px solid var(--gray-200); border-radius: 10px; overflow: hidden; }
  .email-preview-bar { background: var(--blue-dark); color: #fff; padding: 14px 22px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
  .email-preview-title { font-size: 14px; font-weight: 700; }
  .email-preview-body { padding: 22px 26px; }
  .email-field { margin-bottom: 14px; }
  .email-field-lbl { font-size: 10px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gray-600); margin-bottom: 5px; }
  .email-field-val { font-size: 14px; color: var(--blue-dark); font-weight: 600; padding: 10px 14px; background: var(--gray-100); border-radius: 6px; font-family: 'Inter', sans-serif; }
  .email-field-input {
    width: 100%; font-size: 13.5px; color: var(--blue-dark); font-weight: 500;
    padding: 10px 14px; background: #fff; border: 1.5px solid var(--gray-300); border-radius: 6px;
    font-family: 'Inter', sans-serif; outline: none; transition: border-color 0.15s;
  }
  .email-field-input:focus { border-color: var(--blue-brand); }
  .email-to-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  @media (max-width: 600px) { .email-to-row { grid-template-columns: 1fr; } }
  .email-body-wrap {
    background: #fefcf5; border: 1.5px solid #f4e9c8; border-radius: 6px;
    padding: 16px 18px; white-space: pre-wrap; font-size: 13px; color: #374151; line-height: 1.7;
    font-family: 'Inter', sans-serif; min-height: 200px; outline: none;
  }
  .email-body-wrap[contenteditable="true"]:focus { border-color: var(--blue-brand); background: #fffef9; }
  .email-body-wrap .merge { background: #fef3c7; color: #713f12; padding: 1px 5px; border-radius: 3px; font-weight: 600; }
  .email-body-wrap .filled { background: #dcfce7; color: #14532d; padding: 1px 4px; border-radius: 3px; font-weight: 600; }
  .email-note { margin-top: 14px; font-size: 11.5px; color: var(--gray-600); line-height: 1.55; background: var(--gray-100); border-radius: 6px; padding: 10px 14px; border-left: 3px solid var(--blue-brand); }
  .email-note strong { color: var(--blue-dark); font-weight: 600; }
  .email-send-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px; padding-top: 16px; border-top: 1px dashed var(--gray-300); }
  .email-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 18px; border-radius: 7px;
    font-family: 'Inter', sans-serif; font-size: 12.5px; font-weight: 600;
    cursor: pointer; transition: background 0.15s, transform 0.1s;
    border: none; white-space: nowrap;
  }
  .email-btn:active { transform: scale(0.97); }
  .email-btn-outlook { background: #0078d4; color: #fff; }
  .email-btn-outlook:hover { background: #006abe; }
  .email-btn-owa { background: #5059c9; color: #fff; }
  .email-btn-owa:hover { background: #404aa8; }
  .email-btn-copy { background: var(--gray-100); color: var(--blue-dark); border: 1.5px solid var(--gray-300); }
  .email-btn-copy:hover { background: var(--gray-200); }
  .email-btn-copyhtml { background: #fff7e6; color: #92400e; border: 1.5px solid #fcd34d; }
  .email-btn-copyhtml:hover { background: #fef3c7; }
  .email-btn-copypaste { background: var(--green); color: #fff; }
  .email-btn-copypaste:hover { background: #22994f; }

  /* Custom Template toolbar + badges */
  .el-list-toolbar { display: flex; gap: 6px; padding: 8px 4px 10px 4px; border-bottom: 1px solid var(--gray-200); margin-bottom: 6px; flex-wrap: wrap; }
  .el-toolbar-btn {
    background: var(--blue-dark); color: #fff; border: none; border-radius: 6px;
    padding: 8px 12px; font-family: 'Inter', sans-serif; font-size: 11.5px; font-weight: 600;
    cursor: pointer; flex: 1 0 auto; white-space: nowrap;
  }
  .el-toolbar-btn:hover { background: var(--blue-mid); }
  .el-toolbar-btn.secondary { background: #fff; color: var(--blue-dark); border: 1.5px solid var(--gray-300); }
  .el-toolbar-btn.secondary:hover { background: var(--gray-100); }
  .email-item.is-custom { border-left: 3px solid var(--green); padding-left: 10px; }
  .email-item-custom-badge { display: inline-block; background: var(--green-light); color: #14532d; font-size: 9px; font-weight: 700; letter-spacing: 0.08em; padding: 1px 7px; border-radius: 10px; text-transform: uppercase; margin-left: 6px; vertical-align: middle; }
  .email-item-actions { display: flex; gap: 5px; margin-top: 6px; }
  .email-item-action {
    background: var(--gray-100); border: 1px solid var(--gray-300); color: var(--gray-600);
    font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 4px; cursor: pointer;
    font-family: 'Inter', sans-serif;
  }
  .email-item-action:hover { background: var(--gray-200); color: var(--blue-dark); }
  .email-item-action.danger:hover { background: var(--red-light); color: var(--red); border-color: var(--red); }

  /* Template Editor Modal */
  #tpl-modal {
    display: none; position: fixed; inset: 0; z-index: 10000;
    background: rgba(10,61,107,0.78); align-items: center; justify-content: center;
    padding: 20px; overflow-y: auto;
  }
  #tpl-modal.open { display: flex; }
  .tm-card { background: #fff; border-radius: 14px; width: 100%; max-width: 720px; overflow: hidden; box-shadow: 0 20px 50px rgba(0,0,0,0.4); max-height: 92vh; display: flex; flex-direction: column; }
  .tm-hdr { background: var(--blue-dark); color: #fff; padding: 18px 24px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
  .tm-hdr-title { font-size: 17px; font-weight: 700; }
  .tm-hdr-sub { font-size: 11.5px; color: #a8d0ee; margin-top: 2px; }
  .tm-close { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25); color: #fff; border-radius: 6px; padding: 5px 12px; font-size: 12px; cursor: pointer; }
  .tm-close:hover { background: rgba(255,255,255,0.25); }
  .tm-body { padding: 22px 24px; overflow-y: auto; }
  .tm-row { margin-bottom: 14px; }
  .tm-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .tm-lbl { font-size: 10.5px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gray-600); margin-bottom: 5px; }
  .tm-inp { width: 100%; padding: 10px 12px; font-size: 14px; border: 1.5px solid var(--gray-300); border-radius: 7px; font-family: 'Inter', sans-serif; color: var(--blue-dark); background: #fff; outline: none; transition: border-color 0.15s; }
  .tm-inp:focus { border-color: var(--blue-brand); }
  .tm-ta { width: 100%; padding: 12px 14px; font-size: 13px; border: 1.5px solid var(--gray-300); border-radius: 7px; font-family: 'Inter', sans-serif; color: var(--gray-800); background: #fefcf5; outline: none; line-height: 1.6; min-height: 180px; resize: vertical; }
  .tm-ta:focus { border-color: var(--blue-brand); background: #fff; }
  .tm-import-zone {
    border: 2px dashed var(--gray-300); border-radius: 10px; padding: 18px; text-align: center;
    background: var(--gray-100); cursor: pointer; transition: border-color 0.15s, background 0.15s;
  }
  .tm-import-zone:hover, .tm-import-zone.drag { border-color: var(--blue-brand); background: var(--blue-light); }
  .tm-import-zone strong { color: var(--blue-dark); font-size: 13px; }
  .tm-import-zone div { font-size: 11.5px; color: var(--gray-600); margin-top: 4px; }
  .tm-help {
    font-size: 11.5px; color: var(--gray-600); line-height: 1.55; padding: 10px 14px;
    background: var(--blue-light); border-radius: 6px; border-left: 3px solid var(--blue-brand);
  }
  .tm-help strong { color: var(--blue-dark); }
  .tm-save-row { display: flex; gap: 10px; justify-content: space-between; align-items: center; padding: 14px 24px; background: var(--gray-100); border-top: 1px solid var(--gray-200); flex-wrap: wrap; flex-shrink: 0; }
  .tm-btn { padding: 10px 22px; border: none; border-radius: 7px; font-family: 'Inter',sans-serif; font-size: 13px; font-weight: 600; cursor: pointer; }
  .tm-btn-primary { background: var(--blue-dark); color: #fff; }
  .tm-btn-primary:hover { background: var(--blue-mid); }
  .tm-btn-secondary { background: #fff; color: var(--gray-600); border: 1.5px solid var(--gray-300); }
  .tm-btn-secondary:hover { background: var(--gray-100); }
  .tm-btn-danger { background: #fff; color: var(--red); border: 1.5px solid var(--red-light); }
  .tm-btn-danger:hover { background: var(--red-light); }

  .lib-hbtn {
    background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3);
    color: #fff; border-radius: 5px; padding: 6px 12px;
    font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600;
    cursor: pointer;
  }
  .lib-hbtn:hover { background: rgba(255,255,255,0.25); }

  /* ========== PROFILE MODAL ========== */
  #profile-modal {
    display: none; position: fixed; inset: 0; z-index: 10000;
    background: rgba(10,61,107,0.78); align-items: center; justify-content: center;
    padding: 20px;
  }
  #profile-modal.open { display: flex; }
  .pm-card { background: #fff; border-radius: 14px; width: 100%; max-width: 540px; max-height: calc(100vh - 40px); display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 20px 50px rgba(0,0,0,0.4); }
  .pm-hdr { flex-shrink: 0; background: var(--blue-dark); color: #fff; padding: 18px 24px; display: flex; align-items: center; justify-content: space-between; }
  .pm-hdr-title { font-size: 17px; font-weight: 700; }
  .pm-hdr-sub { font-size: 11.5px; color: #a8d0ee; margin-top: 2px; }
  .pm-close { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25); color: #fff; border-radius: 6px; padding: 5px 12px; font-size: 12px; cursor: pointer; }
  .pm-close:hover { background: rgba(255,255,255,0.25); }
  .pm-body { padding: 24px; flex: 1 1 auto; min-height: 0; overflow-y: auto; }
  .pm-row { margin-bottom: 14px; }
  .pm-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .pm-lbl { font-size: 10.5px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gray-600); margin-bottom: 5px; }
  .pm-inp { width: 100%; padding: 10px 12px; font-size: 14px; border: 1.5px solid var(--gray-300); border-radius: 7px; font-family: 'Inter', sans-serif; color: var(--blue-dark); background: #fff; outline: none; transition: border-color 0.15s; }
  .pm-inp:focus { border-color: var(--blue-brand); }
  .pm-toggle { display: flex; border: 1.5px solid var(--gray-300); border-radius: 7px; overflow: hidden; }
  .pm-toggle button { flex: 1; padding: 10px 8px; border: none; cursor: pointer; font-family: 'Inter',sans-serif; font-size: 12px; font-weight: 600; background: #fff; color: var(--gray-600); border-right: 1.5px solid var(--gray-300); transition: all 0.15s; }
  .pm-toggle button:last-child { border-right: none; }
  .pm-toggle button.on { background: var(--blue-dark); color: #fff; }
  .pm-save-row { flex-shrink: 0; display: flex; gap: 10px; justify-content: flex-end; padding: 16px 24px; background: var(--gray-100); border-top: 1px solid var(--gray-200); }
  .pm-btn { padding: 10px 22px; border: none; border-radius: 7px; font-family: 'Inter',sans-serif; font-size: 13px; font-weight: 600; cursor: pointer; }
  .pm-btn-primary { background: var(--blue-dark); color: #fff; }
  .pm-btn-primary:hover { background: var(--blue-mid); }
  .pm-btn-secondary { background: #fff; color: var(--gray-600); border: 1.5px solid var(--gray-300); }
  .pm-btn-secondary:hover { background: var(--gray-100); }
  .pm-help { font-size: 11.5px; color: var(--gray-600); line-height: 1.5; padding: 10px 14px; background: var(--blue-light); border-radius: 6px; border-left: 3px solid var(--blue-brand); margin-bottom: 14px; }
  .pm-help strong { color: var(--blue-dark); }

  /* ========== TOAST ========== */
  #el-toast {
    position: fixed; bottom: 24px; left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--blue-dark); color: #fff; padding: 12px 22px;
    border-radius: 8px; font-size: 13px; font-weight: 600;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    opacity: 0; transition: opacity 0.2s, transform 0.2s;
    z-index: 10001; pointer-events: none;
  }
  #el-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }


  /* v2.19: Rheumatology PFT Estimator (moved from in-body to head) */
  /* SCOPED: only applies inside #tab-rheum */
      #tab-rheum .rheum-est { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; }
      #tab-rheum .rheum-est * { box-sizing: border-box; }
      #tab-rheum .rheum-card { background: #fff; border: 1px solid #d0cfc8; border-radius: 10px; overflow: hidden; max-width: 100%; box-shadow: 0 2px 16px rgba(0,0,0,0.06); margin-top: 16px; }
      #tab-rheum .rheum-top { background: #0C447C; padding: 18px 24px 14px; display: flex; justify-content: space-between; align-items: center; }
      #tab-rheum .rheum-title-h { font-size: 20px; font-weight: 500; color: #E6F1FB; }
      #tab-rheum .rheum-subtitle { font-size: 11px; color: #85B7EB; letter-spacing: 0.05em; text-transform: uppercase; margin-top: 3px; }
      #tab-rheum .rh-section-bar { display: flex; align-items: center; gap: 10px; padding: 9px 20px 8px; border-top: 2px solid; border-bottom: 0.5px solid; }
      #tab-rheum .rh-section-bar.blue  { background: #E6F1FB; border-top-color: #0C447C; border-bottom-color: #B5D4F4; }
      #tab-rheum .rh-section-bar.teal  { background: #E1F5EE; border-top-color: #0F6E56; border-bottom-color: #9FE1CB; }
      #tab-rheum .rh-section-bar.amber { background: #FAEEDA; border-top-color: #854F0B; border-bottom-color: #FAC775; }
      #tab-rheum .rh-section-num { font-size: 10px; font-weight: 700; color: #fff; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      #tab-rheum .rh-section-num.blue  { background: #0C447C; }
      #tab-rheum .rh-section-num.teal  { background: #0F6E56; }
      #tab-rheum .rh-section-num.amber { background: #854F0B; }
      #tab-rheum .rh-section-title { font-size: 12px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }
      #tab-rheum .rh-section-title.blue  { color: #0C447C; }
      #tab-rheum .rh-section-title.teal  { color: #0F6E56; }
      #tab-rheum .rh-section-title.amber { color: #633806; }
      #tab-rheum .rh-section-desc { font-size: 11px; color: #777; margin-left: 2px; }
      #tab-rheum .rh-table-wrap { overflow-x: auto; }
      #tab-rheum .rh-table-wrap table { width: 100%; border-collapse: collapse; }
      #tab-rheum .rh-table-wrap thead tr { background: #f7f6f3; }
      #tab-rheum .rh-table-wrap th { font-size: 10px; color: #777; font-weight: 600; padding: 7px 16px 6px; border-bottom: 1px solid #e0dfd8; text-align: left; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap; }
      #tab-rheum .rh-table-wrap th.c-center { text-align: center; }
      #tab-rheum .rh-table-wrap td { font-size: 13px; color: #1a1a1a; border-bottom: 0.5px solid #eeede8; vertical-align: top; }
      #tab-rheum .rh-table-wrap td .cell { padding: 9px 16px; }
      #tab-rheum .rh-table-wrap tr:last-child td { border-bottom: none; }
      #tab-rheum .rh-table-wrap tr:hover td { background: #fafaf8; }
      #tab-rheum .rh-diag-name { font-size: 13px; color: #1a1a1a; line-height: 1.35; }
      #tab-rheum .rh-diag-drug { font-size: 11px; color: #185FA5; margin-top: 4px; line-height: 1.4; }
      #tab-rheum .rh-code-pill { display: inline-block; font-size: 11px; font-weight: 500; background: #E6F1FB; color: #0C447C; border-radius: 4px; padding: 2px 7px; margin: 2px 2px 0 0; font-family: 'SF Mono','Consolas',monospace; }
      #tab-rheum .rh-icd-pill  { display: inline-block; font-size: 11px; font-weight: 500; background: #f7f6f3; color: #444; border-radius: 4px; padding: 2px 7px; margin: 2px 2px 0 0; font-family: 'SF Mono','Consolas',monospace; border: 0.5px solid #d0cfc8; }
      #tab-rheum .rh-code-pill.teal  { background: #E1F5EE; color: #0F6E56; }
      #tab-rheum .rh-code-pill.red   { background: #FCEBEB; color: #791F1F; }
      #tab-rheum .rh-freq-main { font-size: 13px; font-weight: 500; color: #1a1a1a; }
      #tab-rheum .rh-freq-sub  { font-size: 11px; color: #999; margin-top: 2px; }
      #tab-rheum .rh-risk { display: inline-block; font-size: 9px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; padding: 2px 7px; border-radius: 20px; vertical-align: middle; margin-left: 4px; }
      #tab-rheum .rh-risk-h { background: #F5C4B3; color: #712B13; }
      #tab-rheum .rh-risk-m { background: #FAC775; color: #633806; }
      #tab-rheum .rh-tally { width: 44px; height: 32px; border: 1px solid #c0bfb8; border-radius: 5px; background: #f7f6f3; font-size: 16px; font-weight: 500; color: #1a1a1a; text-align: center; display: inline-flex; align-items: center; justify-content: center; cursor: text; transition: border-color 0.15s, background 0.15s; }
      #tab-rheum .rh-tally:focus { outline: none; border-color: #378ADD; background: #fff; box-shadow: 0 0 0 3px rgba(55,138,221,0.15); }
      #tab-rheum .rh-tally.teal:focus  { border-color: #0F6E56; box-shadow: 0 0 0 3px rgba(15,110,86,0.12); }
      #tab-rheum .rh-tally.amber:focus { border-color: #854F0B; box-shadow: 0 0 0 3px rgba(133,79,11,0.12); }
      #tab-rheum .rh-symptom-body { padding: 16px 20px; }
      #tab-rheum .rh-symptom-intro { font-size: 13px; color: #1a1a1a; margin-bottom: 12px; line-height: 1.5; }
      #tab-rheum .rh-trigger-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
      #tab-rheum .rh-trigger-chip { background: #E1F5EE; border: 0.5px solid #9FE1CB; border-radius: 20px; padding: 5px 14px; font-size: 12px; color: #085041; font-weight: 500; }
      #tab-rheum .rh-symptom-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; align-items: start; margin-bottom: 16px; }
      #tab-rheum .rh-sym-block label { font-size: 10px; font-weight: 600; color: #777; text-transform: uppercase; letter-spacing: 0.06em; display: block; margin-bottom: 5px; }
      #tab-rheum .rh-weekly-box { background: #f0faf6; border: 1px solid #9FE1CB; border-radius: 8px; padding: 14px 18px; margin-bottom: 12px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
      #tab-rheum .rh-weekly-left { display: flex; align-items: center; gap: 12px; }
      #tab-rheum .rh-weekly-label { font-size: 13px; font-weight: 600; color: #085041; }
      #tab-rheum .rh-weekly-sub { font-size: 11px; color: #3B6D11; margin-top: 2px; }
      #tab-rheum .rh-weekly-divider { width: 1px; height: 40px; background: #9FE1CB; }
      #tab-rheum .rh-weekly-result-label { font-size: 10px; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.06em; }
      #tab-rheum .rh-weekly-result-number { font-size: 28px; font-weight: 500; color: #0F6E56; line-height: 1.1; }
      #tab-rheum .rh-weekly-result-sub { font-size: 11px; color: #aaa; }
      #tab-rheum .rh-convert-note { background: #E1F5EE; border: 0.5px solid #9FE1CB; border-radius: 6px; padding: 9px 14px; font-size: 11px; color: #085041; line-height: 1.5; display: flex; align-items: flex-start; gap: 8px; }
      #tab-rheum .rh-drug-body { padding: 16px 20px; }
      #tab-rheum .rh-drug-intro { font-size: 13px; color: #1a1a1a; margin-bottom: 6px; line-height: 1.5; }
      #tab-rheum .rh-emr-tip { font-size: 11px; color: #854F0B; background: #FAEEDA; border: 0.5px solid #FAC775; border-radius: 6px; padding: 7px 12px; margin-bottom: 14px; display: flex; align-items: flex-start; gap: 7px; line-height: 1.5; }
      #tab-rheum .rh-scenario-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
      #tab-rheum .rh-scenario-card { border: 0.5px solid #e0dfd8; border-radius: 8px; overflow: hidden; display: flex; flex-direction: column; }
      #tab-rheum .rh-scenario-head { padding: 8px 12px; border-bottom: 0.5px solid #e0dfd8; }
      #tab-rheum .rh-scenario-num  { font-size: 9px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.06em; }
      #tab-rheum .rh-scenario-name { font-size: 12px; font-weight: 600; color: #1a1a1a; margin-top: 2px; }
      #tab-rheum .rh-scenario-body { padding: 10px 12px; flex: 1; }
      #tab-rheum .rh-scenario-trigger { font-size: 11px; color: #555; margin-bottom: 8px; line-height: 1.4; }
      #tab-rheum .rh-scenario-codes { display: flex; flex-wrap: wrap; gap: 4px; }
      #tab-rheum .rh-scenario-note  { font-size: 10px; color: #999; margin-top: 6px; line-height: 1.4; font-style: italic; }
      #tab-rheum .rh-scenario-tally { border-top: 0.5px solid #e0dfd8; padding: 9px 12px; background: #fafaf8; display: flex; align-items: center; gap: 10px; }
      #tab-rheum .rh-scenario-tally-label { font-size: 11px; color: #555; flex: 1; line-height: 1.3; }
      #tab-rheum .rh-scenario-card.s1 .rh-scenario-head { background: #f7f6f3; }
      #tab-rheum .rh-scenario-card.s2 .rh-scenario-head { background: #FAEEDA; }
      #tab-rheum .rh-scenario-card.s3 .rh-scenario-head { background: #FCEBEB; }
      #tab-rheum .rh-scenario-card.s2 .rh-scenario-name { color: #633806; }
      #tab-rheum .rh-scenario-card.s3 .rh-scenario-name { color: #791F1F; }
      #tab-rheum .rh-revenue-bar { border-top: 2px solid #0C447C; display: grid; grid-template-columns: 1fr 1fr 1fr; }
      #tab-rheum .rh-rev-block { padding: 14px 20px; border-right: 0.5px solid #e0dfd8; }
      #tab-rheum .rh-rev-block:last-child { border-right: none; }
      #tab-rheum .rh-rev-label { font-size: 10px; font-weight: 600; color: #999; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 4px; }
      #tab-rheum .rh-rev-number { font-size: 40px; font-weight: 500; color: #0C447C; line-height: 1; }
      #tab-rheum .rh-rev-number.green { color: #0B6E56; }
      #tab-rheum .rh-rev-sub { font-size: 11px; color: #bbb; margin-top: 3px; }
      #tab-rheum .rh-rev-rate-row { display: flex; align-items: center; gap: 8px; margin-top: 10px; }
      #tab-rheum .rh-rev-rate-row label { font-size: 11px; color: #888; }
      #tab-rheum .rh-rev-rate-input { width: 70px; height: 28px; border: 1px solid #c0bfb8; border-radius: 5px; background: #f7f6f3; font-size: 13px; font-weight: 500; color: #1a1a1a; text-align: center; padding: 0 6px; }
      #tab-rheum .rh-rev-rate-input:focus { outline: none; border-color: #378ADD; }
      #tab-rheum .rh-card-footer { background: #f7f6f3; border-top: 0.5px solid #e0dfd8; padding: 10px 20px; }
      #tab-rheum .rh-footer-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      #tab-rheum .rh-footer-block label { font-size: 9px; font-weight: 700; color: #aaa; text-transform: uppercase; letter-spacing: 0.07em; display: block; margin-bottom: 3px; }
      #tab-rheum .rh-footer-block p { font-size: 10px; color: #999; line-height: 1.6; }
      #tab-rheum .rh-footer-legal { font-size: 9px; color: #bbb; margin-top: 8px; line-height: 1.5; border-top: 0.5px solid #e0dfd8; padding-top: 8px; }

      /* ===== v2.27: GLOBAL SEARCH BAR ===== */
      .global-search-bar { position: relative; background: var(--blue-dark); padding: 0 32px 14px; }
      #global-search { width: 100%; max-width: 1100px; margin: 0 auto; display: block; height: 42px; border: 1.5px solid rgba(255,255,255,0.18); background: rgba(255,255,255,0.10); color: #fff; border-radius: 9px; padding: 0 16px; font-family: 'Inter', sans-serif; font-size: 14px; outline: none; }
      #global-search::placeholder { color: rgba(255,255,255,0.6); }
      #global-search:focus { border-color: var(--blue-brand); background: rgba(255,255,255,0.16); }
      #global-search-results { display: none; position: absolute; left: 50%; transform: translateX(-50%); top: 52px; width: calc(100% - 64px); max-width: 1100px; background: #fff; border: 1px solid var(--gray-300); border-radius: 10px; box-shadow: 0 14px 40px rgba(0,0,0,0.28); z-index: 60; max-height: 60vh; overflow-y: auto; }
      #global-search-results.show { display: block; }
      .gs-result { padding: 11px 16px; border-bottom: 1px solid var(--gray-200); cursor: pointer; }
      .gs-result:last-child { border-bottom: 0; }
      .gs-result:hover { background: var(--blue-light); }
      .gs-result-tab { font-size: 13px; font-weight: 700; color: var(--blue-dark); }
      .gs-count { font-weight: 500; font-size: 11px; color: var(--gray-600); margin-left: 6px; }
      .gs-result-snip { font-size: 12px; color: var(--gray-600); margin-top: 3px; line-height: 1.45; }
      .gs-empty { padding: 14px 16px; font-size: 13px; color: var(--gray-600); }
      mark.gs-mark { background: #ffe58a; color: #1a2733; border-radius: 2px; padding: 0 1px; }
      .gs-section-label { padding: 9px 16px 5px; font-size: 10.5px; font-weight: 800; letter-spacing: .07em; text-transform: uppercase; color: var(--gray-600); background: var(--gray-100); border-bottom: 1px solid var(--gray-200); }
      .gs-result.gs-mat { display: flex; align-items: center; gap: 10px; cursor: default; }
      .gs-mat-main { flex: 1; min-width: 0; cursor: pointer; }
      .gs-mat-btns { display: flex; gap: 6px; flex-shrink: 0; }
      .gs-mat-btns button { font-family: 'Inter', sans-serif; font-size: 11.5px; font-weight: 600; white-space: nowrap; padding: 6px 10px; border-radius: 7px; border: 1px solid var(--gray-300); background: #fff; color: var(--blue-dark); cursor: pointer; }
      .gs-mat-btns button:hover { border-color: var(--blue-brand); background: var(--blue-light); }

      /* ===== v2.27: SAVE PRACTICE ===== */
      .sp-card { background: #fff; border: 1px solid var(--gray-300); border-radius: 12px; padding: 18px 20px; margin-top: 20px; }
      .sp-card-title { font-size: 15px; font-weight: 700; color: var(--blue-dark); margin-bottom: 3px; }
      .sp-card-sub { font-size: 12.5px; color: var(--gray-600); margin-bottom: 14px; }
      .sp-form { display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end; margin-bottom: 16px; }
      .sp-form .sp-field { flex: 1; min-width: 160px; }
      .sp-form label { display: block; font-size: 11px; font-weight: 600; color: var(--gray-600); margin-bottom: 4px; }
      .sp-form input { width: 100%; height: 42px; border: 1.5px solid var(--gray-300); border-radius: 8px; padding: 0 12px; font-family: 'Inter', sans-serif; font-size: 14px; outline: none; }
      .sp-form input:focus { border-color: var(--blue-brand); }
      .sp-save-btn { height: 42px; padding: 0 20px; background: var(--blue-brand); color: #fff; border: 0; border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; }
      .sp-save-btn:hover { background: var(--blue-mid); }
      .sp-item { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 11px 14px; border: 1px solid var(--gray-200); border-radius: 9px; margin-bottom: 8px; flex-wrap: wrap; }
      .sp-item-name { font-size: 14px; font-weight: 700; color: var(--blue-dark); }
      .sp-item-sub { font-size: 11.5px; color: var(--gray-600); margin-top: 2px; }
      .sp-item-actions { display: flex; gap: 6px; }
      .sp-item-actions button { height: 34px; padding: 0 14px; border-radius: 7px; border: 1.5px solid var(--blue-brand); background: #fff; color: var(--blue-brand); font-family: 'Inter', sans-serif; font-size: 12.5px; font-weight: 600; cursor: pointer; }
      .sp-item-actions button:hover { background: var(--blue-light); }
      .sp-item-actions button.sp-del { border-color: var(--gray-300); color: var(--red); }
      .sp-item-actions button.sp-del:hover { background: var(--red-light); }
      .rates-stamp { display: inline-block; font-size: 11px; font-weight: 600; color: var(--gray-600); background: var(--gray-100); border: 1px solid var(--gray-200); border-radius: 6px; padding: 3px 9px; margin-left: 8px; }

      /* ===== v2.27: print a clean one-page ROI leave-behind ===== */
      @media print {
        body.printing-roi .site-header,
        body.printing-roi .global-search-bar,
        body.printing-roi #global-search-results { display: none !important; }
        body.printing-roi #roi-fullscreen { position: static !important; display: block !important; box-shadow: none !important; }
      }

  /* PulmOne logo (added) */
  .header-inner > .tk-logo{height:48px;width:auto;display:block;background:#fff;padding:8px 12px;border-radius:8px;align-self:center;flex:0 0 auto;}
  @media print{.header-inner > .tk-logo{-webkit-print-color-adjust:exact;print-color-adjust:exact;background:#fff !important;}}
</style>
</head>
<body>

<div class="site-header">
  <div class="header-inner">
    <img class="tk-logo" src="data:image/jpeg;base64," alt="PulmOne">
    <div>
      <div class="header-brand">PulmOne Advanced Medical Devices &mdash; Field Reference</div>
      <div class="header-title">MiniBox+&#8482; Master Toolkit</div>
      <div class="header-sub">Clinical proof, competitive positioning, CPT codes, coaching guides, PFT interpretation, email library, people directory, operations &amp; admin &mdash; plus specialty playbooks for Pulmonology, Allergy, Cardiology &amp; Rheumatology under one Specialties menu.</div>
    </div>
    <div class="header-badges">
      <button class="hbadge hbadge-profile" onclick="openProfile()" id="profile-badge" title="Set your rep profile">&#128100; <span id="profile-name-lbl">My Rep Profile</span></button>
      <div class="hbadge" id="m3-env-badge" title="Whether you're on the hosted toolkit or a local offline copy"></div>
    </div>
  </div>
  <div class="global-search-bar">
    <input id="global-search" type="search" autocomplete="off" placeholder="&#128269;  Search the whole toolkit — try “DLCO”, “94726”, “financing”, “troubleshooting”…" oninput="globalSearch(this.value)" onfocus="globalSearch(this.value)">
    <div id="global-search-results"></div>
  </div>
  <div class="tab-bar">
    <div class="tab-bar-inner">
      <!-- ROW 1: Core Selling & Clinical (8 tabs) -->
      <div class="tab-row">
        <button class="tab-btn active" onclick="showTab('overview', this)">Product Overview</button>
        <button class="tab-btn" onclick="showTab('clinical', this)">Clinical Proof</button>
        <button class="tab-btn" onclick="showTab('competitive', this)">vs. Competition</button>
        <button class="tab-btn" onclick="showTab('reimbursement', this)">CPT &amp; Revenue</button>
        <button class="tab-btn" onclick="showTab('coaching', this)">Patient Coaching</button>
        <button class="tab-btn" onclick="showTab('interpretation', this)">PFT Interpretation</button>
        <button class="tab-btn" onclick="showTab('keymsg', this)" style="color:#fda4af; font-weight:700;">&#127919; Key Messages</button>
        <button class="tab-btn" onclick="showTab('contacts', this)">People &amp; Contacts</button>
      </div>
      <!-- ROW 2: Tools, Ops, Service (8 tabs) -->
      <div class="tab-row">
        <button class="tab-btn" onclick="showTab('it', this)">IT &amp; Connectivity</button>
        <button class="tab-btn" onclick="showTab('troubleshooting', this)" style="color:#fcd34d; font-weight:700;">Troubleshooting</button>
        <button class="tab-btn" onclick="showTab('forms', this)" style="color:#86efac; font-weight:700;">&#128203; Forms</button>
        <button class="tab-btn" onclick="showTab('hub', this)" style="color:#f9a8d4; font-weight:700;">&#9889; Daily Hub</button>
        <button class="tab-btn" onclick="showTab('emaillib', this)" style="color:#93c5fd; font-weight:700;">&#9993; Email Library</button>
        <button class="tab-btn" onclick="showTab('aging', this)" style="color:#fbbf24; font-weight:700;">&#9888; Aging Devices</button>
        <button class="tab-btn" onclick="showTab('opsadmin', this)" style="color:#c4b5fd; font-weight:700;">&#9881; Ops &amp; Admin</button>
        <div class="tab-dd" id="mbx-specialties-dd">
          <button type="button" class="tab-btn tab-dd-parent" id="mbx-specialties-btn" onclick="mbxDdToggle(event)" style="color:#a5f3fc; font-weight:700;">&#129658; Specialties<span class="tab-dd-caret">&#9660;</span></button>
          <div class="tab-dd-menu">
            <button class="tab-btn" onclick="showTab('pulmo', this)" style="color:#93c5fd;">&#129729; Pulmonology</button>
            <button class="tab-btn" onclick="showTab('allergy', this)" style="color:#86efac;">&#127793; Allergy / Immunology</button>
            <button class="tab-btn" onclick="showTab('cardio', this)" style="color:#fca5a5;">❤ Cardiology</button>
            <button class="tab-btn" onclick="showTab('rheum', this)" style="color:#a5f3fc;">&#129460; Rheumatology</button>
          </div>
        </div>
      </div>
      <!-- ROW 3: Rep Field Resources -->
      <div class="tab-row">
        <button class="tab-btn" onclick="showTab('trunkstock', this)" style="color:#fdba74; font-weight:700;">&#129528; Trunk Stock</button>
        <button class="tab-btn" onclick="showTab('billing', this)" style="color:#6ee7b7; font-weight:700;">&#128181; Billing Helper</button>
        <button class="tab-btn" onclick="showTab('financing', this)" style="color:#7dd3fc; font-weight:700;">&#128176; Financing</button>
        <button class="tab-btn" id="mbx-chat-tabbtn" onclick="showTab('teamchat', this); mbxChatOpened();" style="color:#5eead4; font-weight:700;">&#128172; Team Chat<span id="mbx-chat-badge" style="display:none;margin-left:5px;background:#ef4444;color:#fff;border-radius:999px;padding:1px 7px;font-size:10px;font-weight:800;vertical-align:1px;"></span></button>
        <button class="tab-btn" onclick="showTab('myday', this)" style="color:#f0abfc; font-weight:700;">&#128506; My Day</button>
      </div>
    </div>
  </div>
</div>

<div class="content-wrap">

  <!-- TEAM CHAT -->
  <div class="tab-panel" id="tab-teamchat">
    <div style="max-width:760px;margin:0 auto;">
      <div style="background:linear-gradient(135deg,var(--blue-dark),var(--blue-mid));color:#fff;border-radius:16px 16px 0 0;padding:18px 22px;">
        <div style="font-size:19px;font-weight:800;">&#128172; Team Chat</div>
        <div style="font-size:12.5px;color:#bcd4ea;margin-top:3px;">Private to the PulmOne team &mdash; everyone behind the toolkit password sees the same conversation. Questions, wins, ideas: fire away.</div>
      </div>
      <div id="mbx-chat-shell" style="background:#fff;border:1px solid var(--gray-200);border-top:0;border-radius:0 0 16px 16px;overflow:hidden;">
        <div id="mbx-chat-list" style="height:52vh;min-height:300px;overflow-y:auto;padding:16px 14px;background:var(--gray-100);">
          <div id="mbx-chat-status" style="text-align:center;color:var(--gray-600);font-size:13px;padding:30px 10px;">Loading the conversation&hellip;</div>
        </div>
        <div id="mbx-chat-namebar" style="display:none;padding:10px 14px;border-top:1px solid var(--gray-200);background:var(--amber-light);font-size:13px;">
          <b>Who's talking?</b> Type your name once and the team will see it on your messages:
          <input id="mbx-chat-name" placeholder="Your name" autocomplete="name" style="border:1px solid var(--gray-300);border-radius:8px;padding:6px 10px;font-size:13px;margin-left:6px;max-width:180px;">
        </div>
        <div id="mbx-chat-compose" style="display:flex;gap:8px;padding:12px;border-top:1px solid var(--gray-200);background:#fff;align-items:flex-end;">
          <textarea id="mbx-chat-input" rows="1" placeholder="Type a message&hellip;" style="flex:1;resize:none;border:1px solid var(--gray-300);border-radius:12px;padding:10px 12px;font-family:'Inter',sans-serif;font-size:14px;line-height:1.45;max-height:120px;box-sizing:border-box;"></textarea>
          <button onclick="mbxChatSend()" id="mbx-chat-sendbtn" style="background:var(--teal);color:#fff;border:0;border-radius:12px;padding:10px 18px;font-weight:800;font-size:14px;cursor:pointer;">Send</button>
        </div>
      </div>
      <div style="font-size:11.5px;color:var(--gray-600);margin-top:10px;text-align:center;">Checks for new messages automatically while you're on this tab. Enter sends &middot; Shift+Enter makes a new line.</div>
    </div>
  </div>

  <!-- OVERVIEW -->
  <div class="tab-panel active" id="tab-overview">
    <div class="section-head">
      <div class="section-icon icon-blue">&#127774;</div>
      <div>
        <div class="section-title">Product Overview</div>
        <div class="section-sub">What the MiniBox+ is, what it does, and why it matters</div>
      </div>
    </div>

    <div class="alert-box alert-blue">
      <div class="alert-icon">&#9432;</div>
      <div><strong>One-line pitch:</strong> The MiniBox+ is the only portable, cabinless pulmonary function testing device that delivers complete Spirometry, Lung Volumes (plethysmography), and DLCO &mdash; equivalent to the body box &mdash; in 15 to 20 minutes, operable by any medical office staff member, with no maintenance fees.</div>
    </div>

    <div class="card-grid grid-3">
      <div class="card">
        <div class="card-title">&#9889; Fast</div>
        <div class="card-body">Complete PFT in as little as <strong>15 to 20 minutes</strong>. Lung volumes in as little as <strong>60 seconds</strong> of tidal breathing. Traditional body box takes 30 to 45 minutes.</div>
      </div>
      <div class="card">
        <div class="card-title">&#9989; Easy</div>
        <div class="card-body">Fully automatic LVM and DLCO. <strong>6 buttons from start to finish.</strong> Anyone on your medical office staff can operate it. No specialized RT required.</div>
      </div>
      <div class="card">
        <div class="card-title">&#128200; Accurate</div>
        <div class="card-body">Clinically proven equivalent to body plethysmography in <strong>over 700 patients across 11 medical centers</strong>. Published in CHEST 2021. Same CPT codes as the body box.</div>
      </div>
      <div class="card">
        <div class="card-title">&#128100; Comfortable</div>
        <div class="card-body">Cabinless &mdash; <strong>no claustrophobia, no anxiety.</strong> Tidal breathing only for LVM. Can test obese, wheelchair-bound, or bedridden patients. Ideal for pediatrics from age 5.</div>
      </div>
      <div class="card">
        <div class="card-title">&#128301; Portable</div>
        <div class="card-body"><strong>Smallest footprint</strong> of any plethysmography device. Sits on a desktop. Moves between exam rooms. Can be wheeled on optional dedicated cart with DLCO gas cylinder.</div>
      </div>
      <div class="card">
        <div class="card-title">&#128176; No Maintenance</div>
        <div class="card-body"><strong>Zero maintenance fees.</strong> No parts contract. No monthly sensor cleaning. No annual PM required. Self-calibrating before every test. 5-minute wipe-down between patients.</div>
      </div>
    </div>

    <div class="divider"></div>

    <div class="section-head">
      <div class="section-icon icon-teal">&#128203;</div>
      <div>
        <div class="section-title">What It Measures</div>
        <div class="section-sub">Complete set of 30+ parameters, fully ATS/ERS compliant</div>
      </div>
    </div>

    <div class="card-grid grid-3">
      <div class="card">
        <div class="card-title" style="color:#1e40af;">&#129295; Spirometry (FVC)</div>
        <div class="card-body">FEV1, FVC, FEV1/FVC, FEF 25-75, PEF, FEV6, MVV, SVC, and more. Pre and post bronchodilator. Methacholine challenge. Provocation testing. 6-Minute Walk Test.</div>
      </div>
      <div class="card">
        <div class="card-title" style="color:#92400e;">&#127847; Lung Volumes (LVM)</div>
        <div class="card-body">TLC, FRC, RV, VC, IC, ERV &mdash; same volumes as body plethysmography. Measures <strong>trapped air</strong> that gas dilution methods miss in obstructive disease. GLI reference values standard.</div>
      </div>
      <div class="card">
        <div class="card-title" style="color:#6d28d9;">&#128165; Diffusing Capacity (DLCO)</div>
        <div class="card-body">DLCO, VA, DLCO/VA (KCO). Single-breath method. Fully automatic. Differentiates damage from COVID vs. COPD vs. asthma. Identifies ILD, emphysema, pulmonary vascular disease.</div>
      </div>
    </div>

    <div class="divider"></div>

    <div class="section-head">
      <div class="section-icon icon-green">&#127968;</div>
      <div>
        <div class="section-title">Ideal Settings</div>
      </div>
    </div>
    <div class="card-grid grid-3">
      <div class="card">
        <div class="card-title">Private Practice</div>
        <div class="card-body">Pulmonology, Allergy, and Internal Medicine offices. Runs without a dedicated PFT room. Any staff member can operate it. Generates immediate revenue through fully reimbursable CPT codes.</div>
      </div>
      <div class="card">
        <div class="card-title">Hospital Outpatient Clinics</div>
        <div class="card-body">Smallest plethysmography footprint available. HL7-compliant, integrates with all major EMR systems. Mobile between locations &mdash; ideal for multi-site health systems.</div>
      </div>
      <div class="card">
        <div class="card-title">Pediatrics</div>
        <div class="card-body">Children can be tested from age 5. Cabinless design eliminates claustrophobia. Tidal breathing only &mdash; no exhausting panting maneuvers. Testing takes 15 to 20 minutes vs. 45 with a body box.</div>
      </div>
    </div>
  </div>

  <!-- CLINICAL PROOF -->
  <div class="tab-panel" id="tab-cardio">
    <style>
      #tab-cardio .cx { --cxink:#0b2545; --cxred:#e0342f; --cxblue:#185fa5; --cxsoft:#5f5e5a; --cxline:#e3e0d8; --cxwash:#fbeaef; }
      #tab-cardio .cx-lede { font-size:14.5px; color:var(--cxsoft); max-width:700px; line-height:1.6; margin:2px 0 6px; }
      #tab-cardio .cx-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin:16px 0 8px; }
      #tab-cardio .cx-stat { background:#fff; border:1px solid var(--cxline); border-left:4px solid var(--cxred); border-radius:11px; padding:15px 17px; }
      #tab-cardio .cx-big { font-size:27px; font-weight:800; color:var(--cxink); line-height:1; }
      #tab-cardio .cx-lbl { margin-top:7px; font-size:12.5px; color:var(--cxsoft); line-height:1.45; }
      #tab-cardio .cx-sec { margin-top:26px; }
      #tab-cardio .cx-sec-title { font-size:18px; font-weight:800; color:var(--cxink); letter-spacing:-.01em; margin-bottom:13px; }
      #tab-cardio .cx-grid2 { display:grid; grid-template-columns:1fr 1fr; gap:13px; }
      #tab-cardio .cx-card { background:#fff; border:1px solid var(--cxline); border-radius:12px; padding:15px 17px; }
      #tab-cardio .cx-card h4 { font-size:14px; font-weight:800; color:var(--cxink); margin:0 0 5px; }
      #tab-cardio .cx-card p { font-size:12.7px; color:#3c4655; margin:0; line-height:1.55; }
      #tab-cardio .cx-src { display:block; margin-top:8px; font-size:10.5px; color:var(--cxblue); line-height:1.4; }
      #tab-cardio .cx-note { font-size:11.5px; color:var(--cxsoft); font-style:italic; }
      #tab-cardio .cx-dlco { margin-top:16px; background:var(--cxink); border-left:5px solid var(--cxred); border-radius:12px; padding:18px 20px; }
      #tab-cardio .cx-dlco h4 { color:#fff; font-size:15px; font-weight:800; margin:0 0 6px; }
      #tab-cardio .cx-dlco p { color:#e6edf6; font-size:13px; line-height:1.55; margin:0 0 8px; }
      #tab-cardio .cx-dlco .cx-src { color:#a9c6ec; }
      #tab-cardio .cx-dlco .cx-pill { display:inline-block; font-size:10px; font-weight:800; letter-spacing:.06em; text-transform:uppercase; background:rgba(224,52,47,.22); color:#ffd7d3; padding:3px 9px; border-radius:6px; margin-bottom:9px; }
      #tab-cardio table.cx-bill { width:100%; border-collapse:collapse; font-size:13.5px; margin-top:6px; }
      #tab-cardio table.cx-bill th { text-align:left; font-size:10px; text-transform:uppercase; letter-spacing:.07em; color:#fff; background:var(--cxblue); font-weight:700; padding:9px 10px; }
      #tab-cardio table.cx-bill th:last-child { text-align:right; }
      #tab-cardio table.cx-bill td { padding:9px 10px; border-bottom:1px solid var(--cxline); color:#3c4655; }
      #tab-cardio table.cx-bill td:last-child { text-align:right; }
      #tab-cardio table.cx-bill td.code { font-weight:700; color:var(--cxblue); }
      #tab-cardio table.cx-bill tr.total td { border-top:2px solid var(--cxred); border-bottom:none; font-weight:800; color:var(--cxink); }
      #tab-cardio table.cx-bill tr.total td:last-child { color:var(--cxred); font-size:16px; }
      #tab-cardio .cx-files { background:#fff; border:1px solid var(--cxline); border-radius:12px; padding:16px 18px; margin-top:14px; }
      #tab-cardio .cx-file-row { display:flex; align-items:center; gap:12px; flex-wrap:wrap; }
      #tab-cardio .cx-file-row .cx-fname { font-weight:700; color:var(--cxink); font-size:13.5px; flex:1; min-width:200px; }
      #tab-cardio .cx-btn { font-size:12.5px; font-weight:700; border:1.5px solid var(--cxline); color:var(--cxink); background:#fff; border-radius:999px; padding:7px 15px; cursor:pointer; }
      #tab-cardio .cx-btn:hover { border-color:var(--cxblue); color:var(--cxblue); }
      #tab-cardio .cx-btn.primary { background:var(--cxred); border-color:var(--cxred); color:#fff; }
      #tab-cardio .cx-disc { font-size:11px; color:var(--cxsoft); line-height:1.55; margin-top:14px; }
      #tab-cardio .cxsub-nav { display:flex; flex-wrap:wrap; gap:8px; margin:4px 0 18px; }
      #tab-cardio .cxsub-btn { font-size:13px; font-weight:700; border:1.5px solid var(--gray-300); color:var(--gray-600); background:#fff; border-radius:999px; padding:8px 18px; cursor:pointer; transition:all .12s; }
      #tab-cardio .cxsub-btn:hover { border-color:#e0342f; color:#b02622; }
      #tab-cardio .cxsub-btn.on { border-color:#e0342f; background:#fbeaef; color:#b02622; }
      @media(max-width:720px){ #tab-cardio .cx-grid2, #tab-cardio .cx-stats { grid-template-columns:1fr; } }
    </style>

    <div class="section-head">
      <div class="section-icon" style="background:#e0342f;color:#fff;">&#10084;</div>
      <div>
        <div class="section-title">Cardiology</div>
        <div class="section-sub">Why cardiologists need complete PFTs &mdash; the clinical case, the DLCO story, and the billing, every claim sourced</div>
      </div>
    </div>

    <div class="cxsub-nav">
      <button type="button" class="cxsub-btn on" id="cxsub-playbook" onclick="cardioShowView('playbook', this)">&#128214; The Playbook</button>
      <button type="button" class="cxsub-btn" id="cxsub-evidence" onclick="cardioShowView('evidence', this)">&#128300; Evidence &amp; Billing</button>
    </div>

    <div id="cardio-view-playbook">
      <div style="background:#f1f5f9; padding:10px 18px; font-size:12px; color:#475569; border:1px solid #e2e8f0; border-bottom:0; border-radius:10px 10px 0 0;">
        &#9432; Two views inside &mdash; <strong>Rep Playbook</strong> (triggers, discovery questions, objection battlecard) and <strong>Show the Doctor</strong> (the clinical case plus a live ROI calculator you can hand across the desk). Flip between them with the toggle at the top of the playbook.
      </div>
      <iframe id="cardio-playbook-iframe" title="MiniBox Cardiology Playbook"
        style="width:100%; border:1px solid #e2e8f0; border-radius:0 0 10px 10px; height:2450px; display:block; background:#F1F6F6;"
        srcdoc="&lt;!DOCTYPE html&gt;
&lt;html lang=&quot;en&quot;&gt;
&lt;head&gt;
&lt;meta charset=&quot;UTF-8&quot;&gt;
&lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot;&gt;
&lt;title&gt;MiniBox Cardiology Playbook&lt;/title&gt;
&lt;link rel=&quot;preconnect&quot; href=&quot;https://fonts.googleapis.com&quot;&gt;
&lt;link rel=&quot;preconnect&quot; href=&quot;https://fonts.gstatic.com&quot; crossorigin&gt;
&lt;link href=&quot;https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&amp;family=Inter:wght@400;500;600;700&amp;family=IBM+Plex+Mono:wght@400;500;600&amp;display=swap&quot; rel=&quot;stylesheet&quot;&gt;
&lt;style&gt;
  :root{
    --ink:#0A1A24;
    --ink-2:#0E2732;
    --ink-3:#12303c;
    --paper:#F1F6F6;
    --card:#FFFFFF;
    --line:#DCE6E6;
    --teal:#0E9E97;
    --teal-bright:#1FC9BE;
    --teal-deep:#0A6f6a;
    --pulse:#E4574C;
    --muted:#5C7078;
    --muted-2:#8AA0A6;
    --readout:#22E0D2;
    --display:&quot;Space Grotesk&quot;,system-ui,sans-serif;
    --body:&quot;Inter&quot;,system-ui,sans-serif;
    --mono:&quot;IBM Plex Mono&quot;,ui-monospace,monospace;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{
    font-family:var(--body);
    background:var(--paper);
    color:var(--ink);
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
    padding-bottom:56px;
  }

  /* Header */
  .topbar{
    position:sticky;top:0;z-index:50;
    background:var(--ink);
    color:#fff;
    border-bottom:1px solid rgba(255,255,255,0.08);
  }
  .topbar-inner{
    max-width:1040px;margin:0 auto;
    padding:14px 20px;
    display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;
  }
  .brand{display:flex;align-items:center;gap:11px;}
  .brand .glyph{width:30px;height:30px;flex:0 0 auto;}
  .brand .word{font-family:var(--display);font-weight:700;letter-spacing:0.02em;font-size:1.02rem;line-height:1;}
  .brand .sub{font-family:var(--mono);font-size:0.6rem;letter-spacing:0.22em;color:var(--teal-bright);text-transform:uppercase;margin-top:3px;}

  .modeswitch{display:inline-flex;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:999px;padding:4px;}
  .modeswitch button{
    font-family:var(--mono);font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;
    color:rgba(255,255,255,0.7);background:transparent;border:none;cursor:pointer;
    padding:9px 16px;border-radius:999px;transition:all .18s ease;white-space:nowrap;
  }
  .modeswitch button.active{background:var(--teal);color:#fff;}
  .modeswitch button:focus-visible{outline:2px solid var(--teal-bright);outline-offset:2px;}

  /* Layout */
  main{max-width:1040px;margin:0 auto;padding:0 20px;}
  .mode{display:none;}
  .mode.active{display:block;animation:fade .35s ease;}
  @keyframes fade{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:none;}}

  .eyebrow{font-family:var(--mono);font-size:0.66rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--teal-deep);}
  .section{padding:34px 0;border-bottom:1px solid var(--line);}
  .section:last-child{border-bottom:none;}
  h2.sh{font-family:var(--display);font-weight:600;font-size:1.5rem;letter-spacing:-0.01em;margin:8px 0 6px;}
  .lead{color:var(--muted);max-width:60ch;font-size:0.98rem;}

  /* HERO (doctor view) */
  .hero{background:var(--ink);color:#fff;border-radius:18px;overflow:hidden;margin-top:26px;position:relative;}
  .hero-inner{padding:38px 30px 30px;position:relative;z-index:2;}
  .hero .eyebrow{color:var(--teal-bright);}
  .hero h1{
    font-family:var(--display);font-weight:700;font-size:2.55rem;line-height:1.02;letter-spacing:-0.02em;
    margin:14px 0 14px;max-width:16ch;
  }
  .hero h1 .em{color:var(--teal-bright);}
  .hero p{color:rgba(255,255,255,0.74);max-width:52ch;font-size:1.02rem;}
  .trace-wrap{width:100%;height:90px;margin-top:22px;}
  .trace{width:100%;height:100%;display:block;}
  .trace path{fill:none;stroke-linecap:round;stroke-linejoin:round;}
  .trace .base{stroke:rgba(255,255,255,0.10);stroke-width:1.5;}
  .trace .live{stroke:var(--teal-bright);stroke-width:2.6;filter:drop-shadow(0 0 6px rgba(31,201,190,0.5));}
  .trace .live.pulse{stroke:var(--pulse);filter:drop-shadow(0 0 6px rgba(228,87,76,0.55));}

  /* thesis chips under hero */
  .thesis{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:14px;overflow:hidden;margin-top:26px;}
  .thesis .cell{background:var(--card);padding:20px 18px;}
  .thesis .n{font-family:var(--mono);font-size:0.66rem;letter-spacing:0.16em;color:var(--teal-deep);}
  .thesis .big{font-family:var(--display);font-weight:700;font-size:1.9rem;line-height:1;margin:8px 0 6px;letter-spacing:-0.02em;}
  .thesis .cap{font-size:0.86rem;color:var(--muted);}

  /* evidence pillars */
  .pillars{display:grid;grid-template-columns:1fr;gap:14px;margin-top:22px;}
  .pillar{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:22px 22px;position:relative;}
  .pillar .tag{font-family:var(--mono);font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:#fff;background:var(--teal);display:inline-block;padding:4px 9px;border-radius:6px;}
  .pillar .tag.risk{background:var(--pulse);}
  .pillar h3{font-family:var(--display);font-weight:600;font-size:1.16rem;margin:13px 0 7px;}
  .pillar p{font-size:0.94rem;color:var(--ink);}
  .pillar .stat{display:flex;align-items:baseline;gap:10px;margin-top:14px;padding-top:14px;border-top:1px dashed var(--line);}
  .pillar .stat .num{font-family:var(--display);font-weight:700;font-size:1.7rem;color:var(--teal-deep);letter-spacing:-0.02em;line-height:1;}
  .pillar .stat .txt{font-size:0.82rem;color:var(--muted);}

  /* ROI monitor */
  .roi{margin-top:24px;display:grid;grid-template-columns:1fr 1fr;gap:20px;}
  .roi-inputs{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:24px;}
  .roi-inputs h3{font-family:var(--display);font-weight:600;font-size:1.1rem;margin-bottom:4px;}
  .roi-inputs .hint{font-size:0.8rem;color:var(--muted);margin-bottom:20px;}
  .field{margin-bottom:20px;}
  .field label{display:flex;justify-content:space-between;align-items:baseline;font-size:0.86rem;font-weight:500;margin-bottom:9px;gap:12px;}
  .field label .val{font-family:var(--mono);font-weight:600;color:var(--teal-deep);font-size:0.92rem;}
  input[type=range]{-webkit-appearance:none;appearance:none;width:100%;height:5px;border-radius:5px;background:var(--line);outline:none;}
  input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:22px;height:22px;border-radius:50%;background:var(--teal);border:3px solid #fff;box-shadow:0 1px 6px rgba(10,26,36,0.25);cursor:pointer;}
  input[type=range]::-moz-range-thumb{width:22px;height:22px;border-radius:50%;background:var(--teal);border:3px solid #fff;box-shadow:0 1px 6px rgba(10,26,36,0.25);cursor:pointer;}
  input[type=range]:focus-visible{outline:2px solid var(--teal-bright);outline-offset:4px;}
  .numfield{display:flex;align-items:center;gap:8px;}
  .numfield .pre{font-family:var(--mono);color:var(--muted);font-size:0.95rem;}
  .numfield input[type=number]{font-family:var(--mono);font-size:0.98rem;font-weight:600;color:var(--ink);border:1px solid var(--line);border-radius:8px;padding:9px 11px;width:100%;background:var(--paper);}
  .numfield input[type=number]:focus-visible{outline:2px solid var(--teal);outline-offset:1px;}
  .fieldnote{font-size:0.75rem;color:var(--muted-2);margin-top:7px;}

  .roi-out{background:var(--ink);color:#fff;border-radius:16px;padding:26px 24px;position:relative;overflow:hidden;}
  .roi-out .label{font-family:var(--mono);font-size:0.64rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.5);}
  .readout{font-family:var(--mono);font-weight:600;color:var(--readout);letter-spacing:-0.01em;line-height:1;text-shadow:0 0 14px rgba(34,224,210,0.35);}
  .readout.big{font-size:2.9rem;margin:8px 0 2px;}
  .roi-sub{font-size:0.82rem;color:rgba(255,255,255,0.6);margin-bottom:22px;}
  .roi-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:6px;}
  .roi-cell{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.09);border-radius:11px;padding:14px 15px;}
  .roi-cell .readout{font-size:1.5rem;}
  .roi-cell .label{margin-bottom:6px;}
  .roi-foot{font-size:0.72rem;color:rgba(255,255,255,0.42);margin-top:20px;line-height:1.5;}

  /* code stack */
  .codes{margin-top:20px;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:20px 22px;}
  .codes .eyebrow{margin-bottom:14px;display:block;}
  .code-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px dashed var(--line);gap:12px;}
  .code-row:last-of-type{border-bottom:none;}
  .code-row .c{font-family:var(--mono);font-weight:600;color:var(--ink);font-size:0.92rem;}
  .code-row .d{font-size:0.85rem;color:var(--muted);flex:1;}
  .code-row .p{font-family:var(--mono);font-weight:600;color:var(--teal-deep);font-size:0.92rem;}
  .code-total{display:flex;justify-content:space-between;margin-top:12px;padding-top:13px;border-top:2px solid var(--ink);font-family:var(--mono);font-weight:600;}
  .code-total .p{color:var(--teal-deep);}

  /* honest note */
  .honest{margin-top:22px;background:#EAF4F3;border:1px solid #CDE6E3;border-left:4px solid var(--teal);border-radius:10px;padding:16px 18px;font-size:0.88rem;color:var(--ink-2);}
  .honest b{color:var(--teal-deep);}

  /* REP MODE */
  .rep-hero{background:var(--ink-2);color:#fff;border-radius:16px;padding:28px 26px;margin-top:26px;}
  .rep-hero .eyebrow{color:var(--teal-bright);}
  .rep-hero h1{font-family:var(--display);font-weight:700;font-size:1.9rem;letter-spacing:-0.015em;margin:12px 0 10px;}
  .rep-hero p{color:rgba(255,255,255,0.72);max-width:60ch;font-size:0.98rem;}
  .rep-hero .one{margin-top:16px;font-family:var(--display);font-size:1.15rem;color:var(--teal-bright);font-weight:500;}

  .mind{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:22px;}
  .mind .m{background:var(--card);border:1px solid var(--line);border-radius:13px;padding:20px;}
  .mind .m .k{font-family:var(--mono);font-size:0.62rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--teal-deep);}
  .mind .m h4{font-family:var(--display);font-weight:600;font-size:1.05rem;margin:9px 0 7px;}
  .mind .m p{font-size:0.88rem;color:var(--muted);}

  .qlist{margin-top:20px;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:8px 22px;}
  .q{display:flex;gap:16px;padding:15px 0;border-bottom:1px solid var(--line);}
  .q:last-child{border-bottom:none;}
  .q .qn{font-family:var(--mono);font-weight:600;color:var(--teal-deep);font-size:0.9rem;flex:0 0 auto;width:26px;}
  .q .qt{font-size:0.95rem;color:var(--ink);}
  .q .qt .why{display:block;font-size:0.8rem;color:var(--muted);margin-top:4px;}

  .cards{margin-top:20px;display:grid;gap:12px;}
  .obj{background:var(--card);border:1px solid var(--line);border-radius:13px;overflow:hidden;}
  .obj summary{cursor:pointer;list-style:none;padding:18px 20px;display:flex;align-items:center;gap:14px;font-weight:600;font-size:0.98rem;}
  .obj summary::-webkit-details-marker{display:none;}
  .obj summary .icon{flex:0 0 auto;width:26px;height:26px;border-radius:7px;background:var(--pulse);color:#fff;display:grid;place-items:center;font-family:var(--mono);font-size:0.9rem;transition:transform .2s ease;}
  .obj[open] summary .icon{transform:rotate(45deg);background:var(--teal);}
  .obj summary .q-txt{flex:1;}
  .obj .ans{padding:0 20px 20px 60px;color:var(--ink-2);font-size:0.93rem;border-top:1px solid var(--line);margin-top:-1px;padding-top:16px;}
  .obj .ans .flip{display:inline-block;margin-top:10px;font-family:var(--mono);font-size:0.75rem;letter-spacing:0.08em;color:var(--teal-deep);background:#EAF4F3;border:1px solid #CDE6E3;border-radius:7px;padding:6px 10px;cursor:pointer;}
  .obj summary:focus-visible{outline:2px solid var(--teal);outline-offset:-2px;}

  .close{margin-top:24px;background:var(--ink);color:#fff;border-radius:16px;padding:28px 26px;}
  .close .eyebrow{color:var(--teal-bright);}
  .close h3{font-family:var(--display);font-weight:600;font-size:1.35rem;margin:12px 0 10px;}
  .close p{color:rgba(255,255,255,0.74);max-width:58ch;font-size:0.96rem;}
  .close .line{display:flex;gap:14px;margin-top:18px;flex-wrap:wrap;}
  .close .line span{font-family:var(--mono);font-size:0.72rem;letter-spacing:0.06em;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.13);border-radius:8px;padding:9px 13px;color:rgba(255,255,255,0.85);}

  footer{max-width:1040px;margin:0 auto;padding:24px 20px 8px;color:var(--muted-2);font-size:0.72rem;line-height:1.6;}

  @media(max-width:760px){
    .hero h1{font-size:2rem;}
    .thesis{grid-template-columns:1fr;}
    .roi{grid-template-columns:1fr;}
    .mind{grid-template-columns:1fr;}
    .roi-grid{grid-template-columns:1fr;}
    .brand .word{font-size:0.95rem;}
    .topbar-inner{padding:12px 16px;}
    main{padding:0 16px;}
  }
  @media(prefers-reduced-motion:reduce){
    .trace .live{stroke-dasharray:none !important;stroke-dashoffset:0 !important;animation:none !important;}
    .mode.active{animation:none;}
  }
&lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;

&lt;header class=&quot;topbar&quot;&gt;
  &lt;div class=&quot;topbar-inner&quot;&gt;
    &lt;div class=&quot;brand&quot;&gt;
      &lt;svg class=&quot;glyph&quot; viewBox=&quot;0 0 32 32&quot; fill=&quot;none&quot; aria-hidden=&quot;true&quot;&gt;
        &lt;rect x=&quot;1.5&quot; y=&quot;1.5&quot; width=&quot;29&quot; height=&quot;29&quot; rx=&quot;7&quot; stroke=&quot;#1FC9BE&quot; stroke-width=&quot;2&quot;/&gt;
        &lt;path d=&quot;M5 17 L11 17 L13.5 9 L17 24 L19.5 14 L22 20 L24 17 L27 17&quot; stroke=&quot;#fff&quot; stroke-width=&quot;2.1&quot; stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot;/&gt;
      &lt;/svg&gt;
      &lt;div&gt;
        &lt;div class=&quot;word&quot;&gt;MiniBox&lt;/div&gt;
        &lt;div class=&quot;sub&quot;&gt;Cardiology Playbook&lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;
    &lt;div class=&quot;modeswitch&quot; role=&quot;tablist&quot; aria-label=&quot;View mode&quot;&gt;
      &lt;button id=&quot;btn-rep&quot; class=&quot;active&quot; role=&quot;tab&quot; aria-selected=&quot;true&quot; onclick=&quot;setMode('rep')&quot;&gt;Rep Playbook&lt;/button&gt;
      &lt;button id=&quot;btn-doc&quot; role=&quot;tab&quot; aria-selected=&quot;false&quot; onclick=&quot;setMode('doc')&quot;&gt;Show the Doctor&lt;/button&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/header&gt;

&lt;main&gt;

  &lt;!-- ================= REP MODE ================= --&gt;
  &lt;section id=&quot;mode-rep&quot; class=&quot;mode active&quot; role=&quot;tabpanel&quot; aria-label=&quot;Rep Playbook&quot;&gt;

    &lt;div class=&quot;rep-hero&quot;&gt;
      &lt;span class=&quot;eyebrow&quot;&gt;Field brief&lt;/span&gt;
      &lt;h1&gt;Selling PFTs into a cardiology practice&lt;/h1&gt;
      &lt;p&gt;The cardiologist does not want to be a pulmonologist. They want an answer to a question their patient already handed them. Sell the answer, not the machine.&lt;/p&gt;
      &lt;div class=&quot;one&quot;&gt;One symptom. Two organs. Test in the room the patient is already sitting in.&lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&quot;section&quot;&gt;
      &lt;span class=&quot;eyebrow&quot;&gt;Get in their head&lt;/span&gt;
      &lt;h2 class=&quot;sh&quot;&gt;Why a cardiologist actually tests&lt;/h2&gt;
      &lt;p class=&quot;lead&quot;&gt;Every reason maps to a patient already on their schedule. Lead with the one that fits the practice in front of you.&lt;/p&gt;
      &lt;div class=&quot;mind&quot;&gt;
        &lt;div class=&quot;m&quot;&gt;
          &lt;div class=&quot;k&quot;&gt;Trigger 01&lt;/div&gt;
          &lt;h4&gt;The breathless patient&lt;/h4&gt;
          &lt;p&gt;Shortness of breath is the symptom the heart and lungs share. A complete study runs about fifteen minutes and tells the cardiologist which organ to treat, instead of treating the heart and hoping.&lt;/p&gt;
        &lt;/div&gt;
        &lt;div class=&quot;m&quot;&gt;
          &lt;div class=&quot;k&quot;&gt;Trigger 02&lt;/div&gt;
          &lt;h4&gt;The amiodarone patient&lt;/h4&gt;
          &lt;p&gt;Baseline diffusion capacity is recommended before amiodarone, and almost nobody gets it. Every atrial fibrillation practice is sitting on scripts with no baseline. This is a safety gap you can close.&lt;/p&gt;
        &lt;/div&gt;
        &lt;div class=&quot;m&quot;&gt;
          &lt;div class=&quot;k&quot;&gt;Trigger 03&lt;/div&gt;
          &lt;h4&gt;The heart failure patient&lt;/h4&gt;
          &lt;p&gt;A quarter to half of heart failure patients also have COPD, and about half of that is undiagnosed. Finding it changes how they dose beta blockers and bronchodilators.&lt;/p&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&quot;section&quot;&gt;
      &lt;span class=&quot;eyebrow&quot;&gt;Open the conversation&lt;/span&gt;
      &lt;h2 class=&quot;sh&quot;&gt;Discovery questions&lt;/h2&gt;
      &lt;p class=&quot;lead&quot;&gt;Ask these before you pitch anything. The answers hand you the pitch and size the revenue for the doctor view.&lt;/p&gt;
      &lt;div class=&quot;qlist&quot;&gt;
        &lt;div class=&quot;q&quot;&gt;&lt;div class=&quot;qn&quot;&gt;01&lt;/div&gt;&lt;div class=&quot;qt&quot;&gt;How many of your patients name shortness of breath as a complaint or carry it as a comorbidity?&lt;span class=&quot;why&quot;&gt;Sizes the whole opportunity and surfaces the differential problem.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;
        &lt;div class=&quot;q&quot;&gt;&lt;div class=&quot;qn&quot;&gt;02&lt;/div&gt;&lt;div class=&quot;qt&quot;&gt;When a patient's breathlessness could be cardiac or pulmonary, where do you send them today, and how long is the wait?&lt;span class=&quot;why&quot;&gt;Exposes the referral delay and the answer they are currently missing.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;
        &lt;div class=&quot;q&quot;&gt;&lt;div class=&quot;qn&quot;&gt;03&lt;/div&gt;&lt;div class=&quot;qt&quot;&gt;How many of your patients are on amiodarone right now, and do you have a baseline diffusion capacity on them?&lt;span class=&quot;why&quot;&gt;The sharpest hook. Most will pause here.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;
        &lt;div class=&quot;q&quot;&gt;&lt;div class=&quot;qn&quot;&gt;04&lt;/div&gt;&lt;div class=&quot;qt&quot;&gt;How many PFT referrals leave this practice in a typical month?&lt;span class=&quot;why&quot;&gt;Turns referral leakage into a dollar figure.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;
        &lt;div class=&quot;q&quot;&gt;&lt;div class=&quot;qn&quot;&gt;05&lt;/div&gt;&lt;div class=&quot;qt&quot;&gt;When you refer a patient out for testing, do they always come back to you?&lt;span class=&quot;why&quot;&gt;Names the retention risk of sending patients to a pulmonologist.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;
        &lt;div class=&quot;q&quot;&gt;&lt;div class=&quot;qn&quot;&gt;06&lt;/div&gt;&lt;div class=&quot;qt&quot;&gt;Who on your staff could run a fifteen minute test that needs almost no training?&lt;span class=&quot;why&quot;&gt;Preempts the staffing objection before it lands.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&quot;section&quot;&gt;
      &lt;span class=&quot;eyebrow&quot;&gt;Handle the pushback&lt;/span&gt;
      &lt;h2 class=&quot;sh&quot;&gt;Objection battlecard&lt;/h2&gt;
      &lt;p class=&quot;lead&quot;&gt;Tap a question to open the answer. These are the six things a sharp cardiologist will fire back.&lt;/p&gt;
      &lt;div class=&quot;cards&quot;&gt;

        &lt;details class=&quot;obj&quot;&gt;
          &lt;summary&gt;&lt;span class=&quot;icon&quot;&gt;+&lt;/span&gt;&lt;span class=&quot;q-txt&quot;&gt;I am a cardiologist, not a pulmonologist. This is not my lane.&lt;/span&gt;&lt;/summary&gt;
          &lt;div class=&quot;ans&quot;&gt;You are not diagnosing lung disease for its own sake. You are answering the question your patient already brought you: is this breathlessness the heart or the lungs. A complete study runs about fifteen minutes and tells you which, so you treat the right organ the first time. When it is clearly pulmonary, you refer with data instead of a guess.&lt;/div&gt;
        &lt;/details&gt;

        &lt;details class=&quot;obj&quot;&gt;
          &lt;summary&gt;&lt;span class=&quot;icon&quot;&gt;+&lt;/span&gt;&lt;span class=&quot;q-txt&quot;&gt;Who runs it? My staff is already maxed out.&lt;/span&gt;&lt;/summary&gt;
          &lt;div class=&quot;ans&quot;&gt;A medical assistant runs it after a short training. The MiniBox coaches the patient through the maneuver and flags quality in real time, so you do not need a respiratory therapist. The complete test takes about fifteen minutes, or ten if you run spirometry and diffusion capacity without lung volumes, and it happens during the visit the patient is already in your chair for.&lt;/div&gt;
        &lt;/details&gt;

        &lt;details class=&quot;obj&quot;&gt;
          &lt;summary&gt;&lt;span class=&quot;icon&quot;&gt;+&lt;/span&gt;&lt;span class=&quot;q-txt&quot;&gt;Will I actually get paid, or will these get denied?&lt;/span&gt;&lt;/summary&gt;
          &lt;div class=&quot;ans&quot;&gt;These are established codes with clear medical necessity when the patient has documented breathlessness or is on a drug like amiodarone. The device produces the report and interpretation that support the claim, and we give you the covered diagnosis list and documentation templates so claims go out clean. This is getting paid for work you are already indicated to do.&lt;/div&gt;
        &lt;/details&gt;

        &lt;details class=&quot;obj&quot;&gt;
          &lt;summary&gt;&lt;span class=&quot;icon&quot;&gt;+&lt;/span&gt;&lt;span class=&quot;q-txt&quot;&gt;I do not read PFTs all day. What if I misinterpret one?&lt;/span&gt;&lt;/summary&gt;
          &lt;div class=&quot;ans&quot;&gt;Every study can go to a board certified over read, so a signed interpretation comes back to you. You get the clinical answer and the medicolegal cover without becoming a pulmonologist. Over time most cardiologists read the common patterns themselves and keep the over read for the harder ones.&lt;/div&gt;
        &lt;/details&gt;

        &lt;details class=&quot;obj&quot;&gt;
          &lt;summary&gt;&lt;span class=&quot;icon&quot;&gt;+&lt;/span&gt;&lt;span class=&quot;q-txt&quot;&gt;What does this cost me, and when do I break even?&lt;/span&gt;&lt;/summary&gt;
          &lt;div class=&quot;ans&quot;&gt;Let me show you your own numbers.&lt;br&gt;&lt;span class=&quot;flip&quot; onclick=&quot;setMode('doc')&quot;&gt;Flip to the calculator&lt;/span&gt;&lt;/div&gt;
        &lt;/details&gt;

        &lt;details class=&quot;obj&quot;&gt;
          &lt;summary&gt;&lt;span class=&quot;icon&quot;&gt;+&lt;/span&gt;&lt;span class=&quot;q-txt&quot;&gt;How big is it, and is it as accurate as the hospital lab?&lt;/span&gt;&lt;/summary&gt;
          &lt;div class=&quot;ans&quot;&gt;It sits on a countertop, about the size of a small printer. No booth, no body box, no dedicated room. It runs full spirometry, lung volumes, and diffusion capacity to guideline standards. For heart failure patients the one rule is to test when they are stable and euvolemic, not mid decompensation, and we train your staff on exactly that.&lt;/div&gt;
        &lt;/details&gt;

      &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&quot;close&quot;&gt;
      &lt;span class=&quot;eyebrow&quot;&gt;Bring it home&lt;/span&gt;
      &lt;h3&gt;Capture the patient and the answer, same day&lt;/h3&gt;
      &lt;p&gt;Right now the cardiologist refers the breathless patient out, waits, and hands the revenue to the hospital. In office testing keeps the patient, keeps the revenue, and answers the heart or lungs question before the visit ends. Close on care first, then let the numbers confirm it.&lt;/p&gt;
      &lt;div class=&quot;line&quot;&gt;
        &lt;span&gt;Keep the patient&lt;/span&gt;
        &lt;span&gt;Keep the revenue&lt;/span&gt;
        &lt;span&gt;Answer same day&lt;/span&gt;
        &lt;span&gt;Close a real safety gap&lt;/span&gt;
      &lt;/div&gt;
    &lt;/div&gt;

  &lt;/section&gt;

  &lt;!-- ================= DOCTOR MODE ================= --&gt;
  &lt;section id=&quot;mode-doc&quot; class=&quot;mode&quot; role=&quot;tabpanel&quot; aria-label=&quot;Show the Doctor&quot;&gt;

    &lt;div class=&quot;hero&quot;&gt;
      &lt;div class=&quot;hero-inner&quot;&gt;
        &lt;span class=&quot;eyebrow&quot;&gt;Pulmonary function testing in your office&lt;/span&gt;
        &lt;h1&gt;One symptom. &lt;span class=&quot;em&quot;&gt;Two organs.&lt;/span&gt; Test in the room.&lt;/h1&gt;
        &lt;p&gt;Breathlessness is the complaint the heart and the lungs share. A complete study in about fifteen minutes tells you which one to treat, without sending your patient anywhere.&lt;/p&gt;
        &lt;div class=&quot;trace-wrap&quot;&gt;
          &lt;svg class=&quot;trace&quot; viewBox=&quot;0 0 700 90&quot; preserveAspectRatio=&quot;none&quot; aria-hidden=&quot;true&quot;&gt;
            &lt;path class=&quot;base&quot; d=&quot;M0 45 L700 45&quot;/&gt;
            &lt;path class=&quot;live pulse&quot; id=&quot;trace-pulse&quot; d=&quot;M0 45 L150 45 L165 45 L172 22 L180 68 L190 30 L200 45 L300 45&quot;/&gt;
            &lt;path class=&quot;live&quot; id=&quot;trace-breath&quot; d=&quot;M300 45 C340 45 350 12 400 12 C460 12 470 78 540 78 C600 78 620 45 700 45&quot;/&gt;
          &lt;/svg&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&quot;thesis&quot;&gt;
      &lt;div class=&quot;cell&quot;&gt;
        &lt;div class=&quot;n&quot;&gt;HEART FAILURE + COPD&lt;/div&gt;
        &lt;div class=&quot;big&quot;&gt;25 to 50%&lt;/div&gt;
        &lt;div class=&quot;cap&quot;&gt;of heart failure patients also have COPD when spirometry is used, and roughly half of it is undiagnosed.&lt;/div&gt;
      &lt;/div&gt;
      &lt;div class=&quot;cell&quot;&gt;
        &lt;div class=&quot;n&quot;&gt;SPIROMETRY USE&lt;/div&gt;
        &lt;div class=&quot;big&quot;&gt;~30%&lt;/div&gt;
        &lt;div class=&quot;cap&quot;&gt;of ambulatory heart failure patients labeled with COPD had spirometry on record. The rest are labeled on a guess.&lt;/div&gt;
      &lt;/div&gt;
      &lt;div class=&quot;cell&quot;&gt;
        &lt;div class=&quot;n&quot;&gt;AMIODARONE BASELINE&lt;/div&gt;
        &lt;div class=&quot;big&quot;&gt;single digits&lt;/div&gt;
        &lt;div class=&quot;cap&quot;&gt;the share of amiodarone patients who receive the recommended baseline pulmonary testing in real cohorts.&lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&quot;section&quot;&gt;
      &lt;span class=&quot;eyebrow&quot;&gt;Three patients already on your schedule&lt;/span&gt;
      &lt;h2 class=&quot;sh&quot;&gt;Why testing belongs in cardiology&lt;/h2&gt;
      &lt;div class=&quot;pillars&quot;&gt;

        &lt;div class=&quot;pillar&quot;&gt;
          &lt;span class=&quot;tag&quot;&gt;The differential&lt;/span&gt;
          &lt;h3&gt;Is the breathlessness the heart or the lungs&lt;/h3&gt;
          &lt;p&gt;Dyspnea is the symptom both organs produce. Without a lung measurement you treat the heart and hope. About a third of heart failure patients are mislabeled with COPD they do not have, and a similar share carry airflow obstruction nobody has confirmed. Both change how you dose beta blockers and inhaled therapy.&lt;/p&gt;
          &lt;div class=&quot;stat&quot;&gt;&lt;span class=&quot;num&quot;&gt;15 min&lt;/span&gt;&lt;span class=&quot;txt&quot;&gt;a complete in office study, during the visit the patient is already in&lt;/span&gt;&lt;/div&gt;
        &lt;/div&gt;

        &lt;div class=&quot;pillar&quot;&gt;
          &lt;span class=&quot;tag risk&quot;&gt;The amiodarone gap&lt;/span&gt;
          &lt;h3&gt;Protect the patients you already prescribe it to&lt;/h3&gt;
          &lt;p&gt;Guidelines recommend pulmonary function testing with diffusion capacity at baseline before amiodarone, because a falling diffusion capacity is the earliest sign of lung toxicity. Adherence to that recommendation is very low, mostly because the test lives somewhere else. Put it in your office and the baseline actually happens.&lt;/p&gt;
          &lt;div class=&quot;stat&quot;&gt;&lt;span class=&quot;num&quot;&gt;DLCO&lt;/span&gt;&lt;span class=&quot;txt&quot;&gt;the sensitive early marker, measured on the same device&lt;/span&gt;&lt;/div&gt;
        &lt;/div&gt;

        &lt;div class=&quot;pillar&quot;&gt;
          &lt;span class=&quot;tag&quot;&gt;The capture&lt;/span&gt;
          &lt;h3&gt;Keep the patient and the reimbursement&lt;/h3&gt;
          &lt;p&gt;The testing is indicated. The only question is whether you do it or hand it to the hospital. Every study you refer out is an answer delayed, a patient sent into someone else's orbit, and revenue you were entitled to. Testing in office keeps all three where they belong.&lt;/p&gt;
          &lt;div class=&quot;stat&quot;&gt;&lt;span class=&quot;num&quot;&gt;~$147&lt;/span&gt;&lt;span class=&quot;txt&quot;&gt;per complete study at Medicare national rates, commercial often higher&lt;/span&gt;&lt;/div&gt;
        &lt;/div&gt;

      &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&quot;section&quot;&gt;
      &lt;span class=&quot;eyebrow&quot;&gt;Run your own numbers&lt;/span&gt;
      &lt;h2 class=&quot;sh&quot;&gt;What in office testing returns&lt;/h2&gt;
      &lt;p class=&quot;lead&quot;&gt;Adjust to your practice. The readout updates as you move the dials.&lt;/p&gt;

      &lt;div class=&quot;roi&quot;&gt;
        &lt;div class=&quot;roi-inputs&quot;&gt;
          &lt;h3&gt;Your practice&lt;/h3&gt;
          &lt;div class=&quot;hint&quot;&gt;Estimate the patients you could appropriately test each week.&lt;/div&gt;

          &lt;div class=&quot;field&quot;&gt;
            &lt;label for=&quot;perweek&quot;&gt;Testable patients per week &lt;span class=&quot;val&quot; id=&quot;perweek-val&quot;&gt;10&lt;/span&gt;&lt;/label&gt;
            &lt;input type=&quot;range&quot; id=&quot;perweek&quot; min=&quot;2&quot; max=&quot;40&quot; value=&quot;10&quot; step=&quot;1&quot; oninput=&quot;calc()&quot;&gt;
            &lt;div class=&quot;fieldnote&quot;&gt;Breathless, heart failure, amiodarone baseline, and preoperative patients.&lt;/div&gt;
          &lt;/div&gt;

          &lt;div class=&quot;field&quot;&gt;
            &lt;label for=&quot;reimb&quot;&gt;Reimbursement per complete study&lt;/label&gt;
            &lt;div class=&quot;numfield&quot;&gt;&lt;span class=&quot;pre&quot;&gt;$&lt;/span&gt;&lt;input type=&quot;number&quot; id=&quot;reimb&quot; value=&quot;147&quot; min=&quot;0&quot; step=&quot;1&quot; oninput=&quot;calc()&quot;&gt;&lt;/div&gt;
            &lt;div class=&quot;fieldnote&quot;&gt;Default is the 94060, 94726, 94729 bundle at Medicare national rates.&lt;/div&gt;
          &lt;/div&gt;

          &lt;div class=&quot;field&quot;&gt;
            &lt;label for=&quot;device&quot;&gt;Device investment&lt;/label&gt;
            &lt;div class=&quot;numfield&quot;&gt;&lt;span class=&quot;pre&quot;&gt;$&lt;/span&gt;&lt;input type=&quot;number&quot; id=&quot;device&quot; value=&quot;&quot; min=&quot;0&quot; step=&quot;500&quot; placeholder=&quot;Enter your quote&quot; oninput=&quot;calc()&quot;&gt;&lt;/div&gt;
            &lt;div class=&quot;fieldnote&quot;&gt;Leave blank until you present the quote. Payback and net fill in once a number is entered.&lt;/div&gt;
          &lt;/div&gt;
        &lt;/div&gt;

        &lt;div class=&quot;roi-out&quot;&gt;
          &lt;div class=&quot;label&quot;&gt;Estimated annual PFT revenue&lt;/div&gt;
          &lt;div class=&quot;readout big&quot; id=&quot;out-annual&quot;&gt;$70,560&lt;/div&gt;
          &lt;div class=&quot;roi-sub&quot; id=&quot;out-studies&quot;&gt;480 studies a year at 48 working weeks&lt;/div&gt;

          &lt;div class=&quot;roi-grid&quot;&gt;
            &lt;div class=&quot;roi-cell&quot;&gt;
              &lt;div class=&quot;label&quot;&gt;Device payback&lt;/div&gt;
              &lt;div class=&quot;readout&quot; id=&quot;out-payback&quot;&gt;add quote&lt;/div&gt;
            &lt;/div&gt;
            &lt;div class=&quot;roi-cell&quot;&gt;
              &lt;div class=&quot;label&quot;&gt;Net after year one&lt;/div&gt;
              &lt;div class=&quot;readout&quot; id=&quot;out-net&quot;&gt;add quote&lt;/div&gt;
            &lt;/div&gt;
          &lt;/div&gt;

          &lt;div class=&quot;roi-foot&quot;&gt;Estimate only. Excludes staff time and consumables. Actual reimbursement depends on payer mix, region, and documented medical necessity. Test heart failure patients when stable and euvolemic.&lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;

      &lt;div class=&quot;codes&quot;&gt;
        &lt;span class=&quot;eyebrow&quot;&gt;The complete study, by code&lt;/span&gt;
        &lt;div class=&quot;code-row&quot;&gt;&lt;span class=&quot;c&quot;&gt;94060&lt;/span&gt;&lt;span class=&quot;d&quot;&gt;Spirometry before and after bronchodilator&lt;/span&gt;&lt;span class=&quot;p&quot;&gt;$37.85&lt;/span&gt;&lt;/div&gt;
        &lt;div class=&quot;code-row&quot;&gt;&lt;span class=&quot;c&quot;&gt;94726&lt;/span&gt;&lt;span class=&quot;d&quot;&gt;Lung volumes by plethysmography&lt;/span&gt;&lt;span class=&quot;p&quot;&gt;$54.99&lt;/span&gt;&lt;/div&gt;
        &lt;div class=&quot;code-row&quot;&gt;&lt;span class=&quot;c&quot;&gt;94729&lt;/span&gt;&lt;span class=&quot;d&quot;&gt;Diffusing capacity, DLCO&lt;/span&gt;&lt;span class=&quot;p&quot;&gt;$54.34&lt;/span&gt;&lt;/div&gt;
        &lt;div class=&quot;code-total&quot;&gt;&lt;span&gt;Complete study&lt;/span&gt;&lt;span class=&quot;p&quot;&gt;$147.18&lt;/span&gt;&lt;/div&gt;
      &lt;/div&gt;

      &lt;div class=&quot;honest&quot;&gt;
        &lt;b&gt;The honest part.&lt;/b&gt; This is not testing everyone to bill everyone. It is testing the symptomatic patient and the monitored patient, which is exactly what clean claims and good care both require. We supply the covered diagnosis list, the documentation templates, and a board certified over read so every study is defensible and every interpretation is signed.
      &lt;/div&gt;
    &lt;/div&gt;

  &lt;/section&gt;

&lt;/main&gt;

&lt;footer&gt;
  MiniBox by PulmOne. Prevalence and monitoring figures reflect peer reviewed cardiology and pulmonology literature. Reimbursement figures are Medicare national averages for 2026 and vary by payer, region, and medical necessity. This tool supports a clinical and business conversation and is not medical, billing, or legal advice.
&lt;/footer&gt;

&lt;script&gt;
  function setMode(mode){
    var rep = mode === 'rep';
    document.getElementById('mode-rep').classList.toggle('active', rep);
    document.getElementById('mode-doc').classList.toggle('active', !rep);
    document.getElementById('btn-rep').classList.toggle('active', rep);
    document.getElementById('btn-doc').classList.toggle('active', !rep);
    document.getElementById('btn-rep').setAttribute('aria-selected', rep);
    document.getElementById('btn-doc').setAttribute('aria-selected', !rep);
    window.scrollTo({top:0, behavior:'smooth'});
  }

  var WEEKS = 48;
  function fmt(n){ return '$' + Math.round(n).toLocaleString('en-US'); }

  function calc(){
    var perWeek = parseInt(document.getElementById('perweek').value, 10) || 0;
    var reimb = parseFloat(document.getElementById('reimb').value) || 0;
    var deviceRaw = document.getElementById('device').value.trim();
    var device = parseFloat(deviceRaw);
    var deviceSet = deviceRaw !== '' &amp;&amp; !isNaN(device) &amp;&amp; device &gt; 0;

    document.getElementById('perweek-val').textContent = perWeek;

    var studies = perWeek * WEEKS;
    var annual = studies * reimb;
    var monthly = annual / 12;

    document.getElementById('out-annual').textContent = fmt(annual);
    document.getElementById('out-studies').textContent = studies.toLocaleString('en-US') + ' studies a year at ' + WEEKS + ' working weeks';

    var paybackEl = document.getElementById('out-payback');
    var netEl = document.getElementById('out-net');

    if(deviceSet &amp;&amp; monthly &gt; 0){
      var months = device / monthly;
      paybackEl.textContent = (months &lt; 1 ? '&lt;1' : months.toFixed(1)) + ' mo';
      var net = annual - device;
      netEl.textContent = (net &lt; 0 ? '-' : '') + fmt(Math.abs(net));
    } else {
      paybackEl.textContent = 'add quote';
      netEl.textContent = 'add quote';
    }
  }

  // animate the trace on load, respecting reduced motion
  (function(){
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if(reduce) { calc(); return; }
    ['trace-pulse','trace-breath'].forEach(function(id, i){
      var p = document.getElementById(id);
      if(!p) return;
      var len = p.getTotalLength();
      p.style.strokeDasharray = len;
      p.style.strokeDashoffset = len;
      p.style.transition = 'stroke-dashoffset 1.1s ease ' + (i * 0.85) + 's';
      requestAnimationFrame(function(){ requestAnimationFrame(function(){ p.style.strokeDashoffset = '0'; }); });
    });
    calc();
  })();
&lt;/script&gt;

&lt;script&gt;
(function(){
  if (window.parent === window) return;
  function post(){ try{ parent.postMessage({cardioPbHeight: document.documentElement.scrollHeight}, '*'); }catch(e){} }
  window.addEventListener('load', function(){ post(); setTimeout(post, 700); setTimeout(post, 1800); });
  window.addEventListener('resize', post);
  document.addEventListener('click', function(){ setTimeout(post, 80); setTimeout(post, 450); });
})();
&lt;/script&gt;
