  {id:'brochure',    file:'MiniBox-Plus-Brochure.pdf',            title:'MiniBox+ Product Brochure',           sub:'Specs, workflow overview, connectivity, EHR integration', cat:'send',     kb:196,  blurb:'MiniBox+ Product Brochure — specs, workflow overview, connectivity options, and EHR integration details.'},
  {id:'why',         file:'Why-MiniBox.pdf',                      title:'“Why MiniBox+” Overview',   sub:'The one-pager that makes the case',                       cat:'send',     kb:373,  blurb:'“Why MiniBox+” Overview — a one-page summary of what sets the device apart.'},
  {id:'samplereport',file:'Sample-PFT-Report.pdf',                title:'Sample PFT Report',                   sub:'What the doctor sees after each test',                    cat:'send',     kb:149,  blurb:'Sample PFT Report — the report your team and referring physicians will see after each test.'},
