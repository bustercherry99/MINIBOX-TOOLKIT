      #tab-allergy .alp-qitem::before { counter-increment:alpq; content:counter(alpq); font-family:'DM Mono','SF Mono',monospace; font-weight:600; font-size:16px; color:#fff; background:var(--alt); width:28px; height:28px; border-radius:50%; display:grid; place-items:center; line-height:1; }
