                <td><div class="cell"><span class="rh-code-pill">94010</span><span class="rh-code-pill">94726</span><span class="rh-code-pill">94729</span></div></td>
                <td><div class="cell" style="text-align:center;"><div class="rh-freq-main">2x</div><div class="rh-freq-sub">semi-annual</div></div></td>
                <td><div class="cell" style="text-align:center;"><div class="rh-tally" contenteditable="true" data-rid="r3" data-freq="2" oninput="rheumCalc()" onblur="rheumClean(this)" onfocus="rheumSel(this)">0</div></div></td>
              </tr>
              <tr>
                <td><div class="cell">
                  <div class="rh-diag-name">RA with pulmonary involvement <span class="rh-risk rh-risk-m">mod</span></div>
                  <div class="rh-diag-drug">&#8595; On methotrexate or leflunomide &rarr; baseline PFT required; retest if symptoms arise</div>
                </div></td>
