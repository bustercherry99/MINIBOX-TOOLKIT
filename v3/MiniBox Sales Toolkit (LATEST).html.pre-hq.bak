      #tab-pulmo .plp-obj .plp-a { font-size:12.5px; color:var(--plsoft); margin-top:3px; line-height:1.5; }
      #tab-pulmo .plp-qs { display:grid; gap:9px; counter-reset:plpq; }
      #tab-pulmo .plp-qitem { display:grid; grid-template-columns:auto 1fr; gap:13px; align-items:start; padding:13px 16px; background:#fff; border:1px solid var(--plt-line); border-radius:11px; }
      #tab-pulmo .plp-qitem::before { counter-increment:plpq; content:counter(plpq); font-family:'DM Mono','SF Mono',monospace; font-weight:600; font-size:16px; color:#fff; background:var(--plt); width:28px; height:28px; border-radius:50%; display:grid; place-items:center; line-height:1; }
      #tab-pulmo .plp-qitem p { font-size:13.5px; color:var(--plink); margin:0; line-height:1.5; }
