    subject: 'MiniBox+ Service Request — [Practice Name]',
    body: 'Dear PulmOne Support,\n\nI am submitting a service request on behalf of [Practice Name].\n\nDevice Serial #: [Serial Number]\nIssue / Error Code: [Describe Issue]\nDate Issue Began: [Date]\nContact at Practice: [Name, Phone]\n\nPlease advise on next steps.\n\nThank you,\n[Your Name]'
  },
  intro: {
    subject: 'Introducing the MiniBox+ — Complete PFTs Without a Body Box',
    body: 'Dear Dr. [Last Name],\n\nMy name is [Your Name] from PulmOne USA. I wanted to introduce you to the MiniBox+ — the only portable device that delivers complete Spirometry, Lung Volumes (plethysmography), and DLCO in 15–20 minutes, operable by any staff member, with zero maintenance fees.\n\nIt\'s been validated against the traditional body box in a published CHEST 2021 study across 700+ patients at 11 medical centers — same accuracy, same CPT codes, fraction of the footprint.\n\nWould you be open to a 15-minute demo at your convenience? I\'m happy to work around your schedule.\n\nBest regards,\n[Your Name]\nPulmOne USA\n1-844-PulmOne (785-6663)'
  },
  cardio_intro: {
    subject: 'Complete PFTs in Your Cardiology Practice — Point-of-Care in 15–20 Minutes',
    body: 'Dear Dr. [Last Name],\n\nMy name is [Your Name] from PulmOne USA. When a patient is short of breath, the heart is only half the picture — and the pulmonary half often means a referral out. The MiniBox+ performs a complete PFT (Spirometry, Lung Volumes, and DLCO) in your own office in 15–20 minutes, operable by any staff member.\n\nFor cardiology this matters clinically: spirometry is a first-line test in the dyspnea workup; COPD is found in roughly 25–50% of heart failure patients and is widely underdiagnosed; and DLCO — which a plain spirometer cannot measure — is a recognized prognostic marker in pulmonary hypertension and HFpEF. Every one of these points is drawn from peer-reviewed sources I am happy to share.\n\nWould you be open to a 15-minute demo at your convenience?\n\nBest regards,\n[Your Name]\nPulmOne USA\n1-844-PulmOne (785-6663)'
  },
  cardio_followup: {
    subject: 'MiniBox+ for Cardiology — The Clinical Case & Billing, One Page',
    body: 'Dear Dr. [Last Name],\n\nThank you for the time today. As promised, attached is a single, fully-sourced page on where complete PFTs fit in a cardiology clinic — sorting cardiac vs pulmonary dyspnea, untangling heart failure and COPD, peri-procedural risk, and why DLCO (a full PFT, not just a spirometer) carries prognostic weight in heart failure and pulmonary hypertension. It also shows the complete-PFT billing: 94010 + 94726 + 94729, about $151.45 per patient at national averages, done in-office.\n\nHappy to walk through any of the references or arrange a hands-on demo with your staff.\n\nBest regards,\n[Your Name]\nPulmOne USA'
  }
};

function emailTemplate(key) {
  var t = EMAIL_TEMPLATES[key];
  if (!t) return;
  document.getElementById('email-subject').value = t.subject;
  document.getElementById('email-body').value = t.body;
}

/* ---- Quick Composer: attach forms & materials ---- */
var QC_SEL = {};                                  /* id -> true for each checked attachment */
function qcSelIds() { return Object.keys(QC_SEL); }
function qcToggleAttach() {
  var body = document.getElementById('qc-attach-body');
  var caret = document.getElementById('qc-attach-caret');
  if (!body) return;
  var opening = body.style.display === 'none';
  body.style.display = opening ? 'block' : 'none';
  if (caret) caret.innerHTML = opening ? '&#9662;' : '&#9656;';
  if (opening && !body.dataset.built) { qcBuildAttachList(); body.dataset.built = '1'; }
}
function qcBuildAttachList() {
  var host = document.getElementById('qc-attach-list');
  if (!host || typeof MATERIALS === 'undefined') return;
  var html = '';
  M3_CAT_ORDER.forEach(function (cat) {
    var items = MATERIALS.filter(function (m) { return m.cat === cat && !m.noembed; });  /* only things that can actually be emailed */
    if (!items.length) return;
    html += '<div class="qc-cat">' + (M3_CATS[cat] || cat) + '</div>';
    items.forEach(function (m) {
      html += '<label class="qc-item">'
        + '<input type="checkbox" onchange="qcToggle(\'' + m.id + '\', this.checked)"' + (QC_SEL[m.id] ? ' checked' : '') + '>'
        + '<span class="qc-item-t">' + m.title + '</span>'
        + '<span class="qc-item-kb">' + m3SizeLabel(m.kb) + '</span>'
        + '</label>';
    });
  });
  host.innerHTML = html;
}
function qcToggle(id, on) {
  if (on) QC_SEL[id] = true; else delete QC_SEL[id];
  qcUpdateCount();
}
function qcUpdateCount() {
  var el = document.getElementById('qc-attach-count');
  if (!el) return;
  var ids = qcSelIds();
  el.textContent = ids.length ? '(' + ids.length + ' selected · ' + m3SizeLabel(m3TotalKB(ids)) + ')' : '';
}
function qcClearSel() {
  QC_SEL = {};
  var host = document.getElementById('qc-attach-list');
  if (host) { var boxes = host.querySelectorAll('input[type=checkbox]'); for (var i = 0; i < boxes.length; i++) boxes[i].checked = false; }
  qcUpdateCount();
}
function qcDownloadAttachments() {
  var ids = qcSelIds();
  if (!ids.length) return;
  if (ids.length === 1) {
    m3Download(ids[0]);
    m3Toast('Your file downloaded — drag it into the email before you send.', 8000);
  } else {
    var subj = document.getElementById('email-subject').value.trim();
    if (m3DownloadZip(ids, 'MiniBox-' + (subj || 'Forms'))) {
      m3Toast('All ' + ids.length + ' files saved as ONE .zip — drag that single file into the email before you send.', 8000);
    }
  }
}

function openInOutlook() {
  var to = document.getElementById('email-to').value.trim();
  var cc = document.getElementById('email-cc').value.trim();
  var subj = document.getElementById('email-subject').value.trim();
  var body = document.getElementById('email-body').value.trim();
  /* Legacy flow: save the files loose/zipped for a manual drag, then mailto. */
  var dragFlow = function(){
    qcDownloadAttachments();
    m3GuardedMailto(to, cc, subj, body);
  };
  /* v3.22: with materials checked, pack the WHOLE email (addresses, subject,
     body, files) into one ready-to-send .eml draft — nothing to drag. */
  m3AttachSend({ to:to, cc:cc, subject:subj, body:body, ids:qcSelIds(),
                 fileName:'MiniBox-' + (subj || 'Email'), dragFlow:dragFlow });
}

function emailClear() {
  ['email-to','email-cc','email-subject','email-body'].forEach(function(id) {
    document.getElementById(id).value = '';
  });
  qcClearSel();
}

/* ---- DAILY NOTES (auto-saved on this device) ---- */
function _loadDailyNotes() {
  try {
    var box = document.getElementById('daily-notes');
    if (!box) return;
    var saved = localStorage.getItem('pulmone_daily_notes');
    var ts = localStorage.getItem('pulmone_notes_ts');
    if (saved != null) box.value = saved;
    if (ts) document.getElementById('notes-timestamp').textContent = 'Saved: ' + ts;
  } catch(e) {}
}
_loadDailyNotes();
if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', _loadDailyNotes);

var _notesSaveTimer = null;
function autoSaveNotes() {
  if (_notesSaveTimer) clearTimeout(_notesSaveTimer);
  _notesSaveTimer = setTimeout(function() { saveNotes(true); }, 500);
}

function saveNotes(quiet) {
  try {
    var val = document.getElementById('daily-notes').value;
    localStorage.setItem('pulmone_daily_notes', val);
    var now = new Date().toLocaleString();
    localStorage.setItem('pulmone_notes_ts', now);
    document.getElementById('notes-timestamp').textContent = 'Saved: ' + now;
    if (!quiet) {
      var msg = document.getElementById('notes-saved-msg');
      if (msg) { msg.style.display = 'inline'; setTimeout(function() { msg.style.display = 'none'; }, 2000); }
    }
  } catch(e) { if (!quiet) alert('Notes saved in session only (localStorage unavailable).'); }
}

function clearNotes() {
  if (!confirm('Clear all notes?')) return;
  document.getElementById('daily-notes').value = '';
  try { localStorage.removeItem('pulmone_daily_notes'); localStorage.removeItem('pulmone_notes_ts'); } catch(e) {}
  document.getElementById('notes-timestamp').textContent = '';
}

/* ---- COLLAPSIBLE DAILY HUB CARDS ----
   Keeps the Hub short enough to scan in one screen. Each rep's open/closed
   choice is remembered on their own device; with no choice saved yet we open
   My References so it's obvious you can add your own people there. */
var HUB_ACC_IDS = ['hub-email', 'hub-notes', 'hub-contacts', 'hub-refs'];

function toggleHubAcc(id) {
  var el = document.getElementById(id);
  if (!el) return;
  var open = el.classList.toggle('open');
  try { localStorage.setItem('pulmone_hub_' + id, open ? '1' : '0'); } catch(e) {}
}

function restoreHubAcc() {
  HUB_ACC_IDS.forEach(function(id) {
    var el = document.getElementById(id);
    if (!el) return;
    var pref = null;
    try { pref = localStorage.getItem('pulmone_hub_' + id); } catch(e) {}
    if (pref === '1') el.classList.add('open');
    else if (pref === '0') el.classList.remove('open');
    /* no saved choice: leave the HTML default (My References open) */
  });
}

/* ---- MY REFERENCES (rep-added, saved on this device) ---- */
var REF_KEY = 'pulmone_my_references';

function loadReferences() {
  try { var a = JSON.parse(localStorage.getItem(REF_KEY) || '[]'); return Array.isArray(a) ? a : []; }
  catch(e) { return []; }
}
function saveReferences(arr) {
  try { localStorage.setItem(REF_KEY, JSON.stringify(arr)); } catch(e) {}
}
function refEscape(s) {
  return String(s == null ? '' : s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}
function renderReferences() {
  var grid = document.getElementById('ref-grid');
  var empty = document.getElementById('ref-empty');
  if (!grid) return;
  var refs = loadReferences();
  grid.innerHTML = '';
  if (empty) empty.style.display = refs.length ? 'none' : 'block';
  refs.forEach(function(r, i) {
    var tel = (r.phone || '').replace(/[^0-9+]/g, '');
    var actions = '';
    if (tel) actions += '<a href="tel:' + refEscape(tel) + '" class="ct-btn ct-call">&#128222; Call</a>';
    if (r.email) actions += '<a href="mailto:' + refEscape(r.email) + '" class="ct-btn ct-email">&#9993; Email</a>';
    actions += '<button class="ct-btn ct-del" title="Remove" onclick="removeReference(' + i + ')">&#10005;</button>';
    var tile = document.createElement('div');
    tile.className = 'contact-tile';
    tile.innerHTML =
      '<div class="ct-name">' + refEscape(r.name || 'Reference') + '</div>' +
      '<div class="ct-role">' + refEscape(r.role || '') + '</div>' +
      '<div class="ct-actions">' + actions + '</div>';
    grid.appendChild(tile);
  });
}
function addReference() {
  var name  = document.getElementById('ref-name').value.trim();
  var role  = document.getElementById('ref-role').value.trim();
  var phone = document.getElementById('ref-phone').value.trim();
  var email = document.getElementById('ref-email').value.trim();
  if (!name) { alert('Please enter a name for the reference.'); return; }
  if (!phone && !email) { alert('Add a phone number or an email so you can reach this reference.'); return; }
  var refs = loadReferences();
  refs.push({ name: name, role: role, phone: phone, email: email });
  saveReferences(refs);
  document.getElementById('ref-name').value = '';
  document.getElementById('ref-role').value = '';
  document.getElementById('ref-phone').value = '';
  document.getElementById('ref-email').value = '';
  renderReferences();
}
function removeReference(i) {
  var refs = loadReferences();
  if (i < 0 || i >= refs.length) return;
  if (!confirm('Remove ' + (refs[i].name || 'this reference') + '?')) return;
  refs.splice(i, 1);
  saveReferences(refs);
  renderReferences();
}
renderReferences();
restoreHubAcc();

/* ---- EMBEDDED ROI BUILDER CONTROLS ---- */
function rmaFullscreen() {
  var f=document.getElementById('rma-iframe'); if(!f) return;
  var r=f.requestFullscreen||f.webkitRequestFullscreen||f.mozRequestFullScreen||f.msRequestFullscreen;
  if(r) r.call(f);
}
/* Collapsible embedded forms: tap the card header to open/close the fillable form so it
   doesn't sit open eating the whole Forms page. Body starts display:none. */
function formToggle(id) {
  var b = document.getElementById(id + '-body');
  var lbl = document.getElementById(id + '-toggle-label');
  if (!b) return;
  var opening = (b.style.display === 'none' || b.style.display === '');
  b.style.display = opening ? 'block' : 'none';
  if (lbl) lbl.innerHTML = opening ? '&#9662; CLOSE FORM' : '&#9656; OPEN FORM';
  if (opening && b.parentNode && b.parentNode.scrollIntoView) {
    try { b.parentNode.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch (e) { b.parentNode.scrollIntoView(); }
  }
}
function roiBuilderFullscreen(id) {
  var iframe = document.getElementById(id || 'roi-builder-iframe');
  if (!iframe) return;
  var req = iframe.requestFullscreen || iframe.webkitRequestFullscreen || iframe.mozRequestFullScreen || iframe.msRequestFullscreen;
  if (req) {
    try { req.call(iframe); return; } catch(e) {}
  }
  // Fallback: toggle CSS fullscreen
  if (iframe.classList.contains('roi-fs-fallback')) {
    iframe.classList.remove('roi-fs-fallback');
    iframe.style.cssText = 'width:100%; border:0; height:1650px; display:block; background:#f1f5f9;';
  } else {
    iframe.classList.add('roi-fs-fallback');
    iframe.style.cssText = 'position:fixed; inset:0; width:100vw; height:100vh; z-index:10000; border:0; background:#fff;';
  }
}

function roiBuilderPrint(id) {
  var iframe = document.getElementById(id || 'roi-builder-iframe');
  if (!iframe) return;
  try {
    var win = iframe.contentWindow;
    if (win && typeof win.printAll === 'function') { win.printAll(); return; }
    if (win && win.document) win.print();
  } catch(e) {
    alert('Click inside the ROI proposal, then press Ctrl/Cmd+P to print.');
  }
}

function quoteBuilderFullscreen() {
  var iframe = document.getElementById('quote-builder-iframe');
  if (!iframe) return;
  var req = iframe.requestFullscreen || iframe.webkitRequestFullscreen || iframe.mozRequestFullScreen || iframe.msRequestFullscreen;
  if (req) { try { req.call(iframe); return; } catch(e) {} }
  if (iframe.classList.contains('qb-fs-fallback')) {
    iframe.classList.remove('qb-fs-fallback');
    iframe.style.cssText = 'width:100%; border:0; height:1500px; display:block; background:#f1f5f9;';
  } else {
    iframe.classList.add('qb-fs-fallback');
    iframe.style.cssText = 'position:fixed; inset:0; width:100vw; height:100vh; z-index:10000; border:0; background:#fff;';
  }
}
function quoteBuilderPrint() {
  var iframe = document.getElementById('quote-builder-iframe');
  if (!iframe) return;
  try { var win = iframe.contentWindow; if (win && win.document) win.print(); }
  catch(e) { alert('Click inside the quote, then press Ctrl/Cmd+P to print.'); }
}
document.addEventListener('keydown', function(e){
  if (e.key === 'Escape') {
    var iframe = document.getElementById('quote-builder-iframe');
    if (iframe && iframe.classList.contains('qb-fs-fallback')) {
      iframe.classList.remove('qb-fs-fallback');
      iframe.style.cssText = 'width:100%; border:0; height:1500px; display:block; background:#f1f5f9;';
    }
  }
});
// Exit fallback fullscreen on Escape
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    var iframe = document.querySelector('iframe.roi-fs-fallback');
    if (iframe) {
      iframe.classList.remove('roi-fs-fallback');
      iframe.style.cssText = 'width:100%; border:0; height:1650px; display:block; background:#f1f5f9;';
    }
  }
});

/* ============================================================
   REP PROFILE + EMAIL LIBRARY
   ============================================================ */

/* ---- PROFILE (saved to localStorage on this device) ---- */
var REP_PROFILE = {
  name: '',
  title: 'PulmOne Sales Representative',
  email: '',
  mobile: '',
  company: 'PulmOne USA',
  emailMode: 'mailto'  // 'mailto' (Outlook desktop) or 'owa' (Outlook Web)
};

function loadProfile() {
  try {
    var raw = localStorage.getItem('pulmone_rep_profile');
    if (raw) {
      var p = JSON.parse(raw);
      if (p && typeof p === 'object') {
        for (var k in REP_PROFILE) { if (p[k] != null) REP_PROFILE[k] = p[k]; }
      }
    }
  } catch(e) {}
  renderProfileHeader();
  renderProfileCard();
}

var pmEmailTouched = false;
function pmSuggestEmail() {
  if (pmEmailTouched) return;
  var nameEl = document.getElementById('pm-name');
  var emailEl = document.getElementById('pm-email');
  if (!nameEl || !emailEl) return;
  var parts = nameEl.value.trim().toLowerCase().replace(/[^a-z0-9\s.]/g,'').split(/\s+/).filter(Boolean);
  emailEl.value = parts.length ? parts.join('.') + '@pulm-one.com' : '';
}

function saveProfile() {
  REP_PROFILE.name   = document.getElementById('pm-name').value.trim();
  REP_PROFILE.title  = document.getElementById('pm-title').value.trim() || 'PulmOne Sales Representative';
  var pmEmail = document.getElementById('pm-email').value.trim();
  if (pmEmail && pmEmail.indexOf('@') === -1) pmEmail = pmEmail + '@pulm-one.com';
  REP_PROFILE.email  = pmEmail;
  REP_PROFILE.mobile = document.getElementById('pm-mobile').value.trim();
  REP_PROFILE.company= document.getElementById('pm-company').value.trim() || 'PulmOne USA';
  // emailMode is toggled via pm-toggle buttons
  try { localStorage.setItem('pulmone_rep_profile', JSON.stringify(REP_PROFILE)); } catch(e) {}
  renderProfileHeader();
  renderProfileCard();
  if (typeof easSyncProfile === 'function') easSyncProfile();
  if (currentElTmpl) selectElTemplate(currentElIdx);
  elToast('Profile saved');
  closeProfile();
}

function clearProfile() {
  if (!confirm('Clear your saved profile from this device?')) return;
  try { localStorage.removeItem('pulmone_rep_profile'); } catch(e) {}
  REP_PROFILE = { name:'', title:'PulmOne Sales Representative', email:'', mobile:'', company:'PulmOne USA', emailMode:'mailto' };
  renderProfileHeader();
  renderProfileCard();
  if (typeof easSyncProfile === 'function') easSyncProfile();
  if (currentElTmpl) selectElTemplate(currentElIdx);
  elToast('Profile cleared');
  closeProfile();
}

function openProfile() {
  pmEmailTouched = !!REP_PROFILE.email;
  document.getElementById('pm-name').value    = REP_PROFILE.name;
  document.getElementById('pm-title').value   = REP_PROFILE.title;
  document.getElementById('pm-email').value   = REP_PROFILE.email;
  document.getElementById('pm-mobile').value  = REP_PROFILE.mobile;
  document.getElementById('pm-company').value = REP_PROFILE.company;
  setEmailMode(REP_PROFILE.emailMode, true);
  document.getElementById('profile-modal').classList.add('open');
}
function closeProfile() {
  document.getElementById('profile-modal').classList.remove('open');
}

function setEmailMode(mode, skipUpdate) {
  REP_PROFILE.emailMode = mode;
  var btnMailto = document.getElementById('pm-mode-mailto');
  var btnOWA    = document.getElementById('pm-mode-owa');
  if (btnMailto) btnMailto.classList.toggle('on', mode === 'mailto');
  if (btnOWA)    btnOWA.classList.toggle('on', mode === 'owa');
  if (!skipUpdate) {
    try { localStorage.setItem('pulmone_rep_profile', JSON.stringify(REP_PROFILE)); } catch(e) {}
  }
}

function renderProfileHeader() {
  var lbl = document.getElementById('profile-name-lbl');
  var badge = document.getElementById('profile-badge');
  if (!lbl) return;
  if (REP_PROFILE.name) {
    lbl.textContent = REP_PROFILE.name;
    if (badge) badge.classList.add('set');
  } else {
    lbl.textContent = 'My Rep Profile';
    if (badge) badge.classList.remove('set');
  }
}

function renderProfileCard() {
  var nameEl = document.getElementById('el-p-name');
  if (!nameEl) return;
  if (REP_PROFILE.name) {
    nameEl.textContent = REP_PROFILE.name;
    document.getElementById('el-p-title').textContent = REP_PROFILE.title + ' &middot; ' + REP_PROFILE.company;
    document.getElementById('el-p-title').innerHTML = REP_PROFILE.title + ' &middot; ' + REP_PROFILE.company;
    var bits = [];
    if (REP_PROFILE.email)  bits.push(REP_PROFILE.email);
    if (REP_PROFILE.mobile) bits.push(REP_PROFILE.mobile);
    document.getElementById('el-p-contact').textContent = bits.join('  \u00B7  ');
  } else {
    nameEl.textContent = '(not set)';
    document.getElementById('el-p-title').textContent = 'Set your profile to auto-sign emails';
    document.getElementById('el-p-contact').textContent = '';
  }
}

/* ---- SIGNATURE BUILDER ---- */
function buildSignature() {
  var sigLines = [];
  if (REP_PROFILE.name)    sigLines.push(REP_PROFILE.name);
  if (REP_PROFILE.title)   sigLines.push(REP_PROFILE.title);
  if (REP_PROFILE.company) sigLines.push(REP_PROFILE.company);
  if (REP_PROFILE.mobile)  sigLines.push('(direct) ' + REP_PROFILE.mobile);
  if (REP_PROFILE.email)   sigLines.push(REP_PROFILE.email);
  if (sigLines.length === 0) {
    return '[Your Name]\nPulmOne USA\n1-844-PulmOne (785-6663)\nUSinfo@pulm-one.com';
  }
  return sigLines.join('\n');
}

function applyProfileMerges(text) {
  var t = text;
  t = t.replace(/\{\{YOUR_NAME\}\}/g,    REP_PROFILE.name    || '[Your Name]');
  t = t.replace(/\{\{YOUR_TITLE\}\}/g,   REP_PROFILE.title   || 'PulmOne Sales Representative');
  t = t.replace(/\{\{YOUR_EMAIL\}\}/g,   REP_PROFILE.email   || '[your.email@pulm-one.com]');
  t = t.replace(/\{\{YOUR_MOBILE\}\}/g,  REP_PROFILE.mobile  || '[your mobile]');
  t = t.replace(/\{\{YOUR_COMPANY\}\}/g, REP_PROFILE.company || 'PulmOne USA');
  t = t.replace(/\{\{SIGNATURE\}\}/g,    buildSignature());
  return t;
}

/* ---- EMAIL LIBRARY: 12 TEMPLATES ---- */
var EL_TEMPLATES = [
  { id:'intro-cold', cat:'Cold Outreach', title:'First-touch intro email',
    sub:'Never met them. You have a reason to reach out.',
