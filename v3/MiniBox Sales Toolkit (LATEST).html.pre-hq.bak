/* ============ OUTLOOK FLAVOR — highlight the right button ============ */
function m3GetOutlook(){ return (typeof REP_PROFILE !== 'undefined' && REP_PROFILE.outlook) || ''; }
function m3SetOutlook(f){
  if (typeof REP_PROFILE === 'undefined') return;
  REP_PROFILE.outlook = f;
  try { localStorage.setItem('pulmone_rep_profile', JSON.stringify(REP_PROFILE)); } catch(e) {}
  m3SyncOutlookToggle();
  m3ApplyFlavor();
  m3RenderSendHelp('m3-eas-send-help');
  m3RenderSendHelp('m3-el-send-help');
}
function m3SyncOutlookToggle(){
  var f = m3GetOutlook();
  ['classic','new','web'].forEach(function(k){
    var b = document.getElementById('pm-ol-' + k);
    if (b) b.classList.toggle('on', f === k);
  });
}
function m3ApplyFlavor(){
  var f = m3GetOutlook();
  var reco = (f === 'classic') ? 'classic' : (f ? 'owa' : '');
  document.querySelectorAll('[data-flavor]').forEach(function(btn){
    btn.classList.toggle('m3-reco', !!reco && btn.getAttribute('data-flavor') === reco);
  });
}
/* v3.14: one team, one Outlook (PulmOne Microsoft 365) — one send button,
   so the help is the same for everyone regardless of the old flavor setting. */
function m3RenderSendHelp(id){
  var el = document.getElementById(id);
  if (!el) return;
  if (m3SendPref() !== 'drag') {
    el.innerHTML = '<strong>How sending works:</strong> tap <strong>&#127760; Send with Outlook</strong> — with materials picked, your whole email (addresses, text, and every file) saves as <strong>ONE ready-to-send draft</strong>. Open the downloaded file, look it over, hit Send &mdash; the attachments are already inside. No materials picked? Outlook just opens signed in as you (press Ctrl+V to drop your text in).';
  } else {
    el.innerHTML = '<strong>How sending works:</strong> tap <strong>&#127760; Send with Outlook</strong> — the email opens addressed, signed in as you, with your text on the clipboard. <strong>1.</strong> Click in the message and press <strong>Ctrl+V</strong> (your Outlook signature stays at the bottom). <strong>2.</strong> Picked materials? Drag the downloaded file into the email &mdash; it&rsquo;s behind the ⬇ download icon at the top of this window (or in your Downloads folder). <strong>3.</strong> Hit Send.';
  }
}
/* v3 override: openProfile also syncs the Outlook-flavor toggle */
function openProfile(){
  document.getElementById('pm-name').value    = REP_PROFILE.name;
  document.getElementById('pm-title').value   = REP_PROFILE.title;
  document.getElementById('pm-email').value   = REP_PROFILE.email;
  document.getElementById('pm-mobile').value  = REP_PROFILE.mobile;
  document.getElementById('pm-company').value = REP_PROFILE.company;
  setEmailMode(REP_PROFILE.emailMode, true);
  m3SyncOutlookToggle();
  document.getElementById('profile-modal').classList.add('open');
}

/* Reads the (possibly edited) Mode A body, preserving line breaks. */
function m3EasBody(){
  var el = document.getElementById('eas-out-body');
  if (!el) return '';
  var html = el.innerHTML.replace(/<br\s*\/?>/gi,'\n').replace(/<\/(div|p)>/gi,'\n').replace(/<(div|p)[^>]*>/gi,'');
  var tmp = document.createElement('div'); tmp.innerHTML = html;
  return tmp.textContent || tmp.innerText || '';
}
/* v3 override: copy the edited body, not the original. */
function easCopy(){
  try { elCopyToClipboard(m3EasBody()); } catch(e) {}
  m3Toast('Email body copied');
}

/* ============ PRACTICE RUN — test the attachment flow on yourself ============ */
function m3SelfTest(){
  var me = (typeof REP_PROFILE !== 'undefined' && REP_PROFILE.email) || '';
  if (!me) {
    m3Toast('Set your work email in My Rep Profile first — then the practice email can be addressed to you.');
    try { openProfile(); } catch(e) {}
    return;
  }
  /* v3.22: practice run rehearses whichever send flow this device uses —
     the one-file draft by default, or the compose+paste+drag legacy flow. */
  var dragFlow = function(){
    if (m3EmlAvailable()) { try { m3DownloadMany(['brochure']); } catch(e) {} }
    m3GuardedOWA(me, '',
      'Practice run — MiniBox+ Toolkit (this email goes to YOU)',
      'This is a practice email from your MiniBox+ Toolkit.\n\nTwo moves, same as every real send:\n\n  1. Press Ctrl+V — this text drops into the email, and your Outlook signature stays at the bottom.\n  2. Drag the brochure PDF into the email (look behind the ⬇ download icon at the top of the window, or in your Downloads folder).\n\nHit Send: it goes to your own inbox only. No customer will ever see this.',
      'Practice time — Outlook is opening addressed to YOU. Click in the message, press Ctrl+V, then drag the downloaded brochure PDF in. Hit Send and check your inbox.');
  };
  m3AttachSend({
    to: me, cc: '',
    subject: 'Practice run — MiniBox+ Toolkit (this email goes to YOU)',
    body: 'This is a practice email from your MiniBox+ Toolkit.\n\nIf you are reading this inside an Outlook draft with the brochure PDF already attached, the send flow works — everything packed itself: address, subject, this text, and the file.\n\nHit Send: it goes to your own inbox only. No customer will ever see this.',
    ids: ['brochure'], fileName: 'Practice-Run', dragFlow: dragFlow });
}

/* ============ FIRST-OPEN WELCOME (30-second setup) ============ */
var m3wEmailTouched = false;
function m3wSuggestEmail(){
  if (m3wEmailTouched) return;
  var nameEl = document.getElementById('m3w-name');
  var emailEl = document.getElementById('m3w-email');
  if (!nameEl || !emailEl) return;
  var parts = nameEl.value.trim().toLowerCase().replace(/[^a-z0-9\s.]/g,'').split(/\s+/).filter(Boolean);
  emailEl.value = parts.length ? parts.join('.') + '@pulm-one.com' : '';
}
function m3MaybeWelcome(){
  m3wEmailTouched = false;
  var done = false;
  try { done = !!localStorage.getItem('mbx3_welcome_done'); } catch(e) {}
  if (done || (typeof REP_PROFILE !== 'undefined' && REP_PROFILE.name)) return;
  document.body.insertAdjacentHTML('beforeend',
    '<div id="m3-welcome"><div class="m3w-card">' +
      '<div class="m3w-title">&#128075; Welcome to your MiniBox+ Toolkit</div>' +
      '<div class="m3w-sub">20 seconds of setup and every email fills itself in with your details. You can change any of this later under <strong>My Rep Profile</strong> at the top.</div>' +
      '<div class="m3w-lbl">Your name</div>' +
      '<input class="m3w-inp" id="m3w-name" type="text" placeholder="First Last" oninput="m3wSuggestEmail()">' +
      '<div class="m3w-lbl">Work email</div>' +
      '<input class="m3w-inp" id="m3w-email" type="email" placeholder="you@pulm-one.com" oninput="m3wEmailTouched=true">' +
      '<div class="m3w-hint" style="font-size:11.5px;color:#64748b;margin-top:5px;">Type your name and this fills in automatically as first.last@pulm-one.com &mdash; edit it if yours is different.</div>' +
      '<div class="m3w-actions">' +
        '<button class="m3w-skip" onclick="m3wClose(false)">Skip for now</button>' +
        '<button class="m3w-go" onclick="m3wClose(true)">Save &amp; start &rarr;</button>' +
      '</div>' +
    '</div></div>');
  document.getElementById('m3-welcome').classList.add('open');
}
function m3wPick(btn){
  document.querySelectorAll('#m3w-ol button').forEach(function(b){ b.classList.remove('on'); });
  btn.classList.add('on');
}
function m3wClose(save){
  if (save && typeof REP_PROFILE !== 'undefined') {
    var n = document.getElementById('m3w-name').value.trim();
    var e = document.getElementById('m3w-email').value.trim();
    if (e && e.indexOf('@') === -1) e = e + '@pulm-one.com';
    var olBtn = document.querySelector('#m3w-ol button.on');
    if (n) REP_PROFILE.name = n;
    if (e) REP_PROFILE.email = e;
    if (olBtn) REP_PROFILE.outlook = olBtn.getAttribute('data-v');
    try { localStorage.setItem('pulmone_rep_profile', JSON.stringify(REP_PROFILE)); } catch(ex) {}
    try { renderProfileHeader(); } catch(ex) {}
    try { easSyncProfile(); } catch(ex) {}
    try { m3ApplyFlavor(); m3RenderSendHelp('m3-eas-send-help'); m3RenderSendHelp('m3-el-send-help'); } catch(ex) {}
    m3Toast(n ? ('Welcome, ' + n.split(' ')[0] + '! Every email now fills itself in.') : 'Saved.');
  }
  try { localStorage.setItem('mbx3_welcome_done', '1'); } catch(ex) {}
  var w = document.getElementById('m3-welcome');
  if (w) w.classList.remove('open');
}

/* ============ ENV BADGE ============ */
function m3RenderEnvBadge(){
  var b = document.getElementById('m3-env-badge');
  if (!b) return;
  if (m3IsHosted()) {
    b.innerHTML = '&#127760; Online edition &middot; <a href="MiniBox_Toolkit_v3_offline.zip" style="color:inherit;" title="Download a copy that works with no internet">get offline copy</a>';
  } else {
    b.textContent = '💾 Offline edition';
    b.title = 'Running from a local file — everything still works, including real email attachments.';
  }
}

/* Sign-in already collected name + work email (the toolkit gate requires a
   pulm-one.com email) — pull that into the Rep Profile so the in-app welcome
   popup never has to ask again. */
function m3AdoptLoginIdentity(){
  try {
    var m = document.cookie.match(/(?:^|;\s*)mbx_id=([^;]+)/);
    if (!m || typeof REP_PROFILE === 'undefined') return;
    var id = JSON.parse(decodeURIComponent(m[1]));
    var changed = false;
    if (!REP_PROFILE.email && id.e) { REP_PROFILE.email = id.e; changed = true; }
    if (!REP_PROFILE.name && id.n) { REP_PROFILE.name = id.n; changed = true; }
    if (changed) {
      try { localStorage.setItem('pulmone_rep_profile', JSON.stringify(REP_PROFILE)); } catch(e) {}
      try { localStorage.setItem('mbx3_welcome_done', '1'); } catch(e) {}
    }
  } catch(e) {}
}

/* ============ INIT v3 ============ */
(function initM3(){
  // Restore the Outlook-flavor field the v2.27 loader doesn't know about.
  try {
    var raw = localStorage.getItem('pulmone_rep_profile');
    if (raw) { var p = JSON.parse(raw); if (p && p.outlook != null && typeof REP_PROFILE !== 'undefined') REP_PROFILE.outlook = p.outlook; }
  } catch(e) {}
  try { m3AdoptLoginIdentity(); } catch(e) {}
  try { m3RenderEasMaterials(); } catch(e) {}
  try { m3RenderLibrary(); } catch(e) {}
  try { m3RenderEnvBadge(); } catch(e) {}
  try { if (typeof currentElTmpl !== 'undefined' && currentElTmpl) renderElPreview(); } catch(e) {}
  try { m3ApplyFlavor(); } catch(e) {}
  try { renderProfileHeader(); } catch(e) {}
  try { m3MaybeWelcome(); } catch(e) {}
})();
</script>


<script>
/* ---- ACH FULL PAYMENT FORM (embedded, namespaced achf-) ---- */
function achfFmt(n) {
  return '$' + (n || 0).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
}
function achfRecalc() {
  var price = parseFloat((document.getElementById('achf-purchase-price') || {}).value) || 0;
  var el = document.getElementById('achf-grand-total');
  if (el) el.textContent = achfFmt(price);
}
function achfClear() {
  if (!confirm('Clear all full-payment ACH fields?')) return;
  ['achf-date','achf-customer','achf-bank-name','achf-bank-addr','achf-routing','achf-account',
   'achf-purchase-price'].forEach(function(id) {
    var el = document.getElementById(id); if (el) el.value = '';
  });
  var dEl = document.getElementById('achf-date');
  if (dEl) dEl.classList.remove('has-value');
  achfRecalc();
}
function achfPrint() { window.print(); }
(function() {
  achfRecalc();
  var dEl = document.getElementById('achf-date');
  if (dEl) {
    function openPicker() { try { dEl.showPicker(); } catch (e) {} }
    dEl.addEventListener('focus', openPicker);
    dEl.addEventListener('click', openPicker);
    dEl.addEventListener('change', function() {
      dEl.classList.toggle('has-value', !!dEl.value);
    });
  }
})();
</script>

<script id="mbx-chat">
/* ── Team Chat — the whole sales force in one conversation ──────────────
   Messages live on the server (/api/chat) behind the SAME team password
   as the rest of the toolkit, stored in the team database. Only works in
   the online app (deploytoolkit.vercel.app) — a file:// offline copy has
   no server, so the tab explains that instead of breaking. */
(function () {
  var API = '/api/chat';
  var POLL_MS = 20000;         // refresh every 20s while the chat tab is open
  var BG_EVERY = 3;            // ...and every 3rd tick (60s) in the background for the badge
  var canChat = (location.protocol === 'https:' || location.protocol === 'http:');
  var newestTs = 0;            // timestamp of the newest message we've seen
  var tick = 0;
  var fetching = false;
  var boxyMode = false;        // when on, every message goes to Boxy — no @tag needed
  try { boxyMode = localStorage.getItem('mbx_chat_boxy') === '1'; } catch (e) {}
  var rec = null, recActive = false, recStop = false, chatMicTimer = null;  // voice-to-text (Web Speech API)

  function $(id) { return document.getElementById(id); }
  function esc(s) { try { return escapeHTML(s); } catch (e) { return String(s).replace(/[&<>"']/g, function (c) { return '&#' + c.charCodeAt(0) + ';'; }); } }

  function myName() {
    var n = '';
    try { if (typeof REP_PROFILE !== 'undefined' && REP_PROFILE && REP_PROFILE.name) n = REP_PROFILE.name; } catch (e) {}
    if (!n) { try { n = localStorage.getItem('mbx_chat_name') || ''; } catch (e) {} }
    return String(n).trim();
  }
  function lastRead() { try { return parseInt(localStorage.getItem('mbx_chat_lastread') || '0', 10) || 0; } catch (e) { return 0; } }
  function setLastRead(ts) { try { localStorage.setItem('mbx_chat_lastread', String(ts)); } catch (e) {} }

  function fmtTs(ts) {
    var d = new Date(ts), now = new Date();
    var t = d.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
    if (d.toDateString() === now.toDateString()) return t;
    return d.toLocaleDateString([], { month: 'short', day: 'numeric' }) + ' ' + t;
  }

  function isOpen() {
    var p = $('tab-teamchat');
    return !!(p && p.classList.contains('active'));
  }

  function setBadge(count) {
    var b = $('mbx-chat-badge');
    if (!b) return;
    if (count > 0) { b.textContent = count > 99 ? '99+' : String(count); b.style.display = 'inline-block'; }
    else { b.style.display = 'none'; }
  }

  function render(messages) {
    var list = $('mbx-chat-list');
    if (!list) return;
    var nearBottom = (list.scrollHeight - list.scrollTop - list.clientHeight) < 80;
    var me = myName().toLowerCase();

    if (!messages.length) {
      list.innerHTML = '<div style="text-align:center;color:var(--gray-600);font-size:13px;padding:30px 10px;">' +
        'No messages yet &mdash; be the first. Say hi to the team! &#128075;</div>';
      return;
    }

    var html = '';
    for (var i = 0; i < messages.length; i++) {
      var m = messages[i];
      var mine = me && String(m.name || '').trim().toLowerCase() === me;
      var isBot = String(m.name || '').indexOf('Boxy') === 0;
      var bubbleStyle = mine
        ? 'background:var(--teal-light);border:1px solid #b8ebe4;margin-left:auto;'
        : isBot
          ? 'background:#f3f0ff;border:1px solid #ddd2f7;margin-right:auto;'
          : 'background:#fff;border:1px solid var(--gray-200);margin-right:auto;';
      html +=
        '<div style="display:flex;flex-direction:column;margin-bottom:10px;">' +
          '<div style="max-width:82%;border-radius:14px;padding:8px 12px;box-shadow:0 1px 2px rgba(16,42,67,0.06);' + bubbleStyle + '">' +
            (mine ? '' : '<div style="font-size:12px;font-weight:800;color:' + (isBot ? '#6b46c1' : 'var(--blue-brand)') + ';margin-bottom:2px;">' + esc(m.name || 'Teammate') + '</div>') +
            '<div style="font-size:14px;color:var(--text);white-space:pre-wrap;word-break:break-word;">' + esc(m.text || '') + '</div>' +
            '<div style="font-size:10.5px;color:var(--gray-600);margin-top:3px;text-align:right;">' + fmtTs(m.ts || 0) + '</div>' +
          '</div>' +
        '</div>';
      if (m.ts > newestTs) newestTs = m.ts;
    }
    list.innerHTML = html;
    if (nearBottom) list.scrollTop = list.scrollHeight;
  }

  function refresh(force) {
    if (!canChat || fetching) return;
    fetching = true;
    fetch(API, { headers: { 'Accept': 'application/json' }, cache: 'no-store' })
      .then(function (r) {
        if (!r.ok) throw new Error('http ' + r.status);
        var ct = r.headers.get('content-type') || '';
        if (ct.indexOf('json') === -1) throw new Error('not-json'); // password session expired -> login page came back
        return r.json();
      })
      .then(function (data) {
        if (!data || !data.ok) throw new Error('bad-data');
        var msgs = data.messages || [];
        var newest = 0, unread = 0, me = myName().toLowerCase();
        for (var i = 0; i < msgs.length; i++) {
          var m = msgs[i];
          if (m.ts > newest) newest = m.ts;
          if (m.ts > lastRead() && String(m.name || '').trim().toLowerCase() !== me) unread++;
        }
        if (isOpen()) {
          render(msgs);
          if (newest) setLastRead(newest);
          setBadge(0);
        } else {
          setBadge(unread);
          newestTs = newest || newestTs;
        }
      })
      .catch(function () {
        if (isOpen() && force) {
          var st = $('mbx-chat-status');
          var list = $('mbx-chat-list');
          if (list && list.textContent.indexOf('Loading') > -1) {
            list.innerHTML = '<div style="text-align:center;color:var(--gray-600);font-size:13px;padding:30px 10px;">' +
              'Can&#39;t reach the chat right now. Check your connection, or close and reopen the app to log back in.</div>';
          }
        }
      })
      .then(function () { fetching = false; });
  }

  window.mbxChatOpened = function () {
    if (!canChat) return;
    refresh(true);
    setBadge(0);
    var list = $('mbx-chat-list');
    if (list) setTimeout(function () { list.scrollTop = list.scrollHeight; }, 250);
  };

  // ── "Ask Boxy" mode: once on, every message is routed to the bot, so a
  //    back-and-forth just keeps going without re-typing @Boxy each time. ──
  function syncBoxyUI() {
    var t = $('mbx-chat-boxytoggle'), note = $('mbx-chat-boxynote'), input = $('mbx-chat-input');
    if (t) {
      t.style.background = boxyMode ? '#6b46c1' : '#f3f0ff';
      t.style.color = boxyMode ? '#fff' : '#6b46c1';
      t.style.borderColor = boxyMode ? '#6b46c1' : '#ddd2f7';
      t.innerHTML = boxyMode ? '\u{1F916} Talking to Boxy ✓' : '\u{1F916} Ask Boxy';
    }
    if (note) note.style.display = boxyMode ? 'inline' : 'none';
    if (input && document.activeElement !== input) {
      input.placeholder = boxyMode ? 'Ask Boxy anything — no need to type @Boxy…' : 'Type a message…';
    }
  }
  function setBoxyMode(on) {
    boxyMode = !!on;
    try { localStorage.setItem('mbx_chat_boxy', boxyMode ? '1' : '0'); } catch (e) {}
    syncBoxyUI();
  }
  window.mbxChatToggleBoxy = function () {
    setBoxyMode(!boxyMode);
    if (boxyMode) setReportMode(false);
    var i = $('mbx-chat-input'); if (i) i.focus();
  };

  // ── "Report a problem" mode: same button the floating Boxy has, right here
  //    in Team Chat. The message is tagged as an ISSUE REPORT, routed to Boxy
  //    (so the rep gets an answer) AND filed in Erik's Problem Reports inbox
  //    (/reports.html) so nothing gets lost in the scroll. ──
  var reportMode = false;
  function syncReportUI() {
    var t = $('mbx-chat-reporttoggle'), note = $('mbx-chat-reportnote'), input = $('mbx-chat-input');
    if (t) {
      t.style.background = reportMode ? '#fee2e2' : '#fff';
      t.style.borderColor = reportMode ? '#fca5a5' : '#fecaca';
      t.innerHTML = reportMode ? '\u{1F41B} Reporting a problem ✓' : '\u{1F41B} Report a problem';
    }
    if (note) note.style.display = reportMode ? 'inline' : 'none';
    if (input && document.activeElement !== input && reportMode) {
      input.placeholder = 'Describe what’s wrong — what screen, what happened…';
    }
  }
  function setReportMode(on) {
    reportMode = !!on;
    if (reportMode) setBoxyMode(false);
    syncBoxyUI();
    syncReportUI();
  }
  window.mbxChatToggleReport = function () {
    setReportMode(!reportMode);
    var i = $('mbx-chat-input'); if (i) i.focus();
  };

  // ── Voice-to-text: talk as long as you want — it keeps listening through
  //    pauses and only stops when you tap the mic again or hit Send. It even
  //    auto-restarts if the browser's speech engine times out, so you're
  //    never cut off mid-thought. The rep reviews the text, then sends. ──
  function speechCtor() { return window.SpeechRecognition || window.webkitSpeechRecognition || null; }
  function micReset(btn, input) {
    recActive = false;
    if (chatMicTimer) { clearTimeout(chatMicTimer); chatMicTimer = null; }
    if (btn) { btn.innerHTML = '\u{1F3A4}'; btn.style.background = '#fff'; btn.title = 'Talk instead of typing'; }
    if (input) input.focus();
  }
  window.mbxStopMic = function () {          // tap-to-stop and Send both call this
    recStop = true;
    if (rec) { try { rec.stop(); } catch (e) {} }
  };
  window.mbxChatMic = function () {
    var SR = speechCtor();
    if (!SR) {
      try { m3Toast("Voice typing isn't available in this browser — use your phone keyboard's mic button instead.", 6000); } catch (e) {}
      return;
    }
    var input = $('mbx-chat-input'), btn = $('mbx-chat-micbtn');
    if (recActive) { window.mbxStopMic(); return; }   // already listening -> tap again stops

    recStop = false;
    // committed = everything already in the box (+ a space); it carries across
    // auto-restarts so nothing said earlier is ever lost.
    var committed = input ? input.value : '';
    if (committed && !/\s$/.test(committed)) committed += ' ';
    var lastFinal = '', lastAny = '';
    // After 10s of silence, stop on its own so the mic never runs forever.
    function armSilence() { if (chatMicTimer) clearTimeout(chatMicTimer); chatMicTimer = setTimeout(function () { recStop = true; if (rec) { try { rec.stop(); } catch (e) {} } }, 10000); }

    function startSession() {
      rec = new SR();
      rec.lang = 'en-US';
      rec.interimResults = true;
      rec.continuous = true;                 // keep going through short pauses
      rec.onstart = function () { recActive = true; if (btn) { btn.innerHTML = '\u{1F534}'; btn.style.background = '#fee2e2'; btn.title = 'Listening… tap to stop'; } armSilence(); };
      rec.onresult = function (e) {
        var fin = '', any = '';
        for (var i = 0; i < e.results.length; i++) {
          var r = e.results[i];
          any += r[0].transcript;
          if (r.isFinal) fin += r[0].transcript;
        }
        lastFinal = fin; lastAny = any;
        if (input) {
          input.value = committed + any;
          input.style.height = 'auto';
          input.style.height = Math.min(input.scrollHeight, 120) + 'px';
        }
        armSilence();                        // new words -> restart the 10s countdown
      };
      rec.onerror = function (ev) {
        if (ev && (ev.error === 'not-allowed' || ev.error === 'service-not-allowed')) {
          recStop = true;                    // don't fight a blocked mic
          try { m3Toast('Microphone is blocked — allow mic access for this site, then tap \u{1F3A4} again.', 6000); } catch (e) {}
        }
      };
      rec.onend = function () {
        // fold this session's words into committed so a restart keeps them
        var add = lastFinal || lastAny;
        if (add) { committed += add; if (!/\s$/.test(committed)) committed += ' '; }
        lastFinal = ''; lastAny = '';
        if (!recStop) {                      // engine timed out but rep's still talking -> keep listening
          if (input) input.value = committed;
          try { startSession(); return; } catch (e) {}
        }
        // Stopped on purpose (tap or Send): leave the box as-is — it already
        // shows the words, and Send clears it right after.
        micReset(btn, input);
      };
      try { rec.start(); } catch (e) { micReset(btn, input); }
    }
    startSession();
  };

  window.mbxChatSend = function () {
    if (!canChat) return;
    if (recActive) { try { window.mbxStopMic(); } catch (e) {} }
    var input = $('mbx-chat-input');
    var text = (input && input.value || '').trim();
    if (!text) return;

    var name = myName();
    if (!name) {
      var bar = $('mbx-chat-namebar'), nameInput = $('mbx-chat-name');
      var typed = (nameInput && nameInput.value || '').trim();
      if (typed) {
        name = typed;
        try { localStorage.setItem('mbx_chat_name', typed); } catch (e) {}
        if (bar) bar.style.display = 'none';
      } else {
        if (bar) bar.style.display = 'block';
        if (nameInput) nameInput.focus();
        return;
      }
    }

    var tagged = /(^|\s)@(boxy|bot)\b|^\s*(hey\s+|ok\s+)?boxy\b/i.test(text);
    if (tagged && !boxyMode && !reportMode) setBoxyMode(true);   // tag Boxy once → it stays in the chat
    var isReport = reportMode;
    var askingBot = boxyMode || tagged || isReport;
    var sent = isReport ? '⚠️ ISSUE REPORT — from Team Chat: ' + text : text;
    var btn = $('mbx-chat-sendbtn');
    if (btn) { btn.disabled = true; btn.textContent = askingBot ? 'Boxy is thinking…' : '...'; }
    fetch(API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ name: name, text: sent, toBoxy: askingBot, issue: isReport, screen: isReport ? 'Team Chat' : undefined })
    })
      .then(function (r) {
        var ct = r.headers.get('content-type') || '';
        if (!r.ok || ct.indexOf('json') === -1) throw new Error('send-failed');
        return r.json();
      })
      .then(function (data) {
        if (!data || !data.ok) throw new Error('send-failed');
        if (input) { input.value = ''; input.style.height = 'auto'; }
        if (data.message && data.message.ts) setLastRead(data.message.ts);
        if (isReport) {
          setReportMode(false);                 // one report, then back to normal chat
          try { m3Toast('Reported ✓ It is in Erik’s Problem Reports inbox — Boxy is replying here too.', 6000); } catch (e) {}
        }
        refresh(true);
      })
      .catch(function () {
        try { m3Toast('Message didn\'t send — check your connection and try again.', 5000); } catch (e) { alert('Message didn\'t send — try again.'); }
      })
      .then(function () { if (btn) { btn.disabled = false; btn.textContent = 'Send'; } });
  };

  document.addEventListener('DOMContentLoaded', function () {
    syncBoxyUI();
    syncReportUI();
    if (!canChat) { var rb = $('mbx-chat-reporttoggle'); if (rb) rb.style.display = 'none'; }
    else { var rl = $('mbx-chat-reportslink'); if (rl) rl.style.display = 'inline'; }   // online only — the inbox needs the server
    if (!speechCtor()) { var mb = $('mbx-chat-micbtn'); if (mb) mb.style.display = 'none'; }
    var input = $('mbx-chat-input');
    if (input) {
      input.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); window.mbxChatSend(); }
      });
      input.addEventListener('input', function () {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 120) + 'px';
      });
    }

    if (!canChat) {
      // Offline file copy: no server behind it, so explain instead of erroring.
      var list = $('mbx-chat-list');
      var compose = $('mbx-chat-compose');
      if (list) list.innerHTML = '<div style="text-align:center;color:var(--gray-600);font-size:13px;padding:30px 10px;">' +
        'Team Chat lives in the online app.<br>Open <b>deploytoolkit.vercel.app</b> (or your installed MiniBox+ app) to join the conversation.</div>';
      if (compose) compose.style.display = 'none';
      var boxybar = $('mbx-chat-boxybar'); if (boxybar) boxybar.style.display = 'none';
      return;
    }

    // First check shortly after launch (for the unread badge), then keep ticking:
    // every 20s with the chat open, every 60s in the background.
    setTimeout(function () { refresh(false); }, 2500);
    setInterval(function () {
      if (document.hidden) return;
      tick++;
      if (isOpen() || tick % BG_EVERY === 0) refresh(false);
    }, POLL_MS);
  });
})();
</script>

<script id="mbx-emails-helper">
/* Recently-used email addresses: feeds a native <datalist> on every To/Cc box,
   so the suggestion dropdown always fills the field when tapped (the browser's
   own saved-address popup won't commit into these dynamically-built inputs). */
function mbxEmailList() {
  try { return JSON.parse(localStorage.getItem('mbx_recent_emails') || '[]'); } catch (e) { return []; }
}
function mbxRenderEmailList() {
  var dl = document.getElementById('mbx-emails');
  if (!dl) {
    dl = document.createElement('datalist');
    dl.id = 'mbx-emails';
    document.body.appendChild(dl);
  }
  var list = mbxEmailList();
  if (typeof REP_PROFILE !== 'undefined' && REP_PROFILE && REP_PROFILE.email && list.indexOf(REP_PROFILE.email) < 0) list.push(REP_PROFILE.email);
  dl.innerHTML = list.map(function (a) {
    return '<option value="' + String(a).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;') + '"></option>';
  }).join('');
}
function mbxRememberEmail(addr) {
  addr = String(addr || '').trim();
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(addr)) return;
  var list = mbxEmailList().filter(function (a) { return a.toLowerCase() !== addr.toLowerCase(); });
  list.unshift(addr);
  if (list.length > 15) list.length = 15;
  try { localStorage.setItem('mbx_recent_emails', JSON.stringify(list)); } catch (e) {}
  mbxRenderEmailList();
}
mbxRenderEmailList();
</script>
<script id="mbx-pwa">
/* MiniBox+ app wiring — install-to-home-screen + auto-update.
   Only runs on the hosted (https) edition; does nothing when this file
   is opened from a download/USB copy, so offline copies are unaffected.
   KEEP THIS BLOCK when mirroring LATEST -> _deploy_toolkit/index.html. */
(function () {
  if (window.__mbxPwa) return; window.__mbxPwa = 1;
  var hosted = location.protocol === 'https:' || location.hostname === 'localhost';
  if (!hosted) return;

  function add(tag, attrs) {
    var el = document.createElement(tag);
    for (var k in attrs) el.setAttribute(k, attrs[k]);
    document.head.appendChild(el);
  }
  add('link', { rel: 'manifest', href: 'manifest.webmanifest' });
  add('link', { rel: 'apple-touch-icon', href: 'icon-180.png' });
  add('meta', { name: 'theme-color', content: '#0a3d6b' });
  add('meta', { name: 'apple-mobile-web-app-capable', content: 'yes' });
  add('meta', { name: 'apple-mobile-web-app-status-bar-style', content: 'black-translucent' });
  add('meta', { name: 'apple-mobile-web-app-title', content: 'MiniBox+' });

  /* ---- background updater: new deploy -> blue "Refresh" bar ---- */
  if ('serviceWorker' in navigator) {
    var refreshing = false;
    navigator.serviceWorker.addEventListener('controllerchange', function () {
      if (refreshing) return; refreshing = true; location.reload();
    });
    navigator.serviceWorker.register('./sw.js').then(function (reg) {
      try { reg.update(); } catch (e) {}
      setInterval(function () { try { reg.update(); } catch (e) {} }, 30 * 60 * 1000);
      if (reg.waiting && navigator.serviceWorker.controller) showUpdateBar(reg);
      reg.addEventListener('updatefound', function () {
        var sw = reg.installing;
        if (!sw) return;
        sw.addEventListener('statechange', function () {
          if (sw.state === 'installed' && navigator.serviceWorker.controller) showUpdateBar(reg);
        });
      });
    }).catch(function () {});
  }

  function showUpdateBar(reg) {
    if (document.getElementById('mbx-update-bar')) return;
    var bar = document.createElement('div');
    bar.id = 'mbx-update-bar';
    bar.style.cssText = 'position:fixed;left:0;right:0;bottom:0;z-index:2147483647;background:#0a3d6b;color:#fff;font-family:-apple-system,Segoe UI,Roboto,Arial,sans-serif;font-size:15px;padding:12px 16px;display:flex;align-items:center;justify-content:center;gap:12px;box-shadow:0 -4px 16px rgba(0,0,0,.35)';
    var msg = document.createElement('span');
    msg.textContent = 'A new version of the toolkit is ready.';
    var btn = document.createElement('button');
    btn.textContent = 'Refresh';
    btn.style.cssText = 'background:#fff;color:#0a3d6b;border:0;border-radius:8px;padding:8px 18px;font-weight:800;font-size:15px;cursor:pointer';
    btn.onclick = function () {
      var w = reg.waiting;
      if (w) w.postMessage({ type: 'SKIP_WAITING' }); else location.reload();
    };
    bar.appendChild(msg); bar.appendChild(btn);
    document.body.appendChild(bar);
  }

  /* ---- friendly install bar ----
     Android / desktop Chrome & Edge fire `beforeinstallprompt`, so we get a
     real Install button. iPhone / iPad NEVER fire it (Apple has no install
     API), so there we show the manual Share -> Add to Home Screen steps
     instead — otherwise iOS users get no prompt at all. */
  var standalone = false;
  try {
    standalone = (window.matchMedia && window.matchMedia('(display-mode: standalone)').matches) ||
      (window.matchMedia && window.matchMedia('(display-mode: fullscreen)').matches) ||
      (window.matchMedia && window.matchMedia('(display-mode: minimal-ui)').matches) ||
      window.navigator.standalone === true ||
      /* already installed on this device — don't re-pitch in a browser tab */
      localStorage.getItem('mbx_is_installed') === '1';
    if (standalone) localStorage.setItem('mbx_is_installed', '1');
  } catch (e) {}

  var ua = navigator.userAgent || '';
  /* iPadOS 13+ masquerades as a Mac, so also treat touch-Macs as iPads. */
  var isIOS = /iphone|ipad|ipod/i.test(ua) ||
    (/macintosh/i.test(ua) && navigator.maxTouchPoints > 1);
  /* Real Safari only — Chrome/Firefox/Edge on iOS and in-app browsers
     (Outlook, Teams, etc.) can't Add to Home Screen. */
  var isIOSSafari = isIOS && /safari/i.test(ua) && !/crios|fxios|edgios/i.test(ua);

  var deferredPrompt = null;
  window.addEventListener('beforeinstallprompt', function (e) {
    e.preventDefault();
    deferredPrompt = e;
    if (standalone || localStorage.getItem('mbx_install_dismissed')) return;
    showInstallBar(false);
  });

  if (isIOS && !standalone && !localStorage.getItem('mbx_install_dismissed')) {
    /* Give the page a beat to settle before nudging. */
    setTimeout(function () { showInstallBar(true); }, 3000);
  }

  function showInstallBar(ios) {
    if (document.getElementById('mbx-install-bar')) return;
    var bar = document.createElement('div');
    bar.id = 'mbx-install-bar';
    bar.style.cssText = 'position:fixed;left:0;right:0;bottom:0;z-index:2147483646;background:#0d4a82;color:#fff;font-family:-apple-system,Segoe UI,Roboto,Arial,sans-serif;font-size:15px;padding:12px 16px;display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;text-align:center;box-shadow:0 -4px 16px rgba(0,0,0,.35)';
    var msg = document.createElement('span');
    if (ios) {
      if (isIOSSafari) {
        msg.innerHTML = 'Put MiniBox+ on your home screen: tap <b>Share</b> ⬆️ below, then <b>“Add to Home Screen”</b>';
      } else {
        msg.innerHTML = 'Put MiniBox+ on your home screen: open this page in <b>Safari</b>, tap <b>Share</b> ⬆️, then <b>“Add to Home Screen”</b>';
      }
    } else {
      msg.textContent = 'Put the MiniBox+ Toolkit on your home screen:';
    }
    bar.appendChild(msg);
    if (!ios) {
      var btn = document.createElement('button');
      btn.textContent = 'Install';
      btn.style.cssText = 'background:#fff;color:#0a3d6b;border:0;border-radius:8px;padding:8px 18px;font-weight:800;font-size:15px;cursor:pointer';
      btn.onclick = function () {
        if (!deferredPrompt) return;
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then(function () { bar.remove(); deferredPrompt = null; });
      };
      bar.appendChild(btn);
    }
    var x = document.createElement('button');
    x.textContent = '×';
    x.setAttribute('aria-label', 'Dismiss');
    x.style.cssText = 'background:transparent;color:#bcd4ea;border:0;font-size:22px;cursor:pointer;padding:0 4px;line-height:1';
    x.onclick = function () { localStorage.setItem('mbx_install_dismissed', '1'); bar.remove(); };
    bar.appendChild(x);
    document.body.appendChild(bar);
  }
})();
</script>

<script>
/* v3.19: Release wave control. MASTER build: MBX_WAVE = null, every tab shows.
   TEAM RELEASE cut: set MBX_WAVE to the tab ids rolled out so far; every other
   tab button hides. Panels stay in the file, just unreachable from the menu. */
var MBX_WAVE = null; /* MBX_WAVE_MARKER */
document.addEventListener('DOMContentLoaded', function () {
  if (!MBX_WAVE) return;
  var shown = {};
  var btns = document.querySelectorAll('.tab-btn');
  for (var i = 0; i < btns.length; i++) {
    var m = (btns[i].getAttribute('onclick') || '').match(/showTab\('([^']+)'/);
    if (!m) continue;
    if (MBX_WAVE.indexOf(m[1]) === -1) btns[i].style.display = 'none';
    else shown[m[1]] = true;
  }
  document.querySelectorAll('.tab-dd').forEach(function (dd) {
    var kids = dd.querySelectorAll('.tab-dd-menu .tab-btn');
    var any = false;
    for (var k = 0; k < kids.length; k++) { if (kids[k].style.display !== 'none') { any = true; break; } }
    if (!any) dd.style.display = 'none';
  });
});
</script>

<script id="mbx-videos-hub">
/* TRAINING VIDEOS HUB — a top-level 🎬 Videos tab + a "🎬 Videos" pill inside every specialty
   sub-nav (… Playbook / Calculators / Files | 🎬 Videos). Self-contained and append-only
   (same pattern as mbx-pwa / mbx-chat) so it never collides with edits to the specialty tabs. */
(function(){
  function vids(){ return (typeof MATERIALS !== 'undefined') ? MATERIALS.filter(function(m){ return m.cat === 'video'; }) : []; }
  function card(m){
    return '<div class="m3-lib-card">'
      + '<div class="m3-lib-title">' + m.title + ' <span class="m3-kb">' + m3SizeLabel(m.kb) + '</span></div>'
      + '<div class="m3-lib-sub">' + m.sub + '</div>'
      + '<div class="m3-lib-btns">'
      +   '<button onclick="m3PlayVideo(\'' + m.id + '\')">&#9654; Play</button>'
      +   '<button onclick="m3Download(\'' + m.id + '\')">&#11015; Download</button>'
      + '</div></div>';
  }
  function grid(){
    var v = vids();
    if (!v.length) return '<div class="m3-lib-sub">Training videos will appear here.</div>';
    var cal = v.filter(function(m){ return m.vgroup === 'cal'; });
    var tests = v.filter(function(m){ return m.vgroup !== 'cal'; });
    if (!cal.length || !tests.length) return '<div class="m3-lib-grid">' + v.map(card).join('') + '</div>';
    function head(txt, sub, first){
      return '<div style="margin:' + (first ? '0' : '22px') + ' 0 10px;">'
        + '<div style="font-weight:800; font-size:1.02em; letter-spacing:.3px;">' + txt + '</div>'
        + '<div class="m3-lib-sub" style="margin-top:2px;">' + sub + '</div>'
        + '</div>';
    }
    return head('&#128295; Calibration Checks', 'Daily QC &mdash; run these before testing patients.', true)
      + '<div class="m3-lib-grid">' + cal.map(card).join('') + '</div>'
      + head('&#129658; Patient Tests', 'How to run each test on the MiniBox+.', false)
      + '<div class="m3-lib-grid">' + tests.map(card).join('') + '</div>';
  }

  /* 1) Top-level 🎬 Videos tab (panel + nav button) */
  function ensureTab(){
    if (!document.getElementById('tab-videos')){
      var ref = document.getElementById('tab-forms') || document.querySelector('.tab-panel');
      if (ref && ref.parentNode){
        var p = document.createElement('div');
        p.className = 'tab-panel';
        p.id = 'tab-videos';
        p.innerHTML =
            '<div class="section-title">&#127916; Training Videos</div>'
          + '<div class="section-sub">Short how-to clips for running every MiniBox+ test &mdash; play one in the exam room, or send it to the clinic staff.</div>'
          + '<div id="mbx-videos-hub-grid" style="margin-top:16px;"></div>';
        ref.parentNode.appendChild(p);
        var g = p.querySelector('#mbx-videos-hub-grid');
        if (g) g.innerHTML = grid();
      }
    }
    if (!document.querySelector('.tab-btn[data-mbxvid="1"]')){
      var anchor = document.querySelector('.tab-btn[onclick*="forms"]') || document.querySelector('.tab-btn');
      if (anchor && anchor.parentNode){
        var b = document.createElement('button');
        b.className = 'tab-btn';
        b.setAttribute('data-mbxvid', '1');
        b.setAttribute('onclick', "showTab('videos', this)");
        b.innerHTML = 'Videos';
        anchor.parentNode.insertBefore(b, anchor.nextSibling);
      }
    }
  }

  /* 2) A "🎬 Videos" pill in every specialty sub-nav — behaves like the other pills */
  var SPECS = ['pulmo','allergy','cardio','rheum','intmed'];
  function wireSpec(spec){
    var panel = document.getElementById('tab-' + spec);
    if (!panel || document.getElementById(spec + '-videos-pill')) return;

    var samplePill = panel.querySelector('button[onclick*="ShowView("]');
    if (!samplePill || !samplePill.parentNode) return;
    var nav = samplePill.parentNode;
    var m = /([A-Za-z]+ShowView)\(/.exec(samplePill.getAttribute('onclick') || '');
    if (!m) return;
    var fn = m[1];

    var anyView = document.getElementById(spec + '-view-playbook');
    if (!anyView || !anyView.parentNode) return;

    /* the videos view (hidden until its pill is clicked) */
    if (!document.getElementById(spec + '-view-videos')){
      var vv = document.createElement('div');
      vv.id = spec + '-view-videos';
      vv.className = anyView.className;
      vv.style.display = 'none';
      vv.innerHTML =
          '<div class="section-title" style="margin-top:0;">&#127916; Training Videos</div>'
        + '<div class="section-sub">How to run every MiniBox+ test &mdash; same device, ready to show this doctor&rsquo;s staff.</div>'
        + '<div style="margin-top:14px;">' + grid() + '</div>';
      anyView.parentNode.appendChild(vv);
    }

    /* the pill (cloned styling, appended after the last sub-nav pill) */
    var pill = document.createElement('button');
    pill.type = 'button';
    pill.id = spec + '-videos-pill';
    pill.className = (samplePill.className || '').replace(/\bon\b/g, '').trim();
    pill.setAttribute('onclick', fn + "('videos', this)");
    pill.innerHTML = '&#127916; Videos';
    nav.appendChild(pill);

    /* wrap the specialty's show fn: 'videos' reveals our view; any other view hides it */
    var orig = window[fn];
    if (typeof orig === 'function' && !orig.__mbxVid){
      var wrapped = function(view, btn){
        if (view === 'videos'){
          try { orig('__mbxnone__', btn); } catch(e){}
          var v2 = document.getElementById(spec + '-view-videos'); if (v2) v2.style.display = '';
          var p2 = document.getElementById(spec + '-videos-pill'); if (p2) p2.classList.add('on');
          return;
        }
        var r = orig.apply(this, arguments);
        var v3 = document.getElementById(spec + '-view-videos'); if (v3) v3.style.display = 'none';
        var p3 = document.getElementById(spec + '-videos-pill'); if (p3) p3.classList.remove('on');
        return r;
      };
      wrapped.__mbxVid = true;
      window[fn] = wrapped;
    }
  }

  function init(){
    try { ensureTab(); } catch(e){}
    SPECS.forEach(function(s){ try { wireSpec(s); } catch(e){} });
    if (typeof window.showTab === 'function' && !window.showTab.__mbxVidTab){
      var orig = window.showTab;
      window.showTab = function(id, btn){ var r = orig.apply(this, arguments); try { if (SPECS.indexOf(id) > -1) wireSpec(id); } catch(e){} return r; };
      window.showTab.__mbxVidTab = true;
    }
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
<script id="mbx-command-center">
/* COMMAND CENTER TAB — owner view, loaded only when Erik opens it.
   The real screen is reports.html (same folder), behind its own admin password
   that the SERVER checks (api/admin.js). Nothing here reveals anything: until
   that password is typed the frame shows only a lock screen. The frame reports
   its open-problem count back so the tab can carry a badge. */
(function () {
  var loaded = false;
  var online = (location.protocol === 'https:' || location.protocol === 'http:');

  window.mbxCommandOpened = function () {
    var frame = document.getElementById('mbx-cc-frame');
    if (!frame) return;
    if (!online) {                       // offline file:// copy — no server behind it
      frame.style.display = 'none';
      if (!document.getElementById('mbx-cc-offline')) {
        var d = document.createElement('div');
        d.id = 'mbx-cc-offline';
        d.style.cssText = 'padding:40px 20px;text-align:center;color:#9aa3ad;font-size:14px;line-height:1.6;';
        d.innerHTML = 'The Command Center lives in the online app.<br>Open <b>deploytoolkit.vercel.app</b> to use it.';
        frame.parentNode.appendChild(d);
      }
      return;
    }
    if (!loaded) { frame.src = './reports.html'; loaded = true; }
  };

  window.addEventListener('message', function (e) {
    if (!e || !e.data || typeof e.data.mbxOpenProblems !== 'number') return;
    if (e.origin !== location.origin) return;       // only our own frame
    var b = document.getElementById('mbx-cc-badge');
    if (!b) return;
    if (e.data.mbxOpenProblems > 0) { b.textContent = e.data.mbxOpenProblems; b.style.display = 'inline-block'; }
    else b.style.display = 'none';
  });
})();
</script>
<script id="mbx-boxy-fab">
/* FLOATING BOXY — Boxy on every screen. A purple 🤖 button rides in the
   bottom-right of every tab; tap it to ask a question or REPORT A PROBLEM
   right where you spotted it. It auto-tags which screen you're on, then
   posts to the SAME /api/chat pipeline with toBoxy:true — so Boxy answers
   inline AND the exchange lands in Team Chat + Erik's daily review log
   (mbx:bot:log), where change requests surface for his approval.
   Self-contained + append-only (same pattern as mbx-chat / mbx-videos-hub):
   NO backend change, NO edits to the tab HTML or the main chat block. */
(function () {
  var API = '/api/chat';
  var online = (location.protocol === 'https:' || location.protocol === 'http:');
  if (!online) return;                     // Boxy needs the server — skip on offline file:// copies
  if (document.getElementById('mbx-boxy-fab-btn')) return;   // idempotent

  var PURPLE = '#6b46c1', LILAC = '#f3f0ff', LILAC_BORDER = '#ddd2f7';
  var open = false, reportMode = false, sending = false;
  var convo = [];                          // this session's Q&A with Boxy (local, so we don't fight main chat render)
  var rec = null, recActive = false, micStop = false, micTimer = null;

  function esc(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) { return '&#' + c.charCodeAt(0) + ';'; }); }
  function myName() {
    var n = '';
    try { if (typeof REP_PROFILE !== 'undefined' && REP_PROFILE && REP_PROFILE.name) n = REP_PROFILE.name; } catch (e) {}
    if (!n) { try { n = localStorage.getItem('mbx_chat_name') || ''; } catch (e) {} }
    return String(n).trim();
  }

  /* Which screen is the rep looking at right now? Used to tag the report. */
  function currentScreen() {
    var p = document.querySelector('.tab-panel.active');
    if (p && p.id && p.id.indexOf('tab-') === 0) {
      var map = {
        hub: 'Daily Hub', pulmo: 'Pulmonology', allergy: 'Allergy / Immunology',
        cardio: 'Cardiology', rheum: 'Rheumatology', intmed: 'Internal Medicine',
        emaillib: 'Email Center',
        teamchat: 'Team Chat', overview: 'Product Overview', competitive: 'vs. Competition',
        keymsg: 'Key Messages', aging: 'Aging Devices', clinical: 'Clinical Proof',
        coaching: 'Patient Coaching', interpretation: 'PFT Interpretation',
        reimbursement: 'CPT & Revenue', billing: 'Billing Helper', financing: 'Financing',
        forms: 'Forms', trunkstock: 'Trunk Stock', videos: 'Videos', myday: 'My Day'
      };
      var key = p.id.slice(4);
      if (map[key]) return map[key];
    }
    var b = document.querySelector('.tab-btn.active');
    if (b) return b.textContent.replace(/[▼▼▲♡⚡]/g, '').replace(/\s+/g, ' ').trim() || 'the toolkit';
    return 'the toolkit';
  }

  function $(id) { return document.getElementById(id); }

  function renderConvo() {
    var box = $('mbx-boxy-log');
    if (!box) return;
    if (!convo.length) {
      box.innerHTML = '<div style="color:#64748b;font-size:13px;line-height:1.5;padding:6px 2px;">'
        + 'Hi &#128075; I\'m <b style="color:' + PURPLE + ';">Boxy</b>. Ask me anything about the toolkit, '
        + 'or hit <b>&#128027; Report a problem</b> and tell me what\'s broken on this screen &mdash; '
        + 'I\'ll answer, and Erik sees every report each morning.</div>';
      return;
    }
    var html = '';
    for (var i = 0; i < convo.length; i++) {
      var m = convo[i], bot = m.who === 'boxy';
      html += '<div style="display:flex;margin-bottom:8px;' + (bot ? '' : 'justify-content:flex-end;') + '">'
        + '<div style="max-width:85%;border-radius:13px;padding:7px 11px;font-size:13.5px;line-height:1.45;white-space:pre-wrap;word-break:break-word;'
        + (bot ? 'background:' + LILAC + ';border:1px solid ' + LILAC_BORDER + ';color:#1f2937;'
               : 'background:#e0f2fe;border:1px solid #bae6fd;color:#0c4a6e;') + '">'
        + (bot ? '<div style="font-size:11px;font-weight:800;color:' + PURPLE + ';margin-bottom:2px;">Boxy &#129302;</div>' : '')
        + esc(m.text) + '</div></div>';
    }
    box.innerHTML = html;
    box.scrollTop = box.scrollHeight;
  }

  function setReport(on) {
    reportMode = !!on;
    var btn = $('mbx-boxy-reportbtn'), input = $('mbx-boxy-input'), chip = $('mbx-boxy-context');
    if (btn) {
      btn.style.background = reportMode ? '#fee2e2' : '#fff';
      btn.style.color = reportMode ? '#b91c1c' : '#b91c1c';
      btn.style.borderColor = reportMode ? '#fca5a5' : '#fecaca';
      btn.innerHTML = reportMode ? '&#128027; Reporting a problem &#10003;' : '&#128027; Report a problem';
    }
    if (chip) chip.innerHTML = '&#128205; ' + (reportMode ? 'Problem on: ' : 'You\'re on: ') + '<b>' + esc(currentScreen()) + '</b>';
    if (input) input.placeholder = reportMode ? 'Describe what\'s wrong on this screen…' : 'Ask Boxy anything…';
    if (input) input.focus();
  }

  function toggle(force) {
    open = (force === undefined) ? !open : !!force;
    var panel = $('mbx-boxy-panel'), btn = $('mbx-boxy-fab-btn');
    if (!panel) return;
    panel.style.display = open ? 'flex' : 'none';
    if (btn) btn.innerHTML = open ? '&#10005;' : '&#129302;';
    if (open) {
      setReport(reportMode);
      renderConvo();
      var i = $('mbx-boxy-input'); if (i) setTimeout(function () { i.focus(); }, 60);
      try { localStorage.setItem('mbx_boxy_seen', '1'); } catch (e) {}
      var dot = $('mbx-boxy-dot'); if (dot) dot.style.display = 'none';
    }
  }

  /* Voice-to-text — keeps listening THROUGH pauses; auto-stops only after
     10 seconds of silence, or the moment you tap the mic again / hit Send.
     Never cuts you off just because you paused to think. */
  function speechCtor() { return window.SpeechRecognition || window.webkitSpeechRecognition || null; }
  var MIC_SILENCE_MS = 10000;              // seconds of silence before it auto-stops
  function micClearTimer() { if (micTimer) { clearTimeout(micTimer); micTimer = null; } }
  function mic() {
    var SR = speechCtor();
    if (!SR) { try { m3Toast("Voice typing isn't in this browser — use your phone keyboard's mic.", 6000); } catch (e) {} return; }
    var input = $('mbx-boxy-input'), btn = $('mbx-boxy-micbtn');
    if (recActive && rec) { micStop = true; try { rec.stop(); } catch (e) {} return; }   // tap again = stop now
    micStop = false;
    var committed = input ? input.value : ''; if (committed && !/\s$/.test(committed)) committed += ' ';
    var lastFinal = '', lastAny = '';
    function armTimer() { micClearTimer(); micTimer = setTimeout(function () { micStop = true; if (rec) { try { rec.stop(); } catch (e) {} } }, MIC_SILENCE_MS); }
    function startSession() {
      rec = new SR(); rec.lang = 'en-US'; rec.interimResults = true; rec.continuous = true;
      rec.onstart = function () { recActive = true; if (btn) { btn.innerHTML = '&#128308;'; btn.style.background = '#fee2e2'; btn.title = 'Listening… tap to stop'; } armTimer(); };
      rec.onresult = function (e) {
        var fin = '', any = '';
        for (var i = 0; i < e.results.length; i++) { any += e.results[i][0].transcript; if (e.results[i].isFinal) fin += e.results[i][0].transcript; }
        lastFinal = fin; lastAny = any;
        if (input) { input.value = committed + any; input.style.height = 'auto'; input.style.height = Math.min(input.scrollHeight, 110) + 'px'; }
        armTimer();                          // new words -> restart the 10s countdown
      };
      rec.onerror = function (ev) { if (ev && (ev.error === 'not-allowed' || ev.error === 'service-not-allowed')) { micStop = true; try { m3Toast('Microphone is blocked — allow mic access, then tap 🎤 again.', 6000); } catch (e) {} } };
      rec.onend = function () {
        var add = lastFinal || lastAny;
        if (add) { committed += add; if (!/\s$/.test(committed)) committed += ' '; }
        lastFinal = ''; lastAny = '';
        if (!micStop) { if (input) input.value = committed; try { startSession(); return; } catch (e) {} }  // engine hiccup, still talking -> keep going
        micClearTimer();
        recActive = false; if (btn) { btn.innerHTML = '&#127908;'; btn.style.background = '#fff'; btn.title = 'Talk instead of typing'; } if (input) input.focus();
      };
      try { rec.start(); } catch (e) { micClearTimer(); recActive = false; }
    }
    startSession();
  }

  function needName() {
    var name = myName();
    if (name) return name;
    var bar = $('mbx-boxy-namebar'), ni = $('mbx-boxy-name');
    var typed = (ni && ni.value || '').trim();
    if (typed) { try { localStorage.setItem('mbx_chat_name', typed); } catch (e) {} if (bar) bar.style.display = 'none'; return typed; }
    if (bar) bar.style.display = 'block';
    if (ni) ni.focus();
    return '';
  }

  /* Poll for Boxy's reply after we post (server answers inline, next fetch shows it). */
  function awaitReply(afterTs, tries) {
    fetch(API, { headers: { 'Accept': 'application/json' }, cache: 'no-store' })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var msgs = (data && data.messages) || [];
        var got = null;
        for (var i = msgs.length - 1; i >= 0; i--) {
          if (String(msgs[i].name || '').indexOf('Boxy') === 0 && msgs[i].ts > afterTs) { got = msgs[i]; break; }
        }
        if (got) { finishReply(got.text); return; }
        if (tries > 0) setTimeout(function () { awaitReply(afterTs, tries - 1); }, 1400);
        else finishReply("Got it — I've logged this for Erik. He reads my log every morning, so an answer (or the fix, once he approves it) is on the way. 📦");
      })
      .catch(function () {
        if (tries > 0) setTimeout(function () { awaitReply(afterTs, tries - 1); }, 1400);
        else finishReply("Saved for Erik's review. 📦");
      });
  }
  function finishReply(text) {
    convo.push({ who: 'boxy', text: text });
    sending = false;
    var b = $('mbx-boxy-sendbtn'); if (b) { b.disabled = false; b.innerHTML = 'Send'; }
    renderConvo();
  }

  function send() {
    if (sending) return;
    if (recActive && rec) { micStop = true; try { rec.stop(); } catch (e) {} }
    var input = $('mbx-boxy-input');
    var raw = (input && input.value || '').trim();
    if (!raw) return;
    var name = needName();
    if (!name) return;

    var screen = currentScreen();
    var text = reportMode
      ? '⚠️ ISSUE REPORT — on the "' + screen + '" screen: ' + raw
      : raw + '  (asked from the "' + screen + '" screen)';

    convo.push({ who: 'me', text: raw });
    renderConvo();
    sending = true;
    var btn = $('mbx-boxy-sendbtn'); if (btn) { btn.disabled = true; btn.innerHTML = 'Boxy is thinking…'; }
    if (input) { input.value = ''; input.style.height = 'auto'; }

    fetch(API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ name: name, text: text, toBoxy: true, issue: reportMode, screen: screen })
    })
      .then(function (r) { var ct = r.headers.get('content-type') || ''; if (!r.ok || ct.indexOf('json') === -1) throw new Error('send-failed'); return r.json(); })
      .then(function (data) {
        if (!data || !data.ok) throw new Error('send-failed');
        var afterTs = (data.message && data.message.ts) || Date.now();
        if (reportMode) setReport(false);   // one report, then back to normal ask mode
        awaitReply(afterTs, 9);
      })
      .catch(function () {
        sending = false;
        if (btn) { btn.disabled = false; btn.innerHTML = 'Send'; }
        convo.push({ who: 'boxy', text: "Couldn't reach me just now — check your connection and try again." });
        renderConvo();
      });
  }

  function build() {
    var wrap = document.createElement('div');
    wrap.id = 'mbx-boxy-fab';
    wrap.style.cssText = 'position:fixed;right:18px;bottom:18px;z-index:900;font-family:inherit;';
    var neverSeen = true; try { neverSeen = localStorage.getItem('mbx_boxy_seen') !== '1'; } catch (e) {}
    wrap.innerHTML =
      '<div id="mbx-boxy-panel" style="display:none;flex-direction:column;width:min(92vw,350px);height:min(72vh,480px);'
        + 'background:#fff;border:1px solid ' + LILAC_BORDER + ';border-radius:18px;box-shadow:0 14px 44px rgba(31,20,60,0.28);overflow:hidden;margin-bottom:12px;">'
        + '<div style="background:' + PURPLE + ';color:#fff;padding:12px 14px;display:flex;align-items:center;gap:9px;">'
          + '<span style="font-size:20px;line-height:1;">&#129302;</span>'
          + '<div style="flex:1;"><div style="font-weight:800;font-size:15px;line-height:1.1;">Boxy</div>'
          + '<div style="font-size:11px;opacity:.9;">Ask a question &middot; report a problem</div></div>'
          + '<button onclick="window.mbxBoxyToggle(false)" title="Close" style="background:rgba(255,255,255,.18);border:0;color:#fff;width:28px;height:28px;border-radius:8px;font-size:15px;cursor:pointer;line-height:1;">&#10005;</button>'
        + '</div>'
        + '<div id="mbx-boxy-context" style="padding:7px 14px;font-size:12px;color:#475569;background:' + LILAC + ';border-bottom:1px solid ' + LILAC_BORDER + ';"></div>'
        + '<div id="mbx-boxy-log" style="flex:1;overflow-y:auto;padding:12px 14px;background:#faf9ff;"></div>'
        + '<div id="mbx-boxy-namebar" style="display:none;padding:8px 12px;background:#fffbeb;border-top:1px solid #fde68a;">'
          + '<input id="mbx-boxy-name" placeholder="Your name (so Erik knows who reported it)" style="width:100%;padding:8px 10px;border:1px solid #fcd34d;border-radius:9px;font-size:13px;box-sizing:border-box;">'
        + '</div>'
        + '<div style="padding:9px 12px 12px;border-top:1px solid #eef0f4;background:#fff;">'
          + '<button id="mbx-boxy-reportbtn" onclick="window.mbxBoxyReport()" style="width:100%;margin-bottom:8px;background:#fff;color:#b91c1c;border:1px solid #fecaca;border-radius:10px;padding:8px;font-weight:800;font-size:13px;cursor:pointer;">&#128027; Report a problem</button>'
          + '<div style="display:flex;gap:7px;align-items:flex-end;">'
            + '<textarea id="mbx-boxy-input" rows="1" placeholder="Ask Boxy anything…" style="flex:1;resize:none;border:1px solid #d7dbe3;border-radius:12px;padding:10px 12px;font-size:14px;font-family:inherit;max-height:110px;box-sizing:border-box;"></textarea>'
            + '<button id="mbx-boxy-micbtn" onclick="window.mbxBoxyMic()" title="Talk instead of typing" style="background:#fff;color:' + PURPLE + ';border:1px solid #d7dbe3;border-radius:11px;padding:9px 11px;font-size:16px;cursor:pointer;line-height:1;">&#127908;</button>'
            + '<button id="mbx-boxy-sendbtn" onclick="window.mbxBoxySend()" style="background:' + PURPLE + ';color:#fff;border:0;border-radius:11px;padding:10px 15px;font-weight:800;font-size:13px;cursor:pointer;white-space:nowrap;">Send</button>'
          + '</div>'
        + '</div>'
      + '</div>'
      + '<button id="mbx-boxy-fab-btn" onclick="window.mbxBoxyToggle()" title="Ask Boxy / report a problem" aria-label="Ask Boxy"'
        + ' style="position:relative;width:58px;height:58px;border-radius:50%;border:0;background:' + PURPLE + ';color:#fff;font-size:27px;line-height:1;cursor:pointer;box-shadow:0 8px 22px rgba(107,70,193,0.45);display:flex;align-items:center;justify-content:center;margin-left:auto;">'
        + '&#129302;'
        + '<span id="mbx-boxy-dot" style="display:' + (neverSeen ? 'block' : 'none') + ';position:absolute;top:-2px;right:-2px;width:15px;height:15px;border-radius:50%;background:#ef4444;border:2px solid #fff;"></span>'
      + '</button>';
    document.body.appendChild(wrap);

    var input = $('mbx-boxy-input');
    if (input) {
      input.addEventListener('keydown', function (e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); } });
      input.addEventListener('input', function () { input.style.height = 'auto'; input.style.height = Math.min(input.scrollHeight, 110) + 'px'; });
    }
    var ni = $('mbx-boxy-name');
    if (ni) ni.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); send(); } });
    if (!speechCtor()) { var mb = $('mbx-boxy-micbtn'); if (mb) mb.style.display = 'none'; }
  }

  window.mbxBoxyToggle = function (f) { toggle(f); };
  window.mbxBoxyReport = function () { setReport(!reportMode); };
  window.mbxBoxyMic = function () { mic(); };
  window.mbxBoxySend = function () { send(); };

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', build);
  else build();
})();
</script>

<!-- ── VOICE-TO-TEXT FOR TODAY'S NOTES ─────────────────────────────────
     Same continuous-listening dictation Boxy/Team Chat use: keeps going
     through short pauses, auto-restarts if the browser's speech engine
     times out, and folds every word into a committed buffer so nothing
     is lost. Whatever it dictates is auto-saved through the existing
     saveNotes() so it survives a refresh just like typed notes.
     Self-contained + append-only (injects its own button at runtime) so
     it never collides with edits to the Daily Hub HTML. ────────────── -->
<script id="mbx-notes-mic">
(function () {
  if (location.protocol === 'file:') { /* still works offline; no early-out needed */ }
  var rec = null, recActive = false, recStop = false, silenceTimer = null;
  function speechCtor() { return window.SpeechRecognition || window.webkitSpeechRecognition || null; }
  function $notes() { return document.getElementById('daily-notes'); }
  function persist() { try { if (typeof window.saveNotes === 'function') window.saveNotes(true); } catch (e) {} }

  function micReset(btn) {
    recActive = false;
    if (silenceTimer) { clearTimeout(silenceTimer); silenceTimer = null; }
    if (btn) { btn.innerHTML = '\u{1F3A4} Dictate'; btn.style.background = 'none'; btn.style.borderColor = 'var(--gray-300)'; btn.style.color = 'var(--gray-600)'; btn.title = 'Talk instead of typing'; }
    var box = $notes(); if (box) box.focus();
  }
  window.mbxNotesStopMic = function () {
    recStop = true;
    if (rec) { try { rec.stop(); } catch (e) {} }
  };
  function startMic() {
    var SR = speechCtor();
    var box = $notes(), btn = document.getElementById('notes-micbtn');
    if (!SR) {
      try { m3Toast("Voice typing isn't available in this browser — use your phone keyboard's mic button instead.", 6000); } catch (e) {}
      return;
    }
    if (recActive) { window.mbxNotesStopMic(); return; }   // tap again = stop

    recStop = false;
    // committed = everything already in the notes (+ a space); dictation
    // is appended to it and carries across engine auto-restarts.
    var committed = box ? box.value : '';
    if (committed && !/\s$/.test(committed)) committed += ' ';
    var lastFinal = '', lastAny = '';
    // Stop on its own after 10s of silence so the mic never runs forever.
    function armSilence() { if (silenceTimer) clearTimeout(silenceTimer); silenceTimer = setTimeout(function () { recStop = true; if (rec) { try { rec.stop(); } catch (e) {} } }, 10000); }

    function startSession() {
      rec = new SR();
      rec.lang = 'en-US';
      rec.interimResults = true;
      rec.continuous = true;                 // keep going through short pauses
      rec.onstart = function () { recActive = true; if (btn) { btn.innerHTML = '\u{1F534} Listening…'; btn.style.background = '#fee2e2'; btn.style.borderColor = '#fca5a5'; btn.style.color = '#b91c1c'; btn.title = 'Listening… tap to stop'; } armSilence(); };
      rec.onresult = function (e) {
        var fin = '', any = '';
        for (var i = 0; i < e.results.length; i++) {
          var r = e.results[i];
          any += r[0].transcript;
          if (r.isFinal) fin += r[0].transcript;
        }
        lastFinal = fin; lastAny = any;
        if (box) { box.value = committed + any; persist(); }
        armSilence();                        // new words -> restart the 10s countdown
      };
      rec.onerror = function (ev) {
        if (ev && (ev.error === 'not-allowed' || ev.error === 'service-not-allowed')) {
          recStop = true;
          try { m3Toast('Microphone is blocked — allow mic access for this site, then tap \u{1F3A4} Dictate again.', 6000); } catch (e) {}
        }
      };
      rec.onend = function () {
        var add = lastFinal || lastAny;
        if (add) { committed += add; if (!/\s$/.test(committed)) committed += ' '; }
        lastFinal = ''; lastAny = '';
        if (box) { box.value = committed; persist(); }
        if (!recStop) {                      // engine timed out but still talking -> keep listening
          try { startSession(); return; } catch (e) {}
        }
        micReset(btn);
      };
      try { rec.start(); } catch (e) { micReset(btn); }
    }
    startSession();
  }
  window.mbxNotesMic = function () { startMic(); };

  function build() {
    var box = $notes(); if (!box) return;
    if (document.getElementById('notes-micbtn')) return;   // idempotent
    var actions = box.parentNode ? box.parentNode.querySelector('.notes-actions') : null;
    if (!actions) return;
    var btn = document.createElement('button');
    btn.id = 'notes-micbtn';
    btn.type = 'button';
    btn.className = 'notes-clear-btn';
    btn.innerHTML = '\u{1F3A4} Dictate';
    btn.title = 'Talk instead of typing';
    btn.style.display = 'inline-flex';
    btn.style.alignItems = 'center';
    btn.style.gap = '5px';
    btn.onclick = function () { startMic(); };
    // sit just before the Clear button
    var clearBtn = actions.querySelector('.notes-clear-btn');
    if (clearBtn) actions.insertBefore(btn, clearBtn); else actions.appendChild(btn);
    if (!speechCtor()) btn.style.display = 'none';   // browser can't dictate
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', build);
  else build();
})();
</script>

<script id="mbx-mytpl">
/* ============================================================
   MBX-MYTPL — Save & tag your OWN follow-up emails from any
   composer (Quick Composer, Assembly Station, Email Library).
   Saved templates live in the same store as the Email Library
   custom templates (pulmone_custom_templates) and show up as
   one-tap chips in the Quick Composer, tagged by category.
   Self-contained append-only block — collision-safe.
   ============================================================ */
(function () {
  var TAG_SUGGESTIONS = ['Free Demo', 'Demo Follow-Up', 'Pricing Follow-Up', 'Check-In', 'Cold Intro', 'Post-Install', 'Service'];

  function esc(s) { return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
  function merges(s) { return (typeof applyProfileMerges === 'function') ? applyProfileMerges(s || '') : (s || ''); }
  function toast(m) { if (typeof elToast === 'function') elToast(m); }

  /* ---------- open the existing template editor, pre-filled from a draft ---------- */
  function saveDraftAsTemplate(subject, body) {
    if (!(subject || '').trim() && !(body || '').trim()) { toast('Write your email first, then save it'); return; }
    if (typeof openTemplateEditor !== 'function') return;
    openTemplateEditor(null);
    var cat = document.getElementById('tm-cat'), ttl = document.getElementById('tm-title'),
        sub = document.getElementById('tm-sub'), subj = document.getElementById('tm-subject'),
        bod = document.getElementById('tm-body'), hdr = document.getElementById('tm-hdr-title');
    if (cat)  cat.value  = '';
    if (ttl)  ttl.value  = (subject || '').slice(0, 60);
    if (subj) subj.value = subject || '';
    if (bod)  bod.value  = body || '';
    if (sub)  { sub.value = ''; sub.placeholder = 'e.g. Send the day after a free demo'; }
    if (hdr)  hdr.innerHTML = '&#128190; Save as My Template';
    if (cat)  { cat.placeholder = 'Tag it \u2014 e.g. Free Demo, Demo Follow-Up, Pricing'; try { cat.focus(); } catch (e) {} }
  }

  window.mbxSaveQuickComposer = function () {
    var s = document.getElementById('email-subject'), b = document.getElementById('email-body');
    saveDraftAsTemplate(s ? s.value : '', b ? b.value : '');
  };
  window.mbxSaveEas = function () {
    var s = document.getElementById('eas-out-subject'), b = document.getElementById('eas-out-body');
    saveDraftAsTemplate(s ? (s.textContent || '').trim() : '', b ? (b.innerText || '').trim() : '');
  };
  window.mbxSaveLibCopy = function () {
    if (typeof currentElTmpl === 'undefined' || !currentElTmpl) { toast('Pick a template first'); return; }
    var subj = (typeof elGetCurrentSubject === 'function') ? elGetCurrentSubject() : '';
    var body = (typeof elGetCurrentBody === 'function') ? elGetCurrentBody() : '';
    saveDraftAsTemplate(subj, body);
  };

  /* ---------- tag suggestions on the Category field ---------- */
  function buildTagList() {
    var dl = document.getElementById('mbx-tpl-tags');
    if (!dl) { dl = document.createElement('datalist'); dl.id = 'mbx-tpl-tags'; document.body.appendChild(dl); }
    var seen = {}, opts = '';
    TAG_SUGGESTIONS.forEach(function (t) { seen[t.toLowerCase()] = 1; opts += '<option value="' + t + '">'; });
    (window.CUSTOM_TEMPLATES || []).forEach(function (t) {
      var c = (t.cat || '').trim();
      if (c && !seen[c.toLowerCase()]) { seen[c.toLowerCase()] = 1; opts += '<option value="' + esc(c).replace(/"/g, '&quot;') + '">'; }
    });
    dl.innerHTML = opts;
    var cat = document.getElementById('tm-cat');
    if (cat && !cat.getAttribute('list')) cat.setAttribute('list', 'mbx-tpl-tags');
  }

  /* ---------- rep's saved templates as one-tap chips in the Quick Composer ---------- */
  function renderChips() {
    var row = document.querySelector('.email-template-btns');
    if (!row) return;
    row.querySelectorAll('.mbx-mytpl-chip').forEach(function (n) { n.remove(); });
    (window.CUSTOM_TEMPLATES || []).forEach(function (t) {
      var b = document.createElement('button');
      b.className = 'etpl-btn mbx-mytpl-chip';
      b.innerHTML = '&#11088; ' + esc(t.title) +
        (t.cat ? ' <span style="opacity:.62;font-size:10.5px;font-weight:600;">\u00b7 ' + esc(t.cat) + '</span>' : '');
      b.title = (t.sub || 'Your saved template') + ' \u2014 tap to fill the composer';
      b.onclick = function () {
        var s = document.getElementById('email-subject'), bo = document.getElementById('email-body');
        if (s)  s.value  = merges(t.subject || '');
        if (bo) bo.value = merges(t.body || '');
        toast('Filled in \u2014 tweak it and send');
      };
      row.appendChild(b);
    });
  }

  /* ---------- inject the save buttons into all three composers ---------- */
  function injectButtons() {
    // 1) Quick Email Composer action row
    var send = document.querySelector('.email-composer .email-send-btn');
    if (send && !document.getElementById('mbx-qc-save')) {
      var b1 = document.createElement('button');
      b1.id = 'mbx-qc-save'; b1.className = 'clear-btn';
      b1.innerHTML = '&#128190; Save as My Template';
      b1.title = 'Save what you wrote as a reusable, tagged template';
      b1.onclick = window.mbxSaveQuickComposer;
      var copied = send.parentNode.querySelector('#email-copied');
      if (copied) send.parentNode.insertBefore(b1, copied); else send.parentNode.appendChild(b1);
    }
    // 2) Email Assembly Station output row
    var easRow = document.getElementById('m3-eas-send-row');
    if (easRow && !document.getElementById('mbx-eas-save')) {
      var b2 = document.createElement('button');
      b2.id = 'mbx-eas-save'; b2.className = 'eas-copy-btn';
      b2.innerHTML = '&#128190; Save as My Template';
      b2.title = 'Keep this email as a reusable, tagged template';
      b2.onclick = window.mbxSaveEas;
      easRow.appendChild(b2);
    }
    // 3) Email Library preview bar, next to Reset
    var resetBtn = document.querySelector('#el-preview .email-preview-bar .lib-hbtn');
    if (resetBtn && !document.getElementById('mbx-lib-save')) {
      var b3 = document.createElement('button');
      b3.id = 'mbx-lib-save'; b3.className = 'lib-hbtn';
      b3.innerHTML = '&#128190; Save as Mine';
      b3.title = 'Save this email \u2014 with your edits \u2014 as your own template';
      b3.onclick = window.mbxSaveLibCopy;
      resetBtn.parentNode.insertBefore(b3, resetBtn);
    }
  }

  /* ---------- keep chips + tag list fresh whenever templates change ---------- */
  var _save = window.saveCustomTemplates;
  if (typeof _save === 'function') {
    window.saveCustomTemplates = function () { _save(); renderChips(); buildTagList(); };
  }

  function boot() { injectButtons(); renderChips(); buildTagList(); }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else boot();
})();
</script>

<style id="mbx-tplmenu-css">
  .mbx-tpl-picker { position:relative; display:inline-block; }
  .mbx-tpl-menu {
    position:absolute; top:calc(100% + 6px); left:0; z-index:60;
    width:360px; max-width:90vw; max-height:62vh; overflow-y:auto;
    background:#fff; border:1px solid var(--gray-200,#e5e7eb); border-radius:12px;
    box-shadow:0 14px 40px rgba(15,40,80,.18); padding:6px;
  }
  .mbx-tpl-search {
    width:100%; box-sizing:border-box; border:1px solid var(--gray-200,#e5e7eb);
    border-radius:8px; padding:8px 10px; font-size:13px; font-family:'Inter',sans-serif;
    margin:2px 0 6px;
  }
  .mbx-tpl-group {
    font-size:10.5px; font-weight:800; letter-spacing:.05em; text-transform:uppercase;
    color:var(--blue-dark,#0C447C); padding:9px 10px 4px; position:sticky; top:0; background:#fff;
  }
  .mbx-tpl-item {
    display:block; width:100%; text-align:left; border:0; background:transparent;
    border-radius:8px; padding:8px 10px; cursor:pointer; font-family:'Inter',sans-serif;
  }
  .mbx-tpl-item:hover { background:var(--sel-wash,#eef2f6); }
  .mbx-tpl-item-t { font-size:13px; font-weight:600; color:#1f2937; }
  .mbx-tpl-item-s { font-size:11px; color:var(--gray-600,#6b7280); margin-top:1px; }
  .mbx-tpl-item-row { display:flex; align-items:stretch; border-radius:8px; }
  .mbx-tpl-item-row:hover { background:var(--sel-wash,#eef2f6); }
  .mbx-tpl-item-row .mbx-tpl-item { flex:1 1 auto; min-width:0; }
  .mbx-tpl-item-row .mbx-tpl-item:hover { background:transparent; }
  .mbx-tpl-actions { display:flex; align-items:center; gap:2px; padding-right:6px; flex:0 0 auto; }
  .mbx-tpl-act { border:0; background:transparent; cursor:pointer; font-size:15px; padding:4px 7px; border-radius:6px; line-height:1; }
  .mbx-tpl-act:hover { background:#dbe4ff; }
  .mbx-tpl-act.del:hover { background:#fee2e2; }
  .mbx-tpl-empty { padding:14px 12px; font-size:12.5px; color:var(--gray-600,#6b7280); text-align:center; }
</style>
<script id="mbx-tplmenu">
/* ============================================================
   MBX-TPLMENU — one "Choose a template" picker in the Quick
   Email Composer that surfaces EVERY template the rep could
   use: their own saved ones (with edit/delete), the quick
   built-ins, and the full Email Library.
   Click/tap to open (no finicky hover-close). Append-only.
   ============================================================ */
(function () {
  function esc(s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
  function merges(s) { return (typeof applyProfileMerges === 'function') ? applyProfileMerges(s || '') : (s || ''); }
  function toast(m) { if (typeof elToast === 'function') elToast(m); }

  var QUICK_ORDER = [
    ['intro',           'Cold intro \u2014 complete PFTs'],
    ['followup',        'Post-demo thank-you'],
    ['cardio_intro',    'Cardiology \u2014 cold intro'],
    ['cardio_followup', 'Cardiology \u2014 post-demo one-pager'],
    ['training',        'Training confirmation'],
    ['ach',             'ACH payment authorization'],
    ['service',         'Service request']
  ];

  var MENU_ITEMS = [];

  function collect() {
    var groups = [];
    var mine = (window.CUSTOM_TEMPLATES || []);
    if (mine.length) {
      groups.push({ label: '\u2b50 My Templates', items: mine.map(function (t) {
        return { id: t.id, custom: true, title: t.title || '(untitled)', sub: t.cat || t.sub || 'Your saved template', subject: t.subject, body: t.body };
      }) });
    }
    if (typeof EMAIL_TEMPLATES !== 'undefined') {
      var q = [];
      QUICK_ORDER.forEach(function (pair) {
        var t = EMAIL_TEMPLATES[pair[0]];
        if (t) q.push({ title: pair[1], sub: t.subject, subject: t.subject, body: t.body });
      });
      if (q.length) groups.push({ label: '\u26a1 Quick Templates', items: q });
    }
    if (typeof EL_TEMPLATES !== 'undefined' && EL_TEMPLATES.length) {
      groups.push({ label: '\ud83d\udcda Email Library', items: EL_TEMPLATES.map(function (t) {
        return { title: t.title, sub: (t.cat ? t.cat + ' \u00b7 ' : '') + (t.sub || ''), subject: t.subject, body: t.body };
      }) });
    }
    return groups;
  }

  function render(filter) {
    var menu = document.getElementById('mbx-tpl-menu');
    if (!menu) return;
    MENU_ITEMS = [];
    var groups = collect();
    var f = (filter || '').trim().toLowerCase();
    var html = '<input class="mbx-tpl-search" id="mbx-tpl-search" type="text" placeholder="\ud83d\udd0d Search templates\u2026" oninput="mbxTplFilter(this.value)">';
    var shown = 0;
    groups.forEach(function (g) {
      var items = g.items.filter(function (it) {
        if (!f) return true;
        return ((it.title || '') + ' ' + (it.sub || '') + ' ' + (it.subject || '')).toLowerCase().indexOf(f) > -1;
      });
      if (!items.length) return;
      html += '<div class="mbx-tpl-group">' + esc(g.label) + '</div>';
      items.forEach(function (it) {
        var idx = MENU_ITEMS.push(it) - 1;
        var main = '<button class="mbx-tpl-item" onclick="mbxTplPick(' + idx + ')">' +
                     '<div class="mbx-tpl-item-t">' + esc(it.title) + '</div>' +
                     (it.sub ? '<div class="mbx-tpl-item-s">' + esc(it.sub) + '</div>' : '') +
                   '</button>';
        if (it.custom) {
          html += '<div class="mbx-tpl-item-row">' + main +
                    '<div class="mbx-tpl-actions">' +
                      '<button class="mbx-tpl-act" title="Edit this template" onclick="mbxTplEdit(\'' + it.id + '\')">&#9998;</button>' +
                      '<button class="mbx-tpl-act del" title="Delete this template" onclick="mbxTplDelete(\'' + it.id + '\')">&#128465;</button>' +
                    '</div>' +
                  '</div>';
        } else {
          html += main;
        }
        shown++;
      });
    });
    if (!shown) html += '<div class="mbx-tpl-empty">No templates match \u201c' + esc(filter) + '\u201d</div>';
    menu.innerHTML = html;
  }

  window.mbxTplFilter = function (v) {
    var box = document.getElementById('mbx-tpl-search');
    var pos = box ? box.selectionStart : null;
    render(v);
    var again = document.getElementById('mbx-tpl-search');
    if (again) { again.value = v; try { again.focus(); if (pos != null) again.setSelectionRange(pos, pos); } catch (e) {} }
  };

  window.mbxTplPick = function (idx) {
    var it = MENU_ITEMS[idx];
    if (!it) return;
    var sub = document.getElementById('email-subject'), b = document.getElementById('email-body');
    if (sub) sub.value = merges(it.subject || '');
    if (b) b.value = merges(it.body || '');
    closeMenu();
    toast('Filled in \u2014 tweak it and send');
    if (b) { try { b.focus(); b.setSelectionRange(0, 0); } catch (e) {} }
  };

  window.mbxTplEdit = function (id) {
    closeMenu();
    if (typeof openTemplateEditor === 'function') openTemplateEditor(id);
  };

  window.mbxTplDelete = function (id) {
    var list = (window.CUSTOM_TEMPLATES || []);
    var t = list.filter(function (x) { return x.id === id; })[0];
    if (!confirm('Delete \u201c' + (t ? t.title : 'this template') + '\u201d? This cannot be undone.')) return;
    window.CUSTOM_TEMPLATES = list.filter(function (x) { return x.id !== id; });
    if (typeof saveCustomTemplates === 'function') saveCustomTemplates(); /* wrapped: refreshes chips + tags */
    if (typeof renderElList === 'function') { try { renderElList(); } catch (e) {} }
    render('');
    toast('Template deleted');
  };

  function openMenu()  { var m = document.getElementById('mbx-tpl-menu'); if (m) { render(''); m.style.display = 'block'; var sb = document.getElementById('mbx-tpl-search'); if (sb) try { sb.focus(); } catch (e) {} } }
  function closeMenu() { var m = document.getElementById('mbx-tpl-menu'); if (m) m.style.display = 'none'; }
  function toggleMenu(){ var m = document.getElementById('mbx-tpl-menu'); if (!m) return; (m.style.display === 'block') ? closeMenu() : openMenu(); }
  window.mbxTplCloseMenu = closeMenu;

  function build() {
    var row = document.querySelector('.email-template-btns');
    if (!row || document.querySelector('.mbx-tpl-picker')) return;

    Array.prototype.forEach.call(row.querySelectorAll('.etpl-btn'), function (btn) {
      if (!btn.classList.contains('mbx-mytpl-chip') && !btn.classList.contains('mbx-tpl-picker-btn')) {
        btn.style.display = 'none';
      }
    });

    var wrap = document.createElement('div');
    wrap.className = 'mbx-tpl-picker';
    var btn = document.createElement('button');
    btn.className = 'etpl-btn mbx-tpl-picker-btn';
    btn.innerHTML = '\ud83d\udccb Choose a template &#9662;';
    btn.title = 'Browse every template \u2014 your saved ones, the quick built-ins, and the full Email Library';
    btn.onclick = function (e) { e.stopPropagation(); toggleMenu(); };
    var menu = document.createElement('div');
    menu.className = 'mbx-tpl-menu';
    menu.id = 'mbx-tpl-menu';
    menu.onclick = function (e) { e.stopPropagation(); };
    wrap.appendChild(btn);
    wrap.appendChild(menu);
    row.insertBefore(wrap, row.firstChild);

    /* Click/tap only \u2014 no hover open/close (that made the menu vanish
       when the pointer moved from the button down into the wider menu). */
    document.addEventListener('click', function (e) { if (!wrap.contains(e.target)) closeMenu(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeMenu(); });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', build);
  else build();
})();
</script>

<!-- ============ mbx-facelift (2026-07-18): "Report Studio" masthead. ============
     Append-only CSS override — no tab ids, handlers, or layout markup touched.
     Design language borrowed from the PFT Report Studio: clean paper masthead,
     mono kicker, big tight navy title, hero search, deep-navy sticky nav with a
     teal active underline. Remove this one block to restore the old dark header. -->
<style id="mbx-facelift">
  :root {
    --fl-navy: #0b1f33;
    --fl-navy-deep: #071627;
    --fl-teal: #0e9f8a;
    --fl-teal-bright: #12c9ae;
    --fl-paper: #f7f9fb;
    --fl-ink: #152534;
    --fl-muted: #5b6b7a;
    --fl-line: #e2e8ee;
    --fl-amber: #c77b1e;
  }

  body { background: var(--fl-paper); }

  /* ---- masthead: slim top bar (logo | badges), hero text left-aligned below ---- */
  .site-header { background: var(--fl-paper); }
  .header-inner { display: block; padding: 20px 32px 0; }
  .fl-topbar { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-bottom: 34px; }
  .fl-topbar .tk-logo { height: 40px; width: auto; display: block; background: #fff; padding: 6px 10px; border: 1px solid var(--fl-line); border-radius: 10px; box-shadow: 0 1px 3px rgba(11,31,51,.06); }
  .header-badges { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; padding-bottom: 0; }
  .fl-hero { max-width: 780px; }
  .header-brand {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 11px; font-weight: 500;
    letter-spacing: .18em; text-transform: uppercase;
    color: var(--fl-teal); margin-bottom: 10px;
  }
  .header-title {
    color: var(--fl-navy);
    font-size: clamp(28px, 3.6vw, 40px);
    font-weight: 800; letter-spacing: -.03em; line-height: 1.08;
  }
  .header-sub { color: var(--fl-muted); font-size: 14px; line-height: 1.55; margin-top: 10px; max-width: 66ch; }

  /* badges -> mono outline pills */
  .hbadge {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 10.5px; font-weight: 500;
    letter-spacing: .1em; text-transform: uppercase;
    background: #fff; border: 1px solid var(--fl-line);
    color: var(--fl-muted); border-radius: 999px; padding: 6px 14px;
  }
  .hbadge-profile { background: #fff; border-color: var(--fl-teal); color: var(--fl-teal); }
  .hbadge-profile:hover { background: rgba(18,201,174,.08); border-color: var(--fl-teal); }
  .hbadge-profile.set { background: var(--fl-teal); border-color: var(--fl-teal); color: #fff; }
  #m3-env-badge { color: var(--fl-amber); border-color: currentColor; background: #fff; }
  #m3-env-badge:empty { display: none; }

  /* ---- hero search ---- */
  .global-search-bar { position: relative; z-index: 600; background: var(--fl-paper); padding: 18px 32px 26px; max-width: 1100px; margin: 0 auto; }
  #global-search {
    height: 54px; background: #fff; color: var(--fl-ink);
    border: 1px solid var(--fl-line); border-radius: 14px; padding: 0 20px;
    font-size: 15px; box-shadow: 0 10px 30px rgba(11,31,51,.06);
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  #global-search::placeholder { color: #8fa0af; }
  #global-search:focus {
    background: #fff; border-color: var(--fl-teal-bright);
    box-shadow: 0 0 0 4px rgba(18,201,174,.14), 0 10px 30px rgba(11,31,51,.08);
  }
  #global-search-results { top: 80px; border-radius: 14px; }

  /* ---- nav: deep studio navy, sticky, teal underline ---- */
  .tab-bar {
    background: var(--fl-navy);
    position: sticky; top: 0; z-index: 500;
    box-shadow: 0 8px 24px rgba(7,22,39,.16);
  }
  /* wider rail + tighter buttons so the whole nav fits ONE row on desktop
     (a lone wrapped orphan button looks broken) */
  .tab-bar-inner { max-width: 1280px; padding: 0 16px; }
  .tab-row > .tab-btn, .tab-row .tab-dd-parent { padding: 13px 10px; font-size: 11px; }
  .tab-row:first-child { border-bottom: 0; }
  .tab-btn.active { border-bottom-color: var(--fl-teal-bright); background: rgba(255,255,255,.07); }
  .tab-dd-menu { background: var(--fl-navy-deep); border-radius: 0 0 14px 14px; }
  .tab-dd-menu .tab-btn.active { border-left-color: var(--fl-teal-bright); }

  /* ---- Daily Hub hero ---- */
  .hub-hero-kicker {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 11px; font-weight: 500;
    letter-spacing: .18em; text-transform: uppercase;
    color: var(--fl-teal); margin-bottom: 8px;
  }
  #tab-hub .hub-hero .section-title { font-size: 30px; font-weight: 800; letter-spacing: -.02em; color: var(--fl-navy); }
  #tab-hub .hub-hero .section-sub { font-size: 14px; }

  @media (max-width: 720px) {
    .header-inner { padding: 14px 18px 0; }
    .fl-topbar { margin-bottom: 20px; }
    .fl-topbar .tk-logo { height: 34px; }
    .global-search-bar { padding: 14px 18px 20px; }
    #global-search { height: 48px; font-size: 14px; }
    #global-search-results { width: calc(100% - 36px); top: 68px; }
  }
</style>
<style id="mbx-katana">
/* ===== KATANA THEME (chrome only; delete this block to revert) ===== */
@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600&display=swap');
:root{
  --k-g0:#07090b; --k-g1:#0c0f13; --k-g2:#12161b;
  --k-line:#2a323b; --k-line2:#39434e;
  --k-silver:#c9d2db; --k-bright:#f2f5f8; --k-mute:#7b8590; --k-blade:#9fd4e8;
}
.site-header{ background:linear-gradient(180deg,var(--k-g2),var(--k-g0)) !important; position:relative; border-bottom:1px solid var(--k-line); }
.site-header::before{ content:""; position:absolute; top:0; left:0; right:0; height:1px; z-index:1; background:linear-gradient(90deg,transparent,rgba(210,228,240,.9) 50%,transparent); }
.site-header::after{ content:""; position:absolute; inset:0; z-index:0; pointer-events:none; opacity:.5; background:repeating-linear-gradient(115deg,rgba(255,255,255,.014) 0,rgba(255,255,255,.014) 1px,transparent 1px,transparent 5px); }
.header-inner, .tab-bar{ position:relative; z-index:2; }
/* search bar must outrank the nav rail, or the dropdown results hide behind it */
.global-search-bar{ position:relative; z-index:600; }
.header-brand{ color:var(--k-mute) !important; font-family:'DM Mono',monospace !important; letter-spacing:.26em !important; }
.header-title{ font-family:'Oswald',sans-serif !important; font-weight:500 !important; text-transform:uppercase; letter-spacing:.02em; font-size:34px !important; background:linear-gradient(180deg,#ffffff,#b9c4ce); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; }
.header-sub{ color:#96a1ac !important; }
.hbadge{ background:linear-gradient(160deg,#1a2027,#0a0d11) !important; border:1px solid var(--k-line2) !important; color:var(--k-silver) !important; font-family:'DM Mono',monospace !important; letter-spacing:.08em; font-size:10.5px !important; }
.global-search-bar{ background:transparent !important; }
#global-search{ background:var(--k-g0) !important; border:1px solid var(--k-line) !important; color:var(--k-bright) !important; border-radius:0 !important; font-family:'DM Mono',monospace !important; letter-spacing:.03em; height:46px !important; }
#global-search::placeholder{ color:#5c6672 !important; }
#global-search:focus{ border-color:var(--k-blade) !important; background:var(--k-g0) !important; box-shadow:0 0 0 1px rgba(159,212,232,.35),0 0 22px -6px rgba(159,212,232,.5) !important; }
.tab-bar{ background:var(--k-g0) !important; border-top:1px solid var(--k-line); }
.tab-row:first-child{ border-bottom:1px solid var(--k-line) !important; }
.tab-btn{ font-weight:500 !important; letter-spacing:.15em !important; text-transform:uppercase; font-size:11px !important; border-bottom:2px solid transparent !important; }
.tab-btn:hover{ color:var(--k-bright) !important; background:rgba(255,255,255,.03) !important; }
.tab-btn.active{ color:#ffffff !important; background:transparent !important; border-bottom-color:transparent !important; position:relative; }
.tab-bar .tab-btn.active::after{ content:""; position:absolute; left:10px; right:10px; bottom:-1px; height:2px; background:linear-gradient(90deg,transparent,var(--k-blade) 22%,#eaf6fb 50%,var(--k-blade) 78%,transparent); box-shadow:0 0 10px -1px rgba(159,212,232,.8); }
.tab-dd-caret{ color:var(--k-mute) !important; }
.tab-dd-menu{ background:var(--k-g1) !important; border-color:var(--k-line2) !important; }
.tab-dd-menu .tab-btn{ color:var(--k-silver) !important; text-align:left; letter-spacing:.08em !important; }
.tab-dd-menu .tab-btn:hover{ color:#ffffff !important; }
.tab-dd-menu .tab-btn.active{ border-left-color:var(--k-blade) !important; }
</style>
<style id="mbx-display">
/* ===== DISPLAY / THEME SWITCHER (delete this block + #mbx-display-js to revert) ===== */

/* The theme filter goes on <html>. Verified: a filter on <body> turns body into the
   containing block for position:fixed, which breaks every modal/toast in this file.
   On <html> it does not. Do not move this to body. */
html[data-mbx-theme="night"]   { filter:invert(1) hue-rotate(180deg); background:#ffffff; }
html[data-mbx-theme="dusk"]    { filter:brightness(.90) contrast(.95) saturate(.88); }
html[data-mbx-theme="paper"]   { filter:sepia(.42) saturate(.80) contrast(.97); }
html[data-mbx-theme="calm"]    { filter:saturate(.42) contrast(.93); }
html[data-mbx-theme="contrast"]{ filter:contrast(1.30) saturate(1.15); }

/* Night: things that must NOT come out inverted get flipped back. */
html[data-mbx-theme="night"] img,
html[data-mbx-theme="night"] video,
html[data-mbx-theme="night"] canvas,
html[data-mbx-theme="night"] iframe,
html[data-mbx-theme="night"] .site-header,
html[data-mbx-theme="night"] #mbx-display-panel,
html[data-mbx-theme="night"] #rhc-toast,
html[data-mbx-theme="night"] #el-toast,
html[data-mbx-theme="night"] #roi-fullscreen,
html[data-mbx-theme="night"] #profile-modal,
html[data-mbx-theme="night"] #tpl-modal,
html[data-mbx-theme="night"] #sh-modal,
html[data-mbx-theme="night"] #as-modal,
html[data-mbx-theme="night"] #m3-welcome,
html[data-mbx-theme="night"] #mbx-boxy-fab,
html[data-mbx-theme="night"] body > div[style*="position:fixed"]{ filter:invert(1) hue-rotate(180deg); }
/* double-flip guard: media already re-inverted by an ancestor above */
html[data-mbx-theme="night"] .site-header img,
html[data-mbx-theme="night"] #mbx-display-panel img,
html[data-mbx-theme="night"] body > div[style*="position:fixed"] img,
html[data-mbx-theme="night"] #m3-welcome img,
html[data-mbx-theme="night"] #mbx-boxy-fab img{ filter:none; }

/* ---- the Display badge ---- */
#mbx-display-btn{ cursor:pointer; }
#mbx-display-btn .mbx-dot{ display:inline-block; width:9px; height:9px; border-radius:50%; margin-right:7px;
  background:linear-gradient(90deg,#f2f5f8 0 50%,#0c0f13 50% 100%); border:1px solid #6d7883; vertical-align:-1px; }

/* ---- the panel ---- */
#mbx-display-panel{
  display:none; position:fixed; z-index:100000; width:272px; padding:14px;
  background:linear-gradient(180deg,#12161b,#07090b); border:1px solid #39434e;
  box-shadow:0 24px 60px -18px rgba(0,0,0,.85), 0 0 0 1px rgba(159,212,232,.10);
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;
}
#mbx-display-panel.open{ display:block; }
#mbx-display-panel::before{ content:""; position:absolute; top:0; left:0; right:0; height:1px;
  background:linear-gradient(90deg,transparent,rgba(210,228,240,.85) 50%,transparent); }
.mbx-dp-head{ font-family:'DM Mono',ui-monospace,monospace; font-size:9.5px; letter-spacing:.26em;
  text-transform:uppercase; color:#7b8590; margin:2px 0 11px; }
.mbx-dp-grid{ display:grid; grid-template-columns:1fr 1fr; gap:7px; }
.mbx-dp-opt{
  display:flex; align-items:center; gap:8px; padding:9px 10px; cursor:pointer; text-align:left;
  background:#0c0f13; border:1px solid #2a323b; color:#c9d2db;
  font-family:'DM Mono',ui-monospace,monospace; font-size:10.5px; letter-spacing:.09em; text-transform:uppercase;
  transition:border-color .15s, color .15s, background .15s;
}
.mbx-dp-opt:hover{ color:#ffffff; border-color:#5b6874; background:#151a20; }
.mbx-dp-opt[aria-pressed="true"]{ color:#ffffff; border-color:#9fd4e8;
  box-shadow:inset 0 -2px 0 -0px rgba(159,212,232,.9), 0 0 18px -8px rgba(159,212,232,.9); }
.mbx-dp-sw{ width:18px; height:18px; flex:0 0 18px; border:1px solid #4a545f; border-radius:2px; }
.mbx-dp-note{ margin-top:11px; padding-top:10px; border-top:1px solid #2a323b;
  font-size:10.5px; line-height:1.45; color:#7b8590; }
.mbx-dp-note kbd{ font-family:'DM Mono',ui-monospace,monospace; font-size:9.5px; color:#c9d2db;
  border:1px solid #39434e; padding:1px 4px; }
/* 272px fits every real phone (360px+), so no vw-based shrink rule — a 100vw
   calc collapses the panel in embedded/headless viewports that report 0 width. */
</style>
<script id="mbx-display-js">
(function(){
  var THEMES = [
    { id:'katana',   label:'Katana',   sw:'linear-gradient(135deg,#f4f7fa 50%,#12161b 50%)', hint:'Bright workspace.' },
    { id:'night',    label:'Night',    sw:'linear-gradient(135deg,#12161b,#243039)',         hint:'True dark, easiest on the eyes.' },
    { id:'dusk',     label:'Dusk',     sw:'linear-gradient(135deg,#c9cfd6,#8d959d)',         hint:'Dimmed, not dark. Cuts screen glare.' },
    { id:'paper',    label:'Paper',    sw:'linear-gradient(135deg,#f3e6cd,#d9c49b)',         hint:'Warm, low blue light.' },
    { id:'calm',     label:'Calm',     sw:'linear-gradient(135deg,#e8eaec,#b9bec3)',         hint:'Muted color. Low stimulation.' },
    { id:'contrast', label:'Contrast', sw:'linear-gradient(135deg,#ffffff 50%,#000000 50%)', hint:'Default. Sharper edges, easier to read.' }
  ];
  /* v3 key: Contrast is now the default (Night was too dark for some reps).
     Bumping the key is how everyone gets moved to the new default once —
     the key is written ONLY on an explicit pick, never on load. */
  var KEY = 'mbx_display_theme_v3';

  function apply(id, save){
    var t = THEMES.filter(function(x){ return x.id===id; })[0] ? id : 'contrast';
    if(t==='katana') document.documentElement.removeAttribute('data-mbx-theme');
    else document.documentElement.setAttribute('data-mbx-theme', t);
    if(save) try{ localStorage.setItem(KEY, t); }catch(e){}
    var panel = document.getElementById('mbx-display-panel');
    if(panel) Array.prototype.forEach.call(panel.querySelectorAll('.mbx-dp-opt'), function(b){
      b.setAttribute('aria-pressed', String(b.dataset.theme===t));
    });
    var lbl = document.getElementById('mbx-display-lbl');
    if(lbl) lbl.textContent = THEMES.filter(function(x){ return x.id===t; })[0].label;
  }

  function saved(){ try{ return localStorage.getItem(KEY) || 'contrast'; }catch(e){ return 'contrast'; } }

  function buildPanel(){
    var p = document.createElement('div');
    p.id = 'mbx-display-panel';
    p.setAttribute('role','dialog');
    p.setAttribute('aria-label','Display settings');
    var html = '<div class="mbx-dp-head">Display &mdash; pick what your eyes like</div><div class="mbx-dp-grid">';
    THEMES.forEach(function(t){
      html += '<button type="button" class="mbx-dp-opt" data-theme="'+t.id+'" title="'+t.hint+'" aria-pressed="false">'
           +  '<span class="mbx-dp-sw" style="background:'+t.sw+'"></span>'+t.label+'</button>';
    });
    html += '</div><div class="mbx-dp-note" id="mbx-dp-hint" data-mbx-tip="dayplan-reopen">Saved on this device. Reopen with <kbd>Alt</kbd> + <kbd>D</kbd>.</div>';
    p.innerHTML = html;
    document.body.appendChild(p);

    p.addEventListener('click', function(e){
      var b = e.target.closest ? e.target.closest('.mbx-dp-opt') : null;
      if(!b) return;
      apply(b.dataset.theme, true);
      var t = THEMES.filter(function(x){ return x.id===b.dataset.theme; })[0];
      document.getElementById('mbx-dp-hint').innerHTML = t.hint + ' Saved on this device.';
    });
    p.addEventListener('mouseover', function(e){
      var b = e.target.closest ? e.target.closest('.mbx-dp-opt') : null;
      if(!b) return;
      var t = THEMES.filter(function(x){ return x.id===b.dataset.theme; })[0];
      document.getElementById('mbx-dp-hint').textContent = t.hint;
    });
    return p;
  }

  function position(){
    var btn = document.getElementById('mbx-display-btn');
    var p = document.getElementById('mbx-display-panel');
    if(!btn || !p) return;
    var r = btn.getBoundingClientRect();
    var w = p.offsetWidth || 272;
    var left = Math.min(Math.max(8, r.right - w), (window.innerWidth||1024) - w - 8);
    p.style.left = left + 'px';
    p.style.top  = (r.bottom + 8) + 'px';
  }

  function toggle(force){
    var p = document.getElementById('mbx-display-panel') || buildPanel();
    var open = (typeof force === 'boolean') ? force : !p.classList.contains('open');
    p.classList.toggle('open', open);
    if(open){ apply(saved()); position(); }
  }

  function mount(){
    apply(saved());                                  // theme first, before paint work
    var host = document.querySelector('.header-badges');
    if(!host || document.getElementById('mbx-display-btn')) return;
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.id = 'mbx-display-btn';
    btn.className = 'hbadge';
    btn.title = 'Change how the toolkit looks — dark mode and easier-on-the-eyes skins';
    btn.innerHTML = '<span class="mbx-dot"></span>Display: <span id="mbx-display-lbl">Night</span>';
    btn.addEventListener('click', function(e){ e.stopPropagation(); toggle(); });
    host.appendChild(btn);
    apply(saved());                                  // refresh the badge label
  }

  document.addEventListener('click', function(e){
    var p = document.getElementById('mbx-display-panel');
    if(p && p.classList.contains('open') && !p.contains(e.target)) toggle(false);
  });
  document.addEventListener('keydown', function(e){
    if(e.altKey && (e.key === 'd' || e.key === 'D')){ e.preventDefault(); toggle(); }
    if(e.key === 'Escape') toggle(false);
  });
  window.addEventListener('resize', function(){
    var p = document.getElementById('mbx-display-panel');
    if(p && p.classList.contains('open')) position();
  });

  // theme as early as possible, badge once the header exists
  apply(saved());
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', mount);
  else mount();
})();
</script>


<!-- ══════════════════════════════════════════════════════════════════════════
     FOCUS LINK  (v3.25) —  ...?only=rheum
     One link Erik can hand out that opens the toolkit, plays the full ignition
     intro, and then leaves the visitor with exactly ONE door: Rheumatology.
     Every other tab is pulled out of the nav, showTab() refuses any other
     panel, and a gate screen sits where the Daily Hub would be until they
     click through. Auto-opens after 10s so nobody ever stalls on the gate.
     Works with the existing share params: ?only=rheum&view=training&spot=...
     Sticks for the session (sessionStorage) so a refresh stays locked.
     Revert = delete this block. Nothing else depends on it.
     ══════════════════════════════════════════════════════════════════════════ -->
<style id="mbx-focus-css">
  /* The whole toolkit stays on the board — you can see every section, read every
     name, open every menu. Only the one live door actually opens. Wanting more is
     the point; dimming (not hiding) is what creates it. */
  body.mbx-focus .mbx-locked{ opacity:.34; cursor:not-allowed; position:relative; }
  body.mbx-focus .mbx-locked:hover{ opacity:.5; }
  /* Hairline hover flag — mono type, no fills, no emoji (house rules). */
  body.mbx-focus .mbx-locked:hover:after{
    content:"In build"; position:absolute; left:50%; top:100%; transform:translateX(-50%);
    margin-top:3px; white-space:nowrap; z-index:30;
    font-family:'DM Mono', ui-monospace, monospace; font-size:9px; font-weight:500;
    letter-spacing:.18em; text-transform:uppercase; color:#eaf6fb;
    background:rgba(10,20,26,.94); border:1px solid rgba(159,212,232,.3);
    border-radius:2px; padding:3px 8px; pointer-events:none;
  }
  body.mbx-focus .tab-dd-menu .mbx-locked:hover:after{ left:auto; right:8px; top:50%; margin-top:-9px; transform:none; }
  /* The one live door reads brighter than everything around it. */
  body.mbx-focus .mbx-focus-btn{ opacity:1 !important; }
  /* Don't broadcast the team's unread chat count to an outside visitor. */
  body.mbx-focus #mbx-chat-badge{ display:none !important; }

  @keyframes mbxFocusPulse{
    0%,100% { text-shadow:0 0 0 rgba(159,212,232,0); background:transparent; }
    50%     { text-shadow:0 0 13px rgba(159,212,232,.95); background:rgba(255,255,255,.07); }
  }
  body.mbx-focus .mbx-focus-btn.pulse{ animation:mbxFocusPulse 1.6s ease-in-out infinite; }

  #mbx-focus-gate{ max-width:640px; margin:8vh auto 0; text-align:center; padding:0 20px; }
  #mbx-focus-gate .fg-kicker{
    font-family:'DM Mono', ui-monospace, monospace;
    font-size:11px; font-weight:500; letter-spacing:.34em; text-transform:uppercase;
    color:#96a1ac; margin-bottom:18px;
  }
  #mbx-focus-gate .fg-title{
    font-family:'Oswald', sans-serif; font-weight:500; text-transform:uppercase;
    letter-spacing:.03em; font-size:clamp(28px,5vw,46px); line-height:1.1; margin:0 0 14px;
  }
  #mbx-focus-gate .fg-sub{ font-size:14px; line-height:1.65; color:#6b7784; margin:0 auto 26px; max-width:440px; }
  #mbx-focus-gate .fg-cta{
    display:inline-block; cursor:pointer; border:1px solid #0d8aa6; background:transparent;
    color:inherit; border-radius:2px; padding:13px 30px;
    font-family:'DM Mono', ui-monospace, monospace;
    font-size:12px; font-weight:500; letter-spacing:.2em; text-transform:uppercase;
    transition:background 180ms ease, box-shadow 180ms ease;
  }
  #mbx-focus-gate .fg-cta:hover{ background:rgba(13,138,166,.10); }
  #mbx-focus-gate .fg-cta.pulse{ animation:mbxFocusCta 1.6s ease-in-out infinite; }
  @keyframes mbxFocusCta{
    0%,100% { box-shadow:0 0 0 0 rgba(13,138,166,.45); }
    50%     { box-shadow:0 0 0 8px rgba(13,138,166,0); }
  }
  #mbx-focus-gate .fg-note{
    margin-top:34px; font-family:'DM Mono', ui-monospace, monospace;
    font-size:10px; letter-spacing:.16em; text-transform:uppercase; color:#96a1ac;
  }
  #mbx-focus-toast{
    position:fixed; left:50%; bottom:26px; transform:translateX(-50%) translateY(8px);
    background:rgba(10,20,26,.94); color:#eaf6fb; border:1px solid rgba(159,212,232,.35);
    border-radius:3px; padding:10px 18px; z-index:9999; opacity:0; pointer-events:none;
    font-family:'DM Mono', ui-monospace, monospace; font-size:11px; letter-spacing:.12em;
    text-transform:uppercase; transition:opacity 220ms ease, transform 220ms ease;
  }
  #mbx-focus-toast.on{ opacity:1; transform:translateX(-50%) translateY(0); }
</style>
<script>
(function () {
  var qs = new URLSearchParams(location.search);
  var only = (qs.get('only') || '').toLowerCase().trim();
  try {
    if (only) sessionStorage.setItem('mbxOnly', only);
    else only = (sessionStorage.getItem('mbxOnly') || '').toLowerCase().trim();
  } catch (e) {}
  if (!only) return;

  var LABEL = { rheum:'Rheumatology', pulmo:'Pulmonology', allergy:'Allergy / Immunology',
                cardio:'Cardiology', intmed:'Internal Medicine', reimbursement:'CPT & Revenue' };
  var AUTO_OPEN_MS = 10000;

  function toast(msg) {
    var t = document.getElementById('mbx-focus-toast');
    if (!t) { t = document.createElement('div'); t.id = 'mbx-focus-toast'; document.body.appendChild(t); }
    t.textContent = msg;
    t.classList.add('on');
    clearTimeout(t._x);
    t._x = setTimeout(function () { t.classList.remove('on'); }, 2600);
  }

  function setup() {
    var row = document.querySelector('.tab-row');
    var panel = document.getElementById('tab-' + only);
    if (!row || !panel) return;               // unknown id: link degrades to the normal toolkit

    document.body.classList.add('mbx-focus');

    /* The real (hidden) nav button for this tab — reused so showTab's dropdown
       bookkeeping and the .active state behave exactly as they always have. */
    var real = null;
    [].slice.call(row.querySelectorAll('.tab-btn')).forEach(function (b) {
      if ((b.getAttribute('onclick') || '').indexOf("showTab('" + only + "'") !== -1) real = b;
    });

    /* Promote it to a top-level tab so it survives the nav cull. */
    var doorLabel = LABEL[only] || (real ? real.textContent.trim() : only);
    var door = document.createElement('button');
    door.className = 'tab-btn mbx-focus-btn';
    door.type = 'button';
    door.textContent = doorLabel;
    door.addEventListener('click', enter);
    row.insertBefore(door, row.firstChild);

    /* Dim every other destination — visible, readable, openable menus, dead click.
       Dropdown parents stay live so people can browse what's coming. */
    function markLocks() {
      document.querySelectorAll('.tab-bar .tab-btn').forEach(function (b) {
        if (b === door || b === real || b.classList.contains('tab-dd-parent')) return;
        b.classList.add('mbx-locked');
      });
    }
    markLocks();

    /* Capture-phase gate: swallow the click before any onclick can fire. */
    var bar = document.querySelector('.tab-bar');
    if (bar) bar.addEventListener('click', function (e) {
      var b = e.target.closest ? e.target.closest('.tab-btn') : null;
      if (!b || !b.classList.contains('mbx-locked')) return;
      e.preventDefault();
      e.stopPropagation();
      toast(b.textContent.trim().replace(/\s+/g,' ') + ' — in build');
    }, true);

    /* Lock every other panel. Cross-links and global search hits land here too. */
    var realShowTab = window.showTab;
    window.showTab = function (id, btn) {
      if (id !== only) { toast('In build — ' + doorLabel + ' is open today'); return; }
      hideGate();
      return realShowTab.apply(this, arguments);
    };

    /* Gate screen where the Daily Hub would have been. */
    var hub = document.getElementById('tab-hub');
    if (hub) hub.classList.remove('active');
    document.querySelectorAll('.tab-panel.active').forEach(function (p) { p.classList.remove('active'); });

    var gate = document.createElement('div');
    gate.className = 'tab-panel active';
    gate.id = 'tab-mbxfocus';
    gate.innerHTML =
      '<div id="mbx-focus-gate">' +
        '<div class="fg-kicker">PulmOne &mdash; Field Reference</div>' +
        '<h1 class="fg-title">' + doorLabel + '</h1>' +
        '<p class="fg-sub">You&rsquo;re looking at the whole MiniBox+ toolkit &mdash; every ' +
          'section above is real. ' + doorLabel + ' is the one that&rsquo;s open today. ' +
          'The rest unlock as each is finished.</p>' +
        '<button type="button" class="fg-cta">Open ' + doorLabel + ' &rarr;</button>' +
        '<div class="fg-note">MiniBox+ Master Toolkit</div>' +
      '</div>';
    var wrap = document.querySelector('.content-wrap') || document.body;
    wrap.insertBefore(gate, wrap.firstChild);
    gate.querySelector('.fg-cta').addEventListener('click', enter);

    /* Start the invitation once the ignition intro has finished landing. */
    var armed = false;
    (function arm() {
      if (document.body.classList.contains('mbx-igniting')) return setTimeout(arm, 250);
      if (armed) return;
      armed = true;
      door.classList.add('pulse');
      var cta = gate.querySelector('.fg-cta');
      if (cta) cta.classList.add('pulse');
      setTimeout(function () { if (document.getElementById('tab-mbxfocus')) enter(); }, AUTO_OPEN_MS);
    })();

    function hideGate() {
      door.classList.remove('pulse');
      if (gate.parentNode) gate.parentNode.removeChild(gate);
    }

    function enter() {
      if (!document.getElementById('tab-' + only)) return;
      hideGate();
      if (real) real.click(); else realShowTab(only, door);
      door.classList.add('active');
      afterOpen();
    }

    /* Honour the existing share params once they're inside. */
    function afterOpen() {
      var view = (qs.get('view') || '').toLowerCase().trim();
      if (view) {
        var sub = document.getElementById('rhsub-' + view);
        if (sub) sub.click();
      }
      var spot = qs.get('spot');
      if (spot) {
        setTimeout(function () {
          var el = document.getElementById(spot);
          if (!el) return;
          if (el.scrollIntoView) el.scrollIntoView({ behavior:'smooth', block:'center' });
          el.classList.add('mbx-spotlight');
          var stop = function () { el.classList.remove('mbx-spotlight'); };
          el.addEventListener('click', stop, { once:true });
          setTimeout(stop, 14000);
        }, 400);
      }
      if (qs.get('act') === 'room' && typeof rhActOpen === 'function') setTimeout(rhActOpen, 900);
    }
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', setup);
  else setup();
})();
</script>

<!-- ══════════════════════════════════════════════════════════════════════════
     IGNITION — the open-up sequence. Plays on every fresh open and refresh —
     Erik wants to see it land each time.

     Beat 1  CIPHER (Mission: Impossible) — the MiniBox+ Master Toolkit title
             appears dead-center screen as flipping split-flap characters that
             lock into place left to right, while a KITT-style scanner pongs
             underneath as they resolve.
     Beat 2  CONVERGE + DOCK — the locked letters tighten to their natural
             spacing, then the whole title glides up and shrinks into its
             resting spot in the header. Brand line + subtitle cascade in and
             a light sheen crosses the hero.
     Beat 3  the blade (the white underline that normally sits under the active
             tab) does a full Knight Rider pong across the nav, then runs the
             tabs left to right — Daily Hub, Specialties, Email, Team Chat and
             on down — lighting each as it passes, and parks under Daily Hub.

     Fully self-contained: one <style id="mbx-ignition-css"> + one IIFE.
     Revert = delete this block. Nothing else in the file depends on it.
     NOTE: the Night display filter inverts the whole page, so the cipher stage
     gets its own explicit counter-invert rule below. The generic
     body > div[style*="position:fixed"] catch-all does NOT match JS-set styles
     (they serialize with a space, "position: fixed") — don't rely on it here.
     ══════════════════════════════════════════════════════════════════════════ -->
<style id="mbx-ignition-css">
  /* ---- Beat 1: the center-screen cipher ---- */
  #mbx-ign-stage{
    position:fixed; inset:0; z-index:9998; pointer-events:none;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    background:rgba(5,7,10,.86); opacity:0;
    transition:opacity 320ms ease, background 460ms ease;
  }
  /* Night inverts the page; counter-invert the stage so its colors stay true. */
  html[data-mbx-theme="night"] #mbx-ign-stage{ filter:invert(1) hue-rotate(180deg); }
  #mbx-ign-kicker{
    font-family:'DM Mono', ui-monospace, monospace;
    font-size:11px; font-weight:500; letter-spacing:.34em; text-transform:uppercase;
    color:#96a1ac; text-align:center; margin-bottom:20px;
    animation: mbxIgnFade 480ms 120ms ease-out both;
  }
  #mbx-ign-cipher{
    font-family:'Oswald', sans-serif; font-weight:500; text-transform:uppercase;
    letter-spacing:.02em; line-height:1.1; text-align:center; white-space:nowrap;
    font-size:clamp(20px, 5.8vw, 64px);
    perspective:520px;
  }
  /* Uniform-width cells while scrambling — reads like a code matrix and keeps
     the line from jittering as random characters swap through. */
  #mbx-ign-cipher .igc{
    display:inline-block; text-align:center; width:.62em;
    background:linear-gradient(180deg,#ffffff,#b9c4ce);
    -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;
    transition:width 380ms cubic-bezier(.2,.8,.2,1);
    backface-visibility:hidden;
  }
  #mbx-ign-cipher .igc.sp{ width:.3em; }
  #mbx-ign-cipher .igc.rolling{ animation:mbxIgnFlap 96ms linear infinite; opacity:.55; }
  #mbx-ign-cipher .igc.lock{ animation:mbxIgnLock 230ms cubic-bezier(.2,.85,.3,1) both; }
  @keyframes mbxIgnFlap{
    0%   { transform:rotateX(0); }
    45%  { transform:rotateX(-66deg); }
    55%  { transform:rotateX(62deg); }
    100% { transform:rotateX(0); }
  }
  @keyframes mbxIgnLock{
    0%   { transform:rotateX(-92deg); filter:brightness(2.4); }
    62%  { transform:rotateX(9deg); }
    100% { transform:rotateX(0); filter:none; }
  }
  /* The KITT scanner strip under the cipher — ice blue, not red: house colors. */
  #mbx-ign-scan{
    position:relative; margin:26px auto 0; height:3px; width:min(420px,64vw);
    background:rgba(159,212,232,.10); border-radius:2px;
    transition:opacity 260ms ease;
  }
  #mbx-ign-scan i{
    position:absolute; top:-1px; height:5px; width:22%; border-radius:3px;
    background:linear-gradient(90deg,transparent,rgba(159,212,232,.55) 18%,#eaf6fb 50%,rgba(159,212,232,.55) 82%,transparent);
    box-shadow:0 0 14px 1px rgba(159,212,232,.75);
    animation:mbxIgnPong 860ms cubic-bezier(.45,.02,.55,.98) infinite alternate;
  }
  @keyframes mbxIgnPong{ from{ left:0; } to{ left:78%; } }

  /* Real header text stays out of the way until the cipher docks. */
  body.mbx-ign-cipher-live .header-title{ opacity:0 !important; }
  body.mbx-igniting .header-title{ transition:opacity 220ms ease; }
  body.mbx-igniting .header-brand,
  body.mbx-igniting .header-sub{ opacity:0; }
  body.mbx-igniting.mbx-ign-docked .header-brand{ animation: mbxIgnFade 620ms 60ms ease-out both; }
  body.mbx-igniting.mbx-ign-docked .header-sub{ animation: mbxIgnFade 620ms 180ms ease-out both; }
  @keyframes mbxIgnFade{ from{opacity:0; transform:translateY(5px);} to{opacity:1; transform:none;} }

  /* Sheen: a thin light bar sweeping across the hero as the title lands. */
  body.mbx-ign-docked .fl-hero{ position:relative; overflow:hidden; }
  body.mbx-ign-docked .fl-hero::after{
    content:""; position:absolute; top:-20%; bottom:-20%; width:90px;
    background:linear-gradient(100deg,transparent,rgba(255,255,255,.20),transparent);
    transform: skewX(-16deg); pointer-events:none;
    animation: mbxIgnSheen 780ms 60ms ease-out both;
  }
  @keyframes mbxIgnSheen{
    0%   { left:-140px; opacity:0; }
    18%  { opacity:1; }
    100% { left:105%;  opacity:0; }
  }

  /* Each nav tab glistens as the blade passes under it. Text + a whisper of
     wash only — no saturated fill, so the Night display filter stays clean. */
  .tab-btn.mbx-ign-lit{ animation: mbxIgnLit 560ms ease-out; }
  @keyframes mbxIgnLit{
    0%   { color:inherit; }
    22%  { color:#ffffff; text-shadow:0 0 13px rgba(159,212,232,.95), 0 0 3px rgba(255,255,255,.7);
           background:rgba(255,255,255,.07); }
    100% { color:inherit; text-shadow:none; background:transparent; }
  }

  /* The travelling blade. Same look as .tab-bar .tab-btn.active::after so the
     hand-off at the end is invisible. */
  #mbx-ign-blade{
    position:absolute; height:2px; pointer-events:none; opacity:0; z-index:5;
    background:linear-gradient(90deg,transparent,#9fd4e8 22%,#eaf6fb 50%,#9fd4e8 78%,transparent);
    box-shadow:0 0 10px -1px rgba(159,212,232,.85);
    transition: left 150ms cubic-bezier(.3,.7,.3,1), width 150ms cubic-bezier(.3,.7,.3,1),
                top 150ms ease, opacity 220ms ease;
  }
  /* Real underline stays out of the way until the blade parks. */
  body.mbx-igniting .tab-bar .tab-btn.active::after{ opacity:0; }
  body.mbx-ign-parked .tab-bar .tab-btn.active::after{ animation: mbxIgnFadeIn 260ms ease-out both; }
  @keyframes mbxIgnFadeIn{ from{opacity:0;} to{opacity:1;} }
</style>
<script>
(function(){

  var CH = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789+/<>#';
  var TICK = 78;          // ms between scramble swaps
  var LOCK_START = 360;   // when the first letter locks
  var LOCK_STEP  = 32;    // each letter after, left to right
  var HOLD = 220;         // beat after the last lock, before converge
  var CONVERGE = 380;     // letters tighten to natural spacing
  var DOCK = 560;         // glide up into the header

  function run(){
    var body  = document.body;
    var title = document.querySelector('.header-title');
    var bar   = document.querySelector('.tab-bar');
    if(!title || !bar) return;

    var old = document.getElementById('mbx-ign-stage');
    if(old && old.parentNode) old.parentNode.removeChild(old);

    window.mbxIgnitionRanAt = Math.round(performance.now());   // debug breadcrumb
    body.classList.add('mbx-igniting', 'mbx-ign-cipher-live');

    /* ---- Beat 1: build the center-screen cipher ---- */
    var stage = document.createElement('div');
    stage.id = 'mbx-ign-stage';        // all static styling lives in #mbx-ign-stage CSS above

    var kicker = document.createElement('div');
    kicker.id = 'mbx-ign-kicker';
    kicker.textContent = 'PulmOne — Field Reference';

    var cipher = document.createElement('div');
    cipher.id = 'mbx-ign-cipher';

    var scan = document.createElement('div');
    scan.id = 'mbx-ign-scan';
    scan.appendChild(document.createElement('i'));

    var text = title.textContent.replace(/\s+/g, ' ').trim();
    var spans = [];
    for(var i = 0; i < text.length; i++){
      var c = text.charAt(i);
      var s = document.createElement('span');
      s.className = 'igc';
      if(c === ' '){
        s.className += ' sp';
        s.innerHTML = '&nbsp;';
        s.setAttribute('data-done', '1');
      } else {
        s.setAttribute('data-ch', c);
        s.textContent = CH.charAt(Math.floor(Math.random() * CH.length));
        s.classList.add('rolling');
      }
      spans.push(s);
      cipher.appendChild(s);
    }

    stage.appendChild(kicker);
    stage.appendChild(cipher);
    stage.appendChild(scan);
    body.appendChild(stage);
    requestAnimationFrame(function(){ stage.style.opacity = '1'; });

    var letters = spans.filter(function(sp){ return !sp.getAttribute('data-done'); });
    letters.forEach(function(sp, idx){ sp.setAttribute('data-lock', LOCK_START + idx * LOCK_STEP); });

    var t0 = performance.now();
    var iv = setInterval(function(){
      var el = performance.now() - t0, done = true;
      letters.forEach(function(sp){
        if(sp.getAttribute('data-locked')) return;
        if(el >= +sp.getAttribute('data-lock')){
          sp.setAttribute('data-locked', '1');
          sp.classList.remove('rolling');
          sp.classList.add('lock');
          sp.textContent = sp.getAttribute('data-ch');
        } else {
          done = false;
          sp.textContent = CH.charAt(Math.floor(Math.random() * CH.length));
        }
      });
      if(done){ clearInterval(iv); setTimeout(converge, HOLD); }
    }, TICK);

    /* ---- Beat 2: letters tighten to natural spacing, then dock ---- */
    function converge(){
      scan.style.opacity = '0';
      kicker.style.animation = 'none';
      kicker.style.transition = 'opacity 260ms ease';
      kicker.style.opacity = '0';
      // Measure each character's natural width, snap back to the grid without
      // painting, then transition every cell at once — the line visibly
      // converges to its true centered width.
      spans.forEach(function(sp){ sp.style.width = 'auto'; });
      var nat = spans.map(function(sp){ return sp.getBoundingClientRect().width; });
      spans.forEach(function(sp){ sp.style.width = ''; });
      void cipher.offsetWidth;
      spans.forEach(function(sp, idx){ sp.style.width = nat[idx] + 'px'; });
      setTimeout(dock, CONVERGE);
    }

    function dock(){
      var from = cipher.getBoundingClientRect();
      var to = title.getBoundingClientRect();
      if(from.width && to.width){
        cipher.style.transformOrigin = '0 0';
        cipher.style.transition = 'transform ' + DOCK + 'ms cubic-bezier(.22,.9,.3,1)';
        cipher.style.transform = 'translate(' + (to.left - from.left) + 'px,' + (to.top - from.top) + 'px) scale(' + (to.width / from.width) + ')';
      }
      stage.style.background = 'transparent';   // scrim melts while the title glides
      setTimeout(landed, DOCK - 40);
    }

    function landed(){
      body.classList.remove('mbx-ign-cipher-live');   // real title crossfades in underneath
      body.classList.add('mbx-ign-docked');           // brand + sub cascade, sheen crosses
      stage.style.opacity = '0';
      setTimeout(function(){ if(stage.parentNode) stage.parentNode.removeChild(stage); }, 380);
      blade();
    }

    /* ---- Beat 3: Knight Rider pong, then the tab run ---- */
    function blade(){
      // Top-level nav buttons, in the order Erik set: Daily Hub -> Specialties
      // -> Email -> Team Chat -> and on down the row. Dropdown children excluded.
      var tabs = [].slice.call(bar.querySelectorAll('.tab-row > .tab-btn, .tab-row > .tab-dd > .tab-dd-parent'))
                   .filter(function(b){ return b.offsetParent !== null; });
      if(!tabs.length){ cleanup(); return; }

      var bl = document.createElement('div');
      bl.id = 'mbx-ign-blade';
      bar.appendChild(bl);

      function place(btn){
        var r = btn.getBoundingClientRect(), br = bar.getBoundingClientRect();
        bl.style.left  = (r.left - br.left + 10) + 'px';
        bl.style.width = Math.max(10, r.width - 20) + 'px';
        bl.style.top   = (r.bottom - br.top - 2) + 'px';
      }

      // KITT pass: one full pong across the first nav row before the tab steps.
      var row = tabs[0].getBoundingClientRect(), br0 = bar.getBoundingClientRect();
      bl.style.top = (row.bottom - br0.top - 2) + 'px';
      bl.style.left = '8px';
      bl.style.width = '110px';
      setTimeout(function(){ bl.style.opacity = '1'; }, 40);
      setTimeout(function(){
        bl.style.transition = 'left 300ms cubic-bezier(.45,.02,.55,.98), width 300ms ease, top 150ms ease, opacity 220ms ease';
        bl.style.left = Math.max(8, bar.clientWidth - 120) + 'px';
      }, 90);
      setTimeout(function(){ bl.style.left = '8px'; }, 410);
      setTimeout(function(){
        bl.style.transition = 'left 150ms cubic-bezier(.3,.7,.3,1), width 150ms cubic-bezier(.3,.7,.3,1), top 150ms ease, opacity 220ms ease';
      }, 730);

      var START = 780, STEP = 88;                    // ms lead-in / between tabs
      tabs.forEach(function(btn, idx){
        setTimeout(function(){
          place(btn);
          btn.classList.add('mbx-ign-lit');
          setTimeout(function(){ btn.classList.remove('mbx-ign-lit'); }, 600);
        }, START + idx * STEP);
      });

      // Ride back to Daily Hub (or whichever tab is actually active) and park.
      var back = START + tabs.length * STEP + 240;
      setTimeout(function(){
        var home = bar.querySelector('.tab-row > .tab-btn.active') || tabs[0];
        bl.style.transition = 'left 430ms cubic-bezier(.22,.9,.3,1), width 430ms cubic-bezier(.22,.9,.3,1), top 430ms ease, opacity 260ms ease';
        place(home);
      }, back);

      setTimeout(function(){
        bl.style.opacity = '0';
        body.classList.remove('mbx-igniting');
        body.classList.add('mbx-ign-parked');
      }, back + 400);

      setTimeout(function(){
        if(bl.parentNode) bl.parentNode.removeChild(bl);
        cleanup();
      }, back + 900);
    }

    function cleanup(){
      body.classList.remove('mbx-igniting', 'mbx-ign-parked', 'mbx-ign-docked', 'mbx-ign-cipher-live');
    }
  }

  window.mbxIgnition = run;   // replay hook — call from the console any time

  // Plays on every open and every refresh — Erik wants to see it land each time.

  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
  else run();
})();
</script>

<!-- ============================================================
     mbx-tips — on-screen coaching that gets out of the way
     - Knows when MiniBox+ is running as an installed app (home
       screen / desktop shortcut) and hides browser-only advice.
     - Any element tagged data-mbx-tip="<key>" gets a small x.
       Dismissed once = gone on that device, forever.
     - "Show tips again" restores everything.
     Self-contained, append-only. Safe to delete as one block.
     ============================================================ -->
<style id="mbx-tips-css">
  html.mbx-installed [data-mbx-tip-when="browser"]{ display:none !important; }
  [data-mbx-tip]{ position:relative; }
  [data-mbx-tip].mbx-tip-hid{ display:none !important; }
  .mbx-tip-x{
    position:absolute; top:4px; right:5px; width:22px; height:22px;
    display:flex; align-items:center; justify-content:center;
    background:transparent; border:0; border-radius:6px; cursor:pointer;
    font-size:16px; line-height:1; color:currentColor; opacity:.42; padding:0;
  }
  .mbx-tip-x:hover{ opacity:1; background:rgba(0,0,0,.07); }
  [data-mbx-tip].mbx-tip-armed{ padding-right:30px; }
  .mbx-tips-restore{
    display:inline-block; margin-top:10px; background:transparent; border:0;
    padding:2px 0; font-size:11.5px; color:#64748b; cursor:pointer;
    text-decoration:underline; font-family:inherit;
  }
  .mbx-tips-restore:hover{ color:#0d4a82; }
</style>
<script id="mbx-tips">
(function () {
  var KEY = 'mbx_tip_hid_';

  /* ---- 1. Are we running as an installed app? ----
     Home-screen / installed launches report display-mode standalone
     (Android, desktop Chrome/Edge) or navigator.standalone (iOS).
     Some launchers open minimal-ui or fullscreen instead, so check
     all three. The manifest start_url can also carry ?mode=app. */
  function installed() {
    try {
      if (window.navigator.standalone === true) return true;
      if (window.matchMedia) {
        if (window.matchMedia('(display-mode: standalone)').matches) return true;
        if (window.matchMedia('(display-mode: fullscreen)').matches) return true;
        if (window.matchMedia('(display-mode: minimal-ui)').matches) return true;
      }
      if (/[?&]mode=app\b/.test(location.search)) return true;
    } catch (e) {}
    return false;
  }

  function markInstalled() {
    var on = installed();
    document.documentElement.classList.toggle('mbx-installed', on);
    /* Remember it: if the rep opens the same page in a browser tab later,
       we still know they have the app and don't re-pitch the install. */
    try { if (on) localStorage.setItem('mbx_is_installed', '1'); } catch (e) {}
    if (!on) {
      try {
        if (localStorage.getItem('mbx_is_installed') === '1') {
          document.documentElement.classList.add('mbx-installed');
        }
      } catch (e) {}
    }
  }
  markInstalled();
  try {
    if (window.matchMedia) {
      var mq = window.matchMedia('(display-mode: standalone)');
      if (mq.addEventListener) mq.addEventListener('change', markInstalled);
    }
  } catch (e) {}
  window.addEventListener('appinstalled', function () {
    try { localStorage.setItem('mbx_is_installed', '1'); } catch (e) {}
    document.documentElement.classList.add('mbx-installed');
  });

  /* ---- 2. Dismissable tips ---- */
  function hidden(key) {
    try { return localStorage.getItem(KEY + key) === '1'; } catch (e) { return false; }
  }

  function arm(el) {
    if (el.getAttribute('data-mbx-tip-armed') === '1') return;
    el.setAttribute('data-mbx-tip-armed', '1');
    var key = el.getAttribute('data-mbx-tip') || '';
    if (!key) return;
    if (hidden(key)) { el.classList.add('mbx-tip-hid'); return; }
    var x = document.createElement('button');
    x.className = 'mbx-tip-x';
    x.type = 'button';
    x.innerHTML = '&times;';
    x.title = 'Got it — hide this tip';
    x.setAttribute('aria-label', 'Hide this tip');
    x.onclick = function (ev) {
      ev.stopPropagation();
      try { localStorage.setItem(KEY + key, '1'); } catch (e) {}
      el.classList.add('mbx-tip-hid');
      restoreLink();
    };
    el.classList.add('mbx-tip-armed');
    el.appendChild(x);
  }

  function scan() {
    var all = document.querySelectorAll('[data-mbx-tip]');
    for (var i = 0; i < all.length; i++) arm(all[i]);
    restoreLink();
  }

  /* ---- 3. "Show tips again" ---- */
  function anyHidden() {
    try {
      for (var i = 0; i < localStorage.length; i++) {
        var k = localStorage.key(i);
        if (k && k.indexOf(KEY) === 0 && localStorage.getItem(k) === '1') return true;
      }
    } catch (e) {}
    return false;
  }

  function restoreLink() {
    var host = document.querySelector('[data-mbx-tip="install"]');
    host = host && host.parentNode;
    if (!host) return;
    var link = document.getElementById('mbx-tips-restore');
    if (!anyHidden()) { if (link) link.remove(); return; }
    if (link) return;
    link = document.createElement('button');
    link.id = 'mbx-tips-restore';
    link.type = 'button';
    link.className = 'mbx-tips-restore';
    link.textContent = 'Show tips again';
    link.onclick = mbxResetTips;
    host.appendChild(link);
  }

  function mbxResetTips() {
    try {
      var doomed = [];
      for (var i = 0; i < localStorage.length; i++) {
        var k = localStorage.key(i);
        if (k && k.indexOf(KEY) === 0) doomed.push(k);
      }
      for (var j = 0; j < doomed.length; j++) localStorage.removeItem(doomed[j]);
    } catch (e) {}
    var all = document.querySelectorAll('[data-mbx-tip]');
    for (var n = 0; n < all.length; n++) {
      all[n].classList.remove('mbx-tip-hid');
      all[n].removeAttribute('data-mbx-tip-armed');
      var old = all[n].querySelector(':scope > .mbx-tip-x');
      if (old) old.remove();
      arm(all[n]);
    }
    restoreLink();
  }
  window.mbxResetTips = mbxResetTips;

  /* Tabs render their tips later, so keep watching. Debounced — the
     observer also sees our own x buttons going in. */
  function boot() {
    scan();
    var pending = null;
    try {
      var mo = new MutationObserver(function () {
        if (pending) return;
        pending = setTimeout(function () { pending = null; scan(); }, 120);
      });
      mo.observe(document.body, { childList: true, subtree: true });
    } catch (e) {}
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else boot();
})();
</script>

<script id="mbx-usage">
/* ============================================================
   USAGE — which screens and buttons the team actually uses.
   Owner-only: this app never reads any of it back. The only way
   to see it is the Command Center, behind the admin password.

   Records: app opened, tab viewed, button pressed (the button's
   own printed label), plus the self-declared rep name.
   Never records anything TYPED — no notes, no emails, no
   customer names, no search terms.

   Fails silent by design. If the network is down the batch waits
   in localStorage; if anything throws, the toolkit carries on.
   ------------------------------------------------------------ */
(function () {
  var online = (location.protocol === 'https:' || location.protocol === 'http:');
  if (!online) return;                       // offline file:// copies stay dark
  if (window.mbxUsageReady) return;          // idempotent
  window.mbxUsageReady = true;

  var API = '/api/usage';
  var QKEY = 'mbx_usage_queue';
  var DEVKEY = 'mbx_device_id';
  var FLUSH_MS = 25000;
  var PING_MS = 60000;                       // still-here heartbeat, visible tab only
  var QUEUE_MAX = 200;                       // a rep offline all week can't grow it forever
  var SESSION_MAX = 400;                     // runaway-click backstop
  var DWELL_MIN = 1500;                      // ignore sub-1.5s flickers between screens
  var DWELL_MAX = 30 * 60000;                // cap a single screen at 30 min (rep walked away)
  var sent = 0;
  var lastLabel = '', lastAt = 0;

  function ls(fn, dflt) { try { return fn(); } catch (e) { return dflt; } }

  /* WHAT ARE THEY ON — phone vs laptop, installed app vs a browser tab. One
     short string, worked out once. This is about the PRODUCT ("is this really
     used in the field on a phone?"), never about the person. */
  function platform() {
    var ua = navigator.userAgent || '';
    var standalone = ls(function () {
      return (window.matchMedia && window.matchMedia('(display-mode: standalone)').matches) ||
             navigator.standalone === true;
    }, false);
    var os = 'Desktop';
    if (/iPhone|iPod/.test(ua)) os = 'iPhone';
    else if (/iPad/.test(ua) || (/Macintosh/.test(ua) && navigator.maxTouchPoints > 1)) os = 'iPad';
    else if (/Android/.test(ua)) os = /Mobile/.test(ua) ? 'Android phone' : 'Android tablet';
    else if (/Windows/.test(ua)) os = 'Windows';
    else if (/Macintosh|Mac OS X/.test(ua)) os = 'Mac';
    else if (/Linux/.test(ua)) os = 'Linux';
    return (os + (standalone ? ' · installed app' : ' · browser')).slice(0, 40);
  }
  var PLAT = ls(platform, '');
  var _d0 = new Date();
  var HR = _d0.getHours();                    // local hour 0-23 — WHEN reps reach for it
  var DOW = _d0.getDay();                      // 0 Sun .. 6 Sat — which day of the week

  /* Did a click actually FINISH something a rep sells with? A button press is
     just a press; producing a quote / an ROI / a PDF / a logged order is an
     outcome. We tag those separately so "opened Forms" can become "closed
     something." Conservative on purpose — only the unmistakable deliverables. */
  var OUTCOMES = [
    [/print|save pdf|\bpdf\b/i,        'Printed / saved a PDF'],
    [/\bquote\b/i,                      'Built a quote'],
    [/\broi\b|proposal/i,               'Built an ROI proposal'],
    [/log (an )?order|order log/i,      'Logged an order'],
    [/copy (this )?email/i,             'Copied an email to send']
  ];
  function outcomeFor(label) {
    for (var i = 0; i < OUTCOMES.length; i++) if (OUTCOMES[i][0].test(label)) return OUTCOMES[i][1];
    return '';
  }

  /* HOW LONG on each screen. We don't poll or watch the mouse — we just note
     when a screen becomes the visible one and, when they leave it (switch tabs,
     hide the app, close it), record how long it was up. Summed per visit, that
     is the session length; per screen, it's what actually holds attention. */
  var dwellScreen = '', dwellStart = 0;
  function dwellBegin() { dwellScreen = currentScreen(); dwellStart = Date.now(); }
  function dwellEnd() {
    if (!dwellScreen || !dwellStart) return;
    var ms = Date.now() - dwellStart;
    dwellStart = 0;
    if (ms >= DWELL_MIN && ms <= DWELL_MAX) log('dwell', dwellScreen, { ms: ms });
  }

  /* One rep on a phone and a laptop shouldn't look like two people. */
  function deviceId() {
    var d = ls(function () { return localStorage.getItem(DEVKEY); }, '');
    if (!d) {
      d = ls(function () { return crypto.randomUUID(); }, '') ||
          ('d' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8));
      ls(function () { localStorage.setItem(DEVKEY, d); });
    }
    return d;
  }

  /* Same resolution order every other feature uses (profile, then chat name). */
  function myName() {
    var n = '';
    try { if (typeof REP_PROFILE !== 'undefined' && REP_PROFILE && REP_PROFILE.name) n = REP_PROFILE.name; } catch (e) {}
    if (!n) n = ls(function () { return localStorage.getItem('mbx_chat_name') || ''; }, '');
    return String(n).trim();
  }

  /* The real identity key. Reps type this into the welcome screen so the email
     tools work, so it's the one field that is both unique and self-correcting. */
  function myEmail() {
    var e = '';
    try { if (typeof REP_PROFILE !== 'undefined' && REP_PROFILE && REP_PROFILE.email) e = REP_PROFILE.email; } catch (ex) {}
    return String(e).trim().toLowerCase();
  }

  var TABS = {
    hub: 'Daily Hub', pulmo: 'Pulmonology', allergy: 'Allergy / Immunology',
    cardio: 'Cardiology', rheum: 'Rheumatology', intmed: 'Internal Medicine',
    emaillib: 'Email Center',
    teamchat: 'Team Chat', overview: 'Product Overview', competitive: 'vs. Competition',
    keymsg: 'Key Messages', aging: 'Aging Devices', clinical: 'Clinical Proof',
    coaching: 'Patient Coaching', interpretation: 'PFT Interpretation',
    reimbursement: 'CPT & Revenue', billing: 'Billing Helper', financing: 'Financing',
    forms: 'Forms', trunkstock: 'Trunk Stock', videos: 'Videos', myday: 'My Day',
    contacts: 'People & Contacts', opsadmin: 'Ops & Admin', command: 'Command Center'
  };

  /* Strip emoji, arrows and carets so "Rheumatology ▼" and "Rheumatology"
     don't become two different rows in the report. */
  function tidy(s) {
    return String(s == null ? '' : s)
      .replace(/[\uD800-\uDFFF]./g, '')
      .replace(/[←-⯿️‍▲▼•]/g, '')
      .replace(/\s+/g, ' ')
      .trim()
      .slice(0, 60);
  }

  function currentScreen() {
    var p = document.querySelector('.tab-panel.active');
    if (p && p.id && p.id.indexOf('tab-') === 0) {
      var k = p.id.slice(4);
      if (TABS[k]) return TABS[k];
      return k;
    }
    var b = document.querySelector('.tab-btn.active');
    return b ? tidy(b.textContent) : '';
  }

  /* ── queue ── */
  function readQ() {
    var raw = ls(function () { return localStorage.getItem(QKEY); }, '');
    if (!raw) return [];
    var a = ls(function () { return JSON.parse(raw); }, []);
    return Array.isArray(a) ? a : [];
  }
  function writeQ(a) {
    ls(function () { localStorage.setItem(QKEY, JSON.stringify(a.slice(-QUEUE_MAX))); });
  }

  function log(kind, label, extra) {
    /* Only real clicks (a button or a tab) are rate-guarded and count against
       the runaway budget. Opens, heartbeats, screen-time and outcome tags are
       automatic or paired with a click already counted — they ride free. */
    var isClick = (kind === 'action' || kind === 'tab');
    if (isClick && sent++ > SESSION_MAX) return;
    label = tidy(label);
    if (!label) return;
    var now = Date.now();
    if (isClick) {
      if (label === lastLabel && now - lastAt < 800) return;   // double-tap, one event
      lastLabel = label; lastAt = now;
    }
    var ev = { t: now, k: kind, label: label, screen: currentScreen(),
               name: myName(), email: myEmail(), dev: deviceId(), plat: PLAT };
    if (extra) for (var kx in extra) if (extra.hasOwnProperty(kx)) ev[kx] = extra[kx];
    var q = readQ();
    q.push(ev);
    writeQ(q);
    if (q.length >= 25) flush();
  }

  function flush(useBeacon) {
    var q = readQ();
    if (!q.length) return;
    var batch = q.slice(0, 60);
    var rest = q.slice(60);
    var payload = JSON.stringify({ events: batch });

    /* Page is closing — beacon is the only thing that reliably survives. */
    if (useBeacon && navigator.sendBeacon) {
      var okBeacon = ls(function () {
        return navigator.sendBeacon(API, new Blob([payload], { type: 'application/json' }));
      }, false);
      if (okBeacon) writeQ(rest);
      return;
    }

    writeQ(rest);                                  // optimistic: don't double-send
    fetch(API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: payload,
      keepalive: true
    }).then(function (r) {
      if (!r.ok) throw new Error('http');
    }).catch(function () {
      writeQ(batch.concat(readQ()));               // put it back, try again next tick
    });
  }

  /* ── hooks ── */
  /* Every tab change on the site funnels through showTab, including deep links
     and the dropdown menus, so one wrapper catches all of them. */
  function hookTabs() {
    if (typeof window.showTab !== 'function' || window.showTab.__mbxUsage) return false;
    var orig = window.showTab;
    var wrapped = function (id, btn) {
      try { dwellEnd(); } catch (e) {}                     // close out time on the screen we're leaving
      try {
        log('tab', TABS[id] || (btn && tidy(btn.textContent)) || id);
      } catch (e) {}
      var r = orig.apply(this, arguments);
      try { dwellBegin(); } catch (e) {}                   // start the clock on the screen we just opened
      return r;
    };
    wrapped.__mbxUsage = true;
    window.showTab = wrapped;
    return true;
  }

  /* Buttons are all inline onclick with no central dispatcher, so listen on the
     way down and read the control's own printed label. */
  function hookClicks() {
    document.addEventListener('click', function (e) {
      try {
        var el = e.target && e.target.closest
          ? e.target.closest('button, .btn, [role="button"], a[onclick]') : null;
        if (!el) return;
        if (el.classList && el.classList.contains('tab-btn')) return;   // counted as a tab
        if (el.closest('#mbx-cc-frame')) return;                        // Command Center is Erik's own
        var label = tidy(el.textContent) ||
                    tidy(el.getAttribute('aria-label')) ||
                    tidy(el.getAttribute('title'));
        if (!label || label.length < 2) return;
        log('action', label);
        var oc = outcomeFor(label);
        if (oc) log('outcome', oc);                        // ...and, if it finished something, tag that too
      } catch (err) {}
    }, true);
  }

  function boot() {
    if (!hookTabs()) {
      // showTab is defined mid-document; if we somehow beat it, retry briefly.
      var tries = 0;
      var iv = setInterval(function () { if (hookTabs() || ++tries > 20) clearInterval(iv); }, 250);
    }
    hookClicks();
    log('open', 'app', { hr: HR, dow: DOW });      // hr/dow ride along so we learn WHEN they open it
    dwellBegin();                                  // start timing the first screen
    flush();                                       // drain anything stranded offline
    setInterval(flush, FLUSH_MS);

    /* STILL-HERE HEARTBEAT.
       Without this, "last seen" only moves when someone CLICKS — so a rep
       reading a screen for ten minutes looks like they left. Once a minute,
       only while the toolkit is actually the visible tab, we send a tiny ping
       that updates last-seen and nothing else. That is what powers the
       "On right now" panel in the Command Center. Costs one small POST/min. */
    setInterval(function () {
      if (document.visibilityState !== 'visible') return;
      log('ping', 'heartbeat');
      flush();                                     // live means live — don't wait for the batch
    }, PING_MS);
    document.addEventListener('visibilitychange', function () {
      if (document.visibilityState === 'hidden') { dwellEnd(); flush(true); }   // stop the screen clock while they're away
      else dwellBegin();                                                        // ...and restart it when they come back
    });
    window.addEventListener('pagehide', function () { dwellEnd(); flush(true); });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else boot();
})();
</script>

<style id="mbx-search-overlay">
/* ===== SEARCH RESULTS MUST FLOAT ABOVE THE NAV RAIL =====
   The results panel used to live inside .site-header, so it shared a stacking
   context with .tab-bar and the navy nav rail painted over the first result.
   z-index tweaks kept losing because the night theme puts a filter on
   .site-header, which traps everything inside it. Fix: the panel is re-parented
   to <body> and positioned with fixed coordinates read off the search input, so
   nothing in the header can cover it. Delete this block + #mbx-search-overlay-js
   to revert. */
#global-search-results {
  position: fixed !important;
  left: 0; top: 0;                 /* real values set by the script below */
  transform: none !important;
  z-index: 100000 !important;
  max-height: 62vh;
  overflow-y: auto;
}
/* Moved out of .site-header, so it no longer inherits the header's night
   re-invert. Flip it back by hand or it renders as a black slab. */
html[data-mbx-theme="night"] #global-search-results { filter: invert(1) hue-rotate(180deg); }
html[data-mbx-theme="night"] #global-search-results img { filter: none; }
</style>
<script id="mbx-search-overlay-js">
(function () {
  function panel() { return document.getElementById('global-search-results'); }
  function input() { return document.getElementById('global-search'); }

  function place() {
    var box = panel(), inp = input();
    if (!box || !inp || !box.classList.contains('show')) return;
    var r = inp.getBoundingClientRect();
    var gap = 8;
    box.style.left  = r.left + 'px';
    box.style.width = r.width + 'px';
    box.style.top   = (r.bottom + gap) + 'px';
    // never let it run off the bottom of the window
    box.style.maxHeight = Math.max(180, window.innerHeight - r.bottom - gap - 16) + 'px';
  }

  function boot() {
    var box = panel();
    if (!box) return;
    if (box.parentNode !== document.body) document.body.appendChild(box);

    // Re-place whenever the panel is shown/hidden or the page moves under it.
    new MutationObserver(place).observe(box, { attributes: true, attributeFilter: ['class'] });
    window.addEventListener('scroll', place, true);
    window.addEventListener('resize', place);
    var inp = input();
    if (inp) { inp.addEventListener('input', place); inp.addEventListener('focus', place); }
    place();
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else boot();
})();
</script>

