  },
  training: {
    subject: 'MiniBox+ Training Confirmation — [Practice Name]',
    body: 'Dear [Name],\n\nThis confirms your MiniBox+ training session:\n\nDate: [Date]\nTime: [Time]\nLocation / Call Link: [Location or Zoom Link]\nTrainer: [Trainer Name]\n\nPlease ensure your MiniBox+ device is powered on and set up in the testing area prior to the session. We will walk through FVC, LVM, and DLCO testing end-to-end.\n\nLooking forward to connecting!\n\n[Your Name]\nPulmOne USA'
