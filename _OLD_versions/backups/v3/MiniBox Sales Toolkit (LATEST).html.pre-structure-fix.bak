  {name:&quot;BlueCross BlueShield of Tennessee&quot;,st:[&quot;Tennessee&quot;]},{name:&quot;Arkansas Blue Cross Blue Shield&quot;,st:[&quot;Arkansas&quot;]},
  {name:&quot;Medical Mutual&quot;,st:[&quot;Ohio&quot;]},{name:&quot;Paramount Health Care&quot;,st:[&quot;Ohio&quot;]},{name:&quot;CareSource&quot;,cls:&quot;medicaid&quot;,st:[&quot;Ohio&quot;,&quot;Indiana&quot;,&quot;Georgia&quot;,&quot;Kentucky&quot;,&quot;West Virginia&quot;]},
  {name:&quot;SelectHealth&quot;,st:[&quot;Utah&quot;,&quot;Idaho&quot;,&quot;Nevada&quot;,&quot;Colorado&quot;]},{name:&quot;Presbyterian Health Plan&quot;,st:[&quot;New Mexico&quot;]},
  {name:&quot;SCAN Health Plan&quot;,st:[&quot;California&quot;,&quot;Arizona&quot;,&quot;Nevada&quot;,&quot;Texas&quot;]}
];
function payerSearchLook(nm){return [nm+&quot; coverage policy&quot;,gsearch(nm+&quot; spirometry 94010 reimbursement coverage policy&quot;)];}

function resolvePayer(pt,state,ins){
  var g=STATES[state];
  if(pt===&quot;medicare&quot;) return {name:&quot;Original Medicare (Part B)&quot;,cls:&quot;medicare&quot;,by:MACS[g[0]],byLabel:&quot;Processed by&quot;,jur:g[1],lookName:&quot;Medicare Coverage Database&quot;,lookUrl:MCD};
  if(pt===&quot;ma&quot;) return {name:&quot;Medicare Advantage (Part C)&quot;,cls:&quot;ma&quot;,by:MACS[g[0]]+&quot; (floor)&quot;,byLabel:&quot;Floor = MAC&quot;,jur:g[1],lookName:&quot;Medicare Coverage Database (floor) + plan policy&quot;,lookUrl:MCD};
  if(pt===&quot;medicaid&quot;){var med=MEDICAID[state]||(state+&quot; Medicaid&quot;);return {name:med,cls:&quot;medicaid&quot;,by:state+&quot; Medicaid program&quot;,byLabel:&quot;State program&quot;,jur:&quot;&quot;,lookName:med+&quot; provider coverage&quot;,lookUrl:gsearch(med+&quot; provider spirometry 94010 coverage policy fee schedule&quot;)};}
  var v=(ins||&quot;&quot;).trim(), lv=v.toLowerCase();
  if(!v) return {name:&quot;Commercial payer&quot;,cls:&quot;commercial&quot;,by:&quot;Commercial insurer&quot;,byLabel:&quot;Payer type&quot;,jur:&quot;&quot;,lookName:&quot;the payer's coverage policy&quot;,lookUrl:gsearch(&quot;spirometry 94010 reimbursement coverage policy&quot;)};
  if(/^blue cross blue shield \(/i.test(v)){var nm0=&quot;Blue Cross Blue Shield (&quot;+state+&quot;)&quot;;var lk0=payerSearchLook(nm0);
    return {name:nm0,cls:&quot;commercial&quot;,by:&quot;Commercial insurer&quot;,byLabel:&quot;Payer type&quot;,jur:&quot;&quot;,lookName:lk0[0],lookUrl:lk0[1]};}
  var hit=null;
  for(var i=0;i&lt;CARRIERS_DB.length;i++){var dn=CARRIERS_DB[i].name.toLowerCase();
    if(dn===lv){hit=CARRIERS_DB[i];break;} if(!hit &amp;&amp; lv.length&gt;=3 &amp;&amp; dn.indexOf(lv)&gt;-1) hit=CARRIERS_DB[i];}
  if(hit){var lk=payerSearchLook(hit.name);
    return {name:hit.name,cls:(hit.cls||&quot;commercial&quot;),by:(hit.cls===&quot;medicaid&quot;?&quot;Medicaid managed-care plan&quot;:&quot;Commercial insurer&quot;),byLabel:&quot;Payer type&quot;,jur:&quot;&quot;,lookName:lk[0],lookUrl:lk[1]};}
  var lk2=payerSearchLook(v);
  return {name:v,cls:&quot;commercial&quot;,by:&quot;Commercial insurer (not in list)&quot;,byLabel:&quot;Payer type&quot;,jur:&quot;&quot;,lookName:lk2[0],lookUrl:lk2[1]};
}
/* ===================== UI WIRING ===================== */
var $=function(id){return document.getElementById(id);};
var stateSel=$(&quot;state&quot;),ptypeSel=$(&quot;ptype&quot;),procSel=$(&quot;proc&quot;),codesBox=$(&quot;codes&quot;),
    insurerWrap=$(&quot;insurerWrap&quot;),insurerInput=$(&quot;insurer&quot;),insurerList=$(&quot;insurerlist&quot;);
Object.keys(STATES).forEach(function(s){var o=document.createElement(&quot;option&quot;);o.value=s;o.textContent=s;stateSel.appendChild(o);});
Object.keys(PROCEDURES).forEach(function(k){var o=document.createElement(&quot;option&quot;);o.value=k;o.textContent=PROCEDURES[k].label;procSel.appendChild(o);});

function opt(v,t){var o=document.createElement(&quot;option&quot;);o.value=v;o.textContent=t;return o;}
function optD(t){var o=document.createElement(&quot;option&quot;);o.value=t;return o;}

function buildPtype(){
  var st=stateSel.value; ptypeSel.innerHTML=&quot;&quot;;
  if(!st){ptypeSel.disabled=true;ptypeSel.appendChild(opt(&quot;&quot;,&quot;— pick a state first —&quot;));return;}
  ptypeSel.disabled=false;
  ptypeSel.appendChild(opt(&quot;&quot;,&quot;— Select payer type —&quot;));
  ptypeSel.appendChild(opt(&quot;medicare&quot;,&quot;Original Medicare (Part B) — &quot;+MACS[STATES[st][0]]));
  ptypeSel.appendChild(opt(&quot;ma&quot;,&quot;Medicare Advantage (Part C)&quot;));
  ptypeSel.appendChild(opt(&quot;medicaid&quot;,&quot;Medicaid — &quot;+(MEDICAID[st]||st+&quot; Medicaid&quot;)));
  ptypeSel.appendChild(opt(&quot;commercial&quot;,&quot;Commercial / private insurer&quot;));
}
function buildInsurerList(){
  var st=stateSel.value; insurerList.innerHTML=&quot;&quot;;
  if(!st) return;
  insurerList.appendChild(optD(&quot;Blue Cross Blue Shield (&quot;+st+&quot;)&quot;));
  CARRIERS_DB.forEach(function(c){ if(!c.st || c.st.indexOf(st)&gt;-1) insurerList.appendChild(optD(c.name)); });
}
function syncInsurer(){
  if(ptypeSel.value===&quot;commercial&quot;){insurerWrap.classList.remove(&quot;hide&quot;);}
  else{insurerWrap.classList.add(&quot;hide&quot;); insurerInput.value=&quot;&quot;;}
}
stateSel.addEventListener(&quot;change&quot;,function(){
  buildPtype(); buildInsurerList(); syncInsurer();
  try{localStorage.setItem(&quot;pft_state&quot;,stateSel.value);}catch(e){}
});
ptypeSel.addEventListener(&quot;change&quot;,syncInsurer);

/* ---- codes with LIVE conflict checking ---- */
function renderCodes(){
  var p=PROCEDURES[procSel.value]; codesBox.innerHTML=&quot;&quot;;
  p.codes.forEach(function(c){
    var l=document.createElement(&quot;label&quot;); l.className=&quot;chk&quot;; l.setAttribute(&quot;data-cpt&quot;,c.cpt);
    l.innerHTML='&lt;input type=&quot;checkbox&quot; value=&quot;'+c.cpt+'&quot;&gt;&lt;span&gt;&lt;b&gt;'+c.cpt+'&lt;/b&gt;&lt;small&gt;'+c.desc+'&lt;/small&gt;&lt;small class=&quot;note&quot;&gt;&lt;/small&gt;&lt;/span&gt;';
    codesBox.appendChild(l);
  });
  [].forEach.call(codesBox.querySelectorAll(&quot;input&quot;),function(i){i.addEventListener(&quot;change&quot;,syncCodes);});
  syncCodes();
}
function syncCodes(){
  var P=PROCEDURES[procSel.value], boxes={}, labels={};
  [].forEach.call(codesBox.querySelectorAll(&quot;.chk&quot;),function(l){var cpt=l.getAttribute(&quot;data-cpt&quot;);labels[cpt]=l;boxes[cpt]=l.querySelector(&quot;input&quot;);});
  Object.keys(boxes).forEach(function(cpt){boxes[cpt].disabled=false;labels[cpt].classList.remove(&quot;off&quot;);var n=labels[cpt].querySelector(&quot;.note&quot;);n.textContent=&quot;&quot;;n.classList.remove(&quot;on&quot;);});
  function block(cpt,msg){var n=labels[cpt].querySelector(&quot;.note&quot;);n.textContent=msg;n.classList.add(&quot;on&quot;);boxes[cpt].checked=false;boxes[cpt].disabled=true;labels[cpt].classList.add(&quot;off&quot;);}
  function flag(cpt,msg){var n=labels[cpt].querySelector(&quot;.note&quot;);n.textContent=msg;n.classList.add(&quot;on&quot;);}

  /* comprehensive code includes a component -&gt; block the component */
  P.codes.forEach(function(c){
    if(c.includesCodes &amp;&amp; boxes[c.cpt] &amp;&amp; boxes[c.cpt].checked){
      c.includesCodes.forEach(function(inc){ if(boxes[inc]) block(inc,&quot;Included in &quot;+c.cpt+&quot; — don’t bill separately&quot;); });
    }
  });
  /* mutually exclusive group -&gt; first picked wins, block the rest */
  (P.mutex||[]).forEach(function(mx){
    var on=mx.codes.filter(function(c){return boxes[c] &amp;&amp; boxes[c].checked;});
    if(on.length&gt;=1){ var keep=on[0];
      mx.codes.forEach(function(c){ if(c!==keep &amp;&amp; boxes[c]) block(c,&quot;Bill only one method — &quot;+keep+&quot; selected&quot;); });
    }
  });
  /* add-on needs a primary still selected */
  P.codes.forEach(function(c){
    if(c.addon &amp;&amp; boxes[c.cpt] &amp;&amp; boxes[c.cpt].checked &amp;&amp; !boxes[c.cpt].disabled){
      var has=c.primaries.some(function(p){return boxes[p] &amp;&amp; boxes[p].checked &amp;&amp; !boxes[p].disabled;});
      if(!has) flag(c.cpt,&quot;Add-on — also pick a primary test (94010, 94060, 94726…)&quot;);
    }
  });
  var bill=Object.keys(boxes).filter(function(c){return boxes[c].checked &amp;&amp; !boxes[c].disabled;});
  $(&quot;codestatus&quot;).textContent = bill.length ? (&quot;✓ Will bill: &quot;+bill.join(&quot; + &quot;)) : &quot;&quot;;
}
procSel.addEventListener(&quot;change&quot;,renderCodes);renderCodes();
try{var last=localStorage.getItem(&quot;pft_state&quot;);if(last&amp;&amp;STATES[last]){stateSel.value=last;}}catch(e){}
buildPtype(); buildInsurerList(); syncInsurer();

function esc(s){return String(s).replace(/&amp;/g,&quot;&amp;amp;&quot;).replace(/&lt;/g,&quot;&amp;lt;&quot;);}
function CODE(c){return '&lt;span class=&quot;pill code&quot;&gt;'+c+'&lt;/span&gt;';}
function MOD(m){return '&lt;span class=&quot;pill mod&quot;&gt;'+m+'&lt;/span&gt;';}

/* ===================== BUILD ===================== */
$(&quot;run&quot;).addEventListener(&quot;click&quot;,function(){
  var st=stateSel.value, pt=ptypeSel.value, P=PROCEDURES[procSel.value];
  if(!st || !pt){var e=$(&quot;err&quot;);e.textContent=(!st?&quot;Please choose a state first.&quot;:&quot;Please choose a payer type — Medicare, Medicare Advantage, Medicaid, or Commercial.&quot;);e.style.display=&quot;block&quot;;if(e.scrollIntoView)e.scrollIntoView({behavior:&quot;smooth&quot;,block:&quot;center&quot;});return;}
  $(&quot;err&quot;).style.display=&quot;none&quot;;
  var PY=resolvePayer(pt,st,insurerInput.value);

  var picked=[].slice.call(codesBox.querySelectorAll(&quot;input:checked&quot;)).filter(function(i){return !i.disabled;}).map(function(i){return i.value;});
  var em=$(&quot;em&quot;).checked;
  var own=document.querySelector('input[name=own]:checked').value;
  var meta=function(c){return P.codes.find(function(x){return x.cpt===c;});};

  $(&quot;jurLabel&quot;).textContent=st+&quot; — &quot;+(PY.cls===&quot;commercial&quot;?&quot;Commercial&quot;:PY.cls===&quot;medicaid&quot;?&quot;Medicaid&quot;:&quot;Medicare&quot;);
  $(&quot;macName&quot;).textContent=PY.name;
  $(&quot;jurTitle&quot;).textContent=PY.byLabel;
  $(&quot;jurName&quot;).textContent=PY.jur?(PY.by+&quot; — &quot;+PY.jur):PY.by;

  var h=&quot;&quot;,warnings=[];
  P.codes.forEach(function(c){
    if(c.includesCodes &amp;&amp; picked.indexOf(c.cpt)&gt;-1){
      c.includesCodes.forEach(function(inc){ if(picked.indexOf(inc)&gt;-1){ warnings.push(&quot;&lt;b&gt;Don't bill &quot;+inc+&quot; with &quot;+c.cpt+&quot;.&lt;/b&gt; &quot;+c.cpt+&quot; already includes the spirometry in &quot;+inc+&quot;. Bill &quot;+c.cpt+&quot; only.&quot;); picked=picked.filter(function(x){return x!==inc;}); } });
    }
  });
  (P.mutex||[]).forEach(function(mx){
    var present=mx.codes.filter(function(c){return picked.indexOf(c)&gt;-1;});
    if(present.length&gt;1){ warnings.push(mx.msg); picked=picked.filter(function(x){return mx.codes.indexOf(x)===-1 || x===mx.keep;}); }
  });
  P.codes.forEach(function(c){
    if(c.addon &amp;&amp; picked.indexOf(c.cpt)&gt;-1){
      var ok=c.primaries.some(function(p){return picked.indexOf(p)&gt;-1;});
      if(!ok) warnings.push(&quot;&lt;b&gt;&quot;+c.cpt+&quot; can't stand alone.&lt;/b&gt; It's an add-on (DLCO) and must be billed with a primary PFT code (&quot;+c.primaries.join(&quot;, &quot;)+&quot;). Add the primary test performed, or remove &quot;+c.cpt+&quot;.&quot;);
    }
  });
  if(warnings.length){
    h+='&lt;div class=&quot;res-h&quot; style=&quot;border-color:var(--red);color:var(--red)&quot;&gt;Fix these before you submit&lt;/div&gt;';
    warnings.forEach(function(w){h+='&lt;div class=&quot;warnbox&quot;&gt;'+w+'&lt;/div&gt;';});
  }

  h+='&lt;div class=&quot;res-h&quot;&gt;Your claim should look like this&lt;/div&gt;';
  var primaries=picked.filter(function(c){return !meta(c).addon;});
  var addons=picked.filter(function(c){return meta(c).addon;});
  var comp= own===&quot;pro&quot;?&quot; 26&quot;:own===&quot;tech&quot;?&quot; TC&quot;:&quot;&quot;;
  if(!picked.length){
    h+='&lt;p class=&quot;muted&quot;&gt;Select at least one test code above to see the claim layout.&lt;/p&gt;';
  }else{
    h+='&lt;div class=&quot;claim&quot;&gt;';
    if(em) h+='&lt;div class=&quot;ln&quot;&gt;&lt;span class=&quot;c&quot;&gt;'+P.emExample+'&lt;/span&gt;&lt;span class=&quot;m&quot;&gt;-25&lt;/span&gt;&lt;span class=&quot;d&quot;&gt;point to the EVALUATION diagnosis&lt;/span&gt;&lt;/div&gt;';
    primaries.forEach(function(c,i){
      h+='&lt;div class=&quot;ln&quot;&gt;&lt;span class=&quot;c&quot;&gt;'+c+comp+'&lt;/span&gt;&lt;span class=&quot;m&quot;&gt;'+(i&gt;0?'-59 / -91*':'&amp;nbsp;')+'&lt;/span&gt;&lt;span class=&quot;d&quot;&gt;point to the RESPIRATORY diagnosis&lt;/span&gt;&lt;/div&gt;';});
    addons.forEach(function(c){
      h+='&lt;div class=&quot;ln&quot;&gt;&lt;span class=&quot;c&quot;&gt;'+c+comp+'&lt;/span&gt;&lt;span class=&quot;m&quot;&gt;add-on&lt;/span&gt;&lt;span class=&quot;d&quot;&gt;same dx as its primary&lt;/span&gt;&lt;/div&gt;';});
    h+='&lt;/div&gt;';
    h+='&lt;p class=&quot;muted&quot;&gt;'+P.emExample+' shown as an example E/M level - bill the level your documentation supports. '+(comp?'&lt;b&gt;'+comp.trim()+'&lt;/b&gt; appended from the equipment/interpretation answer. ':'')+(primaries.length&gt;1?'&lt;b&gt;*&lt;/b&gt; A second distinct test the same day may need 59/XU (separate) or 91 (repeat) - only if truly separate and documented; verify the pair.':'')+'&lt;/p&gt;';
  }

  h+='&lt;div class=&quot;res-h&quot;&gt;Step by step&lt;/div&gt;&lt;ol class=&quot;steps&quot;&gt;';
  h+='&lt;li&gt;Report the test code(s) actually performed: '+(picked.length?picked.map(CODE).join(&quot; &quot;):'&lt;span class=&quot;muted&quot;&gt;(none selected)&lt;/span&gt;')+'.&lt;/li&gt;';
  if(own===&quot;global&quot;) h+='&lt;li&gt;Bill the &lt;b&gt;global service&lt;/b&gt; (no 26/TC) - practice owns the equipment and the provider interprets.&lt;/li&gt;';
  else if(own===&quot;pro&quot;) h+='&lt;li&gt;Append '+MOD('26')+' (professional component) - provider only interprets; equipment owned elsewhere.&lt;/li&gt;';
  else h+='&lt;li&gt;Append '+MOD('TC')+' (technical component) - practice supplied equipment/technician but did not interpret.&lt;/li&gt;';
  if(em){
    h+='&lt;li&gt;Report the office visit and append '+MOD('25')+' &lt;b&gt;to the E/M code&lt;/b&gt; - never to the test. This unbundles the visit so both pay.&lt;/li&gt;';
    h+='&lt;li&gt;Bill the E/M &lt;b&gt;only&lt;/b&gt; if it was a significant, separately identifiable evaluation. If the patient came in solely for the test, do not bill a separate visit.&lt;/li&gt;';
  }else{
    h+='&lt;li&gt;No visit today - bill the test alone. (If the provider did evaluate the patient, check the &quot;office visit also done&quot; box for the Modifier 25 step.)&lt;/li&gt;';
  }
  h+='&lt;li&gt;Link diagnosis pointers as shown above, then confirm coverage in the lookup below before submitting.&lt;/li&gt;';
  h+='&lt;/ol&gt;';

  h+='&lt;div class=&quot;res-h&quot;&gt;Diagnosis &amp;amp; this payer &lt;span class=&quot;tag '+(PY.cls===&quot;commercial&quot;||PY.cls===&quot;medicaid&quot;?&quot;com&quot;:&quot;med&quot;)+'&quot;&gt;'+esc(PY.name)+'&lt;/span&gt;&lt;/div&gt;';
  h+='&lt;p&gt;'+esc(CLASS_DX[PY.cls])+'&lt;/p&gt;';
  h+='&lt;p class=&quot;muted&quot;&gt;Diagnoses that commonly support spirometry/PFT (examples - always match the chart and the payer covered list): '+esc(P.dxExamples)+'.&lt;/p&gt;';

  h+='&lt;div class=&quot;res-h&quot;&gt;Documentation that must be in the chart&lt;/div&gt;&lt;ul class=&quot;chklist&quot;&gt;';
  P.docChecklist.forEach(function(d){h+='&lt;li&gt;'+esc(d)+'&lt;/li&gt;';});
  h+='&lt;/ul&gt;';

  h+='&lt;div class=&quot;res-h&quot;&gt;If it denies - read the code, then fix it&lt;/div&gt;';
  h+='&lt;div class=&quot;claim&quot; style=&quot;background:#1c1410&quot;&gt;'+
    '&lt;div class=&quot;ln&quot; style=&quot;border-color:#3a2c22&quot;&gt;&lt;span class=&quot;c&quot; style=&quot;color:#ffb37a;min-width:120px&quot;&gt;CO-97 + N19/M15&lt;/span&gt;&lt;span class=&quot;d&quot; style=&quot;color:#f0d6c4&quot;&gt;Bundled / incidental - the E/M or a test code folded into another. Fix: confirm Modifier 25 is on the E/M, or that you did not bill a component code (e.g. 94010 with 94060). Appeal with the note + interpretation.&lt;/span&gt;&lt;/div&gt;'+
    '&lt;div class=&quot;ln&quot; style=&quot;border-color:#3a2c22&quot;&gt;&lt;span class=&quot;c&quot; style=&quot;color:#ffb37a;min-width:120px&quot;&gt;CO-50 / CO-56&lt;/span&gt;&lt;span class=&quot;d&quot; style=&quot;color:#f0d6c4&quot;&gt;Not medically necessary - the diagnosis is not on the covered list, or frequency exceeded. Fix: check the policy covered dx &amp;amp; limits, correct the pointer, resubmit.&lt;/span&gt;&lt;/div&gt;'+
    '&lt;div class=&quot;ln&quot;&gt;&lt;span class=&quot;c&quot; style=&quot;color:#ffb37a;min-width:120px&quot;&gt;CO-4 / CO-16&lt;/span&gt;&lt;span class=&quot;d&quot; style=&quot;color:#f0d6c4&quot;&gt;Modifier missing/inconsistent - a required modifier (25, 26, TC, 59) is absent or wrong. Fix: add/correct the modifier and resubmit.&lt;/span&gt;&lt;/div&gt;'+
    '&lt;/div&gt;';

  h+='&lt;div class=&quot;res-h&quot;&gt;Confirm coverage before you submit&lt;/div&gt;';
  h+='&lt;div class=&quot;verify&quot;&gt;&lt;b&gt;VERIFY for '+esc(PY.name)+':&lt;/b&gt; The coding above is standard; the covered-diagnosis list &amp;amp; frequency are set by this payer and can change. Check the current policy and match your diagnosis before submitting. &amp;nbsp;&lt;a href=&quot;'+PY.lookUrl+'&quot; target=&quot;_blank&quot; rel=&quot;noopener&quot;&gt;Open '+esc(PY.lookName)+' &amp;rarr;&lt;/a&gt;&lt;/div&gt;';

  $(&quot;result&quot;).innerHTML=h;
  $(&quot;disclaimer&quot;).innerHTML='General coding guidance, not a coverage determination or billing/legal advice. Reimbursement varies by payer, plan, region, and fee schedule. Confirm against current NCCI policy and the payer policy before submitting. &amp;nbsp;Generated for: &lt;b&gt;'+esc(PY.name)+' — '+esc(st)+'&lt;/b&gt;.';
  $(&quot;out&quot;).style.display=&quot;block&quot;;$(&quot;print&quot;).style.display=&quot;inline-block&quot;;
  $(&quot;out&quot;).scrollIntoView({behavior:&quot;smooth&quot;,block:&quot;start&quot;});
});
$(&quot;print&quot;).addEventListener(&quot;click&quot;,function(){window.print();});
&lt;/script&gt;
&lt;/body&gt;
&lt;/html&gt;
"></iframe>
  </div>

  <div class="tab-panel" id="tab-myday">
    <div class="section-head">
      <div class="section-icon icon-blue">&#128506;</div>
      <div>
        <div class="section-title">My Day &mdash; Route, Visits, Miles &amp; Expenses</div>
        <div class="section-sub">Build your stop list in the morning. The app logs arrivals, calculates stop to stop mileage, captures expenses, and hands you a clean end of day report. One system, zero manual tracking.</div>
      </div>
    </div>

    <div class="alert-box alert-blue">
      <div class="alert-icon">&#9432;</div>
      <div><strong>Framework preview (v1 frame).</strong> This is the working skeleton for review. Stops, arrive and depart stamps, mileage math, expenses, and the day report all function locally on this device. Coming in the full build: live route map (Leaflet, no API cost), GPS auto arrival detection with a 150 meter geofence, auto calculated drive miles between stops, and receipt photos saved with each expense. React to the layout and flow; content and automation fill in after alignment.</div>
    </div>

    <style>
      #tab-myday .md-card { background: #fff; border: 1px solid var(--gray-200, #e5e7eb); border-radius: 10px; padding: 14px 16px; margin: 14px 0; }
      #tab-myday .md-card h4 { margin: 0 0 4px; font-size: 13px; font-weight: 800; letter-spacing: .05em; text-transform: uppercase; color: var(--blue-brand, #1e40af); }
      #tab-myday .md-card .md-sub { font-size: 12px; color: #6b7280; margin-bottom: 10px; }
      #tab-myday .md-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
      #tab-myday input, #tab-myday select { font: inherit; font-size: 13px; padding: 8px 10px; border: 1px solid var(--gray-200, #e5e7eb); border-radius: 7px; }
      #tab-myday .md-btn { font-size: 12px; font-weight: 700; padding: 8px 14px; border-radius: 7px; border: 1px solid transparent; cursor: pointer; background: var(--blue-brand, #1e40af); color: #fff; }
      #tab-myday .md-btn.ghost { background: #fff; color: var(--blue-brand, #1e40af); border-color: var(--gray-200, #e5e7eb); }
      #tab-myday .md-btn.warn { background: #fff; color: #b91c1c; border-color: #fecaca; }
      #tab-myday .md-btn.soon { background: #f3f4f6; color: #9ca3af; cursor: default; }
      #tab-myday .md-stop { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px dashed var(--gray-200, #e5e7eb); }
      #tab-myday .md-stop:last-child { border-bottom: 0; }
      #tab-myday .md-num { width: 26px; height: 26px; border-radius: 50%; background: var(--blue-brand, #1e40af); color: #fff; font-size: 12px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex: none; }
      #tab-myday .md-stop-main { flex: 1; min-width: 0; }
      #tab-myday .md-stop-name { font-size: 14px; font-weight: 700; color: #111827; }
      #tab-myday .md-stop-addr { font-size: 11px; color: #6b7280; }
      #tab-myday .md-stamp { font-family: 'DM Mono', monospace; font-size: 11px; color: #047857; }
      #tab-myday .md-map-ph { height: 200px; border: 2px dashed var(--gray-200, #e5e7eb); border-radius: 10px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; color: #9ca3af; background: #f9fafb; text-align: center; padding: 10px; }
      #tab-myday table.md-tbl { width: 100%; border-collapse: collapse; font-size: 12px; }
      #tab-myday table.md-tbl th { text-align: left; font-size: 10px; letter-spacing: .05em; text-transform: uppercase; color: #6b7280; padding: 6px 8px; border-bottom: 2px solid var(--gray-200, #e5e7eb); }
      #tab-myday table.md-tbl td { padding: 7px 8px; border-bottom: 1px solid var(--gray-100, #f3f4f6); color: #111827; }
      #tab-myday .md-total { font-size: 14px; font-weight: 800; color: var(--blue-brand, #1e40af); }
      #tab-myday .md-miles-in { width: 64px; text-align: right; }
      #tab-myday .md-badge-soon { font-size: 9px; font-weight: 800; letter-spacing: .05em; text-transform: uppercase; background: #fef3c7; color: #92400e; padding: 2px 7px; border-radius: 20px; vertical-align: 2px; }
    </style>

    <div class="md-card">
      <h4>1 &middot; Today&rsquo;s Stops</h4>
      <div class="md-sub">Add each account you plan to visit, in drive order. Tap Maps to open turn by turn navigation. <span class="md-badge-soon">Coming</span> pick stops from your account list and auto optimize the order.</div>
      <div class="md-row" style="margin-bottom:10px;">
        <input id="md-stop-name" type="text" placeholder="Practice / account name" style="flex:1; min-width:160px;">
        <input id="md-stop-addr" type="text" placeholder="Address" style="flex:1.4; min-width:200px;">
        <button class="md-btn" onclick="mdAddStop()">Add Stop</button>
        <button class="md-btn soon" title="Full build: auto order stops by drive time">Optimize Route</button>
      </div>
      <div id="md-stops"></div>
    </div>

    <div class="md-card">
      <h4>2 &middot; Route Map <span class="md-badge-soon">Coming</span></h4>
      <div class="md-sub">All stops pinned with the drive order numbered. Built on Leaflet and OpenStreetMap, so there is no Google Maps API cost.</div>
      <div class="md-map-ph">
        <div style="font-size:34px; opacity:.4;">&#128506;</div>
        <div style="font-size:12px; font-weight:700;">Route map renders here</div>
        <div style="font-size:11px;">Pins for every stop, numbered drive order, your live position, and 150 meter geofence rings around each account</div>
      </div>
    </div>

    <div class="md-card">
      <h4>3 &middot; Arrival &amp; Visit Log</h4>
      <div class="md-sub">Tap Arrive when you walk in and Depart when you leave; the day report picks up every stamp. <span class="md-badge-soon">Coming</span> GPS auto detection stamps arrivals for you and pulls the account card up automatically.</div>
      <div style="overflow-x:auto;">
        <table class="md-tbl" id="md-visit-tbl">
          <thead><tr><th>#</th><th>Stop</th><th>Arrived</th><th>Departed</th><th>Time on site</th><th></th></tr></thead>
          <tbody id="md-visit-rows"></tbody>
        </table>
      </div>
    </div>

    <div class="md-card">
      <h4>4 &middot; Mileage</h4>
      <div class="md-sub">Enter miles per leg for now; the full build calculates driving distance between stops automatically, so there is no background tracking and no battery drain. Rate defaults to the IRS standard; verify the current year rate before submitting.</div>
      <div style="overflow-x:auto;">
        <table class="md-tbl">
          <thead><tr><th>Leg</th><th style="text-align:right;">Miles</th></tr></thead>
          <tbody id="md-mile-rows"></tbody>
        </table>
      </div>
      <div class="md-row" style="margin-top:10px; justify-content:space-between;">
        <div class="md-row" style="gap:6px;">
          <label style="font-size:12px; color:#6b7280;">IRS rate $/mi</label>
          <input id="md-rate" type="number" step="0.005" value="0.70" style="width:80px;" oninput="mdRender()">
        </div>
        <div class="md-total" id="md-mile-total">0.0 mi &middot; $0.00</div>
      </div>
    </div>

    <div class="md-card">
      <h4>5 &middot; Expenses</h4>
      <div class="md-sub">Log spend as it happens and tag it to the day. <span class="md-badge-soon">Coming</span> snap a receipt photo that saves with the entry and exports with the report.</div>
      <div class="md-row" style="margin-bottom:10px;">
        <select id="md-exp-cat">
          <option>Meals</option><option>Parking</option><option>Tolls</option><option>Fuel</option><option>Supplies</option><option>Other</option>
        </select>
        <input id="md-exp-amt" type="number" step="0.01" placeholder="$ amount" style="width:110px;">
        <input id="md-exp-note" type="text" placeholder="Note (account, purpose)" style="flex:1; min-width:150px;">
        <button class="md-btn" onclick="mdAddExp()">Add</button>
        <button class="md-btn soon" title="Full build: camera receipt capture">&#128247; Receipt</button>
      </div>
      <div style="overflow-x:auto;">
        <table class="md-tbl">
          <thead><tr><th>Category</th><th>Note</th><th style="text-align:right;">Amount</th><th></th></tr></thead>
          <tbody id="md-exp-rows"></tbody>
        </table>
      </div>
      <div class="md-total" style="text-align:right; margin-top:8px;" id="md-exp-total">$0.00</div>
    </div>

    <div class="md-card">
      <h4>6 &middot; End of Day Report</h4>
      <div class="md-sub">One tap builds a clean prose summary of stops, visit times, mileage, and expenses, ready to paste into Salesforce or an email to your manager.</div>
      <div class="md-row">
        <button class="md-btn" onclick="mdCopyReport()">Copy Day Report</button>
        <button class="md-btn warn" onclick="mdNewDay()">Start New Day</button>
        <span id="md-copied" style="display:none; font-size:12px; color:#047857; font-weight:700;">Copied</span>
      </div>
      <pre id="md-report-preview" style="white-space:pre-wrap; font-size:12px; color:#374151; background:#f9fafb; border:1px solid var(--gray-200,#e5e7eb); border-radius:8px; padding:12px; margin-top:10px; display:none;"></pre>
    </div>

    <script>
      /* =========================================================
         MY DAY (v3.17 - frame, sample flow; map/GPS/auto-miles TBD)
         Data lives in localStorage under mbx_myday_v1.
         ========================================================= */
      function mdLoad() {
        try { return JSON.parse(localStorage.getItem('mbx_myday_v1')) || { date: mdToday(), stops: [], expenses: [] }; }
        catch (e) { return { date: mdToday(), stops: [], expenses: [] }; }
      }
      function mdSave(d) { localStorage.setItem('mbx_myday_v1', JSON.stringify(d)); }
      function mdToday() { return new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }); }
      function mdTime() { return new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }); }

      function mdAddStop() {
        var n = document.getElementById('md-stop-name').value.trim();
        var a = document.getElementById('md-stop-addr').value.trim();
        if (!n) return;
        var d = mdLoad();
        d.stops.push({ name: n, addr: a, arrived: '', departed: '', miles: '' });
        mdSave(d);
        document.getElementById('md-stop-name').value = '';
        document.getElementById('md-stop-addr').value = '';
        mdRender();
      }
      function mdDelStop(i) { var d = mdLoad(); d.stops.splice(i, 1); mdSave(d); mdRender(); }
      function mdStamp(i, k) { var d = mdLoad(); d.stops[i][k] = mdTime(); mdSave(d); mdRender(); }
      function mdMiles(i, v) { var d = mdLoad(); d.stops[i].miles = v; mdSave(d); mdRender(); }
      function mdAddExp() {
        var amt = parseFloat(document.getElementById('md-exp-amt').value);
        if (!amt) return;
        var d = mdLoad();
        d.expenses.push({ cat: document.getElementById('md-exp-cat').value, amt: amt, note: document.getElementById('md-exp-note').value.trim() });
        mdSave(d);
        document.getElementById('md-exp-amt').value = '';
        document.getElementById('md-exp-note').value = '';
        mdRender();
      }
      function mdDelExp(i) { var d = mdLoad(); d.expenses.splice(i, 1); mdSave(d); mdRender(); }
      function mdNewDay() {
        if (!confirm('Clear all stops, stamps, miles, and expenses and start a new day?')) return;
        mdSave({ date: mdToday(), stops: [], expenses: [] });
        document.getElementById('md-report-preview').style.display = 'none';
        mdRender();
      }
      function mdEsc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

      function mdRender() {
        var d = mdLoad();
        var stopsEl = document.getElementById('md-stops');
        if (!stopsEl) return;
        stopsEl.innerHTML = d.stops.length ? d.stops.map(function (s, i) {
          var maps = 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(s.addr || s.name);
          return '<div class="md-stop">' +
            '<div class="md-num">' + (i + 1) + '</div>' +
            '<div class="md-stop-main"><div class="md-stop-name">' + mdEsc(s.name) + '</div>' +
            (s.addr ? '<div class="md-stop-addr">' + mdEsc(s.addr) + '</div>' : '') + '</div>' +
            '<a class="md-btn ghost" style="text-decoration:none;" target="_blank" rel="noopener" href="' + maps + '">Maps</a>' +
            '<button class="md-btn warn" onclick="mdDelStop(' + i + ')">&times;</button>' +
            '</div>';
        }).join('') : '<div style="font-size:12px; color:#9ca3af; padding:6px 0;">No stops yet. Add your first account above.</div>';

        document.getElementById('md-visit-rows').innerHTML = d.stops.map(function (s, i) {
          var dur = '';
          if (s.arrived && s.departed) dur = mdDur(s.arrived, s.departed);
          return '<tr><td>' + (i + 1) + '</td><td>' + mdEsc(s.name) + '</td>' +
            '<td>' + (s.arrived ? '<span class="md-stamp">' + s.arrived + '</span>' : '<button class="md-btn ghost" onclick="mdStamp(' + i + ',\'arrived\')">Arrive</button>') + '</td>' +
            '<td>' + (s.departed ? '<span class="md-stamp">' + s.departed + '</span>' : '<button class="md-btn ghost" onclick="mdStamp(' + i + ',\'departed\')">Depart</button>') + '</td>' +
            '<td>' + dur + '</td><td></td></tr>';
        }).join('') || '<tr><td colspan="6" style="color:#9ca3af;">Stops appear here as you add them.</td></tr>';

        var legs = '';
        var totMi = 0;
        for (var i = 0; i < d.stops.length; i++) {
          var from = i === 0 ? 'Start of day' : d.stops[i - 1].name;
          var mi = parseFloat(d.stops[i].miles) || 0;
          totMi += mi;
          legs += '<tr><td>' + mdEsc(from) + ' &rarr; ' + mdEsc(d.stops[i].name) + '</td>' +
            '<td style="text-align:right;"><input class="md-miles-in" type="number" step="0.1" value="' + (d.stops[i].miles || '') + '" placeholder="auto" onchange="mdMiles(' + i + ', this.value)"></td></tr>';
        }
        document.getElementById('md-mile-rows').innerHTML = legs || '<tr><td colspan="2" style="color:#9ca3af;">Legs appear here as you add stops.</td></tr>';
        var rate = parseFloat(document.getElementById('md-rate').value) || 0;
        document.getElementById('md-mile-total').textContent = totMi.toFixed(1) + ' mi · $' + (totMi * rate).toFixed(2);

        var totExp = 0;
        document.getElementById('md-exp-rows').innerHTML = d.expenses.map(function (e, i) {
          totExp += e.amt;
          return '<tr><td>' + mdEsc(e.cat) + '</td><td>' + mdEsc(e.note || '') + '</td><td style="text-align:right;">$' + e.amt.toFixed(2) + '</td>' +
            '<td style="text-align:right;"><button class="md-btn warn" onclick="mdDelExp(' + i + ')">&times;</button></td></tr>';
        }).join('') || '<tr><td colspan="4" style="color:#9ca3af;">No expenses logged yet.</td></tr>';
        document.getElementById('md-exp-total').textContent = 'Day total $' + totExp.toFixed(2);
      }
      function mdDur(a, b) {
        function toMin(t) { var m = t.match(/(\d+):(\d+)\s*(AM|PM)/i); if (!m) return 0; var h = +m[1] % 12; if (/pm/i.test(m[3])) h += 12; return h * 60 + (+m[2]); }
        var diff = toMin(b) - toMin(a);
        if (diff < 0) diff += 1440;
        return diff < 60 ? diff + ' min' : Math.floor(diff / 60) + ' hr ' + (diff % 60) + ' min';
      }
      function mdCopyReport() {
        var d = mdLoad();
        var rate = parseFloat(document.getElementById('md-rate').value) || 0;
        var totMi = 0, totExp = 0;
        d.stops.forEach(function (s) { totMi += parseFloat(s.miles) || 0; });
        d.expenses.forEach(function (e) { totExp += e.amt; });
        var lines = ['Field Day Report. ' + (d.date || mdToday()) + '.', ''];
        d.stops.forEach(function (s, i) {
          var t = 'Stop ' + (i + 1) + '. ' + s.name + (s.addr ? ', ' + s.addr : '') + '.';
          if (s.arrived) t += ' Arrived ' + s.arrived + '.';
          if (s.departed) t += ' Departed ' + s.departed + '.';
          if (s.arrived && s.departed) t += ' Time on site ' + mdDur(s.arrived, s.departed) + '.';
          lines.push(t);
        });
        lines.push('');
        lines.push('Mileage total ' + totMi.toFixed(1) + ' miles at $' + rate.toFixed(3).replace(/0$/, '') + ' per mile equals $' + (totMi * rate).toFixed(2) + '.');
        if (d.expenses.length) {
          var parts = d.expenses.map(function (e) { return e.cat + ' $' + e.amt.toFixed(2) + (e.note ? ' (' + e.note + ')' : ''); });
          lines.push('Expenses. ' + parts.join(', ') + '. Expense total $' + totExp.toFixed(2) + '.');
        }
        lines.push('Combined reimbursement $' + (totMi * rate + totExp).toFixed(2) + '.');
        var txt = lines.join('\n');
        var pv = document.getElementById('md-report-preview');
        pv.textContent = txt; pv.style.display = 'block';
        if (navigator.clipboard) navigator.clipboard.writeText(txt);
        var c = document.getElementById('md-copied');
        c.style.display = 'inline'; setTimeout(function () { c.style.display = 'none'; }, 2000);
      }
      document.addEventListener('DOMContentLoaded', mdRender);
    </script>
  </div>

  <div class="tab-panel" id="tab-financing">
    <div class="section-head">
      <div class="section-icon icon-blue">&#128176;</div>
      <div>
        <div class="section-title">NewLane Financing &mdash; Monthly Payment Options</div>
        <div class="section-sub">Customer-facing &middot; enter the equipment price, show the doctor three monthly-payment options &middot; 12 / 24 / 36 months</div>
      </div>
    </div>
    <div style="background:#eff6ff; border:1px solid #bfdbfe; border-radius:10px; padding:12px 16px; margin-bottom:16px; font-size:12.5px; color:#1e3a8a;">
      &#9432; Show this screen to the doctor. It displays <strong>only the three monthly payments</strong> &mdash; the practice never carries the equipment cost up front; <strong>NewLane Finance</strong> pays PulmOne and collects the monthly payments directly. Internal discount / net-invoice figures are intentionally <strong>not</strong> shown here. Use <strong>Print / Save</strong> inside the tool to leave the options with the office.
    </div>
    <iframe id="financing-calc-iframe"
      style="width:100%; border:1px solid #e2e8f0; border-radius:10px; height:1180px; display:block; background:#f4f7fb;"
      title="MiniBox PFT Financing Calculator"
      srcdoc="&lt;!DOCTYPE html&gt;
&lt;!-- MiniBox Financing Calculator v1.0 — NewLane Finance program. CUSTOMER-FACING: shows monthly payment options only. No PulmOne discount / net-invoice figures are displayed anywhere in this file by design (per program terms). --&gt;
&lt;html lang=&quot;en&quot;&gt;
&lt;head&gt;
&lt;meta charset=&quot;UTF-8&quot;&gt;
&lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot;&gt;
&lt;title&gt;MiniBox PFT — Financing Options&lt;/title&gt;
&lt;style&gt;
  :root{
    --blue:#1a7fe0; --blue-d:#0f52a0; --blue-dd:#062960;
    --ink:#0f1b2d; --muted:#5a6b7e; --line:#e2e8f0; --bg:#f4f7fb;
    --card:#ffffff; --good:#0f9d58; --accent:#1a7fe0;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
    background:var(--bg); color:var(--ink); line-height:1.5; padding:18px; -webkit-text-size-adjust:100%}
  .wrap{max-width:760px;margin:0 auto}
  .head{background:linear-gradient(135deg,var(--blue-d),var(--blue-dd)); color:#fff; border-radius:16px;
    padding:24px 22px; text-align:center; box-shadow:0 6px 20px rgba(10,41,128,.18)}
  .head .brand{font-size:13px; letter-spacing:2px; text-transform:uppercase; opacity:.85; font-weight:600}
  .head h1{font-size:26px; margin:6px 0 4px; font-weight:800}
  .head p{font-size:14px; opacity:.9}
  .panel{background:var(--card); border:1px solid var(--line); border-radius:16px; padding:20px;
    margin-top:16px; box-shadow:0 2px 8px rgba(15,27,45,.04)}
  .label{font-size:12px; font-weight:700; letter-spacing:.5px; text-transform:uppercase; color:var(--muted); margin-bottom:8px}
  .price-row{display:flex; align-items:center; gap:12px; flex-wrap:wrap}
  .input-shell{display:flex; align-items:center; background:#fff; border:2px solid var(--blue);
    border-radius:12px; padding:6px 14px; flex:1; min-width:200px}
  .input-shell span{font-size:24px; font-weight:800; color:var(--blue-d); margin-right:4px}
  .input-shell input{border:0; outline:0; font-size:24px; font-weight:800; color:var(--ink); width:100%;
    background:transparent; font-family:inherit}
  .hint{font-size:12px; color:var(--muted); margin-top:8px}
  .cards{display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-top:6px}
  @media(max-width:620px){.cards{grid-template-columns:1fr}}
  .card{background:#fff; border:1px solid var(--line); border-radius:14px; padding:18px 16px;
    text-align:center; position:relative; transition:.15s; overflow:hidden}
  .card.feature{border:2px solid var(--blue); box-shadow:0 6px 18px rgba(26,127,224,.16)}
  .card .ribbon{position:absolute; top:0; left:0; right:0; background:var(--blue); color:#fff;
    font-size:10px; font-weight:800; letter-spacing:1px; padding:4px; text-transform:uppercase}
  .card .term{font-size:13px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:1px; margin-top:14px}
  .card .pay{font-size:34px; font-weight:800; color:var(--blue-d); margin:8px 0 0; line-height:1}
  .card .per{font-size:12px; color:var(--muted); margin-bottom:12px}
  .card .meta{border-top:1px dashed var(--line); padding-top:10px; font-size:13px; color:var(--ink)}
  .card .meta b{color:var(--blue-d)}
  .card .apr{display:inline-block; background:#eaf3fd; color:var(--blue-d); font-weight:700;
    font-size:12px; padding:3px 10px; border-radius:20px; margin-top:10px}
  .foot{margin-top:16px; font-size:12px; color:var(--muted); text-align:center; line-height:1.6}
  .foot b{color:var(--ink)}
  .powered{margin-top:6px; font-size:11px; color:var(--muted); text-align:center; letter-spacing:.5px}
  .chips{display:flex; gap:8px; flex-wrap:wrap; margin-top:12px}
  .chip{background:#eef4fb; border:1px solid #d6e4f5; color:var(--blue-d); border-radius:20px;
    padding:6px 12px; font-size:12px; font-weight:600; cursor:pointer; user-select:none}
  .chip:active{transform:scale(.97)}
  .print-btn{display:inline-block; margin-top:14px; background:var(--blue); color:#fff; border:0;
    border-radius:10px; padding:10px 18px; font-size:14px; font-weight:700; cursor:pointer; font-family:inherit}
  @media print{.input-shell{border-color:#999} .print-btn,.chips{display:none} body{background:#fff}}
&lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
&lt;div class=&quot;wrap&quot;&gt;

  &lt;div class=&quot;head&quot;&gt;
    &lt;div class=&quot;brand&quot;&gt;MiniBox PFT &amp;bull; PulmOne&lt;/div&gt;
    &lt;h1&gt;Flexible Monthly Financing&lt;/h1&gt;
    &lt;p&gt;Put a complete pulmonary function lab in your practice &amp;mdash; and spread the cost over time.&lt;/p&gt;
  &lt;/div&gt;

  &lt;div class=&quot;panel&quot;&gt;
    &lt;div class=&quot;label&quot;&gt;Equipment price&lt;/div&gt;
    &lt;div class=&quot;price-row&quot;&gt;
      &lt;div class=&quot;input-shell&quot;&gt;
        &lt;span&gt;$&lt;/span&gt;
        &lt;input id=&quot;price&quot; type=&quot;text&quot; inputmode=&quot;numeric&quot; value=&quot;39,000&quot; autocomplete=&quot;off&quot;&gt;
      &lt;/div&gt;
    &lt;/div&gt;
    &lt;div class=&quot;chips&quot;&gt;
      &lt;div class=&quot;chip&quot; onclick=&quot;setPrice(35000)&quot;&gt;$35,000&lt;/div&gt;
      &lt;div class=&quot;chip&quot; onclick=&quot;setPrice(39000)&quot;&gt;$39,000&lt;/div&gt;
      &lt;div class=&quot;chip&quot; onclick=&quot;setPrice(45000)&quot;&gt;$45,000&lt;/div&gt;
      &lt;div class=&quot;chip&quot; onclick=&quot;setPrice(49000)&quot;&gt;$49,000&lt;/div&gt;
    &lt;/div&gt;
    &lt;div class=&quot;hint&quot;&gt;Enter the equipment price (before applicable sales tax). Payments update automatically.&lt;/div&gt;
  &lt;/div&gt;

  &lt;div class=&quot;cards&quot; id=&quot;cards&quot;&gt;&lt;/div&gt;

  &lt;div class=&quot;panel&quot; style=&quot;text-align:center&quot;&gt;
    &lt;button class=&quot;print-btn&quot; onclick=&quot;window.print()&quot;&gt;&amp;#128424; Print / Save these options&lt;/button&gt;
    &lt;div class=&quot;foot&quot; style=&quot;margin-top:14px&quot;&gt;
      Financing provided by &lt;b&gt;NewLane Finance&lt;/b&gt;. Monthly payments shown are estimates based on the
      equipment price entered and the annual percentage rate (APR) for each term. Final terms are subject to
      credit approval and the executed finance agreement. Sales tax, if applicable, is additional.
    &lt;/div&gt;
    &lt;div class=&quot;powered&quot;&gt;MiniBox PFT Financing Calculator &amp;bull; v1.0&lt;/div&gt;
  &lt;/div&gt;

&lt;/div&gt;

&lt;script&gt;
/* ===== NewLane Finance program terms (customer-facing) ===== */
/* APR is the customer's annual percentage rate for each term.   */
/* Monthly payment = standard amortization of the price at APR.  */
var TERMS = [
  { months:12, apr:0.0199, tag:'Lowest rate' },
  { months:24, apr:0.0299, tag:'Most popular', feature:true },
  { months:36, apr:0.0399, tag:'Lowest payment' }
];

function money(n){ return '$' + n.toLocaleString('en-US',{minimumFractionDigits:2, maximumFractionDigits:2}); }
function money0(n){ return '$' + Math.round(n).toLocaleString('en-US'); }

/* monthly payment via standard amortization */
function payment(price, apr, n){
  var r = apr/12;
  if(r === 0) return price/n;
  return price * r / (1 - Math.pow(1+r, -n));
}

function getPrice(){
  var raw = (document.getElementById('price').value || '').replace(/[^0-9.]/g,'');
  var v = parseFloat(raw);
  return isNaN(v) ? 0 : v;
}

function setPrice(v){
  document.getElementById('price').value = v.toLocaleString('en-US');
  render();
}

function render(){
  var price = getPrice();
  var html = '';
  TERMS.forEach(function(t){
    var pmt = payment(price, t.apr, t.months);
    var total = pmt * t.months;
    html += '&lt;div class=&quot;card' + (t.feature ? ' feature' : '') + '&quot;&gt;';
    if(t.feature) html += '&lt;div class=&quot;ribbon&quot;&gt;' + t.tag + '&lt;/div&gt;';
    html += '&lt;div class=&quot;term&quot;&gt;' + t.months + ' Months&lt;/div&gt;';
    html += '&lt;div class=&quot;pay&quot;&gt;' + (price&gt;0 ? money(pmt) : '$0.00') + '&lt;/div&gt;';
    html += '&lt;div class=&quot;per&quot;&gt;per month&lt;/div&gt;';
    html += '&lt;div class=&quot;meta&quot;&gt;' + t.months + ' payments &amp;bull; total &lt;b&gt;' + (price&gt;0 ? money0(total) : '$0') + '&lt;/b&gt;&lt;/div&gt;';
    html += '&lt;div class=&quot;apr&quot;&gt;' + (t.apr*100).toFixed(2) + '% APR&lt;/div&gt;';
    html += '&lt;/div&gt;';
  });
  document.getElementById('cards').innerHTML = html;
}

/* live formatting + recompute */
var inp = document.getElementById('price');
inp.addEventListener('input', render);
inp.addEventListener('blur', function(){
  var v = getPrice();
  if(v&gt;0) inp.value = v.toLocaleString('en-US');
});

render();
&lt;/script&gt;
&lt;/body&gt;
&lt;/html&gt;
"></iframe>
  </div>

</div>

<script>
function showTab(id, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  btn.classList.add('active');
  /* Specialty picked from the dropdown: light up the Specialties tab itself and close the menu */
  var dd = btn.closest ? btn.closest('.tab-dd') : null;
  if (dd) {
    var parent = dd.querySelector('.tab-dd-parent');
    if (parent) parent.classList.add('active');
    mbxDdClose(dd);
  }
}
function mbxDdToggle(e) {
  if (e) e.stopPropagation();
  var dd = document.getElementById('mbx-specialties-dd');
  if (dd) dd.classList.toggle('open');
}
function mbxDdClose(dd) {
  dd.classList.remove('open');
  /* also defeat the desktop :hover-open for a beat so the menu actually closes under the pointer */
  var menu = dd.querySelector('.tab-dd-menu');
  if (menu) { menu.style.display = 'none'; setTimeout(function(){ menu.style.display = ''; }, 350); }
}
document.addEventListener('click', function(ev) {
  var dd = document.getElementById('mbx-specialties-dd');
  if (dd && dd.classList.contains('open') && !dd.contains(ev.target)) dd.classList.remove('open');
});

/* ============================================================
   SINGLE SOURCE OF TRUTH FOR REIMBURSEMENT RATES (v2.27)
   Update these ONCE here (when CMS changes, ~yearly) and every
   number across the toolkit follows automatically: the CPT
   table, the "max payout" line, the ROI calculator, the per-
   test grid, and the on-screen "rates current as of" stamp.
   ============================================================ */
var MINIBOX_RATES = {
  asOf: 'April 2026',        // <-- change this when you refresh the numbers below
  completePFT: 151.45,       // FVC + LVM pleth + DLCO, National Medicare/Medicaid avg
  weeksPerYear: 48,          // working weeks used in the yearly projection
  cpt: {
    '94010': { desc: 'Spirometry',                               rate: 27.34 },
    '94375': { desc: 'Spirometry Flow Volume Loop',              rate: 39.11 },
    '94060': { desc: 'Spirometry Pre & Post Bronchodilator',     rate: 38.80 },
    '94726': { desc: 'LVM Plethysmography (Total Lung Capacity)',rate: 55.72 },
    '94729': { desc: 'DLCO (Diffusing Capacity)',                rate: 59.87 }
  }
};

/* ---- ROI CALCULATOR SHARED DATA (all derived from MINIBOX_RATES above) ---- */
var ROI_RATE = MINIBOX_RATES.completePFT;
var ROI_WEEKS = MINIBOX_RATES.weeksPerYear;
var ROI_TESTS = 25;
var ROI_DEVICE = 30000;
var FS_TESTS = 25;
var FS_DEVICE = 30000;
var BAR_COLORS = ['#1a7fe0','#1569c0','#0f52a0','#0a3d80','#062960'];
var FS_BAR_COLORS = ['#5bc8f5','#3ab0e0','#1d94ca','#0e78b0','#065e94'];
var CPT_CODES = [
  {code:'94010', desc:'Spirometry only',          rate:MINIBOX_RATES.cpt['94010'].rate},
  {code:'94060', desc:'Pre & post bronchodilator', rate:MINIBOX_RATES.cpt['94060'].rate},
  {code:'94375', desc:'Flow volume loop',          rate:MINIBOX_RATES.cpt['94375'].rate},
  {code:'94726', desc:'Lung volumes (pleth)',      rate:MINIBOX_RATES.cpt['94726'].rate},
  {code:'94729', desc:'DLCO',                      rate:MINIBOX_RATES.cpt['94729'].rate}
];
var MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

function fmtShort(n) {
  if (n >= 1000000) return '$' + (n/1000000).toFixed(2) + 'M';
  if (n >= 1000) return '$' + Math.round(n/1000) + 'K';
  return '$' + Math.round(n).toLocaleString();
}
function fmtFull(n) { return '$' + Math.round(n).toLocaleString(); }

function addBizDays(days) {
  var d = new Date(); // v2.27: anchor to TODAY (was hardcoded April 10 2026)
  d.setHours(0,0,0,0);
  var added = 0;
  while (added < days) {
    d.setDate(d.getDate() + 1);
    var dow = d.getDay();
    if (dow !== 0 && dow !== 6) added++;
  }
  return d;
}

function getCalcValues(tests, device) {
  var daily = (tests / 5) * ROI_RATE;
  var week = tests * ROI_RATE;
  var month = (tests * ROI_WEEKS / 12) * ROI_RATE;
  var y1 = tests * ROI_WEEKS * ROI_RATE;
  var bkDays = Math.ceil(device / daily);
  var bkDate = addBizDays(bkDays);
  var bkWeeks = Math.round(bkDays / 5 * 10) / 10;
  var dateStr = MONTHS[bkDate.getMonth()] + ' ' + bkDate.getDate() + ', ' + bkDate.getFullYear();
  return {
    daily: daily, week: week, month: month, y1: y1,
    y3: y1*3, y5: y1*5,
    bkDays: bkDays, bkWeeks: bkWeeks, dateStr: dateStr,
    profit: Math.max(0, y1 - device)
  };
}

/* ---- MAIN CALCULATOR ---- */
function roiCalc() {
  var tests = parseInt(document.getElementById('roi-slider').value) || 1;
  var device = parseFloat(document.getElementById('roi-device-cost').value) || 30000;
  var v = getCalcValues(tests, device);

  document.getElementById('roi-tests-display').textContent = tests;
  document.getElementById('roi-per-day').textContent = (tests/5).toFixed(1) + ' per day';
  document.getElementById('roi-week').textContent = fmtFull(v.week);
  document.getElementById('roi-month').textContent = fmtFull(v.month);
  document.getElementById('roi-y1').textContent = fmtShort(v.y1);
  document.getElementById('roi-y3').textContent = fmtShort(v.y3);
  document.getElementById('roi-y5').textContent = fmtShort(v.y5);
  document.getElementById('roi-days').textContent = v.bkDays + ' days';
  document.getElementById('roi-days-sub').textContent = (tests/5).toFixed(1) + ' tests/day';
  document.getElementById('roi-date').textContent = v.dateStr;
  document.getElementById('roi-weeks').textContent = v.bkWeeks + ' working weeks from today';
  document.getElementById('roi-profit').textContent = fmtShort(v.profit);

  var years = [
    {label:'Yr 1', val:v.y1}, {label:'Yr 2', val:v.y1*2},
    {label:'Yr 3', val:v.y3}, {label:'Yr 4', val:v.y1*4}, {label:'Yr 5', val:v.y5}
  ];
  var barsEl = document.getElementById('roi-bars');
  var labelsEl = document.getElementById('roi-bar-labels');
  barsEl.innerHTML = ''; labelsEl.innerHTML = '';
  years.forEach(function(y, i) {
    var pct = v.y5 > 0 ? Math.max(5, (y.val/v.y5)*100) : 5;
    var bar = document.createElement('div');
    bar.className = 'roi-bar-col';
    bar.style.cssText = 'flex:1; background:' + BAR_COLORS[i] + '; border-radius:5px 5px 0 0; height:' + pct + '%; display:flex; align-items:flex-start; justify-content:center; padding-top:5px;';
    bar.innerHTML = '<span style="font-size:10px; font-weight:600; color:rgba(255,255,255,0.9);">' + fmtShort(y.val) + '</span>';
    barsEl.appendChild(bar);
    var lbl = document.createElement('div');
    lbl.className = 'roi-bar-label';
    lbl.textContent = y.label;
    labelsEl.appendChild(lbl);
  });

  var cptGrid = document.getElementById('roi-cpt-grid');
  cptGrid.innerHTML = '';
  CPT_CODES.forEach(function(c) {
    var div = document.createElement('div');
    div.className = 'roi-cpt-card';
    div.innerHTML = '<div style="font-size:10.5px; color:var(--gray-600); margin-bottom:3px;"><span class="cpt-code">' + c.code + '</span> ' + c.desc + '</div><div style="font-size:14px; font-weight:700; color:var(--blue-dark);">' + fmtFull(tests * c.rate) + '<span style="font-weight:400; font-size:11.5px; color:var(--gray-600);">/wk</span></div>';
    cptGrid.appendChild(div);
  });
}

function roiChangeTests(delta) {
  var s = document.getElementById('roi-slider');
  var cur = parseInt(s.value) || 25;
  var next = Math.min(100, Math.max(1, cur + delta));
  s.value = next;
  roiCalc();
}
function roiUpdateFromSlider() { roiCalc(); }

/* ---- FULLSCREEN CALCULATOR ---- */
function fsCalc() {
  var tests = parseInt(document.getElementById('fs-slider').value) || 1;
  var device = parseFloat(document.getElementById('fs-device-cost').value) || 30000;
  var v = getCalcValues(tests, device);

  document.getElementById('fs-tests-val').textContent = tests;
  document.getElementById('fs-per-day').textContent = (tests/5).toFixed(1) + ' per day';
  document.getElementById('fs-hero-num').textContent = fmtShort(v.y1);
  document.getElementById('fs-hero-sub').textContent = 'based on ' + tests + ' complete PFTs per week';

  var cardData = [
    {label:'Per Week', val:fmtFull(v.week)},
    {label:'Per Month', val:fmtFull(v.month)},
    {label:'Year 1', val:fmtShort(v.y1)},
    {label:'Year 3', val:fmtShort(v.y3)},
    {label:'Year 5', val:fmtShort(v.y5)}
  ];
  var cardsEl = document.getElementById('fs-cards');
  cardsEl.innerHTML = '';
  cardData.forEach(function(c) {
    cardsEl.innerHTML += '<div class="fs-card"><div class="fs-card-label">' + c.label + '</div><div class="fs-card-num">' + c.val + '</div></div>';
  });

  var bkData = [
    {label:'Breakeven in', num:v.bkDays + ' days', sub:(tests/5).toFixed(1) + ' tests per day'},
    {label:'Breakeven date', num:v.dateStr, sub:v.bkWeeks + ' working weeks from now'},
    {label:'Pure profit, Year 1', num:fmtShort(v.profit), sub:'after device pays off'}
  ];
  var bkEl = document.getElementById('fs-breakeven');
  bkEl.innerHTML = '';
  bkData.forEach(function(b) {
    bkEl.innerHTML += '<div class="fs-bcard"><div class="fs-bcard-label">' + b.label + '</div><div class="fs-bcard-num">' + b.num + '</div><div class="fs-bcard-sub">' + b.sub + '</div></div>';
  });

  var years = [
    {label:'Yr 1', val:v.y1}, {label:'Yr 2', val:v.y1*2},
    {label:'Yr 3', val:v.y3}, {label:'Yr 4', val:v.y1*4}, {label:'Yr 5', val:v.y5}
  ];
  var barsEl = document.getElementById('fs-bars');
  var labelsEl = document.getElementById('fs-bar-labels');
  barsEl.innerHTML = ''; labelsEl.innerHTML = '';
  years.forEach(function(y, i) {
    var pct = v.y5 > 0 ? Math.max(5, (y.val/v.y5)*100) : 5;
    var bar = document.createElement('div');
    bar.style.cssText = 'flex:1; background:' + FS_BAR_COLORS[i] + '; border-radius:5px 5px 0 0; height:' + pct + '%; display:flex; align-items:flex-start; justify-content:center; padding-top:6px;';
    bar.innerHTML = '<span style="font-size:11px; font-weight:600; color:rgba(255,255,255,0.9);">' + fmtShort(y.val) + '</span>';
    barsEl.appendChild(bar);
    var lbl = document.createElement('div');
    lbl.style.cssText = 'flex:1; text-align:center; font-size:12px; color:#7ab6e0; font-weight:500;';
    lbl.textContent = y.label;
    labelsEl.appendChild(lbl);
  });
}

function fsChangeTests(delta) {
  var s = document.getElementById('fs-slider');
  var cur = parseInt(s.value) || 25;
  var next = Math.min(100, Math.max(1, cur + delta));
  s.value = next;
  fsCalc();
}
function fsUpdateFromSlider() { fsCalc(); }

function openROIFullscreen() {
  var mainTests = parseInt(document.getElementById('roi-slider').value) || 25;
  var mainDevice = parseFloat(document.getElementById('roi-device-cost').value) || 30000;
  document.getElementById('fs-slider').value = mainTests;
  document.getElementById('fs-device-cost').value = mainDevice;
  document.getElementById('roi-fullscreen').classList.add('open');
  document.body.style.overflow = 'hidden';
  fsCalc();
  if (document.documentElement.requestFullscreen) {
    document.documentElement.requestFullscreen().catch(function(){});
  }
}

function closeROIFullscreen() {
  document.getElementById('roi-fullscreen').classList.remove('open');
  document.body.style.overflow = '';
  if (document.exitFullscreen && document.fullscreenElement) {
    document.exitFullscreen().catch(function(){});
  }
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeROIFullscreen();
});

/* ---- ACH FORM ---- */
var achRowCount = 0;

function achAddRow() {
  achRowCount++;
  var tbody = document.getElementById('ach-payment-rows');
  var tr = document.createElement('tr');
  tr.id = 'ach-row-' + achRowCount;
  tr.innerHTML =
    '<td class="td-num">' + (tbody.rows.length + 1) + '</td>' +
    '<td><input type="text" oninput="achUpdateNums()" style="width:100%;"></td>' +
    '<td><input type="number" min="0" step="0.01" placeholder="0.00" oninput="achRecalc()" style="width:100%;"></td>' +
    '<td class="td-del"><button class="ach-del-btn" onclick="achDeleteRow(' + achRowCount + ')">&#215;</button></td>';
  tbody.appendChild(tr);
  achRecalc();
}

function achDeleteRow(id) {
  var row = document.getElementById('ach-row-' + id);
  if (row) row.remove();
  achUpdateNums();
  achRecalc();
}

function achUpdateNums() {
  var rows = document.querySelectorAll('#ach-payment-rows tr');
  rows.forEach(function(r, i) { r.cells[0].textContent = i + 1; });
}

function achFmt(n) {
  return '$' + (n || 0).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
}

/* v2.6: unified recalc that handles down payment + scheduled payments + balance check */
function achRecalc() {
  // 1. Purchase price + down payment inputs
  var price = parseFloat((document.getElementById('ach-purchase-price') || {}).value) || 0;
  var dp    = parseFloat((document.getElementById('ach-down-payment')   || {}).value) || 0;

  // 2. Balance to finance
  var balance = Math.max(0, price - dp);
  var balEl = document.getElementById('ach-balance-financed');
  if (balEl) balEl.value = (price > 0 || dp > 0) ? achFmt(balance) : ''; /* v3.9: blank until a price/down-payment is entered (DocuSign-clean) */

  // 3. Scheduled payments subtotal (existing payment rows)
  var inputs = document.querySelectorAll('#ach-payment-rows td:nth-child(3) input');
  var scheduled = 0;
  inputs.forEach(function(inp) { scheduled += parseFloat(inp.value) || 0; });

  // 4. Display each line
  document.getElementById('ach-total').textContent        = achFmt(scheduled);
  document.getElementById('ach-dp-display').textContent   = achFmt(dp);
  document.getElementById('ach-sched-display').textContent = achFmt(scheduled);

  // 5. Grand total = down payment + scheduled
  var grand = dp + scheduled;
  document.getElementById('ach-grand-total').textContent = achFmt(grand);

  // 6. Balance check vs purchase price (only show if price was entered)
  var check = document.getElementById('ach-balance-check');
  if (!check) return;
  if (price <= 0) {
    check.style.display = 'none';
    return;
  }
  check.style.display = 'block';
  var diff = Math.round((grand - price) * 100) / 100; // round to cents
  if (Math.abs(diff) < 0.01) {
    check.style.background = '#e8f8f0';
    check.style.color = '#1e6b42';
    check.style.border = '1px solid #27ae60';
    check.innerHTML = '&#10003; Grand Total matches Purchase Price exactly.';
  } else if (diff < 0) {
    check.style.background = '#fef3e2';
    check.style.color = '#8a4b10';
    check.style.border = '1px solid #e67e22';
    check.innerHTML = '&#9888; Short by ' + achFmt(-diff) + ' &mdash; add more scheduled payments or increase the down payment.';
  } else {
    check.style.background = '#fde8e6';
    check.style.color = '#8a1f14';
    check.style.border = '1px solid #c0392b';
    check.innerHTML = '&#9888; Over by ' + achFmt(diff) + ' &mdash; reduce scheduled payments or decrease the down payment.';
  }
}

/* Backward compat for any leftover handlers */
function achCalcTotal() { achRecalc(); }

/* v2.7: auto-fill equal payments from financed balance */
function achAddMonthsSafe(dt, months) {
  var d = new Date(dt.getTime());
  var day = d.getDate();
  d.setDate(1);
  d.setMonth(d.getMonth() + months);
  var lastDay = new Date(d.getFullYear(), d.getMonth() + 1, 0).getDate();
  d.setDate(Math.min(day, lastDay));
  return d;
}
function achFmtDate(d) {
  var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  return months[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
}
function achFillSchedule() {
  /* v2.8: Calculator math IDENTICAL to v2.7. Only the date COLUMN changes based on Start Trigger mode. */
  var price = parseFloat((document.getElementById('ach-purchase-price') || {}).value) || 0;
  var dp    = parseFloat((document.getElementById('ach-down-payment')   || {}).value) || 0;
  var n     = parseInt((document.getElementById('ach-num-payments')     || {}).value, 10) || 0;
  var firstVal = (document.getElementById('ach-first-pmt-date') || {}).value;
  var freq  = ((document.getElementById('ach-frequency') || {}).value) || 'monthly';

  /* v2.8 additions — mode + anchor language (only affect date column text) */
  var mode = 'dates';
  var radios = document.getElementsByName('ach-start-mode');
  for (var r = 0; r < radios.length; r++) { if (radios[r].checked) { mode = radios[r].value; break; } }
  var anchorRaw = ((document.getElementById('ach-anchor-lang') || {}).value || '').trim();
  var anchor = anchorRaw || 'after install';

  if (price <= 0) { alert('Enter a Total Purchase Price first.'); return; }
  if (n <= 0) { alert('Enter a valid number of payments (1 or more).'); return; }
  var balance = Math.max(0, price - dp);
  if (balance <= 0) {
    if (!confirm('Financed balance is $0 (down payment covers the full price). Clear the schedule anyway?')) return;
  }

  /* Per-payment math — UNCHANGED from v2.7 */
  var perPayment = Math.round((balance / n) * 100) / 100;
  var totalMinusLast = Math.round(perPayment * (n - 1) * 100) / 100;
  var lastPayment = Math.round((balance - totalMinusLast) * 100) / 100;

  var startDate = firstVal ? new Date(firstVal + 'T00:00:00') : new Date();

  /* Days offset per payment index — used only in Post-Install mode */
  function offsetDaysPerIndex(i) {
    if (freq === 'quarterly') return (i + 1) * 90;
    if (freq === 'biweekly')  return (i + 1) * 14;
    if (freq === 'weekly')    return (i + 1) * 7;
    return (i + 1) * 30; /* monthly default */
  }
  function periodLabel(i) {
    if (freq === 'quarterly') return 'Quarter ' + (i + 1);
    if (freq === 'biweekly')  return 'Payment ' + (i + 1);
    if (freq === 'weekly')    return 'Payment ' + (i + 1);
    return 'Month ' + (i + 1);
  }

  /* Clear existing rows */
  document.getElementById('ach-payment-rows').innerHTML = '';
  achRowCount = 0;

  for (var i = 0; i < n; i++) {
    var dateStr;
    if (mode === 'postinstall') {
      /* v2.9: Row 1 states the trigger; subsequent rows use period label. */
      if (i === 0) {
        var trigger = anchorRaw || 'Payment will begin day of install and training';
        dateStr = trigger;
      } else {
        dateStr = periodLabel(i);
      }
    } else {
      /* Specific Dates (current behavior). If user typed anchor language, append it. */
      var d;
      if (freq === 'monthly')        d = achAddMonthsSafe(startDate, i);
      else if (freq === 'quarterly') d = achAddMonthsSafe(startDate, i * 3);
      else if (freq === 'biweekly')  { d = new Date(startDate.getTime()); d.setDate(d.getDate() + i * 14); }
      else if (freq === 'weekly')    { d = new Date(startDate.getTime()); d.setDate(d.getDate() + i * 7); }
      else                           d = achAddMonthsSafe(startDate, i);
      dateStr = achFmtDate(d);
      if (anchorRaw) { dateStr = dateStr + ' (' + anchorRaw + ')'; }
    }

    achRowCount++;
    var tbody = document.getElementById('ach-payment-rows');
    var tr = document.createElement('tr');
    tr.id = 'ach-row-' + achRowCount;
    var amount = (i === n - 1) ? lastPayment : perPayment;
    tr.innerHTML =
      '<td class="td-num">' + (i + 1) + '</td>' +
      '<td><input type="text" value="' + dateStr.replace(/"/g, '&quot;') + '" oninput="achUpdateNums()" style="width:100%;"></td>' +
      '<td><input type="number" min="0" step="0.01" value="' + amount.toFixed(2) + '" oninput="achRecalc()" style="width:100%;"></td>' +
      '<td class="td-del"><button class="ach-del-btn" onclick="achDeleteRow(' + achRowCount + ')">&#215;</button></td>';
    tbody.appendChild(tr);
  }
  achRecalc();
}

function achClear() {
  if (!confirm('Clear all form fields?')) return;
  ['ach-date','ach-customer','ach-bank-name','ach-bank-addr','ach-routing','ach-account','ach-purchase-price','ach-down-payment','ach-dp-date','ach-first-pmt-date','ach-anchor-lang'].forEach(function(id) {
    var el = document.getElementById(id); if (el) el.value = '';
  });
  var balEl = document.getElementById('ach-balance-financed');
  if (balEl) balEl.value = '$0.00';
  document.getElementById('ach-payment-rows').innerHTML = '';
  achRowCount = 0;
  achRecalc();
  // Add 3 blank rows to start
  achAddRow(); achAddRow(); achAddRow();
}

function achPrint() {
  document.getElementById('ach-form-card').classList.add('print-target');
  window.print();
  document.getElementById('ach-form-card').classList.remove('print-target');
}

// Init ACH with 3 rows + recalc (v2.6)
(function() { achAddRow(); achAddRow(); achAddRow(); achRecalc(); })();

/* ---- v3.9: ACH date left BLANK by design so the saved PDF carries no data; DocuSign overlays the date field ---- */

/* ---- EMAIL COMPOSER ---- */
