<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>Command Center — MiniBox+ Toolkit</title>
<link rel="icon" href="./favicon-32.png">
<style>
  :root{
    --ink:#e8eaed; --ink-dim:#9aa3ad; --line:#252a31;
    --panel:#14181d; --panel-2:#1a1f26; --bg:#0c0f13;
    --red:#e05a4e; --amber:#d1a04a; --green:#4f9d6a;
    --mono:ui-monospace,'SFMono-Regular',Consolas,monospace;
  }
  *{box-sizing:border-box}
  html,body{margin:0;background:var(--bg);color:var(--ink);
    font-family:-apple-system,'Segoe UI',Roboto,Arial,sans-serif;}
  a{color:var(--ink)}
  .wrap{max-width:920px;margin:0 auto;padding:24px 18px 70px;}
  .kicker{font:600 11px/1 var(--mono);letter-spacing:.22em;text-transform:uppercase;color:var(--ink-dim);}
  h1{font-size:26px;margin:10px 0 6px;letter-spacing:-.01em;}
  h2{font-size:13px;margin:30px 0 12px;letter-spacing:.18em;text-transform:uppercase;
    font-family:var(--mono);color:var(--ink-dim);font-weight:600;
    border-bottom:1px solid var(--line);padding-bottom:9px;}
  .lede{color:var(--ink-dim);font-size:14px;line-height:1.55;max-width:660px;margin:0 0 18px;}

  /* ── lock screen ── */
  #lock{max-width:340px;margin:14vh auto 0;text-align:center;}
  #lock .mark{width:70px;height:70px;border:1px solid var(--line);border-radius:16px;margin:0 auto 20px;
    display:flex;align-items:center;justify-content:center;font:800 26px/1 var(--mono);color:var(--ink-dim);}
  #lock input{width:100%;padding:13px 14px;border-radius:10px;border:1px solid var(--line);
    background:var(--panel);color:var(--ink);font-size:16px;text-align:center;margin:16px 0 10px;}
  #lock button{width:100%;padding:13px;border:0;border-radius:10px;background:var(--ink);color:#0c0f13;
    font-weight:800;font-size:15px;cursor:pointer;}
  #lockerr{color:var(--red);font-size:13px;font-weight:700;min-height:19px;margin-top:11px;}
  #lock .hint{color:var(--ink-dim);font-size:12px;margin-top:18px;line-height:1.5;}

  /* ── stats ── */
  .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:6px;}
  .stat{border:1px solid var(--line);background:var(--panel);border-radius:11px;padding:14px 15px;}
  .stat b{display:block;font:800 26px/1.1 var(--mono);letter-spacing:-.02em;}
  .stat span{display:block;font:600 10.5px/1.4 var(--mono);letter-spacing:.14em;text-transform:uppercase;color:var(--ink-dim);margin-top:7px;}
  .stat.alert b{color:var(--red)}

  .bar{display:flex;gap:8px;flex-wrap:wrap;align-items:center;padding:12px 0;}
  .filt{background:transparent;color:var(--ink-dim);border:1px solid var(--line);
    border-radius:999px;padding:6px 13px;font:700 12px/1 inherit;cursor:pointer;}
  .filt.on{color:var(--ink);border-color:#43505e;background:var(--panel-2);}
  .spacer{flex:1}
  .ghost{background:transparent;color:var(--ink-dim);border:1px solid var(--line);
    border-radius:8px;padding:6px 12px;font:700 12px/1 inherit;cursor:pointer;}

  .card{border:1px solid var(--line);background:var(--panel);border-radius:12px;padding:15px 16px;margin-bottom:11px;}
  .card.fixed{opacity:.5}
  .meta{display:flex;gap:10px;align-items:baseline;flex-wrap:wrap;
    font:600 11px/1.4 var(--mono);letter-spacing:.08em;text-transform:uppercase;color:var(--ink-dim);margin-bottom:9px;}
  .who{color:var(--ink);letter-spacing:.04em;}
  .pill{border:1px solid var(--line);border-radius:999px;padding:3px 9px;}
  .pill.open{color:var(--red);border-color:#4a2b28;}
  .pill.working{color:var(--amber);border-color:#4a3d23;}
  .pill.fixed{color:var(--green);border-color:#26402f;}
  .body{font-size:15px;line-height:1.6;white-space:pre-wrap;word-break:break-word;}
  .note{margin-top:9px;font-size:13px;color:var(--ink-dim);border-left:2px solid var(--line);padding-left:10px;}
  .acts{display:flex;gap:7px;flex-wrap:wrap;margin-top:13px;border-top:1px solid var(--line);padding-top:12px;}
  .act{background:transparent;border:1px solid var(--line);color:var(--ink-dim);
    border-radius:8px;padding:6px 12px;font:700 12px/1 inherit;cursor:pointer;}
  .act:hover{color:var(--ink);border-color:#43505e;}
  .empty{border:1px dashed var(--line);border-radius:12px;padding:34px 20px;text-align:center;color:var(--ink-dim);font-size:14px;}

  .q{border-bottom:1px solid var(--line);padding:12px 2px;}
  .q:last-child{border-bottom:0}
  .q .ask{font-size:14.5px;line-height:1.55;}
  .q .ans{font-size:13px;line-height:1.55;color:var(--ink-dim);margin-top:6px;}
  .people{display:flex;flex-wrap:wrap;gap:7px;margin-top:4px;}
  .person{border:1px solid var(--line);border-radius:999px;padding:6px 12px;font-size:12.5px;}
  .person b{font-family:var(--mono);color:var(--ink-dim);margin-left:6px;}

  /* ── usage ── */
  .cols{display:grid;grid-template-columns:1fr 1fr;gap:11px;}
  @media (max-width:680px){ .cols{grid-template-columns:1fr;} }
  .rank{list-style:none;margin:0;padding:0;}
  .rank li{position:relative;padding:8px 10px;margin-bottom:3px;border-radius:7px;
    display:flex;justify-content:space-between;align-items:center;gap:12px;
    font-size:13.5px;overflow:hidden;}
  .rank li .fill{position:absolute;inset:0 auto 0 0;background:#1e2a35;border-radius:7px;z-index:0;}
  .rank li .nm,.rank li .ct{position:relative;z-index:1;}
  .rank li .nm{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .rank li .ct{font:700 12px/1 var(--mono);color:var(--ink-dim);flex:none;}

  .chart{display:flex;align-items:flex-end;gap:3px;height:96px;margin:4px 0 8px;}
  .chart .col{flex:1;display:flex;flex-direction:column;justify-content:flex-end;height:100%;}
  .chart .col i{display:block;background:#3a6b8a;border-radius:3px 3px 0 0;min-height:2px;}
  .chart .col.today i{background:#5b93b8;}
  .chartx{display:flex;gap:3px;font:600 9.5px/1 var(--mono);color:var(--ink-dim);}
  .chartx span{flex:1;text-align:center;overflow:hidden;}

  table.reps{width:100%;border-collapse:collapse;font-size:13.5px;}
  table.reps th{text-align:left;font:600 10.5px/1.4 var(--mono);letter-spacing:.12em;
    text-transform:uppercase;color:var(--ink-dim);padding:0 8px 9px;border-bottom:1px solid var(--line);}
  table.reps td{padding:11px 8px;border-bottom:1px solid var(--line);vertical-align:top;}
  table.reps tr:last-child td{border-bottom:0}
  table.reps td.n{font-family:var(--mono);color:var(--ink-dim);white-space:nowrap;}
  table.reps .nm{font-weight:600}
  table.reps .anon{color:var(--ink-dim);font-style:italic;font-weight:400;}
  .cold{color:var(--amber)}
  .quiet{color:var(--red)}
</style>
</head>
<body>

<div id="lock">
  <div class="mark">M+</div>
  <div class="kicker">MiniBox+ Toolkit</div>
  <h1 style="font-size:21px;margin:9px 0 0;">Command Center</h1>
  <p style="color:var(--ink-dim);font-size:13.5px;margin:8px 0 0;">Owner only. This is a second password, not the team one.</p>
  <input id="lockpw" type="password" placeholder="Admin password" autocomplete="current-password"
         autocapitalize="none" autocorrect="off" spellcheck="false">
  <button onclick="unlock()">Open</button>
  <div id="lockerr"></div>
  <div class="hint">The team password gets you into the toolkit.<br>This one shows what the team is reporting and asking.</div>
</div>

<div class="wrap" id="app" style="display:none">
  <div class="kicker">MiniBox+ Toolkit</div>
  <h1>Command Center</h1>
  <p class="lede">Everything the team is telling you, in one place. Problem reports come in from
    <b>Report a problem</b> — in Team Chat or from the Boxy button on any screen.
    <a href="./index.html">Back to the toolkit</a> ·
    <a href="#" onclick="lockAgain();return false;">Lock this</a></p>

  <div class="stats" id="stats"></div>

  <h2>Problem Reports</h2>
  <div class="bar">
    <button class="filt on" data-f="open">Open</button>
    <button class="filt" data-f="working">Working on it</button>
    <button class="filt" data-f="fixed">Fixed</button>
    <button class="filt" data-f="all">All</button>
    <span class="spacer"></span>
    <button class="ghost" onclick="load()">Refresh</button>
  </div>
  <div id="list"></div>

  <h2>What the team is asking Boxy</h2>
  <div class="card" id="questions"></div>

  <h2>What's actually getting used</h2>
  <p class="lede" style="margin-bottom:14px;">Every screen opened and button pressed in the toolkit.
    Nothing anyone types is recorded &mdash; no notes, no emails, no customer names.
    Reps see none of this.</p>
  <div class="bar">
    <button class="filt" data-d="7">7 days</button>
    <button class="filt on" data-d="14">14 days</button>
    <button class="filt" data-d="30">30 days</button>
    <span class="spacer"></span>
    <button class="ghost" onclick="copyUsage()">Copy summary</button>
  </div>
  <div id="usage"><div class="empty">Loading&hellip;</div></div>

  <h2>Team Chat activity</h2>
  <div class="card" id="whos"></div>
</div>

<script>
var API = '/api/admin';
var KEYSTORE = 'mbx_admin_key';
var key = '';
var filter = 'open';
var data = { issues: [], questions: [], pulse: {} };

function esc(s){ return String(s==null?'':s).replace(/[&<>"']/g,function(c){
  return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }

function when(ts){
  if(!ts) return '';
  var d = new Date(ts), mins = Math.round((Date.now()-ts)/60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + ' min ago';
  if (mins < 60*24) return Math.round(mins/60) + ' hr ago';
  return d.toLocaleDateString(undefined,{month:'short',day:'numeric'}) + ' · ' +
         d.toLocaleTimeString(undefined,{hour:'numeric',minute:'2-digit'});
}

function call(payload){
  payload.key = key;
  return fetch(API, { method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify(payload) }).then(function(r){
      if (r.status === 401) throw new Error('bad-key');
      return r.json();
    });
}

/* ── lock screen ── */
function unlock(){
  var pw = (document.getElementById('lockpw').value || '').trim();
  if (!pw) return;
  var err = document.getElementById('lockerr');
  err.textContent = 'Checking…';
  key = pw;
  call({ action:'load' })
    .then(function(d){
      if (!d || !d.ok) throw new Error('x');
      try { sessionStorage.setItem(KEYSTORE, key); } catch(e){}
      err.textContent = '';
      document.getElementById('lock').style.display = 'none';
      document.getElementById('app').style.display = 'block';
      apply(d);
      loadUsage();
      setInterval(load, 60000);
    })
    .catch(function(e){
      key = '';
      err.textContent = (e && e.message === 'bad-key')
        ? 'That is not the admin password.' : 'Could not reach the server — try again.';
    });
}
function lockAgain(){
  try { sessionStorage.removeItem(KEYSTORE); } catch(e){}
  location.reload();
}

/* ── render ── */
function apply(d){
  data = d;
  var open = (d.issues||[]).filter(function(i){ return (i.status||'open')==='open'; }).length;
  var p = d.pulse || {};
  document.getElementById('stats').innerHTML =
      stat(open, 'Open problems', open > 0)
    + stat((d.issues||[]).length, 'Reports all time')
    + stat(p.today || 0, 'Messages today')
    + stat((p.people||[]).length, 'Reps active this week')
    + stat(p.boxyWeek || 0, 'Boxy answers this week');
  render();
  renderQuestions();
  renderPeople();
  // When embedded in the toolkit's Command Center tab, tell the parent how many
  // problems are open so the tab can carry a red badge.
  try { if (window.parent && window.parent !== window) window.parent.postMessage({ mbxOpenProblems: open }, '*'); } catch (e) {}
}
function stat(n, label, alert){
  return '<div class="stat' + (alert ? ' alert' : '') + '"><b>' + n + '</b><span>' + label + '</span></div>';
}

function render(){
  var list = document.getElementById('list');
  var shown = (data.issues||[]).filter(function(i){ return filter === 'all' || (i.status||'open') === filter; });
  if (!shown.length){
    list.innerHTML = '<div class="empty">' + (filter === 'open'
      ? 'No open problems. Nothing is broken that anyone has told you about.'
      : 'Nothing in this list yet.') + '</div>';
    return;
  }
  list.innerHTML = shown.map(function(i){
    var st = i.status || 'open';
    return '<div class="card ' + st + '">'
      + '<div class="meta">'
        + '<span class="who">' + esc(i.name || 'Someone') + '</span>'
        + '<span>' + esc(i.screen || '') + '</span>'
        + '<span>' + esc(when(i.ts)) + '</span>'
        + '<span class="pill ' + st + '">' + (st === 'working' ? 'Working on it' : st) + '</span>'
      + '</div>'
      + '<div class="body">' + esc(i.text) + '</div>'
      + (i.note ? '<div class="note">' + esc(i.note) + '</div>' : '')
      + '<div class="acts">'
        + (st !== 'working' ? '<button class="act" onclick="mark(\'' + i.id + '\',\'working\')">Working on it</button>' : '')
        + (st !== 'fixed'   ? '<button class="act" onclick="mark(\'' + i.id + '\',\'fixed\')">Mark fixed</button>' : '')
        + (st !== 'open'    ? '<button class="act" onclick="mark(\'' + i.id + '\',\'open\')">Reopen</button>' : '')
        + '<button class="act" onclick="addNote(\'' + i.id + '\',\'' + st + '\')">Add a note</button>'
        + '<button class="act" onclick="copyOne(\'' + i.id + '\')">Copy</button>'
      + '</div>'
    + '</div>';
  }).join('');
}

function renderQuestions(){
  var q = (data.questions||[]).filter(function(x){ return !/ISSUE REPORT/i.test(x.text || ''); }).slice(0, 20);
  document.getElementById('questions').innerHTML = q.length
    ? q.map(function(x){
        return '<div class="q"><div class="meta"><span class="who">' + esc(x.name||'') + '</span><span>'
          + esc(when(x.ts)) + '</span>' + (x.ai ? '' : '<span class="pill">no AI answer</span>') + '</div>'
          + '<div class="ask">' + esc(x.text) + '</div>'
          + '<div class="ans">Boxy: ' + esc(String(x.reply||'').slice(0, 320)) + '</div></div>';
      }).join('')
    : '<div style="color:var(--ink-dim);font-size:14px;">No questions yet.</div>';
}

function renderPeople(){
  var p = (data.pulse||{}).people || [];
  document.getElementById('whos').innerHTML = p.length
    ? '<div style="color:var(--ink-dim);font-size:13px;margin-bottom:10px;">Messages sent in the last 7 days.</div>'
      + '<div class="people">' + p.map(function(x){
          return '<span class="person">' + esc(x.name) + '<b>' + x.count + '</b></span>'; }).join('') + '</div>'
    : '<div style="color:var(--ink-dim);font-size:14px;">Nobody has posted this week.</div>';
}

/* ── actions ── */
function byId(id){ var a = data.issues||[]; for (var i=0;i<a.length;i++) if (a[i].id===id) return a[i]; return null; }

function mark(id, status, note){
  var it = byId(id); if (!it) return;
  var prev = { status: it.status, note: it.note };
  it.status = status; if (note !== undefined) it.note = note;
  apply(data);
  call({ action:'setStatus', issueId:id, status:status, note:(note !== undefined ? note : (it.note || '')) })
    .then(function(d){ if (!d || !d.ok) throw new Error('x'); })
    .catch(function(){ it.status = prev.status; it.note = prev.note; apply(data);
      alert("Couldn't save that — check your connection and try again."); });
}

function addNote(id, st){
  var it = byId(id); if (!it) return;
  var n = prompt('Note for this report (what you did, or what you need from them):', it.note || '');
  if (n === null) return;
  mark(id, st, n);
}

function copyOne(id){
  var i = byId(id); if (!i) return;
  var t = 'PROBLEM REPORT\nFrom: ' + (i.name||'') + '\nScreen: ' + (i.screen||'') +
          '\nWhen: ' + new Date(i.ts).toLocaleString() + '\n\n' + i.text;
  if (navigator.clipboard) navigator.clipboard.writeText(t);
}

function load(){
  if (!key) return;
  call({ action:'load' }).then(function(d){ if (d && d.ok) apply(d); }).catch(function(){});
  loadUsage();
}

/* ── usage ─────────────────────────────────────────────────────────────────
   Screens opened and buttons pressed, from /api/usage. Loaded separately from
   the problem reports so a slow usage query never holds up the thing Erik
   actually needs to act on. */
var usageDays = 14;
var usageData = null;

function loadUsage(){
  if (!key) return;
  call({ action:'usage', days: usageDays })
    .then(function(d){ if (d && d.ok) { usageData = d.usage; renderUsage(); } })
    .catch(function(){
      document.getElementById('usage').innerHTML =
        '<div class="empty">Could not load usage right now.</div>';
    });
}

function ago(ts){
  if (!ts) return 'never';
  var days = Math.floor((Date.now()-ts)/86400000);
  if (days <= 0) return 'today';
  if (days === 1) return 'yesterday';
  return days + ' days ago';
}

function rankList(items, empty){
  if (!items || !items.length) return '<div style="color:var(--ink-dim);font-size:14px;">' + empty + '</div>';
  var max = items[0].count || 1;
  return '<ul class="rank">' + items.map(function(x){
    return '<li><i class="fill" style="width:' + Math.max(3, Math.round(x.count/max*100)) + '%"></i>'
      + '<span class="nm">' + esc(x.label) + '</span>'
      + '<span class="ct">' + x.count + '</span></li>';
  }).join('') + '</ul>';
}

function renderUsage(){
  var u = usageData;
  var box = document.getElementById('usage');
  if (!u) return;

  var totalEvents = (u.daily||[]).reduce(function(a,b){ return a + (b.events||0); }, 0);
  if (!totalEvents){
    box.innerHTML = '<div class="empty">Nothing recorded yet. This fills in as the team uses the toolkit '
      + '&mdash; give it a day or two after the update reaches everyone.</div>';
    return;
  }

  // Bar chart of daily opens.
  var daily = u.daily || [];
  var peak = daily.reduce(function(m,d){ return Math.max(m, d.opens||0); }, 0) || 1;
  var chart = '<div class="chart">' + daily.map(function(d, i){
    var h = Math.round((d.opens||0)/peak*100);
    return '<div class="col' + (i === daily.length-1 ? ' today' : '') + '" title="'
      + esc(d.day) + ': ' + (d.opens||0) + ' opens"><i style="height:' + Math.max(2,h) + '%"></i></div>';
  }).join('') + '</div>'
  + '<div class="chartx">' + daily.map(function(d, i){
      var show = (i === 0 || i === daily.length-1 || i === Math.floor(daily.length/2));
      return '<span>' + (show ? esc(d.day.slice(5)) : '') + '</span>';
    }).join('') + '</div>';

  var people = u.people || [];
  var active7 = people.filter(function(p){ return p.days7 > 0; });
  var byEmail = people.filter(function(p){ return p.id === 'email'; });
  var unknown = people.filter(function(p){ return p.id !== 'email'; });

  var tiles = '<div class="stats">'
    + stat(u.opens7 || 0, 'Opens this week')
    + stat(active7.length, 'People this week')
    + stat(totalEvents, 'Clicks tracked (' + u.days + 'd)')
    + stat(byEmail.length, 'Signed in with email')
    + (unknown.length ? stat(unknown.length, 'No email yet', true) : '')
    + '</div>';

  var lists = '<div class="cols" style="margin-top:14px;">'
    + '<div class="card"><div class="meta">Most-used screens &middot; 7 days</div>'
      + rankList(u.screens7, 'No screens opened this week.') + '</div>'
    + '<div class="card"><div class="meta">Most-pressed buttons &middot; 7 days</div>'
      + rankList(u.actions7, 'No buttons pressed this week.') + '</div>'
    + '</div>';

  // Rep by rep — the "who do I check in with" table.
  var rows = people.map(function(p){
    var cls = p.days7 === 0 ? ' class="quiet"' : (p.days7 <= 1 ? ' class="cold"' : '');
    var sub = p.id === 'email' ? esc(p.email)
            : (p.id === 'name' ? 'no email on file yet' : 'skipped the welcome screen');
    return '<tr>'
      + '<td class="nm' + (p.anon ? ' anon' : '') + '">' + esc(p.name)
        + '<div style="font-size:11.5px;font-style:normal;font-weight:400;color:var(--ink-dim);margin-top:3px;">'
        + sub + '</div></td>'
      + '<td class="n"' + cls + '>' + ago(p.lastTs) + '</td>'
      + '<td class="n">' + p.days7 + ' / 7</td>'
      + '<td class="n">' + p.events7 + '</td>'
      + '<td class="n" style="white-space:normal;">' + esc(p.lastScreen || '') + '</td>'
      + '</tr>';
  }).join('');

  var nag = unknown.length
    ? '<p class="lede" style="margin-bottom:12px;color:var(--amber);">'
      + unknown.length + (unknown.length === 1 ? ' person has' : ' people have')
      + ' not put a work email in yet, so their activity can\'t be tied to a person '
      + 'and may be split across their phone and laptop.</p>'
    : '';

  var table = '<h2 style="margin-top:26px;">Rep by rep</h2>'
    + '<p class="lede" style="margin-bottom:12px;">Identified by the work email each rep enters '
      + 'on the welcome screen &mdash; the same one their email tools use.</p>'
    + nag
    + '<div class="card"><table class="reps"><thead><tr>'
      + '<th>Who</th><th>Last opened</th><th>Days active</th><th>Clicks</th><th>Last screen</th>'
    + '</tr></thead><tbody>' + rows + '</tbody></table></div>';

  box.innerHTML = tiles + chart + lists + table;
}

function copyUsage(){
  var u = usageData;
  if (!u) return;
  var lines = ['MINIBOX TOOLKIT — USAGE (last ' + u.days + ' days)', ''];
  lines.push('Opens this week: ' + (u.opens7||0));
  lines.push('People active this week: ' + (u.people||[]).filter(function(p){return p.days7>0;}).length);
  lines.push('');
  lines.push('TOP SCREENS (7d)');
  (u.screens7||[]).forEach(function(x){ lines.push('  ' + x.label + ' — ' + x.count); });
  lines.push('');
  lines.push('TOP BUTTONS (7d)');
  (u.actions7||[]).forEach(function(x){ lines.push('  ' + x.label + ' — ' + x.count); });
  lines.push('');
  lines.push('REP BY REP');
  (u.people||[]).forEach(function(p){
    lines.push('  ' + p.name + (p.email ? ' <' + p.email + '>' : ' (no email)') +
      ' — last opened ' + ago(p.lastTs) +
      ', active ' + p.days7 + '/7 days, ' + p.events7 + ' clicks');
  });
  var t = lines.join('\n');
  if (navigator.clipboard) navigator.clipboard.writeText(t);
}

/* Filter pills — problem-report status and the usage date range. */
document.addEventListener('click', function(e){
  var b = e.target.closest ? e.target.closest('.filt') : null;
  if (!b) return;
  var group = b.parentNode.querySelectorAll('.filt');
  for (var i=0;i<group.length;i++) group[i].classList.remove('on');
  b.classList.add('on');
  if (b.hasAttribute('data-f')) { filter = b.getAttribute('data-f'); render(); }
  else if (b.hasAttribute('data-d')) { usageDays = Number(b.getAttribute('data-d')) || 14; loadUsage(); }
});

document.getElementById('lockpw').addEventListener('keydown', function(e){
  if (e.key === 'Enter') { e.preventDefault(); unlock(); }
});

/* Already unlocked in this tab/session? Go straight in. */
(function(){
  var saved = '';
  try { saved = sessionStorage.getItem(KEYSTORE) || ''; } catch(e){}
  if (!saved) { document.getElementById('lockpw').focus(); return; }
  document.getElementById('lockpw').value = saved;
  unlock();
})();
</script>
</body>
</html>
