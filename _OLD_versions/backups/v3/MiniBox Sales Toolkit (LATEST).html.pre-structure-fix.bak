  {id:'chestsum',    file:'CHEST-2021-Study-Summary.pdf',         title:'CHEST 2021 Study — Summary',     sub:'The validation study at a glance',                        cat:'clinical', kb:201,  blurb:'CHEST 2021 Study Summary — the validation study at a glance (700+ patients across 11 medical centers).'},
  {id:'chestfull',   file:'CHEST-2021-Full-Article.pdf',          title:'CHEST 2021 Study — Full Article',sub:'Complete peer-reviewed validation paper',                 cat:'clinical', kb:1434, blurb:'CHEST 2021 Full Article — the complete peer-reviewed validation paper.'},
  {id:'verona',      file:'Verona-Study.pdf',                     title:'Verona Study',                        sub:'Additional published clinical evidence',                  cat:'clinical', kb:85,   blurb:'Verona Study — additional published clinical evidence.'},
  {id:'coaching',    file:'PFT-Coaching-Sheet.pdf',               title:'PFT Coaching Sheet',                  sub:'Patient coaching guide for techs',                        cat:'clinical', kb:516,  blurb:'PFT Coaching Sheet — the patient coaching guide your techs can use from day one.'},
  {id:'dlco',        file:'DLCO-Gas-Requirements.pdf',            title:'DLCO Gas Requirements',               sub:'What’s needed on-site for DLCO',                     cat:'tech',     kb:181,  blurb:'DLCO Gas Requirements — what’s needed on-site for DLCO testing.'},
  {id:'hl7',         file:'HL7-Conformance-Statement-2025.pdf',   title:'HL7 Conformance Statement (2025)',    sub:'For the practice’s IT / EHR team',                   cat:'tech',     kb:561,  blurb:'HL7 Conformance Statement (2025) — integration documentation for your IT/EHR team.'},
  {id:'mds2',        file:'MDS2-Cybersecurity-Statement.pdf',     title:'MDS2 Cybersecurity Statement',        sub:'Security documentation for IT review',                    cat:'tech',     kb:271,  blurb:'MDS2 Cybersecurity Statement — security documentation for your IT review.'},
  {id:'manual',      file:'MiniBox-User-Manual-Rev20.pdf',        title:'User Manual (Rev 20)',                sub:'Full manual — too large to email, view/download only', cat:'tech',    kb:8559, noembed:true, blurb:''},
  {id:'certificate', file:'Manufacturer-Certificate.pdf',         title:'Manufacturer Certificate',            sub:'Official MiniBox+ certification',                         cat:'closing',  kb:356,  blurb:'Manufacturer Certificate — official certification for the MiniBox+.'},
  {id:'financing',   file:'Financing-Quick-Application-2025.pdf', title:'Financing Quick Application (2025)',  sub:'GFS application — 12/24/36-month structures',        cat:'closing',  kb:1211, blurb:'Financing Quick Application — flexible 12, 24, and 36-month structures sized to keep the monthly cost below the revenue the device generates.'},
  {id:'w9',          file:'PulmOne-W9.pdf',                       title:'PulmOne W-9',                         sub:'For vendor setup',                                        cat:'closing',  kb:609,  blurb:'PulmOne W-9 — for your vendor setup.'},
  {id:'bank',        file:'PulmOne-Bank-Information.pdf',         title:'PulmOne Bank Information',            sub:'For payment setup',                                       cat:'closing',  kb:148,  care:true, blurb:'PulmOne Bank Information — for payment setup.'},
  {id:'achpdf',      file:'ACH-Payment-Authorization.pdf',        title:'ACH Payment Authorization Form',      sub:'For practices ready to move forward',                     cat:'closing',  kb:286,  care:true, blurb:'ACH Payment Authorization Form — the payment authorization to get your account set up.'},
  // ---- Rheumatology Playbook (from Rheum Playbook.zip) ----
  {id:'rh-slick',     file:'01_Rheumatology_Play_Segment_Slick.pdf',     title:'The Rheumatology Play — Segment Slick',    sub:'2-page field guide — read before every rheum call',        cat:'rheum', kb:113,  blurb:'The Rheumatology Play (Segment Slick) — the two-page field guide: why rheumatology, the four discovery questions, the objections, the CPT bundle, and financing.'},
  {id:'rh-fieldref',  file:'02_MiniBox_Rheumatology_Field_Reference.docx',title:'MiniBox+ Rheumatology Field Reference',   sub:'Deep clinical detail — DMARDs, biologics, financing',       cat:'rheum', kb:18,   blurb:'MiniBox+ Rheumatology Field Reference — the deep version: the clinical argument, DMARDs & biologics explained, objections, and the full financing menu.'},
  {id:'rh-deck',      file:'03_PFT_Rheumatology_Clinic_Training.pptx',   title:'PFT in Rheumatology — Clinic Training Deck',sub:'19-slide staff training to send post-sale',               cat:'rheum', kb:91,   blurb:'PFT in Rheumatology — Clinic Training Deck: customer-facing training that walks the clinic staff through PFT testing for connective-tissue-disease patients.'},
  {id:'rh-guideline', file:'04_ACR_CHEST_ILD_Guideline_2023.pdf',        title:'2023 ACR/CHEST ILD Guideline',            sub:'The primary peer-reviewed source',                         cat:'rheum', kb:1294, blurb:'2023 ACR/CHEST ILD Guideline — the primary peer-reviewed source naming PFTs for ILD screening and monitoring in systemic autoimmune rheumatic diseases.'},
  {id:'rh-pico',      file:'05_ACR_CHEST_PICO_Questions_Appendix.pdf',   title:'ACR/CHEST PICO Questions (Appendix 2)',   sub:'The 24 evidence questions behind the guideline',           cat:'rheum', kb:119,  blurb:'ACR/CHEST PICO Questions — the 24 evidence questions behind the guideline recommendations, for when a rheumatologist asks how rigorous the guideline is.'},
  {id:'rh-factsheet', file:'06_RA_ILD_Patient_Fact_Sheet_PFF.pdf',       title:'RA-ILD Patient Fact Sheet (PFF)',         sub:'Plain-language patient handout',                           cat:'rheum', kb:56,   blurb:'RA-ILD Patient Fact Sheet — the Pulmonary Fibrosis Foundation’s plain-language handout on RA-ILD: symptoms, diagnosis, and prognosis.'},
  {id:'rh-emails',    file:'07_Email_Templates_Sales_Call_Guide.docx',   title:'Rheum Email Templates & Call Guide',      sub:'The Dr. Torres email + call prep checklist',               cat:'rheum', kb:30,   blurb:'Rheumatology Email Templates & Sales Call Guide — the actual post-discovery email, a blank template to adapt, plus a call-prep checklist and follow-up framework.'},
  {id:'cardio-onepager', file:'Cardiology-Complete-PFT-Clinical-Billing.pdf', title:'Pulmonary Function in the Cardiology Clinic', sub:'Clinical case + DLCO + billing — verified, sourced one-pager', cat:'cardio', kb:16, blurb:'Pulmonary Function in the Cardiology Clinic — a one-page, fully-sourced summary: dyspnea differentiation, heart failure vs COPD, peri-procedural risk, the DLCO / full-PFT argument, and the complete-PFT billing breakdown.'}
];
var M3_CATS = { send:'📤 Core send-pack', clinical:'🔬 Clinical evidence', tech:'🖥 IT & technical', closing:'🤝 Closing & payment', rheum:'🦴 Rheumatology Playbook', cardio:'❤️ Cardiology' };
var M3_CAT_ORDER = ['send','clinical','tech','closing','rheum','cardio'];

/* ============ ATTACHMENT / MATERIALS SEARCH ============
   Lets the global search bar FIND the actual files (W-9, ACH, brochure, studies…).
   Each material carries extra keyword aliases so short, real-world searches hit —
   e.g. "w9" finds "PulmOne W-9" even though the title has a hyphen. */
var M3_MAT_ALIASES = {
  brochure:   'brochure spec specs datasheet sell sheet one pager product info',
  why:        'why minibox overview one pager onepager summary the case',
  samplereport:'sample pft report example results printout what the doctor sees',
  comparison: 'competitive comparison versus vs competitor competition body box bodybox bodyplethysmography',
  chestsum:   'chest 2021 study summary validation evidence 700 patients',
  chestfull:  'chest 2021 full article study paper peer reviewed publication',
  verona:     'verona study italy italian clinical evidence published',
  coaching:   'pft coaching sheet patient guide technician tech how to test',
  dlco:       'dlco gas requirements diffusion capacity on site',
  hl7:        'hl7 conformance statement interface integration ehr emr it information technology',
  mds2:       'mds2 cybersecurity security statement it information technology hipaa',
  manual:     'user manual rev 20 rev20 instructions guide documentation',
  certificate:'manufacturer certificate certification official approval',
  financing:  'financing finance application loan lease gfs payment plan monthly terms 12 24 36 month',
  w9:         'w9 w-9 w 9 tax taxpayer ein irs vendor setup form taxid tin',
  bank:       'bank banking wire routing account number payment setup remittance',
  achpdf:     'ach ach form payment authorization bank draft autopay direct debit',
  'rh-slick':    'rheumatology rheum play segment slick field guide discovery objections cpt',
  'rh-fieldref': 'rheumatology rheum field reference dmards biologics financing clinical',
  'rh-deck':     'rheumatology rheum training deck slides clinic staff connective tissue',
  'rh-guideline':'rheumatology rheum acr chest ild guideline 2023 screening monitoring autoimmune',
  'rh-pico':     'rheumatology rheum pico questions appendix evidence guideline',
  'rh-factsheet':'rheumatology rheum ra ild patient fact sheet handout pff fibrosis',
  'rh-emails':   'rheumatology rheum email templates call guide torres followup checklist'
};
/* collapse to bare alphanumerics so "w-9" / "W 9" / "w9" all compare equal */
function m3SearchSquish(s){ return String(s || '').toLowerCase().replace(/[^a-z0-9]+/g, ''); }
function m3SearchMaterials(q){
  var sq = m3SearchSquish(q);
  if (sq.length < 2) return [];
  var out = [];
  MATERIALS.forEach(function(m){
    var hay = m3SearchSquish([m.title, m.sub, m.blurb, m.file, M3_MAT_ALIASES[m.id] || ''].join(' '));
    if (hay.indexOf(sq) > -1) out.push(m);
  });
  return out;
}
function m3SearchCloseBox(){
  var box = document.getElementById('global-search-results'); if (box) box.classList.remove('show');
  var s = document.getElementById('global-search'); if (s) s.value = '';
}
function m3SearchOpen(id){ m3SearchCloseBox(); try { m3View(id); } catch(e) {} }
function m3SearchEmail(id){ m3SearchCloseBox(); try { m3EmailThis(id); } catch(e) {} }
var M3_STATE = { easIds:[], elIds:[], elTmplTitle:null };

function m3ById(id){ for (var i=0;i<MATERIALS.length;i++) if (MATERIALS[i].id===id) return MATERIALS[i]; return null; }
function m3HasData(id){ return (typeof MATERIALS_B64 !== 'undefined') && !!MATERIALS_B64[id]; }
function m3IsHosted(){ return location.protocol === 'http:' || location.protocol === 'https:'; }
function m3Mime(file){
  var f = String(file || '').toLowerCase();
  if (f.indexOf('.pdf') >= 0)  return 'application/pdf';
  if (f.indexOf('.docx') >= 0) return 'application/vnd.openxmlformats-officedocument.wordprocessingml.document';
  if (f.indexOf('.pptx') >= 0) return 'application/vnd.openxmlformats-officedocument.presentationml.presentation';
  if (f.indexOf('.xlsx') >= 0) return 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet';
  return 'application/octet-stream';
}
function m3IsViewable(file){ return /\.pdf$/i.test(String(file || '')); }

function m3Blob(id){
  var m = m3ById(id);
  var b64 = MATERIALS_B64[id];
  var bin = atob(b64), len = bin.length, bytes = new Uint8Array(len);
  for (var i=0;i<len;i++) bytes[i] = bin.charCodeAt(i);
  return new Blob([bytes], {type: m3Mime(m ? m.file : '')});
}
function m3View(id){
  var m = m3ById(id); if (!m) return;
  // Word/PowerPoint can't render in a browser tab — download instead of opening a blank tab.
  if (!m3IsViewable(m.file)) { m3Download(id); return; }
  if (m3HasData(id)) {
    var url = URL.createObjectURL(m3Blob(id));
    window.open(url, '_blank');
    setTimeout(function(){ URL.revokeObjectURL(url); }, 60000);
  } else {
    window.open('materials/' + m.file, '_blank');
  }
}
function m3Download(id){
  var m = m3ById(id); if (!m) return;
  var a = document.createElement('a');
  if (m3HasData(id)) { a.href = URL.createObjectURL(m3Blob(id)); }
  else { a.href = 'materials/' + m.file; }
  a.download = m.file; a.style.display = 'none';
  document.body.appendChild(a); a.click();
  setTimeout(function(){ document.body.removeChild(a); if (a.href.indexOf('blob:')===0) URL.revokeObjectURL(a.href); }, 4000);
}
function m3DownloadMany(ids){
  ids.forEach(function(id, i){ setTimeout(function(){ m3Download(id); }, i * 450); });
}
function m3TotalKB(ids){ var t=0; ids.forEach(function(id){ var m=m3ById(id); if (m) t+=m.kb; }); return t; }
function m3SizeLabel(kb){ return kb >= 1000 ? (kb/1024).toFixed(1) + ' MB' : kb + ' KB'; }

/* ============ .EML BUILDER — a real Outlook draft with real attachments ============ */
function m3Chunk76(b64){ var out=''; for (var i=0;i<b64.length;i+=76) out += b64.substring(i,i+76) + '\r\n'; return out; }
function m3B64Utf8(str){ return btoa(unescape(encodeURIComponent(str))); }
function m3BuildEml(opts){
  // opts: {to, cc, subject, body, ids, fileName}
  var boundary = '----=_MBX3_' + Date.now() + '_' + Math.random().toString(36).slice(2,10);
  var eml = '';
  eml += 'MIME-Version: 1.0\r\n';
  eml += 'X-Unsent: 1\r\n';
  if (opts.to) eml += 'To: ' + opts.to + '\r\n';
  if (opts.cc) eml += 'Cc: ' + opts.cc + '\r\n';
  eml += 'Subject: ' + (opts.subject || '') + '\r\n';
  eml += 'Content-Type: multipart/mixed; boundary="' + boundary + '"\r\n\r\n';
  eml += '--' + boundary + '\r\n';
  eml += 'Content-Type: text/plain; charset=utf-8\r\n';
  eml += 'Content-Transfer-Encoding: base64\r\n\r\n';
  eml += m3Chunk76(m3B64Utf8(opts.body || '')) + '\r\n';
  (opts.ids || []).forEach(function(id){
    var m = m3ById(id);
    if (!m || !m3HasData(id)) return;
    eml += '--' + boundary + '\r\n';
    eml += 'Content-Type: ' + m3Mime(m.file) + '; name="' + m.file + '"\r\n';
    eml += 'Content-Transfer-Encoding: base64\r\n';
    eml += 'Content-Disposition: attachment; filename="' + m.file + '"\r\n\r\n';
    eml += m3Chunk76(MATERIALS_B64[id]) + '\r\n';
  });
  eml += '--' + boundary + '--\r\n';
  var name = (opts.fileName || 'PulmOne-Email').replace(/[^a-zA-Z0-9 _-]/g,'').replace(/\s+/g,'-').slice(0,60) + '.eml';
  var blob = new Blob([eml], {type:'message/rfc822'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url; a.download = name; a.style.display = 'none';
  document.body.appendChild(a); a.click();
  setTimeout(function(){ document.body.removeChild(a); URL.revokeObjectURL(url); }, 4000);
  return name;
}
/* ===== Pure-JS ZIP (store mode) — bundle every selected PDF into ONE file so
   it rides into ANY Outlook (New, Web, or Classic) with a single drag. No
   library, works fully offline. PDFs are already compressed, so store = fine. ===== */
var M3_CRC_TABLE = (function(){
  var t = []; for (var n=0;n<256;n++){ var c=n; for (var k=0;k<8;k++){ c=(c&1)?(0xEDB88320^(c>>>1)):(c>>>1); } t[n]=c>>>0; } return t;
})();
function m3Crc32(bytes){
  var c = 0xFFFFFFFF;
  for (var i=0;i<bytes.length;i++){ c = M3_CRC_TABLE[(c ^ bytes[i]) & 0xFF] ^ (c >>> 8); }
  return (c ^ 0xFFFFFFFF) >>> 0;
}
function m3B64ToBytes(b64){
  var bin = atob(b64), len = bin.length, bytes = new Uint8Array(len);
  for (var i=0;i<len;i++) bytes[i] = bin.charCodeAt(i);
  return bytes;
}
function m3StrBytes(s){
  var b = new Uint8Array(s.length);
  for (var i=0;i<s.length;i++) b[i] = s.charCodeAt(i) & 0xFF;
  return b;
}
function m3BuildZip(ids){
  var files = [];
  (ids || []).forEach(function(id){
    var m = m3ById(id);
    if (m && m3HasData(id)) files.push({ name: m.file, data: m3B64ToBytes(MATERIALS_B64[id]) });
  });
  if (!files.length) return null;
  function u16(n){ return new Uint8Array([n & 0xFF, (n>>>8) & 0xFF]); }
  function u32(n){ return new Uint8Array([n & 0xFF, (n>>>8) & 0xFF, (n>>>16) & 0xFF, (n>>>24) & 0xFF]); }
  var local = [], central = [], offset = 0;
  files.forEach(function(f){
    var nameB = m3StrBytes(f.name), crc = m3Crc32(f.data), size = f.data.length;
    local.push(u32(0x04034b50), u16(20), u16(0), u16(0), u16(0), u16(0), u32(crc), u32(size), u32(size), u16(nameB.length), u16(0), nameB, f.data);
    central.push(u32(0x02014b50), u16(20), u16(20), u16(0), u16(0), u16(0), u16(0), u32(crc), u32(size), u32(size), u16(nameB.length), u16(0), u16(0), u16(0), u16(0), u32(0), u32(offset), nameB);
    offset += 30 + nameB.length + size;
  });
  var localSize = offset, centralSize = 0;
  central.forEach(function(p){ centralSize += p.length; });
  var eocd = [ u32(0x06054b50), u16(0), u16(0), u16(files.length), u16(files.length), u32(centralSize), u32(localSize), u16(0) ];
  return new Blob(local.concat(central).concat(eocd), { type: 'application/zip' });
}
function m3DownloadZip(ids, zipName){
  var blob = m3BuildZip(ids);
  if (!blob) { m3Toast('No materials selected to bundle.'); return false; }
  var name = (zipName || 'PulmOne-Materials').replace(/[^a-zA-Z0-9 _-]/g,'').replace(/\s+/g,'-').slice(0,60) + '.zip';
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob); a.download = name; a.style.display = 'none';
  document.body.appendChild(a); a.click();
  setTimeout(function(){ document.body.removeChild(a); URL.revokeObjectURL(a.href); }, 4000);
  return name;
}
function m3EasDownloadZip(){
  if (!M3_STATE.easIds.length) { m3Toast('Pick at least one file above first.'); return; }
  var practice = document.getElementById('eas-practice').value.trim();
  if (m3DownloadZip(M3_STATE.easIds, 'PulmOne-' + (practice || 'Materials'))) {
    m3Toast('All ' + M3_STATE.easIds.length + ' files saved as ONE .zip in your Downloads — open a new email to your contact and drag that single file in. Works in any Outlook.');
  }
}
function m3ElZip(){
  if (!M3_STATE.elIds.length) { m3Toast('Tap a 📎 material chip first.'); return; }
  if (m3DownloadZip(M3_STATE.elIds, 'PulmOne-' + (currentElTmpl ? currentElTmpl.title : 'Materials'))) {
    m3Toast('All ' + M3_STATE.elIds.length + ' files saved as ONE .zip — drag that single file into your email. Works in any Outlook.');
  }
}
function m3EmlAvailable(){ return typeof MATERIALS_B64 !== 'undefined'; }
function m3Toast(msg, ms){ try { elToast(msg, ms); } catch(e) { alert(msg); } }

/* Friendly guard: mailto/OWA links silently cut off long bodies. */
function m3GuardedMailto(to, cc, subject, body){
  var url = 'mailto:' + encodeURIComponent(to||'') + '?subject=' + encodeURIComponent(subject||'') + '&body=' + encodeURIComponent(body||'');
  if (cc) url += '&cc=' + encodeURIComponent(cc);
  if (url.length > 1900) {
    try { elCopyToClipboard(body); } catch(e) {}
    var short = 'mailto:' + encodeURIComponent(to||'') + '?subject=' + encodeURIComponent(subject||'');
    if (cc) short += '&cc=' + encodeURIComponent(cc);
    window.location.href = short;
    m3Toast('Email body was too long for Outlook’s link limit — it’s on your clipboard. Click into the email and press Ctrl+V.');
    return;
  }
  window.location.href = url;
}
/* v3.12 SINGLE-SIGNATURE FIX: Outlook Web always injects the account's own
   auto-signature at the TOP of a link-composed email, and there is no URL
   switch to suppress it — so passing the body in the link produced TWO
   signatures (Outlook's on top, the toolkit's at the bottom). Fix: strip the
   toolkit's plain-text signature, put the body on the clipboard, and open the
   compose window with To/Cc/Subject only. Pasting drops the text ABOVE the
   auto-signature, so the rep's real Outlook signature ends the email — once.
   (Desktop mailto and .eml drafts keep the toolkit signature: those paths
   don't auto-insert one.) */
function m3StripToolkitSig(body){
  var out = String(body == null ? '' : body).replace(/\s+$/,'');
  var sigs = [];
  try { if (typeof buildSignature === 'function') sigs.push(buildSignature()); } catch(e) {}
  sigs.push('[Your Name]\nPulmOne USA\n1-844-PulmOne (785-6663)\nUSinfo@pulm-one.com');
  for (var i=0;i<sigs.length;i++){
    var sig = (sigs[i]||'').replace(/\s+$/,'');
    if (sig && out.slice(-sig.length) === sig) {
      out = out.slice(0, out.length - sig.length).replace(/\s+$/,'');
      break;
    }
  }
  /* Assembly-station fallback signature: "...\n<rep name>\nPulmOne USA" */
  out = out.replace(/\n[^\n]{0,60}\nPulmOne USA$/,'');
  return out;
}
function m3GuardedOWA(to, cc, subject, body, toastMsg){
  try { elCopyToClipboard(m3StripToolkitSig(body)); } catch(e) {}
  var url = 'https://outlook.office.com/mail/deeplink/compose?to=' + encodeURIComponent(to||'') + '&subject=' + encodeURIComponent(subject||'');
  if (cc) url += '&cc=' + encodeURIComponent(cc);
  window.open(url, '_blank', 'noopener');
  if (toastMsg !== false) m3Toast(toastMsg || 'Outlook Web is opening — click in the message and press Ctrl+V (tablet: press-and-hold, then Paste). Your email drops in and your Outlook signature stays at the bottom, just once.', 8000);
}

/* v3.16: after a send with materials, show a stay-up steps panel instead of an
   8-second toast. Reps kept missing the downloaded .zip — the installed app
   tucks downloads behind the small ⬇ icon in the title bar — and the old
   checklist line promised "no manual attaching", which no Outlook Web compose
   link can deliver (only .eml drafts or Microsoft Graph can auto-attach).
   The panel names the exact file, stays until dismissed, and can re-save it. */
function m3SendSteps(fileName, n, redownload){
  var old = document.getElementById('m3-send-steps');
  if (old && old.parentNode) old.parentNode.removeChild(old);
  var wrap = document.createElement('div');
  wrap.id = 'm3-send-steps';
  wrap.style.cssText = 'position:fixed; inset:0; background:rgba(15,23,42,.55); z-index:99999; display:flex; align-items:center; justify-content:center; padding:18px;';
  var fileLabel = n > 1 ? 'the ONE .zip (all ' + n + ' PDFs inside)' : 'the PDF';
  var safeName = String(fileName || '').replace(/&/g,'&amp;').replace(/</g,'&lt;');
  var card = document.createElement('div');
  card.style.cssText = 'background:#fff; border-radius:16px; max-width:540px; width:100%; padding:22px 24px; box-shadow:0 24px 60px rgba(0,0,0,.35); font-size:15px; line-height:1.55; color:#1f2937;';
  card.innerHTML =
    '<div style="font-size:18px; font-weight:800; margin-bottom:10px;">&#128236; Outlook is open &mdash; 2 moves to send</div>'
    + '<div style="display:flex; gap:10px; margin:10px 0;"><div style="font-weight:800; color:#1d4ed8;">1.</div><div>Click into the email and press <strong>Ctrl+V</strong> &mdash; your message drops in (your Outlook signature stays at the bottom).</div></div>'
    + '<div style="display:flex; gap:10px; margin:10px 0;"><div style="font-weight:800; color:#1d4ed8;">2.</div><div>Drag ' + fileLabel + ' into the email &mdash; that&rsquo;s your attachment' + (n > 1 ? 's' : '') + ':<br><strong style="word-break:break-all;">' + safeName + '</strong><br><span style="font-size:13px; color:#6b7280;">It just downloaded &mdash; look behind the ⬇ download icon at the top of this window, or in your Downloads folder.</span></div></div>'
    + '<div style="display:flex; gap:10px; margin-top:16px; flex-wrap:wrap;">'
    + '<button id="m3-steps-again" style="flex:1; min-width:180px; padding:11px 14px; border:0; border-radius:10px; background:#eff6ff; color:#1d4ed8; font-weight:700; font-size:14px; cursor:pointer;">&#128230; Save the file again</button>'
    + '<button id="m3-steps-done" style="flex:1; min-width:120px; padding:11px 14px; border:0; border-radius:10px; background:#16a34a; color:#fff; font-weight:800; font-size:14px; cursor:pointer;">&#10003; Got it</button>'
    + '</div>';
  wrap.appendChild(card);
  document.body.appendChild(wrap);
  function close(){ if (wrap.parentNode) wrap.parentNode.removeChild(wrap); }
  document.getElementById('m3-steps-done').onclick = close;
  document.getElementById('m3-steps-again').onclick = function(){ if (redownload) redownload(); };
  wrap.addEventListener('click', function(ev){ if (ev.target === wrap) close(); });
}

/* ============ MODE A — EMAIL ASSEMBLY STATION (v3 real materials) ============ */
var M3_PACKS = {
  intro:    { label:'⚡ Intro Pack',    ids:['brochure','why','samplereport'] },
  evidence: { label:'🔬 Evidence Pack', ids:['chestsum','chestfull','verona'] },
  it:       { label:'🖥 IT Pack',       ids:['hl7','mds2','dlco'] },
  closing:  { label:'🤝 Closing Pack',  ids:['financing','achpdf','w9','bank'] },
  rheum:    { label:'🦴 Rheum Pack',    ids:['rh-slick','rh-guideline','rh-factsheet'] },
  cardio:   { label:'❤️ Cardiology Pack', ids:['cardio-onepager'] }
};
function m3ApplyPack(key){
  if (key === 'clear') { M3_STATE.easIds = []; m3RenderEasMaterials(); m3Toast('Selection cleared'); return; }
  var p = M3_PACKS[key]; if (!p) return;
  M3_STATE.easIds = p.ids.slice();
  m3RenderEasMaterials();
  m3Toast(p.label.replace(/^\S+\s/,'') + ' selected — ' + p.ids.length + ' files, ' + m3SizeLabel(m3TotalKB(p.ids)));
}
function m3RenderEasMaterials(){
  var host = document.getElementById('m3-eas-materials');
  if (!host) return;
  var html = '<div class="m3-packs"><span class="m3-chips-lbl">One-tap packs:</span>';
  Object.keys(M3_PACKS).forEach(function(k){
    html += '<button type="button" class="m3-pack-btn" onclick="m3ApplyPack(\'' + k + '\')">' + M3_PACKS[k].label + '</button>';
  });
  html += '<button type="button" class="m3-pack-btn m3-pack-clear" onclick="m3ApplyPack(\'clear\')">Clear</button></div>';
  M3_CAT_ORDER.forEach(function(cat){
    var items = MATERIALS.filter(function(m){ return m.cat===cat && !m.noembed; });
    if (!items.length) return;
    html += '<div class="m3-cat-label">' + M3_CATS[cat] + '</div>';
    items.forEach(function(m){
      var on = M3_STATE.easIds.indexOf(m.id) >= 0;
      html += '<label class="m3-mat-row' + (on?' on':'') + '" id="m3-eas-row-' + m.id + '">'
            + '<input type="checkbox"' + (on?' checked':'') + ' onchange="m3EasToggle(\'' + m.id + '\', this.checked)">'
            + '<div style="flex:1;"><div class="m3-mat-title">' + m.title + '<span class="m3-kb">' + m3SizeLabel(m.kb) + '</span>'
            + (m.care ? ' <span class="m3-care">send only when closing</span>' : '') + '</div>'
            + '<div class="m3-mat-sub">' + m.sub + '</div></div></label>';
    });
  });
  host.innerHTML = html;
  m3EasSizeUpdate();
}
function m3EasToggle(id, on){
  var i = M3_STATE.easIds.indexOf(id);
  if (on && i < 0) M3_STATE.easIds.push(id);
  if (!on && i >= 0) M3_STATE.easIds.splice(i,1);
  var row = document.getElementById('m3-eas-row-' + id);
  if (row) row.classList.toggle('on', on);
  m3EasSizeUpdate();
}
function m3EasSizeUpdate(){
  var el = document.getElementById('m3-eas-size');
  if (!el) return;
  var n = M3_STATE.easIds.length;
  el.textContent = n ? ('📎 ' + n + ' file' + (n>1?'s':'') + ' selected · ' + m3SizeLabel(m3TotalKB(M3_STATE.easIds)) + ' total') : 'No materials selected yet — tap any file above to include it.';
}

/* v3 override: builds the package email from REAL selected materials. */
function easBuildEmail(){
  var doctor   = document.getElementById('eas-doctor').value.trim()   || '[Doctor Name]';
  var practice = document.getElementById('eas-practice').value.trim() || '[Practice Name]';
  var profileSet = (typeof REP_PROFILE !== 'undefined' && !!REP_PROFILE.name);
  var rep = document.getElementById('eas-rep').value.trim() || (profileSet ? REP_PROFILE.name : '') || '[Your Name]';
  var ids = M3_STATE.easIds.slice();

  var subjects = {
    intro:    'MiniBox+ Resources for ' + practice,
    postdemo: 'Following Up on Our Meeting at ' + practice,
    pricing:  'MiniBox+ Pricing and Materials for ' + practice,
    checkin:  'Checking In and Sharing MiniBox+ Resources'
  };
  var greetings = {
    intro:    'I wanted to reach out and share some resources that give you a clear picture of how the MiniBox+ can benefit ' + practice + '.',
    postdemo: 'Thank you for the time today. It was great walking through what the MiniBox+ can do for ' + practice + '. As promised, here is everything we discussed in one place.',
    pricing:  'Following up on our recent conversation. I have put together the pricing details alongside supporting materials so you have everything in one place.',
    checkin:  'I wanted to check in and make sure you have everything you need to evaluate the MiniBox+ for ' + practice + '.'
  };
  var closings = {
    intro:    'I would love to set up a quick call or demo at your convenience. Please let me know what works best for you and your team.',
    postdemo: 'Please do not hesitate to reach out with any questions. I will follow up in a few days, but feel free to reach out directly at any time.',
    pricing:  'If you would like to discuss any of the pricing details or explore financing options, I am happy to connect at your convenience.',
    checkin:  'I am happy to answer any questions or schedule a follow-up demo. Just let me know how I can help.'
  };
  var type = (typeof easEmailType !== 'undefined') ? easEmailType : 'intro';

  var body = 'Dear ' + doctor + ',\n\n' + (greetings[type] || greetings.intro);
  if (ids.length) {
    var lines = ids.map(function(id, i){ var m = m3ById(id); return (i+1) + '. ' + m.blurb; });
    body += '\n\nI have attached the following materials:\n\n' + lines.join('\n\n');
  }
  body += '\n\n' + (closings[type] || closings.intro) + '\n\nBest regards,\n'
        + (profileSet && typeof buildSignature === 'function' ? buildSignature() : rep + '\nPulmOne USA');

  document.getElementById('eas-out-subject').textContent = subjects[type] || subjects.intro;
  document.getElementById('eas-out-body').textContent = body;

  var ul = document.getElementById('eas-checklist-items');
  if (ids.length) {
    ul.innerHTML = ids.map(function(id){ var m = m3ById(id); return '<li><strong>' + m.title + '</strong> · ' + m3SizeLabel(m.kb) + '</li>'; }).join('')
      + '<li style="list-style:none; margin-top:6px; font-weight:700;">Total: ' + m3SizeLabel(m3TotalKB(ids)) + (ids.length > 1 ? ' — they save as ONE .zip when you tap Send with Outlook; drag that file into the email.' : ' — it downloads when you tap Send with Outlook; drag it into the email.') + '</li>';
  } else {
    ul.innerHTML = '<li>No materials selected — this will be a plain email with no attachments.</li>';
  }
  m3RenderSendHelp('m3-eas-send-help');
  m3ApplyFlavor();

  var out = document.getElementById('eas-output');
  out.classList.add('show');
  setTimeout(function(){ out.scrollIntoView({behavior:'smooth', block:'start'}); }, 50);
}
function m3EasDownloadEml(){
  var subj = document.getElementById('eas-out-subject').textContent;
  if (!subj) { m3Toast('Tap “Generate Send Package Email” first'); return; }
  if (!m3EmlAvailable()) { m3Toast('Materials data file missing — keep materials-data.js next to this page. Using Outlook Web instead.'); m3EasOWA(); return; }
  var body = m3EasBody();
  var to = (typeof easGetTo === 'function') ? easGetTo() : '';
  var practice = document.getElementById('eas-practice').value.trim();
  m3BuildEml({ to:to, subject:subj, body:body, ids:M3_STATE.easIds, fileName:'PulmOne-' + (practice || 'Materials') });
  m3Toast('Draft downloaded — double-click it, review, and hit Send. (' + M3_STATE.easIds.length + ' attachment' + (M3_STATE.easIds.length===1?'':'s') + ' already inside.)');
}
function m3EasOWA(){
  var subj = document.getElementById('eas-out-subject').textContent;
  if (!subj) { m3Toast('Tap “Generate Send Package Email” first'); return; }
  var body = m3EasBody();
  var to = (typeof easGetTo === 'function') ? easGetTo() : '';
  var n = M3_STATE.easIds.length;
  var practice = (document.getElementById('eas-practice') || {value:''}).value.trim();
  var save = function(){
    if (n === 1) { m3DownloadMany(M3_STATE.easIds); var m = m3ById(M3_STATE.easIds[0]); return (m && m.file) || 'the downloaded PDF'; }
    var z = m3DownloadZip(M3_STATE.easIds, 'PulmOne-' + (practice || 'Materials'));
    if (!z) { m3DownloadMany(M3_STATE.easIds); return n + ' downloaded PDFs'; }
    return z;
  };
  var fname = n ? save() : null;
  m3GuardedOWA(to, '', subj, body, n ? false : null);
  if (n) m3SendSteps(fname, n, save);
}
function easOpenOutlook(){ m3EasOWA(); }
function easSendMailto(){
  var subj = document.getElementById('eas-out-subject').textContent;
  if (!subj) { m3Toast('Tap “Generate Send Package Email” first'); return; }
  var body = m3EasBody();
  var to = (typeof easGetTo === 'function') ? easGetTo() : '';
  m3GuardedMailto(to, '', subj, body);
  var n = M3_STATE.easIds.length;
  var practice = (document.getElementById('eas-practice') || {value:''}).value.trim();
  if (n === 1) {
    m3DownloadMany(M3_STATE.easIds);
    m3Toast('Outlook is opening — now drag the downloaded PDF from your Downloads folder into the email.', 6000);
  } else if (n > 1) {
    if (!m3DownloadZip(M3_STATE.easIds, 'PulmOne-' + (practice || 'Materials'))) m3DownloadMany(M3_STATE.easIds);
    m3Toast('Outlook is opening — now drag the ONE downloaded .zip (all ' + n + ' PDFs inside) from your Downloads folder into the email.', 6000);
  }
}

/* ============ MODE B — TEMPLATE LIBRARY: attach chips + draft send ============ */
function m3ElChipsHtml(){
  var chips = MATERIALS.filter(function(m){ return !m.noembed; }).map(function(m){
    var on = M3_STATE.elIds.indexOf(m.id) >= 0;
    return '<span class="m3-chip' + (on?' on':'') + '" onclick="m3ElToggle(\'' + m.id + '\')" title="' + m.sub.replace(/"/g,'&quot;') + ' · ' + m3SizeLabel(m.kb) + '">' + m.title + '</span>';
  }).join('');
  return '<div class="m3-chips-row"><span class="m3-chips-lbl">📎 Attach materials:</span>' + chips + '</div>';
}
function m3ElToggle(id){
  var i = M3_STATE.elIds.indexOf(id);
  if (i >= 0) M3_STATE.elIds.splice(i,1); else M3_STATE.elIds.push(id);
  renderElPreview();
}
/* v3 override of renderElPreview: same as v2.27 + attach chips + draft button.
   Preserves To/Cc the user already typed when the preview re-renders. */
function renderElPreview() {
  if (!currentElTmpl) return;
  var t = currentElTmpl;
  if (M3_STATE.elTmplTitle !== t.title) { M3_STATE.elTmplTitle = t.title; M3_STATE.elIds = []; }
  var prevTo = document.getElementById('el-to'); prevTo = prevTo ? prevTo.value : '';
  var prevCc = document.getElementById('el-cc'); prevCc = prevCc ? prevCc.value : '';
  var subject = currentElCustom.subject != null ? currentElCustom.subject : applyProfileMerges(t.subject);
  var body    = currentElCustom.body    != null ? currentElCustom.body    : applyProfileMerges(t.body);
  document.getElementById('el-preview-title').textContent = t.title;
  var highlight = function(s) {
    return escapeHTML(s).replace(/\{\{([A-Z_0-9]+)\}\}/g, '<span class="merge">{{$1}}</span>');
  };
  var nAtt = M3_STATE.elIds.length;
  document.getElementById('el-preview-body').innerHTML =
    '<div class="email-field email-to-row">' +
      '<div><div class="email-field-lbl">To</div><input class="email-field-input" id="el-to" name="to-email" type="email" autocomplete="email" list="mbx-emails" onchange="mbxRememberEmail(this.value)" placeholder="doctor@practice.com"></div>' +
      '<div><div class="email-field-lbl">Cc (optional)</div><input class="email-field-input" id="el-cc" name="cc-email" type="email" autocomplete="email" list="mbx-emails" onchange="mbxRememberEmail(this.value)" placeholder=""></div>' +
    '</div>' +
    '<div class="email-field">' +
      '<div class="email-field-lbl">Subject</div>' +
      '<input class="email-field-input" id="el-subject" type="text" value="' + escapeAttr(subject) + '" oninput="elSubjectEdit()">' +
    '</div>' +
    '<div class="email-field">' +
      '<div class="email-field-lbl">Body &mdash; yellow = still needs filling, tap to edit</div>' +
      '<div class="email-body-wrap" id="el-body" contenteditable="true" oninput="elBodyEdit()">' + highlight(body).replace(/\n/g,'<br>') + '</div>' +
    '</div>' +
    m3ElChipsHtml() +
    '<div class="email-send-row" id="m3-el-send-row">' +
      '<button class="email-btn email-btn-owa" onclick="elSendOWA()" title="Opens Outlook signed in as you. Press Ctrl+V to drop your email in (your Outlook signature stays at the bottom)' + (nAtt ? ', drag the downloaded file in' : '') + ', hit Send.">&#127760; Send with Outlook' + (nAtt ? ' (+' + nAtt + ' &#128206;)' : '') + '</button>' +
      '<button class="email-btn email-btn-copy" onclick="elCopyBody()">&#128196; Copy email text</button>' +
    '</div>' +
    '<div class="m3-send-help" id="m3-el-send-help"></div>' +
    '<div class="email-note"><strong>When to use this template:</strong> ' + t.note + '</div>';
  var toEl = document.getElementById('el-to'); if (toEl && prevTo) toEl.value = prevTo;
  var ccEl = document.getElementById('el-cc'); if (ccEl && prevCc) ccEl.value = prevCc;
  m3RenderSendHelp('m3-el-send-help');
  m3ApplyFlavor();
}
function m3ElEml(){
  if (!currentElTmpl) { m3Toast('Pick a template first'); return; }
  if (!m3EmlAvailable()) { m3Toast('Materials data file missing — keep materials-data.js next to this page. Using Outlook Web instead.'); elSendOWA(); return; }
  var name = m3BuildEml({
    to: elGetCurrentTo(), cc: elGetCurrentCc(),
    subject: elGetCurrentSubject(), body: elGetCurrentBody(),
    ids: M3_STATE.elIds, fileName: 'PulmOne-' + currentElTmpl.title
  });
  var n = M3_STATE.elIds.length;
  m3Toast('Draft downloaded — double-click it, review, and hit Send.' + (n ? ' (' + n + ' attachment' + (n===1?'':'s') + ' already inside.)' : ''));
}
/* v3 overrides: same behavior + length guard + companion file downloads */
function elSendOWA(){
  if (!currentElTmpl) { m3Toast('Pick a template first'); return; }
  var n = M3_STATE.elIds.length;
  /* v3.13: bundle multi-file sends into ONE zip automatically — loose PDFs
     triggered the browser's "open with Acrobat" auto-open on every file. */
  var save = function(){
    if (n === 1) { m3DownloadMany(M3_STATE.elIds); var m = m3ById(M3_STATE.elIds[0]); return (m && m.file) || 'the downloaded PDF'; }
    var z = m3DownloadZip(M3_STATE.elIds, 'PulmOne-' + (currentElTmpl ? currentElTmpl.title : 'Materials'));
    if (!z) { m3DownloadMany(M3_STATE.elIds); return n + ' downloaded PDFs'; }
    return z;
  };
  var fname = n ? save() : null;
  m3GuardedOWA(elGetCurrentTo(), elGetCurrentCc(), elGetCurrentSubject(), elGetCurrentBody(), n ? false : null);
  if (n) m3SendSteps(fname, n, save);
}
function elSendMailto(){
  if (!currentElTmpl) { m3Toast('Pick a template first'); return; }
  m3GuardedMailto(elGetCurrentTo(), elGetCurrentCc(), elGetCurrentSubject(), elGetCurrentBody());
  var n = M3_STATE.elIds.length;
  if (n === 1) {
    m3DownloadMany(M3_STATE.elIds);
    m3Toast('Outlook is opening — drag the downloaded PDF into the email.', 6000);
  } else if (n > 1) {
    if (!m3DownloadZip(M3_STATE.elIds, 'PulmOne-' + (currentElTmpl ? currentElTmpl.title : 'Materials'))) m3DownloadMany(M3_STATE.elIds);
    m3Toast('Outlook is opening — drag the ONE downloaded .zip (all ' + n + ' PDFs inside) into the email.', 6000);
  }
}

/* ============ MATERIALS LIBRARY (Forms tab) ============ */
function m3EmailThis(id){
  M3_STATE.easIds = [id];
  showTab('emaillib', document.querySelector('.tab-btn[onclick*="emaillib"]'));
  m3RenderEasMaterials();
  setTimeout(function(){
    var eas = document.querySelector('.eas-wrap');
    if (eas) eas.scrollIntoView({behavior:'smooth', block:'start'});
    m3Toast('Material selected — fill in the doctor’s info and generate the email.');
  }, 120);
}
function m3RenderLibrary(){
  var host = document.getElementById('m3-library');
  if (!host) return;
  var html = '';
  M3_CAT_ORDER.forEach(function(cat){
    var items = MATERIALS.filter(function(m){ return m.cat===cat; });
    if (!items.length) return;
    html += '<div class="m3-cat-label">' + M3_CATS[cat] + '</div><div class="m3-lib-grid">';
    items.forEach(function(m){
      html += '<div class="m3-lib-card">'
        + '<div class="m3-lib-title">' + m.title + ' <span class="m3-kb">' + m3SizeLabel(m.kb) + '</span></div>'
        + '<div class="m3-lib-sub">' + m.sub + (m.care ? ' &nbsp;<span class="m3-care">send only when closing</span>' : '') + '</div>'
        + '<div class="m3-lib-btns">'
        + '<button onclick="m3View(\'' + m.id + '\')">&#128065; View</button>'
        + '<button onclick="m3Download(\'' + m.id + '\')">&#11015; Download</button>'
        + (m.noembed ? '' : '<button class="m3-mail" onclick="m3EmailThis(\'' + m.id + '\')">&#9993; Email it</button>')
        + '</div></div>';
    });
    html += '</div>';
  });
  if (!m3EmlAvailable()) {
    html = '<div class="m3-send-help" style="margin-bottom:12px; border-color:#fcd34d; background:#fff7e6;"><strong>&#9888; materials-data.js not found.</strong> Keep that file (and the materials folder) in the same folder as this page — without it, View/Download still work but emails can’t carry attachments automatically.</div>' + html;
  }
  host.innerHTML = html;
}

/* ============ CARDIOLOGY TAB — sub-view switch + playbook iframe height ============ */
function cardioShowView(view, btn){
  ['playbook','evidence'].forEach(function(v){
    var el = document.getElementById('cardio-view-' + v);
    if (el) el.style.display = (v === view) ? '' : 'none';
    var b = document.getElementById('cxsub-' + v);
    if (b) b.classList.toggle('on', v === view);
  });
}
window.addEventListener('message', function(e){
  if (e.data && e.data.cardioPbHeight){
    var f = document.getElementById('cardio-playbook-iframe');
    if (f) f.style.height = (Math.max(900, e.data.cardioPbHeight) + 30) + 'px';
  }
});

/* ============ RHEUMATOLOGY TAB — sub-view switch + files ============ */
function rheumShowView(view, btn){
  ['playbook','estimator','files'].forEach(function(v){
    var el = document.getElementById('rheum-view-' + v);
    if (el) el.style.display = (v === view) ? '' : 'none';
    var b = document.getElementById('rhsub-' + v);
    if (b) b.classList.toggle('on', v === view);
  });
  if (btn && btn.classList) { /* explicit button click already handled above */ }
  if (view === 'files') m3RenderRheumFiles();
}
function m3RenderRheumFiles(){
  var host = document.getElementById('rheum-files-grid');
  if (!host) return;
  var items = MATERIALS.filter(function(m){ return m.cat === 'rheum'; });
  var html = '<div class="m3-lib-grid">';
  items.forEach(function(m){
    html += '<div class="m3-lib-card">'
      + '<div class="m3-lib-title">' + m.title + ' <span class="m3-kb">' + m3SizeLabel(m.kb) + '</span></div>'
      + '<div class="m3-lib-sub">' + m.sub + '</div>'
      + '<div class="m3-lib-btns">'
      + (m3IsViewable(m.file) ? '<button onclick="m3View(\'' + m.id + '\')">&#128065; View</button>' : '')
      + '<button onclick="m3Download(\'' + m.id + '\')">&#11015; Download</button>'
      + '<button class="m3-mail" onclick="m3EmailThis(\'' + m.id + '\')">&#9993; Email it</button>'
      + '</div></div>';
  });
  html += '</div>';
  host.innerHTML = html;
}
function rheumEmailAll(){
  M3_STATE.easIds = MATERIALS.filter(function(m){ return m.cat === 'rheum'; }).map(function(m){ return m.id; });
  showTab('emaillib', document.querySelector('.tab-btn[onclick*="emaillib"]'));
  m3RenderEasMaterials();
  setTimeout(function(){
    var eas = document.querySelector('.eas-wrap');
    if (eas) eas.scrollIntoView({behavior:'smooth', block:'start'});
    m3Toast('All 7 rheumatology files loaded — fill in the doctor’s info and generate the email.');
  }, 120);
}

function cardioEmailAll(){
  M3_STATE.easIds = MATERIALS.filter(function(m){ return m.cat === 'cardio'; }).map(function(m){ return m.id; });
  showTab('emaillib', document.querySelector('.tab-btn[onclick*="emaillib"]'));
  m3RenderEasMaterials();
  setTimeout(function(){
    var eas = document.querySelector('.eas-wrap');
    if (eas) eas.scrollIntoView({behavior:'smooth', block:'start'});
    m3Toast('Cardiology one-pager loaded - fill in the doctor info and generate the email.');
  }, 120);
}

/* ============ OUTLOOK FLAVOR — highlight the right button ============ */
function m3GetOutlook(){ return (typeof REP_PROFILE !== 'undefined' && REP_PROFILE.outlook) || ''; }
function m3SetOutlook(f){
  if (typeof REP_PROFILE === 'undefined') return;
  REP_PROFILE.outlook = f;
  try { localStorage.setItem('pulmone_rep_profile', JSON.stringify(REP_PROFILE)); } catch(e) {}
  m3SyncOutlookToggle();
  m3ApplyFlavor();
  m3RenderSendHelp('m3-eas-send-help');
  m3RenderSendHelp('m3-el-send-help');
}
function m3SyncOutlookToggle(){
  var f = m3GetOutlook();
  ['classic','new','web'].forEach(function(k){
    var b = document.getElementById('pm-ol-' + k);
    if (b) b.classList.toggle('on', f === k);
  });
}
function m3ApplyFlavor(){
  var f = m3GetOutlook();
  var reco = (f === 'classic') ? 'classic' : (f ? 'owa' : '');
  document.querySelectorAll('[data-flavor]').forEach(function(btn){
    btn.classList.toggle('m3-reco', !!reco && btn.getAttribute('data-flavor') === reco);
  });
}
/* v3.14: one team, one Outlook (PulmOne Microsoft 365) — one send button,
   so the help is the same for everyone regardless of the old flavor setting. */
function m3RenderSendHelp(id){
  var el = document.getElementById(id);
  if (!el) return;
  el.innerHTML = '<strong>How sending works:</strong> tap <strong>&#127760; Send with Outlook</strong> — the email opens addressed, signed in as you, with your text on the clipboard. <strong>1.</strong> Click in the message and press <strong>Ctrl+V</strong> (your Outlook signature stays at the bottom). <strong>2.</strong> Picked materials? Drag the downloaded file into the email &mdash; it&rsquo;s behind the ⬇ download icon at the top of this window (or in your Downloads folder). <strong>3.</strong> Hit Send.';
}
/* v3 override: openProfile also syncs the Outlook-flavor toggle */
function openProfile(){
  document.getElementById('pm-name').value    = REP_PROFILE.name;
  document.getElementById('pm-title').value   = REP_PROFILE.title;
  document.getElementById('pm-email').value   = REP_PROFILE.email;
  document.getElementById('pm-mobile').value  = REP_PROFILE.mobile;
  document.getElementById('pm-company').value = REP_PROFILE.company;
  setEmailMode(REP_PROFILE.emailMode, true);
  m3SyncOutlookToggle();
  document.getElementById('profile-modal').classList.add('open');
}

/* Reads the (possibly edited) Mode A body, preserving line breaks. */
function m3EasBody(){
  var el = document.getElementById('eas-out-body');
  if (!el) return '';
  var html = el.innerHTML.replace(/<br\s*\/?>/gi,'\n').replace(/<\/(div|p)>/gi,'\n').replace(/<(div|p)[^>]*>/gi,'');
  var tmp = document.createElement('div'); tmp.innerHTML = html;
  return tmp.textContent || tmp.innerText || '';
}
/* v3 override: copy the edited body, not the original. */
function easCopy(){
  try { elCopyToClipboard(m3EasBody()); } catch(e) {}
  m3Toast('Email body copied');
}

/* ============ PRACTICE RUN — test the attachment flow on yourself ============ */
function m3SelfTest(){
  var me = (typeof REP_PROFILE !== 'undefined' && REP_PROFILE.email) || '';
  if (!me) {
    m3Toast('Set your work email in My Rep Profile first — then the practice email can be addressed to you.');
    try { openProfile(); } catch(e) {}
    return;
  }
  /* v3.14: practice run now rehearses the real send flow (Outlook compose +
     paste + drag) instead of downloading an .eml the web team can't open. */
  if (m3EmlAvailable()) { try { m3DownloadMany(['brochure']); } catch(e) {} }
  m3GuardedOWA(me, '',
    'Practice run — MiniBox+ Toolkit (this email goes to YOU)',
    'This is a practice email from your MiniBox+ Toolkit.\n\nTwo moves, same as every real send:\n\n  1. Press Ctrl+V — this text drops into the email, and your Outlook signature stays at the bottom.\n  2. Drag the brochure PDF into the email (look behind the ⬇ download icon at the top of the window, or in your Downloads folder).\n\nHit Send: it goes to your own inbox only. No customer will ever see this.',
    'Practice time — Outlook is opening addressed to YOU. Click in the message, press Ctrl+V, then drag the downloaded brochure PDF in. Hit Send and check your inbox.');
}

/* ============ FIRST-OPEN WELCOME (30-second setup) ============ */
function m3MaybeWelcome(){
  var done = false;
  try { done = !!localStorage.getItem('mbx3_welcome_done'); } catch(e) {}
  if (done || (typeof REP_PROFILE !== 'undefined' && REP_PROFILE.name)) return;
  document.body.insertAdjacentHTML('beforeend',
    '<div id="m3-welcome"><div class="m3w-card">' +
      '<div class="m3w-title">&#128075; Welcome to your MiniBox+ Toolkit</div>' +
      '<div class="m3w-sub">20 seconds of setup and every email fills itself in with your details. You can change any of this later under <strong>My Rep Profile</strong> at the top.</div>' +
      '<div class="m3w-lbl">Your name</div>' +
      '<input class="m3w-inp" id="m3w-name" type="text" placeholder="First Last">' +
      '<div class="m3w-lbl">Work email</div>' +
      '<input class="m3w-inp" id="m3w-email" type="email" placeholder="you@pulm-one.com">' +
      '<div class="m3w-actions">' +
        '<button class="m3w-skip" onclick="m3wClose(false)">Skip for now</button>' +
        '<button class="m3w-go" onclick="m3wClose(true)">Save &amp; start &rarr;</button>' +
      '</div>' +
    '</div></div>');
  document.getElementById('m3-welcome').classList.add('open');
}
function m3wPick(btn){
  document.querySelectorAll('#m3w-ol button').forEach(function(b){ b.classList.remove('on'); });
  btn.classList.add('on');
}
function m3wClose(save){
  if (save && typeof REP_PROFILE !== 'undefined') {
    var n = document.getElementById('m3w-name').value.trim();
    var e = document.getElementById('m3w-email').value.trim();
    var olBtn = document.querySelector('#m3w-ol button.on');
    if (n) REP_PROFILE.name = n;
    if (e) REP_PROFILE.email = e;
    if (olBtn) REP_PROFILE.outlook = olBtn.getAttribute('data-v');
    try { localStorage.setItem('pulmone_rep_profile', JSON.stringify(REP_PROFILE)); } catch(ex) {}
    try { renderProfileHeader(); } catch(ex) {}
    try { easSyncProfile(); } catch(ex) {}
    try { m3ApplyFlavor(); m3RenderSendHelp('m3-eas-send-help'); m3RenderSendHelp('m3-el-send-help'); } catch(ex) {}
    m3Toast(n ? ('Welcome, ' + n.split(' ')[0] + '! Every email now fills itself in.') : 'Saved.');
  }
  try { localStorage.setItem('mbx3_welcome_done', '1'); } catch(ex) {}
  var w = document.getElementById('m3-welcome');
  if (w) w.classList.remove('open');
}

/* ============ ENV BADGE ============ */
function m3RenderEnvBadge(){
  var b = document.getElementById('m3-env-badge');
  if (!b) return;
  if (m3IsHosted()) {
    b.innerHTML = '&#127760; Online edition &middot; <a href="MiniBox_Toolkit_v3_offline.zip" style="color:inherit;" title="Download a copy that works with no internet">get offline copy</a>';
  } else {
    b.textContent = '💾 Offline edition';
    b.title = 'Running from a local file — everything still works, including real email attachments.';
  }
}

/* ============ INIT v3 ============ */
(function initM3(){
  // Restore the Outlook-flavor field the v2.27 loader doesn't know about.
  try {
    var raw = localStorage.getItem('pulmone_rep_profile');
    if (raw) { var p = JSON.parse(raw); if (p && p.outlook != null && typeof REP_PROFILE !== 'undefined') REP_PROFILE.outlook = p.outlook; }
  } catch(e) {}
  try { m3RenderEasMaterials(); } catch(e) {}
  try { m3RenderLibrary(); } catch(e) {}
  try { m3RenderEnvBadge(); } catch(e) {}
  try { if (typeof currentElTmpl !== 'undefined' && currentElTmpl) renderElPreview(); } catch(e) {}
  try { m3ApplyFlavor(); } catch(e) {}
  try { m3MaybeWelcome(); } catch(e) {}
})();
</script>


<script>
/* ---- ACH FULL PAYMENT FORM (embedded, namespaced achf-) ---- */
function achfFmt(n) {
  return '$' + (n || 0).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
}
function achfRecalc() {
  var price = parseFloat((document.getElementById('achf-purchase-price') || {}).value) || 0;
  var el = document.getElementById('achf-grand-total');
  if (el) el.textContent = achfFmt(price);
}
function achfClear() {
  if (!confirm('Clear all full-payment ACH fields?')) return;
  ['achf-date','achf-customer','achf-bank-name','achf-bank-addr','achf-routing','achf-account',
   'achf-purchase-price'].forEach(function(id) {
    var el = document.getElementById(id); if (el) el.value = '';
  });
  var dEl = document.getElementById('achf-date');
  if (dEl) dEl.classList.remove('has-value');
  achfRecalc();
}
function achfPrint() { window.print(); }
(function() {
  achfRecalc();
  var dEl = document.getElementById('achf-date');
  if (dEl) {
    function openPicker() { try { dEl.showPicker(); } catch (e) {} }
    dEl.addEventListener('focus', openPicker);
    dEl.addEventListener('click', openPicker);
    dEl.addEventListener('change', function() {
      dEl.classList.toggle('has-value', !!dEl.value);
    });
  }
})();
</script>

<script id="mbx-chat">
/* ── Team Chat — the whole sales force in one conversation ──────────────
   Messages live on the server (/api/chat) behind the SAME team password
   as the rest of the toolkit, stored in the team database. Only works in
   the online app (deploytoolkit.vercel.app) — a file:// offline copy has
   no server, so the tab explains that instead of breaking. */
(function () {
  var API = '/api/chat';
  var POLL_MS = 20000;         // refresh every 20s while the chat tab is open
  var BG_EVERY = 3;            // ...and every 3rd tick (60s) in the background for the badge
  var canChat = (location.protocol === 'https:' || location.protocol === 'http:');
  var newestTs = 0;            // timestamp of the newest message we've seen
  var tick = 0;
  var fetching = false;

  function $(id) { return document.getElementById(id); }
  function esc(s) { try { return escapeHTML(s); } catch (e) { return String(s).replace(/[&<>"']/g, function (c) { return '&#' + c.charCodeAt(0) + ';'; }); } }

  function myName() {
    var n = '';
    try { if (typeof REP_PROFILE !== 'undefined' && REP_PROFILE && REP_PROFILE.name) n = REP_PROFILE.name; } catch (e) {}
    if (!n) { try { n = localStorage.getItem('mbx_chat_name') || ''; } catch (e) {} }
    return String(n).trim();
  }
  function lastRead() { try { return parseInt(localStorage.getItem('mbx_chat_lastread') || '0', 10) || 0; } catch (e) { return 0; } }
  function setLastRead(ts) { try { localStorage.setItem('mbx_chat_lastread', String(ts)); } catch (e) {} }

  function fmtTs(ts) {
    var d = new Date(ts), now = new Date();
    var t = d.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
    if (d.toDateString() === now.toDateString()) return t;
    return d.toLocaleDateString([], { month: 'short', day: 'numeric' }) + ' ' + t;
  }

  function isOpen() {
    var p = $('tab-teamchat');
    return !!(p && p.classList.contains('active'));
  }

  function setBadge(count) {
    var b = $('mbx-chat-badge');
    if (!b) return;
    if (count > 0) { b.textContent = count > 99 ? '99+' : String(count); b.style.display = 'inline-block'; }
    else { b.style.display = 'none'; }
  }

  function render(messages) {
    var list = $('mbx-chat-list');
    if (!list) return;
    var nearBottom = (list.scrollHeight - list.scrollTop - list.clientHeight) < 80;
    var me = myName().toLowerCase();

    if (!messages.length) {
      list.innerHTML = '<div style="text-align:center;color:var(--gray-600);font-size:13px;padding:30px 10px;">' +
        'No messages yet &mdash; be the first. Say hi to the team! &#128075;</div>';
      return;
    }

    var html = '';
    for (var i = 0; i < messages.length; i++) {
      var m = messages[i];
      var mine = me && String(m.name || '').trim().toLowerCase() === me;
      var bubbleStyle = mine
        ? 'background:var(--teal-light);border:1px solid #b8ebe4;margin-left:auto;'
        : 'background:#fff;border:1px solid var(--gray-200);margin-right:auto;';
      html +=
        '<div style="display:flex;flex-direction:column;margin-bottom:10px;">' +
          '<div style="max-width:82%;border-radius:14px;padding:8px 12px;box-shadow:0 1px 2px rgba(16,42,67,0.06);' + bubbleStyle + '">' +
            (mine ? '' : '<div style="font-size:12px;font-weight:800;color:var(--blue-brand);margin-bottom:2px;">' + esc(m.name || 'Teammate') + '</div>') +
            '<div style="font-size:14px;color:var(--text);white-space:pre-wrap;word-break:break-word;">' + esc(m.text || '') + '</div>' +
            '<div style="font-size:10.5px;color:var(--gray-600);margin-top:3px;text-align:right;">' + fmtTs(m.ts || 0) + '</div>' +
          '</div>' +
        '</div>';
      if (m.ts > newestTs) newestTs = m.ts;
    }
    list.innerHTML = html;
    if (nearBottom) list.scrollTop = list.scrollHeight;
  }

  function refresh(force) {
    if (!canChat || fetching) return;
    fetching = true;
    fetch(API, { headers: { 'Accept': 'application/json' }, cache: 'no-store' })
      .then(function (r) {
        if (!r.ok) throw new Error('http ' + r.status);
        var ct = r.headers.get('content-type') || '';
        if (ct.indexOf('json') === -1) throw new Error('not-json'); // password session expired -> login page came back
        return r.json();
      })
      .then(function (data) {
        if (!data || !data.ok) throw new Error('bad-data');
        var msgs = data.messages || [];
        var newest = 0, unread = 0, me = myName().toLowerCase();
        for (var i = 0; i < msgs.length; i++) {
          var m = msgs[i];
          if (m.ts > newest) newest = m.ts;
          if (m.ts > lastRead() && String(m.name || '').trim().toLowerCase() !== me) unread++;
        }
        if (isOpen()) {
          render(msgs);
          if (newest) setLastRead(newest);
          setBadge(0);
        } else {
          setBadge(unread);
          newestTs = newest || newestTs;
        }
      })
      .catch(function () {
        if (isOpen() && force) {
          var st = $('mbx-chat-status');
          var list = $('mbx-chat-list');
          if (list && list.textContent.indexOf('Loading') > -1) {
            list.innerHTML = '<div style="text-align:center;color:var(--gray-600);font-size:13px;padding:30px 10px;">' +
              'Can&#39;t reach the chat right now. Check your connection, or close and reopen the app to log back in.</div>';
          }
        }
      })
      .then(function () { fetching = false; });
  }

  window.mbxChatOpened = function () {
    if (!canChat) return;
    refresh(true);
    setBadge(0);
    var list = $('mbx-chat-list');
    if (list) setTimeout(function () { list.scrollTop = list.scrollHeight; }, 250);
  };

  window.mbxChatSend = function () {
    if (!canChat) return;
    var input = $('mbx-chat-input');
    var text = (input && input.value || '').trim();
    if (!text) return;

    var name = myName();
    if (!name) {
      var bar = $('mbx-chat-namebar'), nameInput = $('mbx-chat-name');
      var typed = (nameInput && nameInput.value || '').trim();
      if (typed) {
        name = typed;
        try { localStorage.setItem('mbx_chat_name', typed); } catch (e) {}
        if (bar) bar.style.display = 'none';
      } else {
        if (bar) bar.style.display = 'block';
        if (nameInput) nameInput.focus();
        return;
      }
    }

    var btn = $('mbx-chat-sendbtn');
    if (btn) { btn.disabled = true; btn.textContent = '...'; }
    fetch(API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ name: name, text: text })
    })
      .then(function (r) {
        var ct = r.headers.get('content-type') || '';
        if (!r.ok || ct.indexOf('json') === -1) throw new Error('send-failed');
        return r.json();
      })
      .then(function (data) {
        if (!data || !data.ok) throw new Error('send-failed');
        if (input) { input.value = ''; input.style.height = 'auto'; }
        if (data.message && data.message.ts) setLastRead(data.message.ts);
        refresh(true);
      })
      .catch(function () {
        try { m3Toast('Message didn\'t send — check your connection and try again.', 5000); } catch (e) { alert('Message didn\'t send — try again.'); }
      })
      .then(function () { if (btn) { btn.disabled = false; btn.textContent = 'Send'; } });
  };

  document.addEventListener('DOMContentLoaded', function () {
    var input = $('mbx-chat-input');
    if (input) {
      input.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); window.mbxChatSend(); }
      });
      input.addEventListener('input', function () {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 120) + 'px';
      });
    }

    if (!canChat) {
      // Offline file copy: no server behind it, so explain instead of erroring.
      var list = $('mbx-chat-list');
      var compose = $('mbx-chat-compose');
      if (list) list.innerHTML = '<div style="text-align:center;color:var(--gray-600);font-size:13px;padding:30px 10px;">' +
        'Team Chat lives in the online app.<br>Open <b>deploytoolkit.vercel.app</b> (or your installed MiniBox+ app) to join the conversation.</div>';
      if (compose) compose.style.display = 'none';
      return;
    }

    // First check shortly after launch (for the unread badge), then keep ticking:
    // every 20s with the chat open, every 60s in the background.
    setTimeout(function () { refresh(false); }, 2500);
    setInterval(function () {
      if (document.hidden) return;
      tick++;
      if (isOpen() || tick % BG_EVERY === 0) refresh(false);
    }, POLL_MS);
  });
})();
</script>

<script id="mbx-emails-helper">
/* Recently-used email addresses: feeds a native <datalist> on every To/Cc box,
   so the suggestion dropdown always fills the field when tapped (the browser's
   own saved-address popup won't commit into these dynamically-built inputs). */
function mbxEmailList() {
  try { return JSON.parse(localStorage.getItem('mbx_recent_emails') || '[]'); } catch (e) { return []; }
}
function mbxRenderEmailList() {
  var dl = document.getElementById('mbx-emails');
  if (!dl) {
    dl = document.createElement('datalist');
    dl.id = 'mbx-emails';
    document.body.appendChild(dl);
  }
  var list = mbxEmailList();
  if (typeof REP_PROFILE !== 'undefined' && REP_PROFILE && REP_PROFILE.email && list.indexOf(REP_PROFILE.email) < 0) list.push(REP_PROFILE.email);
  dl.innerHTML = list.map(function (a) {
    return '<option value="' + String(a).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;') + '"></option>';
  }).join('');
}
function mbxRememberEmail(addr) {
  addr = String(addr || '').trim();
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(addr)) return;
  var list = mbxEmailList().filter(function (a) { return a.toLowerCase() !== addr.toLowerCase(); });
  list.unshift(addr);
  if (list.length > 15) list.length = 15;
  try { localStorage.setItem('mbx_recent_emails', JSON.stringify(list)); } catch (e) {}
  mbxRenderEmailList();
}
mbxRenderEmailList();
</script>
<script id="mbx-pwa">
/* MiniBox+ app wiring — install-to-home-screen + auto-update.
   Only runs on the hosted (https) edition; does nothing when this file
   is opened from a download/USB copy, so offline copies are unaffected.
   KEEP THIS BLOCK when mirroring LATEST -> _deploy_toolkit/index.html. */
(function () {
  if (window.__mbxPwa) return; window.__mbxPwa = 1;
  var hosted = location.protocol === 'https:' || location.hostname === 'localhost';
  if (!hosted) return;

  function add(tag, attrs) {
    var el = document.createElement(tag);
    for (var k in attrs) el.setAttribute(k, attrs[k]);
    document.head.appendChild(el);
  }
  add('link', { rel: 'manifest', href: 'manifest.webmanifest' });
  add('link', { rel: 'apple-touch-icon', href: 'icon-180.png' });
  add('meta', { name: 'theme-color', content: '#0a3d6b' });
  add('meta', { name: 'apple-mobile-web-app-capable', content: 'yes' });
  add('meta', { name: 'apple-mobile-web-app-status-bar-style', content: 'black-translucent' });
  add('meta', { name: 'apple-mobile-web-app-title', content: 'MiniBox+' });

  /* ---- background updater: new deploy -> blue "Refresh" bar ---- */
  if ('serviceWorker' in navigator) {
    var refreshing = false;
    navigator.serviceWorker.addEventListener('controllerchange', function () {
      if (refreshing) return; refreshing = true; location.reload();
    });
    navigator.serviceWorker.register('./sw.js').then(function (reg) {
      try { reg.update(); } catch (e) {}
      setInterval(function () { try { reg.update(); } catch (e) {} }, 30 * 60 * 1000);
      if (reg.waiting && navigator.serviceWorker.controller) showUpdateBar(reg);
      reg.addEventListener('updatefound', function () {
        var sw = reg.installing;
        if (!sw) return;
        sw.addEventListener('statechange', function () {
          if (sw.state === 'installed' && navigator.serviceWorker.controller) showUpdateBar(reg);
        });
      });
    }).catch(function () {});
  }

  function showUpdateBar(reg) {
    if (document.getElementById('mbx-update-bar')) return;
    var bar = document.createElement('div');
    bar.id = 'mbx-update-bar';
    bar.style.cssText = 'position:fixed;left:0;right:0;bottom:0;z-index:2147483647;background:#0a3d6b;color:#fff;font-family:-apple-system,Segoe UI,Roboto,Arial,sans-serif;font-size:15px;padding:12px 16px;display:flex;align-items:center;justify-content:center;gap:12px;box-shadow:0 -4px 16px rgba(0,0,0,.35)';
    var msg = document.createElement('span');
    msg.textContent = 'A new version of the toolkit is ready.';
    var btn = document.createElement('button');
    btn.textContent = 'Refresh';
    btn.style.cssText = 'background:#fff;color:#0a3d6b;border:0;border-radius:8px;padding:8px 18px;font-weight:800;font-size:15px;cursor:pointer';
    btn.onclick = function () {
      var w = reg.waiting;
      if (w) w.postMessage({ type: 'SKIP_WAITING' }); else location.reload();
    };
    bar.appendChild(msg); bar.appendChild(btn);
    document.body.appendChild(bar);
  }

  /* ---- friendly install bar ----
     Android / desktop Chrome & Edge fire `beforeinstallprompt`, so we get a
     real Install button. iPhone / iPad NEVER fire it (Apple has no install
     API), so there we show the manual Share -> Add to Home Screen steps
     instead — otherwise iOS users get no prompt at all. */
  var standalone = false;
  try {
    standalone = (window.matchMedia && window.matchMedia('(display-mode: standalone)').matches) ||
      window.navigator.standalone === true;
  } catch (e) {}

  var ua = navigator.userAgent || '';
  /* iPadOS 13+ masquerades as a Mac, so also treat touch-Macs as iPads. */
  var isIOS = /iphone|ipad|ipod/i.test(ua) ||
    (/macintosh/i.test(ua) && navigator.maxTouchPoints > 1);
  /* Real Safari only — Chrome/Firefox/Edge on iOS and in-app browsers
     (Outlook, Teams, etc.) can't Add to Home Screen. */
  var isIOSSafari = isIOS && /safari/i.test(ua) && !/crios|fxios|edgios/i.test(ua);

  var deferredPrompt = null;
  window.addEventListener('beforeinstallprompt', function (e) {
    e.preventDefault();
    deferredPrompt = e;
    if (standalone || localStorage.getItem('mbx_install_dismissed')) return;
    showInstallBar(false);
  });

  if (isIOS && !standalone && !localStorage.getItem('mbx_install_dismissed')) {
    /* Give the page a beat to settle before nudging. */
    setTimeout(function () { showInstallBar(true); }, 3000);
  }

  function showInstallBar(ios) {
    if (document.getElementById('mbx-install-bar')) return;
    var bar = document.createElement('div');
    bar.id = 'mbx-install-bar';
    bar.style.cssText = 'position:fixed;left:0;right:0;bottom:0;z-index:2147483646;background:#0d4a82;color:#fff;font-family:-apple-system,Segoe UI,Roboto,Arial,sans-serif;font-size:15px;padding:12px 16px;display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;text-align:center;box-shadow:0 -4px 16px rgba(0,0,0,.35)';
    var msg = document.createElement('span');
    if (ios) {
      if (isIOSSafari) {
        msg.innerHTML = 'Put MiniBox+ on your home screen: tap <b>Share</b> ⬆️ below, then <b>“Add to Home Screen”</b>';
      } else {
        msg.innerHTML = 'Put MiniBox+ on your home screen: open this page in <b>Safari</b>, tap <b>Share</b> ⬆️, then <b>“Add to Home Screen”</b>';
      }
    } else {
      msg.textContent = 'Put the MiniBox+ Toolkit on your home screen:';
    }
    bar.appendChild(msg);
    if (!ios) {
      var btn = document.createElement('button');
      btn.textContent = 'Install';
      btn.style.cssText = 'background:#fff;color:#0a3d6b;border:0;border-radius:8px;padding:8px 18px;font-weight:800;font-size:15px;cursor:pointer';
      btn.onclick = function () {
        if (!deferredPrompt) return;
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then(function () { bar.remove(); deferredPrompt = null; });
      };
      bar.appendChild(btn);
    }
    var x = document.createElement('button');
    x.textContent = '×';
    x.setAttribute('aria-label', 'Dismiss');
    x.style.cssText = 'background:transparent;color:#bcd4ea;border:0;font-size:22px;cursor:pointer;padding:0 4px;line-height:1';
    x.onclick = function () { localStorage.setItem('mbx_install_dismissed', '1'); bar.remove(); };
    bar.appendChild(x);
    document.body.appendChild(bar);
  }
})();
</script>

</body>
</html>
