  </div>

  <!-- ============================ TRUNK STOCK ============================ -->
  <div class="tab-panel" id="tab-trunkstock">
    <div class="section-head">
      <div class="section-icon icon-blue">&#129528;</div>
      <div>
        <div class="section-title">Trunk Stock &mdash; Rep Field Kit</div>
        <div class="section-sub">Everything a rep should keep in the car. Recommended quantities, what each item is for, and a one-tap reorder link.</div>
      </div>
    </div>

    <div class="alert-box alert-blue">
      <div class="alert-icon">&#9432;</div>
      <div><strong>How to use this page:</strong> Keep your trunk stocked to the recommended quantities below so you&rsquo;re never stuck at an account waiting on a shipment. Tap <strong>Reorder</strong> on any item &mdash; confirm the quantity and price, and it goes into the shared <strong>Order Log</strong> below (so the team&rsquo;s spend tracks itself), then the store page opens. This is a starter list &mdash; photos, exact part numbers, and reorder links are placeholders for now; send the real ones and they&rsquo;ll be dropped in.</div>
    </div>

    <style>
      #tab-trunkstock .ts-cat-head { font-size: 12px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; color: var(--blue-brand, #1e40af); margin: 22px 0 10px; padding-bottom: 6px; border-bottom: 2px solid var(--gray-200, #e5e7eb); }
      #tab-trunkstock .ts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
      #tab-trunkstock .ts-card { background: #fff; border: 1px solid var(--gray-200, #e5e7eb); border-radius: 10px; overflow: hidden; display: flex; flex-direction: column; }
      #tab-trunkstock .ts-photo { height: 150px; background: #f3f4f6; display: flex; align-items: center; justify-content: center; border-bottom: 1px solid var(--gray-200, #e5e7eb); position: relative; }
      #tab-trunkstock .ts-photo img { width: 100%; height: 100%; object-fit: contain; }
      #tab-trunkstock .ts-photo .ts-placeholder { font-size: 40px; opacity: .35; }
      #tab-trunkstock .ts-photo .ts-photo-tag { position: absolute; bottom: 6px; left: 6px; font-size: 9px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; color: #9ca3af; background: rgba(255,255,255,.85); padding: 2px 6px; border-radius: 4px; }
      #tab-trunkstock .ts-qty { position: absolute; top: 8px; right: 8px; background: #fb923c; color: #fff; font-size: 11px; font-weight: 800; padding: 4px 9px; border-radius: 20px; box-shadow: 0 1px 3px rgba(0,0,0,.2); }
      #tab-trunkstock .ts-body { padding: 12px 13px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
      #tab-trunkstock .ts-name { font-size: 14px; font-weight: 700; color: #111827; line-height: 1.25; }
      #tab-trunkstock .ts-use { font-size: 12px; color: #4b5563; line-height: 1.4; }
      #tab-trunkstock .ts-part { font-family: 'DM Mono', monospace; font-size: 11px; color: #6b7280; background: var(--gray-100, #f3f4f6); padding: 4px 8px; border-radius: 5px; word-break: break-word; }
      #tab-trunkstock .ts-part span { color: #9ca3af; font-weight: 600; }
      #tab-trunkstock .ts-actions { margin-top: auto; padding-top: 4px; }
      #tab-trunkstock .ts-reorder { display: inline-flex; align-items: center; gap: 6px; width: 100%; justify-content: center; box-sizing: border-box; text-decoration: none; font-size: 12px; font-weight: 700; padding: 9px 12px; border-radius: 7px; border: 1px solid transparent; cursor: pointer; }
      #tab-trunkstock .ts-reorder.live { background: #ff9900; color: #111; }
      #tab-trunkstock .ts-reorder.live:hover { background: #ffa929; }
      #tab-trunkstock .ts-reorder.todo { background: #fff; color: #9ca3af; border-color: var(--gray-200, #e5e7eb); cursor: default; }
    </style>

    <div id="ts-render"></div>

    <script>
      /* =========================================================
         TRUNK STOCK INVENTORY  (v3.1 - frame, content placeholder)
         To add / edit an item, just edit this list. Fields:
           name   : item name shown on the card
           emoji  : placeholder icon shown until a real photo is added
           qty    : recommended number to carry (text, e.g. "2" or "1 box")
           use    : what it's for / when to use it
           part   : exact part # or model (for reordering the right thing)
           amazon : Amazon (or vendor) reorder URL - leave '' until known
           img    : photo URL/path or data-URI - leave '' for placeholder
           cat    : category bucket (see TS_CATS order below)
         ========================================================= */
      var TS_CATS = ['Devices &amp; Spares', 'Cables &amp; Power', 'Connectivity', 'Consumables', 'Misc / Field Bag'];

      var TRUNK_STOCK = [
        { name: 'HHU (Handheld Unit) - spare #1', emoji: '&#128241;', qty: '2', cat: 'Devices &amp; Spares',
          use: 'Primary backup if a customer HHU fails or is being swapped/serviced. Keeps a demo or install running.', part: 'TBD - model / SKU', amazon: '', img: '' },
        { name: 'HHU (Handheld Unit) - spare #2', emoji: '&#128241;', qty: '2', cat: 'Devices &amp; Spares',
          use: 'Second backup so you can leave one at an account and still cover a demo elsewhere.', part: 'TBD - model / SKU', amazon: '', img: '' },
        { name: 'Spare Tablet', emoji: '&#128252;', qty: '1', cat: 'Devices &amp; Spares',
          use: 'Loaner / replacement tablet pre-loaded with software for demos and installs when the site tablet is down.', part: 'TBD - make / model', amazon: '', img: '' },

        { name: 'USB Cable - Type A to B', emoji: '&#128268;', qty: '2', cat: 'Cables &amp; Power',
          use: 'Connects device to PC/tablet. Most common failure point - always carry spares.', part: 'TBD - length / type', amazon: '', img: '' },
        { name: 'USB Cable - Type A to C', emoji: '&#128268;', qty: '2', cat: 'Cables &amp; Power',
          use: 'For newer tablets/laptops with USB-C ports.', part: 'TBD - length / type', amazon: '', img: '' },
        { name: 'Tablet Charger / Power Supply', emoji: '&#128267;', qty: '1', cat: 'Cables &amp; Power',
          use: 'Spare charger so a low battery never stalls a demo or install.', part: 'TBD - wattage / connector', amazon: '', img: '' },
        { name: 'Power Strip / Surge Protector', emoji: '&#128268;', qty: '1', cat: 'Cables &amp; Power',
          use: 'Exam rooms are short on outlets. One strip powers device, tablet, and charger at once.', part: 'TBD', amazon: '', img: '' },

        { name: 'WiFi Range Extender', emoji: '&#128246;', qty: '1', cat: 'Connectivity',
          use: 'Boosts weak office WiFi so the device/tablet stays connected during testing and upload.', part: 'TBD - make / model', amazon: '', img: '' },
        { name: 'Ethernet Cable', emoji: '&#128376;', qty: '1', cat: 'Connectivity',
          use: 'Hard-wired fallback when site WiFi is unreliable or locked down by IT.', part: 'TBD - Cat6, length', amazon: '', img: '' },
        { name: 'USB-to-Ethernet Adapter', emoji: '&#128268;', qty: '1', cat: 'Connectivity',
          use: 'Lets a tablet/laptop with no Ethernet port use a wired connection.', part: 'TBD', amazon: '', img: '' },

        { name: 'Disposable Mouthpieces / Filters', emoji: '&#128137;', qty: '1 box', cat: 'Consumables',
          use: 'Consumables for demo testing. Confirm correct filter type for the device.', part: 'TBD - confirm SKU', amazon: '', img: '' },
        { name: 'Nose Clips', emoji: '&#128083;', qty: '1 pack', cat: 'Consumables',
          use: 'Required for spirometry/lung-volume testing during demos.', part: 'TBD', amazon: '', img: '' },
        { name: 'Calibration Syringe (3 L)', emoji: '&#128295;', qty: '1', cat: 'Consumables',
          use: 'For verifying/calibrating the device during install or troubleshooting.', part: 'TBD - 3 L standard', amazon: '', img: '' },

        { name: 'Carrying / Hard Case', emoji: '&#129512;', qty: '1', cat: 'Misc / Field Bag',
          use: 'Protects the spare device and tablet in the trunk.', part: 'TBD - Pelican-style', amazon: '', img: '' },
        { name: 'Disinfecting Wipes', emoji: '&#129532;', qty: '1 tub', cat: 'Misc / Field Bag',
          use: 'Wipe-down between demos; offices appreciate it.', part: 'TBD', amazon: '', img: '' }
      ];

      (function renderTrunkStock() {
        var host = document.getElementById('ts-render');
        if (!host) return;
        var html = '';
        TS_CATS.forEach(function(cat) {
          var items = TRUNK_STOCK.filter(function(i) { return i.cat === cat; });
          if (!items.length) return;
          html += '<div class="ts-cat-head">' + cat + '</div>';
          html += '<div class="ts-grid">';
          items.forEach(function(i) {
            var photo = i.img
              ? '<img src="' + i.img + '" alt="">'
              : '<span class="ts-placeholder">' + i.emoji + '</span><span class="ts-photo-tag">Photo to come</span>';
            var idx = TRUNK_STOCK.indexOf(i);
            var btn = '<button type="button" class="ts-reorder live" onclick="tsOrderStart(' + idx + ')">&#128722; Reorder</button>'
                    + (i.amazon ? '' : '<div style="font-size:10px; color:#9ca3af; text-align:center; margin-top:4px;">store link to come &mdash; logs the order either way</div>');
            html += '<div class="ts-card">'
                  +   '<div class="ts-photo">' + photo + '<span class="ts-qty">Carry ' + i.qty + '</span></div>'
                  +   '<div class="ts-body">'
                  +     '<div class="ts-name">' + i.name + '</div>'
                  +     '<div class="ts-use">' + i.use + '</div>'
                  +     '<div class="ts-part"><span>Part&nbsp;#:</span> ' + i.part + '</div>'
                  +     '<div class="ts-actions">' + btn + '</div>'
                  +   '</div>'
                  + '</div>';
          });
          html += '</div>';
        });
        host.innerHTML = html;

        /* v3.21: Order Log section under the items */
        var log = document.createElement('div');
        log.innerHTML =
          '<div class="ts-cat-head" style="margin-top:30px;">&#129534; Team Order Log</div>' +
          '<div style="font-size:12px; color:#4b5563; margin-bottom:10px;">Every Reorder tap lands here for the whole team &mdash; who ordered what, when, and the cost. Totals update as orders come in. Export CSV for finance at month end.</div>' +
          '<div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:10px;">' +
            '<button class="ts-reorder live" style="width:auto;" onclick="tsLoadOrders(true)">&#8635; Refresh</button>' +
            '<button class="ts-reorder live" style="width:auto; background:#e5e7eb;" onclick="tsExportCsv()">&#11015; Export CSV</button>' +
          '</div>' +
          '<div id="ts-log-totals" style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:10px;"></div>' +
          '<div id="ts-log-status" style="font-size:12px; color:#9ca3af; margin-bottom:8px;">Loading order log&hellip;</div>' +
          '<div style="overflow-x:auto;"><table style="width:100%; border-collapse:collapse; font-size:12px;">' +
            '<thead><tr style="text-align:left; color:#6b7280;"><th style="padding:6px 8px;">Date</th><th style="padding:6px 8px;">Rep</th><th style="padding:6px 8px;">Item</th><th style="padding:6px 8px; text-align:right;">Qty</th><th style="padding:6px 8px; text-align:right;">Cost</th></tr></thead>' +
            '<tbody id="ts-log-rows"></tbody></table></div>';
        host.parentNode.appendChild(log);
      })();

      /* =========================================================
         v3.21: ORDER LOG — shared team spend tracking
         POST/GET /api/orders (same Redis + password as Team Chat).
         Offline or API-down: orders queue in localStorage and
         flush the next time the log loads successfully.
         ========================================================= */
      var TS_ORDERS = [];
      function tsEsc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
      function tsRepName() { try { return localStorage.getItem('mbx_chat_name') || ''; } catch (e) { return ''; } }

      function tsOrderStart(idx) {
        var it = TRUNK_STOCK[idx]; if (!it) return;
        var old = document.getElementById('ts-order-pop'); if (old) old.remove();
        var ov = document.createElement('div');
        ov.id = 'ts-order-pop';
        ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:99999;display:flex;align-items:center;justify-content:center;padding:20px;';
        ov.innerHTML =
          '<div style="background:#fff;border-radius:14px;max-width:360px;width:100%;padding:20px;box-shadow:0 20px 60px rgba(0,0,0,.35);" onclick="event.stopPropagation()">' +
            '<div style="font-size:15px;font-weight:800;color:#111827;margin-bottom:2px;">&#128722; Log this order</div>' +
            '<div style="font-size:12.5px;color:#4b5563;margin-bottom:14px;">' + tsEsc(it.name) + '</div>' +
            '<div style="display:flex;gap:8px;margin-bottom:10px;">' +
              '<label style="flex:1;font-size:11px;color:#6b7280;">Qty<input id="ts-o-qty" type="number" min="1" step="1" value="1" style="width:100%;margin-top:3px;padding:8px;border:1px solid #e5e7eb;border-radius:7px;font-size:14px;"></label>' +
              '<label style="flex:2;font-size:11px;color:#6b7280;">Est. cost (total $)<input id="ts-o-cost" type="number" min="0" step="0.01" placeholder="e.g. 24.99" style="width:100%;margin-top:3px;padding:8px;border:1px solid #e5e7eb;border-radius:7px;font-size:14px;"></label>' +
            '</div>' +
            '<label style="display:block;font-size:11px;color:#6b7280;margin-bottom:14px;">Your name<input id="ts-o-name" type="text" value="' + tsEsc(tsRepName()) + '" placeholder="First name" style="width:100%;margin-top:3px;padding:8px;border:1px solid #e5e7eb;border-radius:7px;font-size:14px;box-sizing:border-box;"></label>' +
            '<div style="display:flex;gap:8px;">' +
              '<button class="ts-reorder live" style="flex:1;" onclick="tsOrderSubmit(' + idx + ')">Log' + (it.amazon ? ' &amp; open store' : ' order') + '</button>' +
              '<button class="ts-reorder todo" style="width:auto;cursor:pointer;" onclick="document.getElementById(\'ts-order-pop\').remove()">Cancel</button>' +
            '</div>' +
          '</div>';
        ov.onclick = function () { ov.remove(); };
        document.body.appendChild(ov);
      }

      function tsOrderSubmit(idx) {
        var it = TRUNK_STOCK[idx]; if (!it) return;
        var qty = parseFloat(document.getElementById('ts-o-qty').value) || 1;
        var cost = parseFloat(document.getElementById('ts-o-cost').value) || 0;
        var name = (document.getElementById('ts-o-name').value || '').trim();
        if (!name) { document.getElementById('ts-o-name').style.borderColor = '#ef4444'; return; }
        try { localStorage.setItem('mbx_chat_name', name); } catch (e) {}
        var entry = { name: name, item: it.name.replace(/&amp;/g, '&'), part: it.part, qty: qty, cost: cost, note: '', ts: Date.now() };
        document.getElementById('ts-order-pop').remove();
        if (it.amazon) window.open(it.amazon, '_blank', 'noopener');
        tsPostOrder(entry);
      }

      function tsPostOrder(entry) {
        fetch('/api/orders', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(entry) })
          .then(function (r) { return r.json(); })
          .then(function (j) {
            if (!j || !j.ok) throw new Error('api');
            tsLoadOrders(false);
          })
          .catch(function () {
            try {
              var q = JSON.parse(localStorage.getItem('mbx_orders_queue') || '[]');
              q.push(entry);
              localStorage.setItem('mbx_orders_queue', JSON.stringify(q));
            } catch (e) {}
            var st = document.getElementById('ts-log-status');
            if (st) { st.style.color = '#b45309'; st.textContent = 'Order saved on this device — it syncs to the team log next time the toolkit is online.'; }
          });
      }

      function tsFlushQueue() {
        var q;
        try { q = JSON.parse(localStorage.getItem('mbx_orders_queue') || '[]'); } catch (e) { q = []; }
        if (!q.length) return Promise.resolve();
        return q.reduce(function (p, entry) {
          return p.then(function () {
            return fetch('/api/orders', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(entry) })
              .then(function (r) { return r.json(); })
              .then(function (j) { if (!j || !j.ok) throw new Error('api'); });
          });
        }, Promise.resolve()).then(function () {
          try { localStorage.removeItem('mbx_orders_queue'); } catch (e) {}
        }).catch(function () {});
      }

      function tsLoadOrders(manual) {
        var st = document.getElementById('ts-log-status');
        if (st && manual) { st.style.color = '#9ca3af'; st.textContent = 'Refreshing…'; }
        tsFlushQueue().then(function () {
          return fetch('/api/orders').then(function (r) { return r.json(); });
        }).then(function (j) {
          if (!j || !j.ok) throw new Error(j && j.error || 'api');
          TS_ORDERS = j.orders || [];
          tsRenderLog();
        }).catch(function (e) {
          if (st) {
            st.style.color = '#b45309';
            st.textContent = (location.protocol === 'file:')
              ? 'The shared log needs the deployed site (it talks to the team server). Opening this file directly, orders queue on-device.'
              : 'Could not reach the order log — check connection and tap Refresh.';
          }
        });
      }

      function tsRenderLog() {
        var rows = document.getElementById('ts-log-rows');
        var tot = document.getElementById('ts-log-totals');
        var st = document.getElementById('ts-log-status');
        if (!rows) return;
        var now = new Date(); var mNow = now.getFullYear() + '-' + now.getMonth();
        var monthTotal = 0, byRep = {};
        TS_ORDERS.forEach(function (o) {
          var d = new Date(o.ts);
          if ((d.getFullYear() + '-' + d.getMonth()) === mNow) monthTotal += (o.cost || 0);
          byRep[o.name] = (byRep[o.name] || 0) + (o.cost || 0);
        });
        var chips = '<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:8px 14px;font-size:12px;"><strong>$' + monthTotal.toFixed(2) + '</strong> this month</div>';
        Object.keys(byRep).sort().forEach(function (n) {
          chips += '<div style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:8px 14px;font-size:12px;">' + tsEsc(n) + ': <strong>$' + byRep[n].toFixed(2) + '</strong></div>';
        });
        if (tot) tot.innerHTML = chips;
        rows.innerHTML = TS_ORDERS.map(function (o) {
          var d = new Date(o.ts);
          return '<tr style="border-top:1px solid #e5e7eb;">' +
            '<td style="padding:6px 8px;white-space:nowrap;">' + d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) + '</td>' +
            '<td style="padding:6px 8px;">' + tsEsc(o.name) + '</td>' +
            '<td style="padding:6px 8px;">' + tsEsc(o.item) + '</td>' +
            '<td style="padding:6px 8px;text-align:right;">' + o.qty + '</td>' +
            '<td style="padding:6px 8px;text-align:right;">' + (o.cost ? '$' + o.cost.toFixed(2) : '&mdash;') + '</td></tr>';
        }).join('') || '<tr><td colspan="5" style="padding:10px 8px;color:#9ca3af;">No orders logged yet. Tap Reorder on any item above.</td></tr>';
        if (st) { st.style.color = '#9ca3af'; st.textContent = TS_ORDERS.length + ' order' + (TS_ORDERS.length === 1 ? '' : 's') + ' on the team log.'; }
      }

      function tsExportCsv() {
        var lines = ['Date,Rep,Item,Part,Qty,Cost'];
        TS_ORDERS.slice().reverse().forEach(function (o) {
          var d = new Date(o.ts);
          function q(s) { return '"' + String(s == null ? '' : s).replace(/"/g, '""') + '"'; }
          lines.push([d.toLocaleDateString('en-US'), q(o.name), q(o.item), q(o.part), o.qty, (o.cost || 0).toFixed(2)].join(','));
        });
        var blob = new Blob([lines.join('\n')], { type: 'text/csv' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'trunk-stock-orders.csv';
        a.click();
        setTimeout(function () { URL.revokeObjectURL(a.href); }, 5000);
      }

      document.addEventListener('DOMContentLoaded', function () { tsLoadOrders(false); });
    </script>
  </div>

  <!-- ============================ BILLING HELPER ============================ -->
  <div class="tab-panel" id="tab-billing">
    <div class="section-head">
      <div class="section-icon icon-blue">&#128181;</div>
      <div>
        <div class="section-title">PFT / Spirometry Billing Helper</div>
        <div class="section-sub">For the biller &middot; pick state + payer, check what was performed, get the exact claim with live NCCI conflict checks</div>
      </div>
    </div>
    <div style="background:#ecfdf5; border:1px solid #a7f3d0; border-radius:10px; padding:12px 16px; margin-bottom:16px; font-size:12.5px; color:#065f46;">
      &#9432; This is a <strong>living helper</strong> for your billing staff. Codes that can&#39;t be billed together grey out as you select. Covered-diagnosis &amp; frequency rules vary by payer and are <strong>not hard-coded</strong> &mdash; the tool links out to each payer&#39;s own policy to confirm before submitting. Use <strong>Print / Save PDF</strong> inside the tool to hand a clean claim sheet to the office.
    </div>
    <iframe id="billing-helper-iframe"
      style="width:100%; border:1px solid #e2e8f0; border-radius:10px; height:1500px; display:block; background:#f4f6f9;"
      title="PFT / Spirometry Billing Helper"
      srcdoc="&lt;!doctype html&gt;
&lt;html lang=&quot;en&quot;&gt;
&lt;head&gt;
&lt;meta charset=&quot;utf-8&quot;&gt;
&lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1&quot;&gt;
&lt;title&gt;Spirometry / PFT Billing Helper&lt;/title&gt;
&lt;style&gt;
  :root{color-scheme:light;--navy:#1f3a5f;--navy2:#27496d;--red:#b3261e;--green:#1d7a46;
    --amber:#fff3cd;--grey:#5b6470;--line:#d8dee6;--bg:#f4f6f9;--card:#fff;--soft:#eef3f8;--warn:#fdeceb}
  *{box-sizing:border-box}
  body{margin:0;font-family:-apple-system,BlinkMacSystemFont,&quot;Segoe UI&quot;,Arial,sans-serif;color:#1c2733;background:var(--bg);line-height:1.5}
  .wrap{max-width:940px;margin:0 auto;padding:0 18px 60px}
  header{background:linear-gradient(135deg,var(--navy),var(--navy2));color:#fff;padding:26px 0 22px;margin-bottom:22px}
  header .wrap{padding-top:0;padding-bottom:0}
  h1{margin:0 0 4px;font-size:26px}
  .sub{opacity:.88;font-size:14px;max-width:700px}
  .badge{display:inline-block;background:rgba(255,255,255,.16);border:1px solid rgba(255,255,255,.3);font-size:11px;padding:2px 8px;border-radius:20px;margin-top:8px}
  .card{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:20px;margin-bottom:18px;box-shadow:0 1px 2px rgba(20,40,70,.04)}
  .step{display:flex;align-items:center;gap:10px;font-weight:700;color:var(--navy);font-size:15px;margin:0 0 14px}
  .num{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;background:var(--navy);color:#fff;font-size:13px;flex:0 0 auto}
  label.fld{display:block;font-size:12px;font-weight:700;color:var(--grey);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
  select,.combo{width:100%;padding:11px 12px;font-size:15px;border:1px solid var(--line);border-radius:8px;background:#fff;color:#1c2733;font-family:inherit}
  select:disabled,.combo:disabled{background:#f1f3f6;color:#9aa3ad}
  select:focus,.combo:focus{outline:2px solid var(--navy);outline-offset:1px}
  .combo::placeholder{color:#9aa3ad}
  .hide{display:none}
  .row{display:flex;gap:16px;flex-wrap:wrap}.row&gt;div{flex:1;min-width:200px}
  .codes{display:grid;grid-template-columns:1fr 1fr;gap:8px 18px;margin-top:4px}
  @media(max-width:620px){.codes{grid-template-columns:1fr}}
  .chk{display:flex;gap:9px;align-items:flex-start;font-size:14px;padding:8px 10px;border:1px solid var(--line);border-radius:8px;cursor:pointer;background:#fff}
  .chk:hover{background:var(--soft)}.chk input{margin-top:3px}.chk b{font-variant-numeric:tabular-nums}
  .chk small{display:block;color:var(--grey);font-size:12px}
  .chk.off{opacity:.5;cursor:not-allowed;background:#f7f8fa}
  .chk .note{display:none;color:var(--red);font-size:11.5px;font-weight:700;margin-top:3px}
  .chk .note.on{display:block}
  .codestatus{margin-top:10px;font-size:13px;font-weight:800;color:var(--green)}
  .toggle{display:flex;gap:10px;align-items:center;padding:12px;border:1px solid var(--line);border-radius:8px;margin-top:12px;background:var(--soft)}
  .toggle input{width:18px;height:18px}.opts{margin-top:12px}.opts .chk{margin-bottom:6px;cursor:default}
  button.go{margin-top:16px;background:var(--red);color:#fff;border:0;padding:13px 22px;font-size:15px;font-weight:700;border-radius:8px;cursor:pointer}
  button.go:hover{filter:brightness(1.07)}
  .btns{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
  button.ghost{margin-top:16px;background:#fff;color:var(--navy);border:1px solid var(--navy);padding:13px 18px;font-size:14px;font-weight:700;border-radius:8px;cursor:pointer}
  #out{display:none}
  .mac{display:flex;flex-wrap:wrap;gap:14px;align-items:center;background:var(--soft);border:1px solid var(--line);border-radius:10px;padding:14px 16px;margin-bottom:16px}
  .mac .big{font-size:19px;font-weight:800;color:var(--navy)}
  .mac .jur{font-size:12px;color:var(--grey);font-weight:700;letter-spacing:.5px;text-transform:uppercase}
  .res-h{font-size:13px;font-weight:800;color:var(--navy);text-transform:uppercase;letter-spacing:.6px;margin:22px 0 8px;border-bottom:2px solid var(--navy);padding-bottom:4px}
  ol.steps{padding-left:20px;margin:6px 0}ol.steps li{margin-bottom:9px}
  ul.chklist{list-style:none;padding:0;margin:6px 0}
  ul.chklist li{padding:5px 0 5px 26px;position:relative;font-size:14px}
  ul.chklist li:before{content:&quot;\2713&quot;;position:absolute;left:0;top:4px;color:var(--green);font-weight:800}
  .pill{display:inline-block;font-size:12px;font-weight:700;padding:2px 8px;border-radius:5px;vertical-align:middle}
  .pill.code{background:var(--navy);color:#fff;font-variant-numeric:tabular-nums}
  .pill.mod{background:#fde8e6;color:var(--red);border:1px solid #f3c2bd}
  .pill.dx{background:#e7eef6;color:var(--navy);border:1px solid #c4d4e6}
  .verify{background:var(--amber);border-left:5px solid var(--red);border-radius:6px;padding:12px 14px;margin:12px 0;font-size:13.5px}
  .verify b{color:var(--red)}
  .warnbox{background:var(--warn);border-left:5px solid var(--red);border-radius:6px;padding:12px 14px;margin:10px 0;font-size:14px}
  .warnbox b{color:var(--red)}
  .claim{background:#0f1b2b;color:#e8eef6;border-radius:10px;padding:14px 16px;font-family:&quot;SF Mono&quot;,Consolas,Menlo,monospace;font-size:14px;margin:8px 0}
  .claim .ln{display:flex;gap:10px;align-items:baseline;padding:5px 0;border-bottom:1px solid #24364c}
  .claim .ln:last-child{border-bottom:0}
  .claim .c{color:#7fd1a0;font-weight:700;min-width:96px}
  .claim .m{color:#ff9a90;font-weight:700}
  .claim .d{color:#9fc2e8;margin-left:auto;font-size:12.5px;text-align:right}
  a{color:var(--navy);font-weight:600}
  .muted{color:var(--grey);font-size:12.5px}
  .foot{font-size:12px;color:var(--grey);border-top:1px solid var(--line);margin-top:24px;padding-top:14px}
  .err{color:var(--red);font-weight:700;font-size:13px;margin-top:8px;display:none}
  .tag{display:inline-block;font-size:11px;font-weight:700;padding:2px 9px;border-radius:20px;margin-left:8px;vertical-align:middle}
  .tag.med{background:#e7eef6;color:var(--navy)}.tag.com{background:#efe7f6;color:#5a2a82}
  @media print{header{background:var(--navy)!important;-webkit-print-color-adjust:exact;print-color-adjust:exact}
    .input-card,.aboutcard{display:none}button{display:none}body{background:#fff}
    .claim{-webkit-print-color-adjust:exact;print-color-adjust:exact}}
&lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
&lt;header&gt;&lt;div class=&quot;wrap&quot;&gt;
  &lt;h1&gt;Spirometry / PFT Billing Helper&lt;/h1&gt;
  &lt;div class=&quot;sub&quot;&gt;For billers. Pick the state and payer type, check what was performed, and get the exact claim. Codes that can't be billed together grey out as you go.&lt;/div&gt;
  &lt;span class=&quot;badge&quot;&gt;v6 - Live conflict checks - Verify against the payer&lt;/span&gt;
&lt;/div&gt;&lt;/header&gt;
&lt;div class=&quot;wrap&quot;&gt;
  &lt;div class=&quot;card input-card&quot;&gt;
    &lt;div class=&quot;step&quot;&gt;&lt;span class=&quot;num&quot;&gt;1&lt;/span&gt; Where, and who's the payer?&lt;/div&gt;
    &lt;div class=&quot;row&quot;&gt;
      &lt;div&gt;
        &lt;label class=&quot;fld&quot; for=&quot;state&quot;&gt;State / territory&lt;/label&gt;
        &lt;select id=&quot;state&quot;&gt;&lt;option value=&quot;&quot;&gt;— Select state —&lt;/option&gt;&lt;/select&gt;
      &lt;/div&gt;
      &lt;div&gt;
        &lt;label class=&quot;fld&quot; for=&quot;ptype&quot;&gt;Payer type&lt;/label&gt;
        &lt;select id=&quot;ptype&quot; disabled&gt;
          &lt;option value=&quot;&quot;&gt;— pick a state first —&lt;/option&gt;
        &lt;/select&gt;
      &lt;/div&gt;
      &lt;div&gt;
        &lt;label class=&quot;fld&quot; for=&quot;proc&quot;&gt;Procedure family&lt;/label&gt;
        &lt;select id=&quot;proc&quot;&gt;&lt;/select&gt;
      &lt;/div&gt;
    &lt;/div&gt;
    &lt;div id=&quot;insurerWrap&quot; class=&quot;hide&quot; style=&quot;margin-top:14px&quot;&gt;
      &lt;label class=&quot;fld&quot; for=&quot;insurer&quot;&gt;Commercial insurer &lt;span style=&quot;text-transform:none;font-weight:600;color:#9aa3ad&quot;&gt;(type to search — optional)&lt;/span&gt;&lt;/label&gt;
      &lt;input id=&quot;insurer&quot; class=&quot;combo&quot; list=&quot;insurerlist&quot; autocomplete=&quot;off&quot; placeholder=&quot;e.g. Aetna, Florida Blue — or leave blank&quot;&gt;
      &lt;datalist id=&quot;insurerlist&quot;&gt;&lt;/datalist&gt;
    &lt;/div&gt;
    &lt;div class=&quot;err&quot; id=&quot;err&quot;&gt;Please choose a state and payer type.&lt;/div&gt;
  &lt;/div&gt;
  &lt;div class=&quot;card input-card&quot;&gt;
    &lt;div class=&quot;step&quot;&gt;&lt;span class=&quot;num&quot;&gt;2&lt;/span&gt; What was performed today?&lt;/div&gt;
    &lt;label class=&quot;fld&quot;&gt;Test / codes performed&lt;/label&gt;
    &lt;div class=&quot;codes&quot; id=&quot;codes&quot;&gt;&lt;/div&gt;
    &lt;div class=&quot;codestatus&quot; id=&quot;codestatus&quot;&gt;&lt;/div&gt;
    &lt;div class=&quot;toggle&quot;&gt;
      &lt;input type=&quot;checkbox&quot; id=&quot;em&quot;&gt;
      &lt;label for=&quot;em&quot; style=&quot;margin:0;cursor:pointer&quot;&gt;&lt;b&gt;An office visit (E/M) was also done today&lt;/b&gt;&lt;br&gt;
      &lt;small class=&quot;muted&quot;&gt;Check this only if the provider evaluated the patient beyond running the test.&lt;/small&gt;&lt;/label&gt;
    &lt;/div&gt;
    &lt;div class=&quot;opts&quot;&gt;
      &lt;label class=&quot;fld&quot; style=&quot;margin-top:14px&quot;&gt;Who owns the equipment &amp;amp; reads the result?&lt;/label&gt;
      &lt;label class=&quot;chk&quot;&gt;&lt;input type=&quot;radio&quot; name=&quot;own&quot; value=&quot;global&quot; checked&gt;
        &lt;span&gt;&lt;b&gt;Practice owns the machine AND the provider interprets&lt;/b&gt;&lt;small&gt;In-office testing — bill the global service (most common)&lt;/small&gt;&lt;/span&gt;&lt;/label&gt;
      &lt;label class=&quot;chk&quot;&gt;&lt;input type=&quot;radio&quot; name=&quot;own&quot; value=&quot;pro&quot;&gt;
        &lt;span&gt;&lt;b&gt;Provider only interprets&lt;/b&gt; (equipment owned elsewhere)&lt;small&gt;Bill professional component only&lt;/small&gt;&lt;/span&gt;&lt;/label&gt;
      &lt;label class=&quot;chk&quot;&gt;&lt;input type=&quot;radio&quot; name=&quot;own&quot; value=&quot;tech&quot;&gt;
        &lt;span&gt;&lt;b&gt;Practice only provides equipment/technician&lt;/b&gt;&lt;small&gt;Bill technical component only&lt;/small&gt;&lt;/span&gt;&lt;/label&gt;
    &lt;/div&gt;
    &lt;div class=&quot;btns&quot;&gt;
      &lt;button class=&quot;go&quot; id=&quot;run&quot;&gt;Build my claim &amp;rarr;&lt;/button&gt;
      &lt;button class=&quot;ghost&quot; id=&quot;print&quot; style=&quot;display:none&quot;&gt;Print / Save PDF&lt;/button&gt;
    &lt;/div&gt;
  &lt;/div&gt;
  &lt;div class=&quot;card&quot; id=&quot;out&quot;&gt;
    &lt;div class=&quot;mac&quot; id=&quot;macCard&quot;&gt;
      &lt;div&gt;&lt;div class=&quot;jur&quot; id=&quot;jurLabel&quot;&gt;Payer&lt;/div&gt;&lt;div class=&quot;big&quot; id=&quot;macName&quot;&gt;—&lt;/div&gt;&lt;/div&gt;
      &lt;div style=&quot;text-align:right;flex:1&quot;&gt;&lt;div class=&quot;jur&quot; id=&quot;jurTitle&quot;&gt;Processed by&lt;/div&gt;&lt;div class=&quot;big&quot; id=&quot;jurName&quot;&gt;—&lt;/div&gt;&lt;/div&gt;
    &lt;/div&gt;
    &lt;div id=&quot;result&quot;&gt;&lt;/div&gt;
    &lt;div class=&quot;foot&quot; id=&quot;disclaimer&quot;&gt;&lt;/div&gt;
  &lt;/div&gt;
  &lt;div class=&quot;card aboutcard&quot; style=&quot;background:var(--soft)&quot;&gt;
    &lt;div class=&quot;step&quot; style=&quot;margin-bottom:8px&quot;&gt;&lt;span class=&quot;num&quot; style=&quot;background:var(--grey)&quot;&gt;i&lt;/span&gt; About this tool&lt;/div&gt;
    &lt;p class=&quot;muted&quot; style=&quot;margin:0&quot;&gt;A &lt;b&gt;living helper&lt;/b&gt;. Codes that can't be billed together (bundled or mutually exclusive under NCCI) grey out the moment you select the one that controls them, so you only ever build a valid combination. &lt;b&gt;Each payer's covered-diagnosis list and frequency rules vary and are not hard-coded&lt;/b&gt; — the tool routes you to that payer's own policy to confirm before you submit.&lt;/p&gt;
  &lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
/* ===================== DATA ENGINE ===================== */
var MACS={palmetto:&quot;Palmetto GBA&quot;,novitas:&quot;Novitas Solutions&quot;,firstcoast:&quot;First Coast Service Options&quot;,
  ngs:&quot;National Government Services (NGS)&quot;,wps:&quot;WPS (Wisconsin Physicians Service)&quot;,cgs:&quot;CGS Administrators&quot;,
  noridian:&quot;Noridian Healthcare Solutions&quot;};
var STATES={
  &quot;Alabama&quot;:[&quot;palmetto&quot;,&quot;JJ&quot;],&quot;Alaska&quot;:[&quot;noridian&quot;,&quot;JF&quot;],&quot;Arizona&quot;:[&quot;noridian&quot;,&quot;JF&quot;],&quot;Arkansas&quot;:[&quot;novitas&quot;,&quot;JH&quot;],
  &quot;California&quot;:[&quot;noridian&quot;,&quot;JE&quot;],&quot;Colorado&quot;:[&quot;novitas&quot;,&quot;JH&quot;],&quot;Connecticut&quot;:[&quot;ngs&quot;,&quot;JK&quot;],&quot;Delaware&quot;:[&quot;novitas&quot;,&quot;JL&quot;],
  &quot;District of Columbia&quot;:[&quot;novitas&quot;,&quot;JL&quot;],&quot;Florida&quot;:[&quot;firstcoast&quot;,&quot;JN&quot;],&quot;Georgia&quot;:[&quot;palmetto&quot;,&quot;JJ&quot;],&quot;Hawaii&quot;:[&quot;noridian&quot;,&quot;JE&quot;],
  &quot;Idaho&quot;:[&quot;noridian&quot;,&quot;JF&quot;],&quot;Illinois&quot;:[&quot;ngs&quot;,&quot;J6&quot;],&quot;Indiana&quot;:[&quot;wps&quot;,&quot;J8&quot;],&quot;Iowa&quot;:[&quot;wps&quot;,&quot;J5&quot;],&quot;Kansas&quot;:[&quot;wps&quot;,&quot;J5&quot;],
  &quot;Kentucky&quot;:[&quot;cgs&quot;,&quot;J15&quot;],&quot;Louisiana&quot;:[&quot;novitas&quot;,&quot;JH&quot;],&quot;Maine&quot;:[&quot;ngs&quot;,&quot;JK&quot;],&quot;Maryland&quot;:[&quot;novitas&quot;,&quot;JL&quot;],
  &quot;Massachusetts&quot;:[&quot;ngs&quot;,&quot;JK&quot;],&quot;Michigan&quot;:[&quot;wps&quot;,&quot;J8&quot;],&quot;Minnesota&quot;:[&quot;ngs&quot;,&quot;J6&quot;],&quot;Mississippi&quot;:[&quot;novitas&quot;,&quot;JH&quot;],
  &quot;Missouri&quot;:[&quot;wps&quot;,&quot;J5&quot;],&quot;Montana&quot;:[&quot;noridian&quot;,&quot;JF&quot;],&quot;Nebraska&quot;:[&quot;wps&quot;,&quot;J5&quot;],&quot;Nevada&quot;:[&quot;noridian&quot;,&quot;JE&quot;],
  &quot;New Hampshire&quot;:[&quot;ngs&quot;,&quot;JK&quot;],&quot;New Jersey&quot;:[&quot;novitas&quot;,&quot;JL&quot;],&quot;New Mexico&quot;:[&quot;novitas&quot;,&quot;JH&quot;],&quot;New York&quot;:[&quot;ngs&quot;,&quot;JK&quot;],
  &quot;North Carolina&quot;:[&quot;palmetto&quot;,&quot;JM&quot;],&quot;North Dakota&quot;:[&quot;noridian&quot;,&quot;JF&quot;],&quot;Ohio&quot;:[&quot;cgs&quot;,&quot;J15&quot;],&quot;Oklahoma&quot;:[&quot;novitas&quot;,&quot;JH&quot;],
  &quot;Oregon&quot;:[&quot;noridian&quot;,&quot;JF&quot;],&quot;Pennsylvania&quot;:[&quot;novitas&quot;,&quot;JL&quot;],&quot;Rhode Island&quot;:[&quot;ngs&quot;,&quot;JK&quot;],&quot;South Carolina&quot;:[&quot;palmetto&quot;,&quot;JM&quot;],
  &quot;South Dakota&quot;:[&quot;noridian&quot;,&quot;JF&quot;],&quot;Tennessee&quot;:[&quot;palmetto&quot;,&quot;JJ&quot;],&quot;Texas&quot;:[&quot;novitas&quot;,&quot;JH&quot;],&quot;Utah&quot;:[&quot;noridian&quot;,&quot;JF&quot;],
  &quot;Vermont&quot;:[&quot;ngs&quot;,&quot;JK&quot;],&quot;Virginia&quot;:[&quot;palmetto&quot;,&quot;JM&quot;],&quot;Washington&quot;:[&quot;noridian&quot;,&quot;JF&quot;],&quot;West Virginia&quot;:[&quot;palmetto&quot;,&quot;JM&quot;],
  &quot;Wisconsin&quot;:[&quot;ngs&quot;,&quot;J6&quot;],&quot;Wyoming&quot;:[&quot;noridian&quot;,&quot;JF&quot;],&quot;Puerto Rico&quot;:[&quot;firstcoast&quot;,&quot;JN&quot;],&quot;U.S. Virgin Islands&quot;:[&quot;firstcoast&quot;,&quot;JN&quot;],
  &quot;Guam / American Samoa / N. Mariana Is.&quot;:[&quot;noridian&quot;,&quot;JE&quot;]
};
var MEDICAID={
  &quot;Alabama&quot;:&quot;Alabama Medicaid&quot;,&quot;Alaska&quot;:&quot;Alaska Medicaid (DenaliCare)&quot;,&quot;Arizona&quot;:&quot;AHCCCS&quot;,&quot;Arkansas&quot;:&quot;Arkansas Medicaid&quot;,
  &quot;California&quot;:&quot;Medi-Cal&quot;,&quot;Colorado&quot;:&quot;Health First Colorado&quot;,&quot;Connecticut&quot;:&quot;HUSKY Health&quot;,&quot;Delaware&quot;:&quot;Delaware Medicaid&quot;,
  &quot;District of Columbia&quot;:&quot;DC Medicaid&quot;,&quot;Florida&quot;:&quot;Florida Medicaid&quot;,&quot;Georgia&quot;:&quot;Georgia Medicaid&quot;,&quot;Hawaii&quot;:&quot;Med-QUEST&quot;,
  &quot;Idaho&quot;:&quot;Idaho Medicaid&quot;,&quot;Illinois&quot;:&quot;Illinois Medicaid&quot;,&quot;Indiana&quot;:&quot;Indiana Health Coverage Programs (IHCP)&quot;,&quot;Iowa&quot;:&quot;IA Health Link&quot;,
  &quot;Kansas&quot;:&quot;KanCare&quot;,&quot;Kentucky&quot;:&quot;Kentucky Medicaid&quot;,&quot;Louisiana&quot;:&quot;Healthy Louisiana&quot;,&quot;Maine&quot;:&quot;MaineCare&quot;,
  &quot;Maryland&quot;:&quot;Maryland Medical Assistance&quot;,&quot;Massachusetts&quot;:&quot;MassHealth&quot;,&quot;Michigan&quot;:&quot;Michigan Medicaid&quot;,&quot;Minnesota&quot;:&quot;Medical Assistance (MN)&quot;,
  &quot;Mississippi&quot;:&quot;Mississippi Medicaid&quot;,&quot;Missouri&quot;:&quot;MO HealthNet&quot;,&quot;Montana&quot;:&quot;Montana Medicaid&quot;,&quot;Nebraska&quot;:&quot;Nebraska Medicaid&quot;,
  &quot;Nevada&quot;:&quot;Nevada Medicaid&quot;,&quot;New Hampshire&quot;:&quot;New Hampshire Medicaid&quot;,&quot;New Jersey&quot;:&quot;NJ FamilyCare&quot;,&quot;New Mexico&quot;:&quot;Centennial Care&quot;,
  &quot;New York&quot;:&quot;New York Medicaid&quot;,&quot;North Carolina&quot;:&quot;NC Medicaid&quot;,&quot;North Dakota&quot;:&quot;North Dakota Medicaid&quot;,&quot;Ohio&quot;:&quot;Ohio Medicaid&quot;,
  &quot;Oklahoma&quot;:&quot;SoonerCare&quot;,&quot;Oregon&quot;:&quot;Oregon Health Plan (OHP)&quot;,&quot;Pennsylvania&quot;:&quot;Medical Assistance (PA)&quot;,&quot;Rhode Island&quot;:&quot;Rhode Island Medicaid&quot;,
  &quot;South Carolina&quot;:&quot;Healthy Connections&quot;,&quot;South Dakota&quot;:&quot;South Dakota Medicaid&quot;,&quot;Tennessee&quot;:&quot;TennCare&quot;,&quot;Texas&quot;:&quot;Texas Medicaid&quot;,
  &quot;Utah&quot;:&quot;Utah Medicaid&quot;,&quot;Vermont&quot;:&quot;Vermont Medicaid&quot;,&quot;Virginia&quot;:&quot;Cardinal Care&quot;,&quot;Washington&quot;:&quot;Apple Health&quot;,
  &quot;West Virginia&quot;:&quot;West Virginia Medicaid&quot;,&quot;Wisconsin&quot;:&quot;BadgerCare Plus&quot;,&quot;Wyoming&quot;:&quot;Wyoming Medicaid&quot;,
  &quot;Puerto Rico&quot;:&quot;Puerto Rico Medicaid&quot;,&quot;U.S. Virgin Islands&quot;:&quot;USVI Medicaid&quot;,&quot;Guam / American Samoa / N. Mariana Is.&quot;:&quot;Territory Medicaid&quot;
};
var CLASS_DX={
  medicare:&quot;Medicare does NOT require a different diagnosis for the E/M than the test - Modifier 25 just needs a documented, separate evaluation.&quot;,
  ma:&quot;MA plans cover at least what Medicare covers and follow the same NCCI/Modifier 25 rules - but each plan adds its own edits and prior-auth. Use the Medicare LCD as the floor, then check the plan policy.&quot;,
  commercial:&quot;Many commercial payers deny the E/M as bundled when it shares the SAME primary diagnosis as the test. Where clinically supported, point the E/M to the evaluation diagnosis and the test to the respiratory diagnosis - and confirm this payer's Modifier 25 / reimbursement policy.&quot;,
  medicaid:&quot;Medicaid coverage, covered diagnoses, and modifier rules are set by the state and can be stricter than Medicare. Verify against the state program's provider manual / fee schedule.&quot;
};
function gsearch(q){return &quot;https://www.google.com/search?q=&quot;+encodeURIComponent(q);}
var MCD=&quot;https://www.cms.gov/medicare-coverage-database/search.aspx&quot;;

var PROCEDURES={
  pft:{
    label:&quot;Spirometry / Pulmonary Function Test&quot;,
    emExample:&quot;99214&quot;,
    codes:[
      {cpt:&quot;94010&quot;,desc:&quot;Spirometry (FVC, FEV1) - single set&quot;},
      {cpt:&quot;94060&quot;,desc:&quot;Spirometry pre &amp; post bronchodilator&quot;,includesCodes:[&quot;94010&quot;]},
      {cpt:&quot;94070&quot;,desc:&quot;Multiple/repeat spirometry (provocation)&quot;,includesCodes:[&quot;94010&quot;]},
      {cpt:&quot;94375&quot;,desc:&quot;Flow-volume loop&quot;},
      {cpt:&quot;94726&quot;,desc:&quot;Lung volumes - plethysmography&quot;},
      {cpt:&quot;94727&quot;,desc:&quot;Lung volumes - gas dilution/washout&quot;},
      {cpt:&quot;94729&quot;,desc:&quot;Diffusing capacity (DLCO) - ADD-ON&quot;,addon:true,primaries:[&quot;94010&quot;,&quot;94060&quot;,&quot;94070&quot;,&quot;94375&quot;,&quot;94726&quot;,&quot;94727&quot;]}
    ],
    mutex:[{codes:[&quot;94726&quot;,&quot;94727&quot;],keep:&quot;94726&quot;,msg:&quot;Bill only ONE lung-volume method. 94726 (plethysmography) and 94727 (gas dilution/washout) measure the same thing (lung volumes) two different ways - NCCI treats them as one and bundles them. Report the method actually performed (keeping 94726 here); billing both denies unless you have documentation of two genuinely distinct techniques.&quot;}],
    dxExamples:&quot;J44.9 (COPD), J45.909 (asthma), R06.02 (shortness of breath), R05.9 (cough), J98.4 (other lung disorder), Z01.811 (pre-op respiratory exam)&quot;,
    docChecklist:[
      &quot;Order/referral + medical reason for the test (symptoms, monitoring, pre-op, etc.)&quot;,
      &quot;Signed interpretation &amp; report - numeric values, the graphic record, and the provider's reading&quot;,
      &quot;Diagnosis code(s) that genuinely support medical necessity (a vague code alone often denies)&quot;,
      &quot;Repeat test: document why again (change in symptoms, status, or treatment decision)&quot;,
      &quot;If a visit is billed too: the note shows a separate, significant evaluation beyond the test&quot;
    ]
  }
};
var CARRIERS_DB=[
  {name:&quot;UnitedHealthcare&quot;},{name:&quot;Aetna&quot;},{name:&quot;Cigna&quot;},{name:&quot;Humana&quot;},{name:&quot;Elevance Health&quot;},
  {name:&quot;Anthem Blue Cross Blue Shield&quot;},{name:&quot;Wellpoint&quot;},{name:&quot;Oscar Health&quot;},{name:&quot;Ambetter&quot;},{name:&quot;TRICARE&quot;},
  {name:&quot;Centene&quot;,cls:&quot;medicaid&quot;},{name:&quot;WellCare&quot;,cls:&quot;medicaid&quot;},{name:&quot;Molina Healthcare&quot;,cls:&quot;medicaid&quot;},
  {name:&quot;AmeriHealth Caritas&quot;,cls:&quot;medicaid&quot;},{name:&quot;Aetna Better Health&quot;,cls:&quot;medicaid&quot;},{name:&quot;UnitedHealthcare Community Plan&quot;,cls:&quot;medicaid&quot;},
  {name:&quot;Kaiser Permanente&quot;,st:[&quot;California&quot;,&quot;Colorado&quot;,&quot;Georgia&quot;,&quot;Hawaii&quot;,&quot;Maryland&quot;,&quot;Virginia&quot;,&quot;Oregon&quot;,&quot;Washington&quot;,&quot;District of Columbia&quot;]},
  {name:&quot;Health Net&quot;,st:[&quot;California&quot;]},{name:&quot;L.A. Care Health Plan&quot;,cls:&quot;medicaid&quot;,st:[&quot;California&quot;]},
  {name:&quot;Inland Empire Health Plan&quot;,cls:&quot;medicaid&quot;,st:[&quot;California&quot;]},{name:&quot;Blue Shield of California&quot;,st:[&quot;California&quot;]},
  {name:&quot;Florida Blue&quot;,st:[&quot;Florida&quot;]},{name:&quot;AvMed&quot;,st:[&quot;Florida&quot;]},
  {name:&quot;Horizon Blue Cross Blue Shield&quot;,st:[&quot;New Jersey&quot;]},
  {name:&quot;Highmark Blue Cross Blue Shield&quot;,st:[&quot;Pennsylvania&quot;,&quot;West Virginia&quot;,&quot;Delaware&quot;]},
  {name:&quot;Independence Blue Cross&quot;,st:[&quot;Pennsylvania&quot;]},{name:&quot;Capital Blue Cross&quot;,st:[&quot;Pennsylvania&quot;]},
  {name:&quot;Geisinger Health Plan&quot;,st:[&quot;Pennsylvania&quot;]},{name:&quot;UPMC Health Plan&quot;,st:[&quot;Pennsylvania&quot;]},
  {name:&quot;CareFirst BlueCross BlueShield&quot;,st:[&quot;Maryland&quot;,&quot;District of Columbia&quot;,&quot;Virginia&quot;]},
  {name:&quot;Sentara Health Plans&quot;,st:[&quot;Virginia&quot;]},
  {name:&quot;Excellus BlueCross BlueShield&quot;,st:[&quot;New York&quot;]},{name:&quot;EmblemHealth&quot;,st:[&quot;New York&quot;]},
  {name:&quot;Healthfirst&quot;,st:[&quot;New York&quot;]},{name:&quot;Fidelis Care&quot;,cls:&quot;medicaid&quot;,st:[&quot;New York&quot;]},
  {name:&quot;MVP Health Care&quot;,st:[&quot;New York&quot;,&quot;Vermont&quot;]},{name:&quot;CDPHP&quot;,st:[&quot;New York&quot;]},
  {name:&quot;Point32Health&quot;,st:[&quot;Massachusetts&quot;,&quot;New Hampshire&quot;,&quot;Maine&quot;,&quot;Rhode Island&quot;,&quot;Connecticut&quot;]},
  {name:&quot;Harvard Pilgrim Health Care&quot;,st:[&quot;Massachusetts&quot;,&quot;New Hampshire&quot;,&quot;Maine&quot;,&quot;Connecticut&quot;]},
  {name:&quot;Tufts Health Plan&quot;,st:[&quot;Massachusetts&quot;]},
  {name:&quot;Premera Blue Cross&quot;,st:[&quot;Washington&quot;,&quot;Alaska&quot;]},{name:&quot;Regence BlueShield&quot;,st:[&quot;Washington&quot;,&quot;Oregon&quot;,&quot;Idaho&quot;,&quot;Utah&quot;]},
  {name:&quot;Providence Health Plan&quot;,st:[&quot;Oregon&quot;,&quot;Washington&quot;]},{name:&quot;Moda Health&quot;,st:[&quot;Oregon&quot;,&quot;Alaska&quot;]},
  {name:&quot;CareOregon&quot;,cls:&quot;medicaid&quot;,st:[&quot;Oregon&quot;]},{name:&quot;PacificSource Health Plans&quot;,st:[&quot;Oregon&quot;,&quot;Idaho&quot;,&quot;Montana&quot;,&quot;Washington&quot;]},
  {name:&quot;Wellmark Blue Cross Blue Shield&quot;,st:[&quot;Iowa&quot;,&quot;South Dakota&quot;]},
  {name:&quot;Sanford Health Plan&quot;,st:[&quot;South Dakota&quot;,&quot;North Dakota&quot;,&quot;Iowa&quot;,&quot;Minnesota&quot;]},
  {name:&quot;HealthPartners&quot;,st:[&quot;Minnesota&quot;,&quot;Wisconsin&quot;]},{name:&quot;Security Health Plan&quot;,st:[&quot;Wisconsin&quot;]},
  {name:&quot;Blue Cross Blue Shield of Illinois&quot;,st:[&quot;Illinois&quot;]},{name:&quot;Blue Cross Blue Shield of Texas&quot;,st:[&quot;Texas&quot;]},
  {name:&quot;Blue Cross Blue Shield of Michigan&quot;,st:[&quot;Michigan&quot;]},{name:&quot;Priority Health&quot;,st:[&quot;Michigan&quot;]},
  {name:&quot;Blue Cross Blue Shield of North Carolina&quot;,st:[&quot;North Carolina&quot;]},
  {name:&quot;BlueCross BlueShield of Tennessee&quot;,st:[&quot;Tennessee&quot;]},{name:&quot;Arkansas Blue Cross Blue Shield&quot;,st:[&quot;Arkansas&quot;]},
  {name:&quot;Medical Mutual&quot;,st:[&quot;Ohio&quot;]},{name:&quot;Paramount Health Care&quot;,st:[&quot;Ohio&quot;]},{name:&quot;CareSource&quot;,cls:&quot;medicaid&quot;,st:[&quot;Ohio&quot;,&quot;Indiana&quot;,&quot;Georgia&quot;,&quot;Kentucky&quot;,&quot;West Virginia&quot;]},
  {name:&quot;SelectHealth&quot;,st:[&quot;Utah&quot;,&quot;Idaho&quot;,&quot;Nevada&quot;,&quot;Colorado&quot;]},{name:&quot;Presbyterian Health Plan&quot;,st:[&quot;New Mexico&quot;]},
  {name:&quot;SCAN Health Plan&quot;,st:[&quot;California&quot;,&quot;Arizona&quot;,&quot;Nevada&quot;,&quot;Texas&quot;]}
];
function payerSearchLook(nm){return [nm+&quot; coverage policy&quot;,gsearch(nm+&quot; spirometry 94010 reimbursement coverage policy&quot;)];}

function resolvePayer(pt,state,ins){
  var g=STATES[state];
  if(pt===&quot;medicare&quot;) return {name:&quot;Original Medicare (Part B)&quot;,cls:&quot;medicare&quot;,by:MACS[g[0]],byLabel:&quot;Processed by&quot;,jur:g[1],lookName:&quot;Medicare Coverage Database&quot;,lookUrl:MCD};
  if(pt===&quot;ma&quot;) return {name:&quot;Medicare Advantage (Part C)&quot;,cls:&quot;ma&quot;,by:MACS[g[0]]+&quot; (floor)&quot;,byLabel:&quot;Floor = MAC&quot;,jur:g[1],lookName:&quot;Medicare Coverage Database (floor) + plan policy&quot;,lookUrl:MCD};
  if(pt===&quot;medicaid&quot;){var med=MEDICAID[state]||(state+&quot; Medicaid&quot;);return {name:med,cls:&quot;medicaid&quot;,by:state+&quot; Medicaid program&quot;,byLabel:&quot;State program&quot;,jur:&quot;&quot;,lookName:med+&quot; provider coverage&quot;,lookUrl:gsearch(med+&quot; provider spirometry 94010 coverage policy fee schedule&quot;)};}
  var v=(ins||&quot;&quot;).trim(), lv=v.toLowerCase();
  if(!v) return {name:&quot;Commercial payer&quot;,cls:&quot;commercial&quot;,by:&quot;Commercial insurer&quot;,byLabel:&quot;Payer type&quot;,jur:&quot;&quot;,lookName:&quot;the payer's coverage policy&quot;,lookUrl:gsearch(&quot;spirometry 94010 reimbursement coverage policy&quot;)};
  if(/^blue cross blue shield \(/i.test(v)){var nm0=&quot;Blue Cross Blue Shield (&quot;+state+&quot;)&quot;;var lk0=payerSearchLook(nm0);
    return {name:nm0,cls:&quot;commercial&quot;,by:&quot;Commercial insurer&quot;,byLabel:&quot;Payer type&quot;,jur:&quot;&quot;,lookName:lk0[0],lookUrl:lk0[1]};}
  var hit=null;
  for(var i=0;i&lt;CARRIERS_DB.length;i++){var dn=CARRIERS_DB[i].name.toLowerCase();
    if(dn===lv){hit=CARRIERS_DB[i];break;} if(!hit &amp;&amp; lv.length&gt;=3 &amp;&amp; dn.indexOf(lv)&gt;-1) hit=CARRIERS_DB[i];}
  if(hit){var lk=payerSearchLook(hit.name);
    return {name:hit.name,cls:(hit.cls||&quot;commercial&quot;),by:(hit.cls===&quot;medicaid&quot;?&quot;Medicaid managed-care plan&quot;:&quot;Commercial insurer&quot;),byLabel:&quot;Payer type&quot;,jur:&quot;&quot;,lookName:lk[0],lookUrl:lk[1]};}
  var lk2=payerSearchLook(v);
  return {name:v,cls:&quot;commercial&quot;,by:&quot;Commercial insurer (not in list)&quot;,byLabel:&quot;Payer type&quot;,jur:&quot;&quot;,lookName:lk2[0],lookUrl:lk2[1]};
}
/* ===================== UI WIRING ===================== */
var $=function(id){return document.getElementById(id);};
var stateSel=$(&quot;state&quot;),ptypeSel=$(&quot;ptype&quot;),procSel=$(&quot;proc&quot;),codesBox=$(&quot;codes&quot;),
    insurerWrap=$(&quot;insurerWrap&quot;),insurerInput=$(&quot;insurer&quot;),insurerList=$(&quot;insurerlist&quot;);
Object.keys(STATES).forEach(function(s){var o=document.createElement(&quot;option&quot;);o.value=s;o.textContent=s;stateSel.appendChild(o);});
Object.keys(PROCEDURES).forEach(function(k){var o=document.createElement(&quot;option&quot;);o.value=k;o.textContent=PROCEDURES[k].label;procSel.appendChild(o);});

function opt(v,t){var o=document.createElement(&quot;option&quot;);o.value=v;o.textContent=t;return o;}
function optD(t){var o=document.createElement(&quot;option&quot;);o.value=t;return o;}

function buildPtype(){
  var st=stateSel.value; ptypeSel.innerHTML=&quot;&quot;;
  if(!st){ptypeSel.disabled=true;ptypeSel.appendChild(opt(&quot;&quot;,&quot;— pick a state first —&quot;));return;}
  ptypeSel.disabled=false;
  ptypeSel.appendChild(opt(&quot;&quot;,&quot;— Select payer type —&quot;));
  ptypeSel.appendChild(opt(&quot;medicare&quot;,&quot;Original Medicare (Part B) — &quot;+MACS[STATES[st][0]]));
  ptypeSel.appendChild(opt(&quot;ma&quot;,&quot;Medicare Advantage (Part C)&quot;));
  ptypeSel.appendChild(opt(&quot;medicaid&quot;,&quot;Medicaid — &quot;+(MEDICAID[st]||st+&quot; Medicaid&quot;)));
  ptypeSel.appendChild(opt(&quot;commercial&quot;,&quot;Commercial / private insurer&quot;));
}
function buildInsurerList(){
  var st=stateSel.value; insurerList.innerHTML=&quot;&quot;;
  if(!st) return;
  insurerList.appendChild(optD(&quot;Blue Cross Blue Shield (&quot;+st+&quot;)&quot;));
  CARRIERS_DB.forEach(function(c){ if(!c.st || c.st.indexOf(st)&gt;-1) insurerList.appendChild(optD(c.name)); });
}
function syncInsurer(){
  if(ptypeSel.value===&quot;commercial&quot;){insurerWrap.classList.remove(&quot;hide&quot;);}
  else{insurerWrap.classList.add(&quot;hide&quot;); insurerInput.value=&quot;&quot;;}
}
stateSel.addEventListener(&quot;change&quot;,function(){
  buildPtype(); buildInsurerList(); syncInsurer();
  try{localStorage.setItem(&quot;pft_state&quot;,stateSel.value);}catch(e){}
});
ptypeSel.addEventListener(&quot;change&quot;,syncInsurer);

/* ---- codes with LIVE conflict checking ---- */
function renderCodes(){
  var p=PROCEDURES[procSel.value]; codesBox.innerHTML=&quot;&quot;;
  p.codes.forEach(function(c){
    var l=document.createElement(&quot;label&quot;); l.className=&quot;chk&quot;; l.setAttribute(&quot;data-cpt&quot;,c.cpt);
    l.innerHTML='&lt;input type=&quot;checkbox&quot; value=&quot;'+c.cpt+'&quot;&gt;&lt;span&gt;&lt;b&gt;'+c.cpt+'&lt;/b&gt;&lt;small&gt;'+c.desc+'&lt;/small&gt;&lt;small class=&quot;note&quot;&gt;&lt;/small&gt;&lt;/span&gt;';
    codesBox.appendChild(l);
  });
  [].forEach.call(codesBox.querySelectorAll(&quot;input&quot;),function(i){i.addEventListener(&quot;change&quot;,syncCodes);});
  syncCodes();
}
function syncCodes(){
  var P=PROCEDURES[procSel.value], boxes={}, labels={};
  [].forEach.call(codesBox.querySelectorAll(&quot;.chk&quot;),function(l){var cpt=l.getAttribute(&quot;data-cpt&quot;);labels[cpt]=l;boxes[cpt]=l.querySelector(&quot;input&quot;);});
  Object.keys(boxes).forEach(function(cpt){boxes[cpt].disabled=false;labels[cpt].classList.remove(&quot;off&quot;);var n=labels[cpt].querySelector(&quot;.note&quot;);n.textContent=&quot;&quot;;n.classList.remove(&quot;on&quot;);});
  function block(cpt,msg){var n=labels[cpt].querySelector(&quot;.note&quot;);n.textContent=msg;n.classList.add(&quot;on&quot;);boxes[cpt].checked=false;boxes[cpt].disabled=true;labels[cpt].classList.add(&quot;off&quot;);}
  function flag(cpt,msg){var n=labels[cpt].querySelector(&quot;.note&quot;);n.textContent=msg;n.classList.add(&quot;on&quot;);}

  /* comprehensive code includes a component -&gt; block the component */
  P.codes.forEach(function(c){
    if(c.includesCodes &amp;&amp; boxes[c.cpt] &amp;&amp; boxes[c.cpt].checked){
      c.includesCodes.forEach(function(inc){ if(boxes[inc]) block(inc,&quot;Included in &quot;+c.cpt+&quot; — don’t bill separately&quot;); });
    }
  });
  /* mutually exclusive group -&gt; first picked wins, block the rest */
  (P.mutex||[]).forEach(function(mx){
    var on=mx.codes.filter(function(c){return boxes[c] &amp;&amp; boxes[c].checked;});
    if(on.length&gt;=1){ var keep=on[0];
      mx.codes.forEach(function(c){ if(c!==keep &amp;&amp; boxes[c]) block(c,&quot;Bill only one method — &quot;+keep+&quot; selected&quot;); });
    }
  });
  /* add-on needs a primary still selected */
  P.codes.forEach(function(c){
    if(c.addon &amp;&amp; boxes[c.cpt] &amp;&amp; boxes[c.cpt].checked &amp;&amp; !boxes[c.cpt].disabled){
      var has=c.primaries.some(function(p){return boxes[p] &amp;&amp; boxes[p].checked &amp;&amp; !boxes[p].disabled;});
      if(!has) flag(c.cpt,&quot;Add-on — also pick a primary test (94010, 94060, 94726…)&quot;);
    }
  });
  var bill=Object.keys(boxes).filter(function(c){return boxes[c].checked &amp;&amp; !boxes[c].disabled;});
  $(&quot;codestatus&quot;).textContent = bill.length ? (&quot;✓ Will bill: &quot;+bill.join(&quot; + &quot;)) : &quot;&quot;;
}
procSel.addEventListener(&quot;change&quot;,renderCodes);renderCodes();
try{var last=localStorage.getItem(&quot;pft_state&quot;);if(last&amp;&amp;STATES[last]){stateSel.value=last;}}catch(e){}
buildPtype(); buildInsurerList(); syncInsurer();

function esc(s){return String(s).replace(/&amp;/g,&quot;&amp;amp;&quot;).replace(/&lt;/g,&quot;&amp;lt;&quot;);}
function CODE(c){return '&lt;span class=&quot;pill code&quot;&gt;'+c+'&lt;/span&gt;';}
function MOD(m){return '&lt;span class=&quot;pill mod&quot;&gt;'+m+'&lt;/span&gt;';}

/* ===================== BUILD ===================== */
$(&quot;run&quot;).addEventListener(&quot;click&quot;,function(){
  var st=stateSel.value, pt=ptypeSel.value, P=PROCEDURES[procSel.value];
  if(!st || !pt){var e=$(&quot;err&quot;);e.textContent=(!st?&quot;Please choose a state first.&quot;:&quot;Please choose a payer type — Medicare, Medicare Advantage, Medicaid, or Commercial.&quot;);e.style.display=&quot;block&quot;;if(e.scrollIntoView)e.scrollIntoView({behavior:&quot;smooth&quot;,block:&quot;center&quot;});return;}
  $(&quot;err&quot;).style.display=&quot;none&quot;;
  var PY=resolvePayer(pt,st,insurerInput.value);

  var picked=[].slice.call(codesBox.querySelectorAll(&quot;input:checked&quot;)).filter(function(i){return !i.disabled;}).map(function(i){return i.value;});
  var em=$(&quot;em&quot;).checked;
  var own=document.querySelector('input[name=own]:checked').value;
  var meta=function(c){return P.codes.find(function(x){return x.cpt===c;});};

  $(&quot;jurLabel&quot;).textContent=st+&quot; — &quot;+(PY.cls===&quot;commercial&quot;?&quot;Commercial&quot;:PY.cls===&quot;medicaid&quot;?&quot;Medicaid&quot;:&quot;Medicare&quot;);
  $(&quot;macName&quot;).textContent=PY.name;
  $(&quot;jurTitle&quot;).textContent=PY.byLabel;
  $(&quot;jurName&quot;).textContent=PY.jur?(PY.by+&quot; — &quot;+PY.jur):PY.by;

  var h=&quot;&quot;,warnings=[];
  P.codes.forEach(function(c){
    if(c.includesCodes &amp;&amp; picked.indexOf(c.cpt)&gt;-1){
      c.includesCodes.forEach(function(inc){ if(picked.indexOf(inc)&gt;-1){ warnings.push(&quot;&lt;b&gt;Don't bill &quot;+inc+&quot; with &quot;+c.cpt+&quot;.&lt;/b&gt; &quot;+c.cpt+&quot; already includes the spirometry in &quot;+inc+&quot;. Bill &quot;+c.cpt+&quot; only.&quot;); picked=picked.filter(function(x){return x!==inc;}); } });
    }
  });
  (P.mutex||[]).forEach(function(mx){
    var present=mx.codes.filter(function(c){return picked.indexOf(c)&gt;-1;});
    if(present.length&gt;1){ warnings.push(mx.msg); picked=picked.filter(function(x){return mx.codes.indexOf(x)===-1 || x===mx.keep;}); }
  });
  P.codes.forEach(function(c){
    if(c.addon &amp;&amp; picked.indexOf(c.cpt)&gt;-1){
      var ok=c.primaries.some(function(p){return picked.indexOf(p)&gt;-1;});
      if(!ok) warnings.push(&quot;&lt;b&gt;&quot;+c.cpt+&quot; can't stand alone.&lt;/b&gt; It's an add-on (DLCO) and must be billed with a primary PFT code (&quot;+c.primaries.join(&quot;, &quot;)+&quot;). Add the primary test performed, or remove &quot;+c.cpt+&quot;.&quot;);
    }
  });
  if(warnings.length){
    h+='&lt;div class=&quot;res-h&quot; style=&quot;border-color:var(--red);color:var(--red)&quot;&gt;Fix these before you submit&lt;/div&gt;';
    warnings.forEach(function(w){h+='&lt;div class=&quot;warnbox&quot;&gt;'+w+'&lt;/div&gt;';});
  }

  h+='&lt;div class=&quot;res-h&quot;&gt;Your claim should look like this&lt;/div&gt;';
  var primaries=picked.filter(function(c){return !meta(c).addon;});
  var addons=picked.filter(function(c){return meta(c).addon;});
  var comp= own===&quot;pro&quot;?&quot; 26&quot;:own===&quot;tech&quot;?&quot; TC&quot;:&quot;&quot;;
  if(!picked.length){
    h+='&lt;p class=&quot;muted&quot;&gt;Select at least one test code above to see the claim layout.&lt;/p&gt;';
  }else{
    h+='&lt;div class=&quot;claim&quot;&gt;';
    if(em) h+='&lt;div class=&quot;ln&quot;&gt;&lt;span class=&quot;c&quot;&gt;'+P.emExample+'&lt;/span&gt;&lt;span class=&quot;m&quot;&gt;-25&lt;/span&gt;&lt;span class=&quot;d&quot;&gt;point to the EVALUATION diagnosis&lt;/span&gt;&lt;/div&gt;';
    primaries.forEach(function(c,i){
      h+='&lt;div class=&quot;ln&quot;&gt;&lt;span class=&quot;c&quot;&gt;'+c+comp+'&lt;/span&gt;&lt;span class=&quot;m&quot;&gt;'+(i&gt;0?'-59 / -91*':'&amp;nbsp;')+'&lt;/span&gt;&lt;span class=&quot;d&quot;&gt;point to the RESPIRATORY diagnosis&lt;/span&gt;&lt;/div&gt;';});
    addons.forEach(function(c){
      h+='&lt;div class=&quot;ln&quot;&gt;&lt;span class=&quot;c&quot;&gt;'+c+comp+'&lt;/span&gt;&lt;span class=&quot;m&quot;&gt;add-on&lt;/span&gt;&lt;span class=&quot;d&quot;&gt;same dx as its primary&lt;/span&gt;&lt;/div&gt;';});
    h+='&lt;/div&gt;';
    h+='&lt;p class=&quot;muted&quot;&gt;'+P.emExample+' shown as an example E/M level - bill the level your documentation supports. '+(comp?'&lt;b&gt;'+comp.trim()+'&lt;/b&gt; appended from the equipment/interpretation answer. ':'')+(primaries.length&gt;1?'&lt;b&gt;*&lt;/b&gt; A second distinct test the same day may need 59/XU (separate) or 91 (repeat) - only if truly separate and documented; verify the pair.':'')+'&lt;/p&gt;';
  }

  h+='&lt;div class=&quot;res-h&quot;&gt;Step by step&lt;/div&gt;&lt;ol class=&quot;steps&quot;&gt;';
  h+='&lt;li&gt;Report the test code(s) actually performed: '+(picked.length?picked.map(CODE).join(&quot; &quot;):'&lt;span class=&quot;muted&quot;&gt;(none selected)&lt;/span&gt;')+'.&lt;/li&gt;';
  if(own===&quot;global&quot;) h+='&lt;li&gt;Bill the &lt;b&gt;global service&lt;/b&gt; (no 26/TC) - practice owns the equipment and the provider interprets.&lt;/li&gt;';
  else if(own===&quot;pro&quot;) h+='&lt;li&gt;Append '+MOD('26')+' (professional component) - provider only interprets; equipment owned elsewhere.&lt;/li&gt;';
  else h+='&lt;li&gt;Append '+MOD('TC')+' (technical component) - practice supplied equipment/technician but did not interpret.&lt;/li&gt;';
  if(em){
    h+='&lt;li&gt;Report the office visit and append '+MOD('25')+' &lt;b&gt;to the E/M code&lt;/b&gt; - never to the test. This unbundles the visit so both pay.&lt;/li&gt;';
    h+='&lt;li&gt;Bill the E/M &lt;b&gt;only&lt;/b&gt; if it was a significant, separately identifiable evaluation. If the patient came in solely for the test, do not bill a separate visit.&lt;/li&gt;';
  }else{
    h+='&lt;li&gt;No visit today - bill the test alone. (If the provider did evaluate the patient, check the &quot;office visit also done&quot; box for the Modifier 25 step.)&lt;/li&gt;';
  }
  h+='&lt;li&gt;Link diagnosis pointers as shown above, then confirm coverage in the lookup below before submitting.&lt;/li&gt;';
  h+='&lt;/ol&gt;';

  h+='&lt;div class=&quot;res-h&quot;&gt;Diagnosis &amp;amp; this payer &lt;span class=&quot;tag '+(PY.cls===&quot;commercial&quot;||PY.cls===&quot;medicaid&quot;?&quot;com&quot;:&quot;med&quot;)+'&quot;&gt;'+esc(PY.name)+'&lt;/span&gt;&lt;/div&gt;';
  h+='&lt;p&gt;'+esc(CLASS_DX[PY.cls])+'&lt;/p&gt;';
  h+='&lt;p class=&quot;muted&quot;&gt;Diagnoses that commonly support spirometry/PFT (examples - always match the chart and the payer covered list): '+esc(P.dxExamples)+'.&lt;/p&gt;';

  h+='&lt;div class=&quot;res-h&quot;&gt;Documentation that must be in the chart&lt;/div&gt;&lt;ul class=&quot;chklist&quot;&gt;';
  P.docChecklist.forEach(function(d){h+='&lt;li&gt;'+esc(d)+'&lt;/li&gt;';});
  h+='&lt;/ul&gt;';

  h+='&lt;div class=&quot;res-h&quot;&gt;If it denies - read the code, then fix it&lt;/div&gt;';
  h+='&lt;div class=&quot;claim&quot; style=&quot;background:#1c1410&quot;&gt;'+
    '&lt;div class=&quot;ln&quot; style=&quot;border-color:#3a2c22&quot;&gt;&lt;span class=&quot;c&quot; style=&quot;color:#ffb37a;min-width:120px&quot;&gt;CO-97 + N19/M15&lt;/span&gt;&lt;span class=&quot;d&quot; style=&quot;color:#f0d6c4&quot;&gt;Bundled / incidental - the E/M or a test code folded into another. Fix: confirm Modifier 25 is on the E/M, or that you did not bill a component code (e.g. 94010 with 94060). Appeal with the note + interpretation.&lt;/span&gt;&lt;/div&gt;'+
    '&lt;div class=&quot;ln&quot; style=&quot;border-color:#3a2c22&quot;&gt;&lt;span class=&quot;c&quot; style=&quot;color:#ffb37a;min-width:120px&quot;&gt;CO-50 / CO-56&lt;/span&gt;&lt;span class=&quot;d&quot; style=&quot;color:#f0d6c4&quot;&gt;Not medically necessary - the diagnosis is not on the covered list, or frequency exceeded. Fix: check the policy covered dx &amp;amp; limits, correct the pointer, resubmit.&lt;/span&gt;&lt;/div&gt;'+
    '&lt;div class=&quot;ln&quot;&gt;&lt;span class=&quot;c&quot; style=&quot;color:#ffb37a;min-width:120px&quot;&gt;CO-4 / CO-16&lt;/span&gt;&lt;span class=&quot;d&quot; style=&quot;color:#f0d6c4&quot;&gt;Modifier missing/inconsistent - a required modifier (25, 26, TC, 59) is absent or wrong. Fix: add/correct the modifier and resubmit.&lt;/span&gt;&lt;/div&gt;'+
    '&lt;/div&gt;';

  h+='&lt;div class=&quot;res-h&quot;&gt;Confirm coverage before you submit&lt;/div&gt;';
  h+='&lt;div class=&quot;verify&quot;&gt;&lt;b&gt;VERIFY for '+esc(PY.name)+':&lt;/b&gt; The coding above is standard; the covered-diagnosis list &amp;amp; frequency are set by this payer and can change. Check the current policy and match your diagnosis before submitting. &amp;nbsp;&lt;a href=&quot;'+PY.lookUrl+'&quot; target=&quot;_blank&quot; rel=&quot;noopener&quot;&gt;Open '+esc(PY.lookName)+' &amp;rarr;&lt;/a&gt;&lt;/div&gt;';

  $(&quot;result&quot;).innerHTML=h;
  $(&quot;disclaimer&quot;).innerHTML='General coding guidance, not a coverage determination or billing/legal advice. Reimbursement varies by payer, plan, region, and fee schedule. Confirm against current NCCI policy and the payer policy before submitting. &amp;nbsp;Generated for: &lt;b&gt;'+esc(PY.name)+' — '+esc(st)+'&lt;/b&gt;.';
  $(&quot;out&quot;).style.display=&quot;block&quot;;$(&quot;print&quot;).style.display=&quot;inline-block&quot;;
  $(&quot;out&quot;).scrollIntoView({behavior:&quot;smooth&quot;,block:&quot;start&quot;});
});
$(&quot;print&quot;).addEventListener(&quot;click&quot;,function(){window.print();});
&lt;/script&gt;
&lt;/body&gt;
&lt;/html&gt;
"></iframe>
  </div>

  <div class="tab-panel" id="tab-myday">
    <div class="section-head">
      <div class="section-icon icon-blue">&#128506;</div>
      <div>
        <div class="section-title">My Day &mdash; Route, Visits, Miles &amp; Expenses</div>
        <div class="section-sub">Build your stop list in the morning. The app logs arrivals, calculates stop to stop mileage, captures expenses, and hands you a clean end of day report. One system, zero manual tracking.</div>
      </div>
    </div>

    <div class="alert-box alert-blue">
      <div class="alert-icon">&#9432;</div>
      <div><strong>Framework preview (v1 frame).</strong> This is the working skeleton for review. Stops, arrive and depart stamps, mileage math, expenses, and the day report all function locally on this device. Coming in the full build: live route map (Leaflet, no API cost), GPS auto arrival detection with a 150 meter geofence, auto calculated drive miles between stops. New in v3.18: Snap Receipt is live in Expenses — photo plus on device OCR pre fill. React to the layout and flow; content and automation fill in after alignment.</div>
    </div>

    <style>
      #tab-myday .md-card { background: #fff; border: 1px solid var(--gray-200, #e5e7eb); border-radius: 10px; padding: 14px 16px; margin: 14px 0; }
      #tab-myday .md-card h4 { margin: 0 0 4px; font-size: 13px; font-weight: 800; letter-spacing: .05em; text-transform: uppercase; color: var(--blue-brand, #1e40af); }
      #tab-myday .md-card .md-sub { font-size: 12px; color: #6b7280; margin-bottom: 10px; }
      #tab-myday .md-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
      #tab-myday input, #tab-myday select { font: inherit; font-size: 13px; padding: 8px 10px; border: 1px solid var(--gray-200, #e5e7eb); border-radius: 7px; }
      #tab-myday .md-btn { font-size: 12px; font-weight: 700; padding: 8px 14px; border-radius: 7px; border: 1px solid transparent; cursor: pointer; background: var(--blue-brand, #1e40af); color: #fff; }
      #tab-myday .md-btn.ghost { background: #fff; color: var(--blue-brand, #1e40af); border-color: var(--gray-200, #e5e7eb); }
      #tab-myday .md-btn.warn { background: #fff; color: #b91c1c; border-color: #fecaca; }
      #tab-myday .md-btn.soon { background: #f3f4f6; color: #9ca3af; cursor: default; }
      #tab-myday .md-stop { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px dashed var(--gray-200, #e5e7eb); }
      #tab-myday .md-stop:last-child { border-bottom: 0; }
      #tab-myday .md-num { width: 26px; height: 26px; border-radius: 50%; background: var(--blue-brand, #1e40af); color: #fff; font-size: 12px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex: none; }
      #tab-myday .md-stop-main { flex: 1; min-width: 0; }
      #tab-myday .md-stop-name { font-size: 14px; font-weight: 700; color: #111827; }
      #tab-myday .md-stop-addr { font-size: 11px; color: #6b7280; }
      #tab-myday .md-stamp { font-family: 'DM Mono', monospace; font-size: 11px; color: #047857; }
      #tab-myday .md-map-ph { height: 200px; border: 2px dashed var(--gray-200, #e5e7eb); border-radius: 10px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; color: #9ca3af; background: #f9fafb; text-align: center; padding: 10px; }
      #tab-myday table.md-tbl { width: 100%; border-collapse: collapse; font-size: 12px; }
      #tab-myday table.md-tbl th { text-align: left; font-size: 10px; letter-spacing: .05em; text-transform: uppercase; color: #6b7280; padding: 6px 8px; border-bottom: 2px solid var(--gray-200, #e5e7eb); }
      #tab-myday table.md-tbl td { padding: 7px 8px; border-bottom: 1px solid var(--gray-100, #f3f4f6); color: #111827; }
      #tab-myday .md-total { font-size: 14px; font-weight: 800; color: var(--blue-brand, #1e40af); }
      #tab-myday .md-miles-in { width: 64px; text-align: right; }
      #tab-myday .md-badge-soon { font-size: 9px; font-weight: 800; letter-spacing: .05em; text-transform: uppercase; background: #fef3c7; color: #92400e; padding: 2px 7px; border-radius: 20px; vertical-align: 2px; }
    </style>

    <div class="md-card">
      <h4>1 &middot; Today&rsquo;s Stops</h4>
      <div class="md-sub">Load a saved target list or add accounts one at a time, in drive order. Tap Maps for a single stop, or <strong>Run Full Route</strong> to send the whole day to Google Maps; on the phone the route carries straight into CarPlay or Android Auto. <span class="md-badge-soon">Coming</span> auto optimize the order by drive time.</div>
      <div class="md-row" style="margin-bottom:10px;">
        <select id="md-list-sel" style="flex:1; min-width:170px;"></select>
        <button class="md-btn" onclick="mdLoadList()">Load List</button>
        <button class="md-btn ghost" onclick="mdSaveList()">Save Today as List</button>
        <button class="md-btn warn" onclick="mdDelList()">Delete List</button>
      </div>
      <div class="md-row" style="margin-bottom:10px;">
        <input id="md-stop-name" type="text" placeholder="Practice / account name" style="flex:1; min-width:160px;">
        <input id="md-stop-addr" type="text" placeholder="Address" style="flex:1.4; min-width:200px;">
        <input id="md-stop-phone" type="tel" placeholder="Phone (optional)" style="width:140px;">
        <button class="md-btn" onclick="mdAddStop()">Add Stop</button>
        <button class="md-btn soon" title="Full build: auto order stops by drive time">Optimize Route</button>
      </div>
      <div id="md-stops"></div>
      <div class="md-row" style="margin-top:12px;">
        <button class="md-btn" style="flex:1; background:#047857; font-size:14px; padding:12px;" onclick="mdFullRoute()">&#9654; Run Full Route</button>
      </div>
    </div>

    <div class="md-card">
      <h4>2 &middot; Route Map <span class="md-badge-soon">Coming</span></h4>
      <div class="md-sub">All stops pinned with the drive order numbered. Built on Leaflet and OpenStreetMap, so there is no Google Maps API cost.</div>
      <div class="md-map-ph">
        <div style="font-size:34px; opacity:.4;">&#128506;</div>
        <div style="font-size:12px; font-weight:700;">Route map renders here</div>
        <div style="font-size:11px;">Pins for every stop, numbered drive order, your live position, and 150 meter geofence rings around each account</div>
      </div>
    </div>

    <div class="md-card">
      <h4>3 &middot; Arrival &amp; Visit Log</h4>
      <div class="md-sub">Tap Arrive when you walk in and Depart when you leave; the day report picks up every stamp. Type or tap the mic to leave a quick visit note right at the account &mdash; tap Save to push it to the team log so it is there when you write it up later. <span class="md-badge-soon">Coming</span> GPS auto detection stamps arrivals for you and pulls the account card up automatically.</div>
      <div style="overflow-x:auto;">
        <table class="md-tbl" id="md-visit-tbl">
          <thead><tr><th>#</th><th>Stop</th><th>Arrived</th><th>Departed</th><th>Time on site</th><th style="min-width:220px;">Visit Note</th><th></th></tr></thead>
          <tbody id="md-visit-rows"></tbody>
        </table>
      </div>
    </div>

    <div class="md-card">
      <h4>3b &middot; Team Visit Notes Log <span id="mn-log-badge" style="font-size:9px; font-weight:800; letter-spacing:.05em; text-transform:uppercase; background:#ede9fe; color:#5b21b6; padding:2px 7px; border-radius:20px; vertical-align:2px;">Shared</span></h4>
      <div class="md-sub">Every saved visit note lands here for the whole team &mdash; each one auto-stamped with the exact date &amp; time and backed up to the shared team server. Searchable by rep or account, ready to copy into Salesforce. Tap <b>This Week&#39;s Report</b> for a clean day-by-day breakdown you can paste into chat.</div>
      <div id="mn-quick" style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:10px; padding:12px 14px; margin-bottom:14px;">
        <div style="font-size:13px; font-weight:800; color:#065f46;">&#128221; Quick Note <span style="font-weight:600; color:#059669;">&mdash; talk or type, tap Save. It&#39;s stamped with the time and kept for you.</span></div>
        <div style="display:flex; gap:8px; align-items:flex-start; margin-top:8px;">
          <textarea id="mn-quick-text" rows="2" placeholder="Say or type anything — e.g. Dr. Lee wants a demo Thursday" style="flex:1; font:inherit; font-size:13px; padding:8px 10px; border:1px solid #cbd5e1; border-radius:8px; resize:vertical; box-sizing:border-box;"></textarea>
          <button class="md-btn ghost" type="button" id="mn-quick-mic" onclick="mnQuickMic()" title="Talk instead of typing" style="padding:8px 11px; font-size:17px; line-height:1;">&#127908;</button>
        </div>
        <div style="display:flex; gap:8px; align-items:center; margin-top:8px; flex-wrap:wrap;">
          <input id="mn-quick-acct" type="text" placeholder="Account / who it's about (optional)" style="flex:1; min-width:150px; font:inherit; font-size:12.5px; padding:7px 10px; border:1px solid #cbd5e1; border-radius:8px;">
          <button class="md-btn" onclick="mnQuickSave()" style="background:#059669; color:#fff;">&#10003; Save note</button>
        </div>
        <div id="mn-quick-status" style="font-size:11.5px; color:#059669; margin-top:6px; min-height:14px;"></div>
      </div>
      <div class="md-row" style="margin-bottom:10px;">
        <button class="md-btn" onclick="mnReport(7)" style="background:#5b21b6; color:#fff;">&#128203; This Week&#39;s Report</button>
        <button class="md-btn ghost" onclick="mnReport(30)">This Month</button>
        <button class="md-btn ghost" onclick="mnLoadNotes(true)">&#8635; Refresh</button>
        <button class="md-btn ghost" onclick="mnExportCsv()">&#11015; Export CSV</button>
        <input id="mn-filter" type="text" placeholder="Filter by rep or account" style="flex:1; min-width:160px;" oninput="mnRenderLog()">
      </div>
      <div id="mn-log-status" style="font-size:12px; color:#9ca3af; margin-bottom:8px;">Loading visit notes&hellip;</div>
      <div id="mn-report" style="display:none; margin-bottom:12px; border:1px solid #d8caf5; border-radius:10px; padding:12px 14px; background:#faf8ff;">
        <div class="md-row" style="margin-bottom:8px; align-items:center;">
          <strong id="mn-report-title" style="flex:1; color:#5b21b6; font-size:13px;">Report</strong>
          <button class="md-btn" onclick="mnCopyReport()" style="background:#5b21b6; color:#fff;">&#128203; Copy report</button>
          <button class="md-btn ghost" onclick="document.getElementById('mn-report').style.display='none'">Close</button>
        </div>
        <textarea id="mn-report-text" readonly style="width:100%; min-height:220px; font-family:'SFMono-Regular',Consolas,'Liberation Mono',Menlo,monospace; font-size:12px; line-height:1.55; border:1px solid #e2e8f0; border-radius:8px; padding:10px; background:#fff; white-space:pre; overflow:auto; box-sizing:border-box;"></textarea>
      </div>
      <div style="overflow-x:auto;">
        <table class="md-tbl">
          <thead><tr><th>Date &amp; time</th><th>Rep</th><th>Account</th><th>Note</th></tr></thead>
          <tbody id="mn-log-rows"></tbody>
        </table>
      </div>
    </div>

    <div class="md-card">
      <h4>4 &middot; Mileage</h4>
      <div class="md-sub">Enter miles per leg for now; the full build calculates driving distance between stops automatically, so there is no background tracking and no battery drain. Rate defaults to the IRS standard; verify the current year rate before submitting.</div>
      <div style="overflow-x:auto;">
        <table class="md-tbl">
          <thead><tr><th>Leg</th><th style="text-align:right;">Miles</th></tr></thead>
          <tbody id="md-mile-rows"></tbody>
        </table>
      </div>
      <div class="md-row" style="margin-top:10px; justify-content:space-between;">
        <div class="md-row" style="gap:6px;">
          <label style="font-size:12px; color:#6b7280;">IRS rate $/mi</label>
          <input id="md-rate" type="number" step="0.005" value="0.70" style="width:80px;" oninput="mdRender()">
        </div>
        <div class="md-total" id="md-mile-total">0.0 mi &middot; $0.00</div>
      </div>
    </div>

    <div class="md-card">
      <h4>5 &middot; Expenses</h4>
      <div class="md-sub">Log spend as it happens, or tap <strong>&#128247; Snap Receipt</strong> &mdash; the camera opens, the app reads the merchant, date, and total right on this device, and pre fills the entry. Check the fields, tap Add, and the photo saves with the expense.</div>
      <div class="md-row" style="margin-bottom:10px;">
        <select id="md-exp-cat">
          <option>Meals</option><option>Parking</option><option>Tolls</option><option>Fuel</option><option>Supplies</option><option>Other</option>
        </select>
        <input id="md-exp-amt" type="number" step="0.01" placeholder="$ amount" style="width:110px;">
        <input id="md-exp-note" type="text" placeholder="Note (account, purpose)" style="flex:1; min-width:150px;">
        <button class="md-btn" onclick="mdAddExp()">Add</button>
        <button class="md-btn" onclick="document.getElementById('md-rcpt-file').click()">&#128247; Snap Receipt</button>
        <input id="md-rcpt-file" type="file" accept="image/*" capture="environment" style="display:none;" onchange="mdReceiptPicked(this)">
      </div>
      <div id="md-rcpt-status" style="display:none; font-size:12px; font-weight:600; margin:-4px 0 10px;"></div>
      <div style="overflow-x:auto;">
        <table class="md-tbl">
          <thead><tr><th>Category</th><th>Note</th><th style="text-align:right;">Amount</th><th></th></tr></thead>
          <tbody id="md-exp-rows"></tbody>
        </table>
      </div>
      <div class="md-total" style="text-align:right; margin-top:8px;" id="md-exp-total">$0.00</div>
    </div>

    <div class="md-card">
      <h4>6 &middot; End of Day Report</h4>
      <div class="md-sub">One tap builds a clean prose summary of stops, visit times, mileage, and expenses, ready to paste into Salesforce or an email to your manager.</div>
      <div class="md-row">
        <button class="md-btn" onclick="mdCopyReport()">Copy Day Report</button>
        <button class="md-btn warn" onclick="mdNewDay()">Start New Day</button>
        <span id="md-copied" style="display:none; font-size:12px; color:#047857; font-weight:700;">Copied</span>
      </div>
      <pre id="md-report-preview" style="white-space:pre-wrap; font-size:12px; color:#374151; background:#f9fafb; border:1px solid var(--gray-200,#e5e7eb); border-radius:8px; padding:12px; margin-top:10px; display:none;"></pre>
    </div>

    <script>
      /* =========================================================
         MY DAY (v3.18 - frame + live Snap Receipt OCR; map/GPS/auto-miles TBD)
         Data lives in localStorage under mbx_myday_v1.
         ========================================================= */
      function mdLoad() {
        try { return JSON.parse(localStorage.getItem('mbx_myday_v1')) || { date: mdToday(), stops: [], expenses: [] }; }
        catch (e) { return { date: mdToday(), stops: [], expenses: [] }; }
      }
      function mdSave(d) {
        try { localStorage.setItem('mbx_myday_v1', JSON.stringify(d)); }
        catch (e) {
          d.expenses.forEach(function (x) { delete x.rcpt; });
          try { localStorage.setItem('mbx_myday_v1', JSON.stringify(d)); alert('Storage is full — the entry was saved but receipt photos were dropped.'); } catch (e2) {}
        }
      }
      function mdToday() { return new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }); }
      function mdTime() { return new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }); }

      function mdAddStop() {
        var n = document.getElementById('md-stop-name').value.trim();
        var a = document.getElementById('md-stop-addr').value.trim();
        var p = (document.getElementById('md-stop-phone') || { value: '' }).value.replace(/[^0-9+]/g, '');
        if (!n) return;
        var d = mdLoad();
        d.stops.push({ name: n, addr: a, phone: p, arrived: '', departed: '', miles: '', note: '', noteSaved: false });
        mdSave(d);
        document.getElementById('md-stop-name').value = '';
        document.getElementById('md-stop-addr').value = '';
        if (document.getElementById('md-stop-phone')) document.getElementById('md-stop-phone').value = '';
        mdRender();
      }

      /* ===== v3.21 Target Lists and one tap full route =====
         Saved lists live in localStorage under mbx_targetlists_v1.
         Seeded with the Rockville Centre rheumatology hit list. */
      var MD_SEED_LISTS = {
        'Rheumatology, Rockville Centre ring': [
          { name: 'Long Island Rheumatology, Dr. Van de Stouwe (refers PFTs out, biologic infusion suite)', addr: '30 Hempstead Ave, Unit 156, Rockville Centre, NY 11570', phone: '5168728235' },
          { name: 'Dr. Joseph Cohn (verify affiliation, low Medicare volume, ask testing pathway)', addr: '2000 N Village Ave, Ste 407, Rockville Centre, NY 11570', phone: '5166785330' },
          { name: 'Valley Stream Rheumatology (refers PFTs out, 3 mi west)', addr: '260 Sunrise Hwy, Ste 200, Valley Stream, NY 11581', phone: '5168253600' },
          { name: 'PRINE Rheumatology (follow up, ask testing pathway)', addr: '877 Stewart Ave, Ste 16, Garden City, NY 11530', phone: '' },
          { name: 'Rheumatology Consultants, Dr. Cohen (verify, in house lab, refers PFTs out)', addr: '1157 Broadway, Unit 1, Hewlett, NY 11557', phone: '5162954481' },
          { name: 'Dr. Jonathan Klahr (refers PFTs out, does own ECGs)', addr: '660 Central Ave, Cedarhurst, NY 11516', phone: '5163747122' },
          { name: 'Long Beach Rheumatology, Dr. Gupta (refers PFTs out, biggest Medicare panel)', addr: '206 W Park Ave, Long Beach, NY 11561', phone: '5168973885' }
        ]
      };
      function mdLists() {
        var l = null;
        try { l = JSON.parse(localStorage.getItem('mbx_targetlists_v1')); } catch (e) {}
        if (!l) l = {};
        /* built in lists always refresh from the app so new intel reaches every phone */
        Object.keys(MD_SEED_LISTS).forEach(function (k) { l[k] = MD_SEED_LISTS[k]; });
        try { localStorage.setItem('mbx_targetlists_v1', JSON.stringify(l)); } catch (e) {}
        return l;
      }
      function mdListsSave(l) { try { localStorage.setItem('mbx_targetlists_v1', JSON.stringify(l)); } catch (e) { alert('Storage is full, the list could not be saved.'); } }
      function mdListsRender() {
        var sel = document.getElementById('md-list-sel');
        if (!sel) return;
        var l = mdLists(), keys = Object.keys(l);
        sel.innerHTML = keys.length ? keys.map(function (k) { return '<option>' + mdEsc(k) + '</option>'; }).join('') : '<option value="">No saved lists yet</option>';
      }
      function mdLoadList() {
        var sel = document.getElementById('md-list-sel');
        var l = mdLists(), k = sel && sel.value;
        if (!k || !l[k]) return;
        var d = mdLoad();
        l[k].forEach(function (s) {
          var dup = d.stops.some(function (x) { return x.name === s.name; });
          if (!dup) d.stops.push({ name: s.name, addr: s.addr || '', phone: s.phone || '', arrived: '', departed: '', miles: '' });
        });
        mdSave(d); mdRender();
      }
      function mdSaveList() {
        var d = mdLoad();
        if (!d.stops.length) { alert('Add stops first, then save them as a list.'); return; }
        var k = prompt('Name this target list', '');
        if (!k) return;
        var l = mdLists();
        l[k] = d.stops.map(function (s) { return { name: s.name, addr: s.addr || '', phone: s.phone || '' }; });
        mdListsSave(l); mdListsRender();
        var sel = document.getElementById('md-list-sel'); if (sel) sel.value = k;
      }
      function mdDelList() {
        var sel = document.getElementById('md-list-sel'), k = sel && sel.value;
        var l = mdLists();
        if (!k || !l[k]) return;
        if (!confirm('Delete the saved list "' + k + '"? Today\'s stops are not affected.')) return;
        delete l[k]; mdListsSave(l); mdListsRender();
      }
      function mdFullRoute() {
        var d = mdLoad();
        var pending = d.stops.filter(function (s) { return !s.departed; });
        if (!pending.length) { alert('No stops left to route. Add stops or start a new day.'); return; }
        var addrs = pending.slice(0, 10).map(function (s) { return s.addr || s.name; });
        var dest = addrs.pop();
        var url = 'https://www.google.com/maps/dir/?api=1&travelmode=driving&destination=' + encodeURIComponent(dest);
        if (addrs.length) url += '&waypoints=' + addrs.map(encodeURIComponent).join('%7C');
        if (pending.length > 10) alert('Google Maps takes 10 stops per run. Routing your next 10 now; tap Run Full Route again later and the finished stops drop off automatically.');
        window.open(url, '_blank', 'noopener');
      }
      function mdDelStop(i) { var d = mdLoad(); d.stops.splice(i, 1); mdSave(d); mdRender(); }
      function mdStamp(i, k) { var d = mdLoad(); d.stops[i][k] = mdTime(); mdSave(d); mdRender(); }
      function mdMiles(i, v) { var d = mdLoad(); d.stops[i].miles = v; mdSave(d); mdRender(); }
      function mdAddExp() {
        var amt = parseFloat(document.getElementById('md-exp-amt').value);
        if (!amt) return;
        var d = mdLoad();
        d.expenses.push({ cat: document.getElementById('md-exp-cat').value, amt: amt, note: document.getElementById('md-exp-note').value.trim(), rcpt: mdPendingRcpt || '' });
        mdSave(d);
        document.getElementById('md-exp-amt').value = '';
        document.getElementById('md-exp-note').value = '';
        mdPendingRcpt = null; mdRcptStatus('');
        mdRender();
      }
      function mdDelExp(i) { var d = mdLoad(); d.expenses.splice(i, 1); mdSave(d); mdRender(); }
      function mdNewDay() {
        if (!confirm('Clear all stops, stamps, miles, and expenses and start a new day?')) return;
        mdSave({ date: mdToday(), stops: [], expenses: [] });
        document.getElementById('md-report-preview').style.display = 'none';
        mdRender();
      }
      function mdEsc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

      function mdRender() {
        var d = mdLoad();
        var stopsEl = document.getElementById('md-stops');
        if (!stopsEl) return;
        stopsEl.innerHTML = d.stops.length ? d.stops.map(function (s, i) {
          var maps = 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(s.addr || s.name);
          return '<div class="md-stop">' +
            '<div class="md-num">' + (i + 1) + '</div>' +
            '<div class="md-stop-main"><div class="md-stop-name">' + mdEsc(s.name) + '</div>' +
            (s.addr ? '<div class="md-stop-addr">' + mdEsc(s.addr) + '</div>' : '') + '</div>' +
            '<a class="md-btn ghost" style="text-decoration:none;" target="_blank" rel="noopener" href="' + maps + '">Maps</a>' +
            (s.phone ? '<a class="md-btn ghost" style="text-decoration:none;" href="tel:' + mdEsc(s.phone) + '">Call</a>' : '') +
            '<button class="md-btn warn" onclick="mdDelStop(' + i + ')">&times;</button>' +
            '</div>';
        }).join('') : '<div style="font-size:12px; color:#9ca3af; padding:6px 0;">No stops yet. Add your first account above.</div>';

        document.getElementById('md-visit-rows').innerHTML = d.stops.map(function (s, i) {
          var dur = '';
          if (s.arrived && s.departed) dur = mdDur(s.arrived, s.departed);
          var micBtn = MD_MIC_OK ? '<button class="md-btn ghost" type="button" id="md-mic-' + i + '" style="padding:6px 9px;" onclick="mdMicToggle(' + i + ')" title="Speak your note">&#127908;</button>' : '';
          var savedTag = s.noteSaved ? '<span style="font-size:10px; color:#047857; font-weight:700; white-space:nowrap;">&#10003; on team log</span>' : (s.note ? '<span style="font-size:10px; color:#b45309; font-weight:700; white-space:nowrap;">not saved</span>' : '');
          return '<tr><td>' + (i + 1) + '</td><td>' + mdEsc(s.name) + '</td>' +
            '<td>' + (s.arrived ? '<span class="md-stamp">' + s.arrived + '</span>' : '<button class="md-btn ghost" onclick="mdStamp(' + i + ',\'arrived\')">Arrive</button>') + '</td>' +
            '<td>' + (s.departed ? '<span class="md-stamp">' + s.departed + '</span>' : '<button class="md-btn ghost" onclick="mdStamp(' + i + ',\'departed\')">Depart</button>') + '</td>' +
            '<td>' + dur + '</td>' +
            '<td><div style="display:flex; flex-direction:column; gap:4px; min-width:200px;">' +
              '<div style="display:flex; gap:6px; align-items:flex-start;">' +
                '<textarea id="md-note-' + i + '" rows="2" placeholder="Quick note (e.g. infusion suite, refers PFTs out)" style="flex:1; font:inherit; font-size:12px; padding:6px 8px; border:1px solid var(--gray-200,#e5e7eb); border-radius:7px; resize:vertical;" oninput="mdNoteDraft(' + i + ', this.value)">' + mdEsc(s.note || '') + '</textarea>' +
                micBtn +
              '</div>' +
              '<div style="display:flex; gap:8px; align-items:center;">' +
                '<button class="md-btn" style="padding:5px 10px; font-size:11px;" onclick="mdLogNote(' + i + ')">Save Note</button>' +
                savedTag +
              '</div>' +
            '</div></td>' +
            '<td></td></tr>';
        }).join('') || '<tr><td colspan="7" style="color:#9ca3af;">Stops appear here as you add them.</td></tr>';

        var legs = '';
        var totMi = 0;
        for (var i = 0; i < d.stops.length; i++) {
          var from = i === 0 ? 'Start of day' : d.stops[i - 1].name;
          var mi = parseFloat(d.stops[i].miles) || 0;
          totMi += mi;
          legs += '<tr><td>' + mdEsc(from) + ' &rarr; ' + mdEsc(d.stops[i].name) + '</td>' +
            '<td style="text-align:right;"><input class="md-miles-in" type="number" step="0.1" value="' + (d.stops[i].miles || '') + '" placeholder="auto" onchange="mdMiles(' + i + ', this.value)"></td></tr>';
        }
        document.getElementById('md-mile-rows').innerHTML = legs || '<tr><td colspan="2" style="color:#9ca3af;">Legs appear here as you add stops.</td></tr>';
        var rate = parseFloat(document.getElementById('md-rate').value) || 0;
        document.getElementById('md-mile-total').textContent = totMi.toFixed(1) + ' mi · $' + (totMi * rate).toFixed(2);

        var totExp = 0;
        document.getElementById('md-exp-rows').innerHTML = d.expenses.map(function (e, i) {
          totExp += e.amt;
          return '<tr><td>' + mdEsc(e.cat) + '</td><td>' + mdEsc(e.note || '') + (e.rcpt ? ' <button class="md-btn ghost" style="padding:2px 8px; font-size:11px;" onclick="mdViewRcpt(' + i + ')" title="View receipt photo">&#129534;</button>' : '') + '</td><td style="text-align:right;">$' + e.amt.toFixed(2) + '</td>' +
            '<td style="text-align:right;"><button class="md-btn warn" onclick="mdDelExp(' + i + ')">&times;</button></td></tr>';
        }).join('') || '<tr><td colspan="4" style="color:#9ca3af;">No expenses logged yet.</td></tr>';
        document.getElementById('md-exp-total').textContent = 'Day total $' + totExp.toFixed(2);
      }
      function mdDur(a, b) {
        function toMin(t) { var m = t.match(/(\d+):(\d+)\s*(AM|PM)/i); if (!m) return 0; var h = +m[1] % 12; if (/pm/i.test(m[3])) h += 12; return h * 60 + (+m[2]); }
        var diff = toMin(b) - toMin(a);
        if (diff < 0) diff += 1440;
        return diff < 60 ? diff + ' min' : Math.floor(diff / 60) + ' hr ' + (diff % 60) + ' min';
      }
      function mdCopyReport() {
        var d = mdLoad();
        var rate = parseFloat(document.getElementById('md-rate').value) || 0;
        var totMi = 0, totExp = 0;
        d.stops.forEach(function (s) { totMi += parseFloat(s.miles) || 0; });
        d.expenses.forEach(function (e) { totExp += e.amt; });
        var lines = ['Field Day Report. ' + (d.date || mdToday()) + '.', ''];
        d.stops.forEach(function (s, i) {
          var t = 'Stop ' + (i + 1) + '. ' + s.name + (s.addr ? ', ' + s.addr : '') + '.';
          if (s.arrived) t += ' Arrived ' + s.arrived + '.';
          if (s.departed) t += ' Departed ' + s.departed + '.';
          if (s.arrived && s.departed) t += ' Time on site ' + mdDur(s.arrived, s.departed) + '.';
          if (s.note) t += ' Note. ' + s.note;
          lines.push(t);
        });
        lines.push('');
        lines.push('Mileage total ' + totMi.toFixed(1) + ' miles at $' + rate.toFixed(3).replace(/0$/, '') + ' per mile equals $' + (totMi * rate).toFixed(2) + '.');
        if (d.expenses.length) {
          var parts = d.expenses.map(function (e) { return e.cat + ' $' + e.amt.toFixed(2) + (e.note ? ' (' + e.note + ')' : '') + (e.rcpt ? ' [receipt on file]' : ''); });
          lines.push('Expenses. ' + parts.join(', ') + '. Expense total $' + totExp.toFixed(2) + '.');
        }
        lines.push('Combined reimbursement $' + (totMi * rate + totExp).toFixed(2) + '.');
        var txt = lines.join('\n');
        var pv = document.getElementById('md-report-preview');
        pv.textContent = txt; pv.style.display = 'block';
        if (navigator.clipboard) navigator.clipboard.writeText(txt);
        var c = document.getElementById('md-copied');
        c.style.display = 'inline'; setTimeout(function () { c.style.display = 'none'; }, 2000);
      }

      /* ---- v3.18: Snap Receipt — camera + on-device OCR ---- */
      var mdPendingRcpt = null;
      function mdRcptStatus(msg, color) {
        var el = document.getElementById('md-rcpt-status'); if (!el) return;
        if (!msg) { el.style.display = 'none'; return; }
        el.style.display = 'block'; el.style.color = color || '#1d4ed8'; el.innerHTML = msg;
      }
      function mdLoadTesseract(cb) {
        if (window.Tesseract) return cb(true);
        var s = document.createElement('script');
        s.src = 'https://cdnjs.cloudflare.com/ajax/libs/tesseract.js/5.1.0/tesseract.min.js';
        s.onload = function () { cb(true); }; s.onerror = function () { cb(false); };
        document.head.appendChild(s);
      }
      function mdShrinkImage(dataUrl, maxW, q, cb) {
        var img = new Image();
        img.onload = function () {
          var sc = Math.min(1, maxW / img.width);
          var c = document.createElement('canvas');
          c.width = Math.round(img.width * sc); c.height = Math.round(img.height * sc);
          c.getContext('2d').drawImage(img, 0, 0, c.width, c.height);
          cb(c.toDataURL('image/jpeg', q));
        };
        img.src = dataUrl;
      }
      function mdReceiptPicked(inp) {
        var f = inp.files && inp.files[0]; inp.value = ''; if (!f) return;
        mdRcptStatus('&#128247; Processing photo&hellip;');
        var rd = new FileReader();
        rd.onload = function () {
          mdShrinkImage(rd.result, 640, 0.6, function (thumb) {
            mdPendingRcpt = thumb;
            mdShrinkImage(rd.result, 1400, 0.85, function (ocrImg) {
              mdRcptStatus('&#128269; Reading receipt&hellip; first use downloads the reader (~15 sec on wifi)');
              mdLoadTesseract(function (ok) {
                if (!ok) { mdRcptStatus('No connection to load the reader. Photo is attached &mdash; type the amount, then tap Add.', '#b45309'); return; }
                Tesseract.recognize(ocrImg, 'eng').then(function (res) {
                  mdApplyOcr(res && res.data ? res.data.text : '');
                }).catch(function () {
                  mdRcptStatus('Could not read this photo. It is still attached &mdash; type the details, then tap Add.', '#b45309');
                });
              });
            });
          });
        };
        rd.readAsDataURL(f);
      }
      function mdApplyOcr(text) {
        var lines = (text || '').split('\n').map(function (l) { return l.trim(); }).filter(Boolean);
        var amt = mdOcrTotal(lines), merch = mdOcrMerchant(lines), date = mdOcrDate(text || ''), cat = mdOcrCat(text || '');
        if (amt) document.getElementById('md-exp-amt').value = amt.toFixed(2);
        var bits = []; if (merch) bits.push(merch); if (date) bits.push(date);
        if (bits.length) document.getElementById('md-exp-note').value = bits.join(' \u2014 ');
        if (cat) document.getElementById('md-exp-cat').value = cat;
        var found = []; if (merch) found.push('merchant'); if (date) found.push('date'); if (amt) found.push('total');
        if (found.length) mdRcptStatus('&#10003; Read ' + found.join(', ') + '. Check the fields, then tap <strong>Add</strong> to save with the photo.', '#047857');
        else mdRcptStatus('Photo attached, but the print was too faint to read. Type the details, then tap Add.', '#b45309');
      }
      function mdOcrTotal(lines) {
        var best = 0, kw = 0;
        lines.forEach(function (l) {
          var ms = l.replace(/,/g, '').match(/\d{1,5}\.\d{2}/g); if (!ms) return;
          var v = Math.max.apply(null, ms.map(parseFloat));
          if (/(grand\s*total|amount\s*due|balance\s*due|\btotal\b)/i.test(l) && !/sub\s*total|subtotal/i.test(l)) { if (v > kw) kw = v; }
          if (v > best) best = v;
        });
        return kw || best || null;
      }
      function mdOcrDate(t) {
        var m = t.match(/\b(0?[1-9]|1[0-2])[\/\-.](0?[1-9]|[12]\d|3[01])[\/\-.](20\d{2}|\d{2})\b/);
        if (m) return m[0];
        m = t.match(/\b(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*\.?\s+\d{1,2},?\s+20\d{2}\b/i);
        return m ? m[0] : null;
      }
      function mdOcrMerchant(lines) {
        for (var i = 0; i < Math.min(lines.length, 6); i++) {
          var l = lines[i];
          if (l.length < 3 || l.length > 40) continue;
          if (/\d{3,}/.test(l)) continue;
          if (/receipt|invoice|welcome|thank|customer|copy/i.test(l)) continue;
          if (!/[a-z]/i.test(l)) continue;
          var clean = l.replace(/[^\w&' .\-]/g, '').trim();
          if (clean.length >= 3) return clean;
        }
        return null;
      }
      function mdOcrCat(t) {
        if (/parking|garage|meter/i.test(t)) return 'Parking';
        if (/toll|e-?zpass/i.test(t)) return 'Tolls';
        if (/fuel|gasoline|shell|exxon|chevron|mobil|sunoco|diesel|unleaded/i.test(t)) return 'Fuel';
        if (/restaurant|cafe|coffee|grill|pizza|deli|starbucks|dunkin|mcdonald|bagel|diner|panera|chipotle/i.test(t)) return 'Meals';
        return null;
      }
      function mdViewRcpt(i) {
        var d = mdLoad(); var r = d.expenses[i] && d.expenses[i].rcpt; if (!r) return;
        var ov = document.createElement('div');
        ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:99999;display:flex;align-items:center;justify-content:center;padding:20px;cursor:pointer;';
        ov.innerHTML = '<img src="' + r + '" style="max-width:100%;max-height:90vh;border-radius:8px;box-shadow:0 10px 40px rgba(0,0,0,.5);">';
        ov.onclick = function () { document.body.removeChild(ov); };
        document.body.appendChild(ov);
      }

      /* =========================================================
         v3.22: VISIT NOTES — per stop note (type or speak), saved
         locally with the stop, and pushed to a shared team log
         (/api/visitnotes, same Redis + password pattern as the
         Trunk Stock Order Log). Offline/API-down: notes queue in
         localStorage (mbx_notes_queue) and flush on next load.
         ========================================================= */
      var MD_MIC_OK = !!(window.webkitSpeechRecognition || window.SpeechRecognition);
      var MD_MIC_ACTIVE = null;
      function mdRepName() { try { return localStorage.getItem('mbx_chat_name') || ''; } catch (e) { return ''; } }

      function mdNoteDraft(i, v) {
        var d = mdLoad();
        if (!d.stops[i]) return;
        d.stops[i].note = v;
        d.stops[i].noteSaved = false;
        mdSave(d);
        var tag = document.querySelector('#md-visit-rows tr:nth-child(' + (i + 1) + ') td:nth-child(6) span');
        /* light touch: full re-render happens on Save so typing stays smooth */
      }

      /* Voice note — keeps listening through pauses; auto-stops after 10s of
         silence, or when you tap the mic again. A pause no longer cuts you off. */
      var MD_MIC_TIMER = null;
      function mdMicClearTimer() { if (MD_MIC_TIMER) { clearTimeout(MD_MIC_TIMER); MD_MIC_TIMER = null; } }
      function mdMicToggle(i) {
        if (!MD_MIC_OK) return;
        if (MD_MIC_ACTIVE) { MD_MIC_ACTIVE._stop = true; try { MD_MIC_ACTIVE.stop(); } catch (e) {} return; }   // tap again = stop now
        var Rec = window.webkitSpeechRecognition || window.SpeechRecognition;
        var ta = document.getElementById('md-note-' + i);
        var btn = document.getElementById('md-mic-' + i);
        if (btn) { btn.style.background = '#fee2e2'; btn.style.borderColor = '#fecaca'; }
        var committed = ta ? ta.value : ''; if (committed && !/\s$/.test(committed)) committed += ' ';
        var lastFinal = '', lastAny = '';
        function armTimer() { mdMicClearTimer(); MD_MIC_TIMER = setTimeout(function () { if (MD_MIC_ACTIVE) { MD_MIC_ACTIVE._stop = true; try { MD_MIC_ACTIVE.stop(); } catch (e) {} } }, 10000); }
        function startSession() {
          var rec = new Rec();
          rec.lang = 'en-US'; rec.interimResults = true; rec.continuous = true; rec.maxAlternatives = 1;
          rec._stop = false;
          rec.onstart = function () { armTimer(); };
          rec.onresult = function (ev) {
            var fin = '', any = '';
            for (var k = 0; k < ev.results.length; k++) { any += ev.results[k][0].transcript; if (ev.results[k].isFinal) fin += ev.results[k][0].transcript; }
            lastFinal = fin; lastAny = any;
            if (ta) { ta.value = committed + any; if (fin) mdNoteDraft(i, ta.value); }
            armTimer();                        // new words -> restart the 10s countdown
          };
          rec.onerror = function () {
            var st = document.getElementById('mn-log-status');
            if (st) { st.style.color = '#b45309'; st.textContent = 'Could not hear that — check microphone permission and try again.'; }
          };
          rec.onend = function () {
            var add = lastFinal || lastAny;
            if (add) { committed += add; if (!/\s$/.test(committed)) committed += ' '; }
            lastFinal = ''; lastAny = '';
            if (!rec._stop) { if (ta) { ta.value = committed; mdNoteDraft(i, ta.value); } try { startSession(); return; } catch (e) {} }
            mdMicClearTimer();
            MD_MIC_ACTIVE = null;
            if (btn) { btn.style.background = ''; btn.style.borderColor = ''; }
          };
          MD_MIC_ACTIVE = rec;
          try { rec.start(); } catch (e) { mdMicClearTimer(); MD_MIC_ACTIVE = null; if (btn) { btn.style.background = ''; btn.style.borderColor = ''; } }
        }
        startSession();
      }

      function mdLogNote(i) {
        var d = mdLoad();
        var s = d.stops[i]; if (!s) return;
        var ta = document.getElementById('md-note-' + i);
        var note = (ta ? ta.value : s.note || '').trim();
        if (!note) return;
        var rep = (mdRepName() || prompt('Your name, so this note lands on the team log') || '').trim();
        if (!rep) return;
        try { localStorage.setItem('mbx_chat_name', rep); } catch (e) {}
        s.note = note;
        s.noteSaved = true;
        mdSave(d);
        mnPostNote({ rep: rep, account: s.name, note: note, ts: Date.now() });
        mdRender();
      }

      function mnEsc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
      var MN_NOTES = [];

      function mnPostNote(entry) {
        fetch('/api/visitnotes', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(entry) })
          .then(function (r) { return r.json(); })
          .then(function (j) {
            if (!j || !j.ok) throw new Error('api');
            mnLoadNotes(false);
          })
          .catch(function () {
            try {
              var q = JSON.parse(localStorage.getItem('mbx_notes_queue') || '[]');
              q.push(entry);
              localStorage.setItem('mbx_notes_queue', JSON.stringify(q));
            } catch (e) {}
            var st = document.getElementById('mn-log-status');
            if (st) { st.style.color = '#b45309'; st.textContent = 'Note saved on this device — it syncs to the team log next time the toolkit is online.'; }
          });
      }

      function mnFlushQueue() {
        var q;
        try { q = JSON.parse(localStorage.getItem('mbx_notes_queue') || '[]'); } catch (e) { q = []; }
        if (!q.length) return Promise.resolve();
        return q.reduce(function (p, entry) {
          return p.then(function () {
            return fetch('/api/visitnotes', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(entry) })
              .then(function (r) { return r.json(); })
              .then(function (j) { if (!j || !j.ok) throw new Error('api'); });
          });
        }, Promise.resolve()).then(function () {
          try { localStorage.removeItem('mbx_notes_queue'); } catch (e) {}
        }).catch(function () {});
      }

      function mnLoadNotes(manual) {
        var st = document.getElementById('mn-log-status');
        if (st && manual) { st.style.color = '#9ca3af'; st.textContent = 'Refreshing…'; }
        mnFlushQueue().then(function () {
          return fetch('/api/visitnotes').then(function (r) { return r.json(); });
        }).then(function (j) {
          if (!j || !j.ok) throw new Error(j && j.error || 'api');
          MN_NOTES = j.notes || [];
          mnRenderLog();
        }).catch(function () {
          if (st) {
            st.style.color = '#b45309';
            st.textContent = (location.protocol === 'file:')
              ? 'The shared log needs the deployed site (it talks to the team server). Opening this file directly, notes queue on-device.'
              : 'Could not reach the team notes log — check connection and tap Refresh.';
          }
        });
      }

      function mnRenderLog() {
        var rows = document.getElementById('mn-log-rows');
        var st = document.getElementById('mn-log-status');
        if (!rows) return;
        var filt = (document.getElementById('mn-filter') || { value: '' }).value.trim().toLowerCase();
        var list = MN_NOTES.filter(function (n) {
          if (!filt) return true;
          return (n.rep || '').toLowerCase().indexOf(filt) > -1 || (n.account || '').toLowerCase().indexOf(filt) > -1;
        });
        rows.innerHTML = list.map(function (n) {
          var d = new Date(n.ts);
          var dstr = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
          var tstr = d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
          return '<tr><td style="white-space:nowrap;">' + dstr + '<br><span style="color:#9ca3af; font-size:11px;">' + tstr + '</span></td>' +
            '<td>' + mnEsc(n.rep) + '</td><td>' + mnEsc(n.account) + '</td><td>' + mnEsc(n.note) + '</td></tr>';
        }).join('') || '<tr><td colspan="4" style="color:#9ca3af;">No visit notes logged yet. Save one from the Visit Log above.</td></tr>';
        if (st) { st.style.color = '#9ca3af'; st.textContent = list.length + ' note' + (list.length === 1 ? '' : 's') + ' on the team log' + (filt ? ' (filtered)' : '') + '.'; }
      }

      /* Weekly / monthly report — a readable, day-by-day breakdown of every
         note in the period, with exact times, ready to copy into chat or SF.
         Respects the current rep/account filter box if one is set. */
      var MN_REPORT_TEXT = '';
      function mnReport(days) {
        days = days || 7;
        if (!MN_NOTES.length) { mnLoadNotes(false); }
        var cutoff = Date.now() - days * 24 * 60 * 60 * 1000;
        var filt = (document.getElementById('mn-filter') || { value: '' }).value.trim().toLowerCase();
        var list = MN_NOTES.filter(function (n) {
          if (!(n.ts >= cutoff)) return false;
          if (!filt) return true;
          return (n.rep || '').toLowerCase().indexOf(filt) > -1 || (n.account || '').toLowerCase().indexOf(filt) > -1;
        }).slice().sort(function (a, b) { return a.ts - b.ts; }); // oldest first, reads top-down by day

        var byDay = [], idx = {};
        list.forEach(function (n) {
          var key = new Date(n.ts).toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' });
          if (idx[key] === undefined) { idx[key] = byDay.length; byDay.push({ label: key, notes: [] }); }
          byDay[idx[key]].notes.push(n);
        });

        var periodLabel = days === 7 ? 'This Week' : (days === 30 ? 'Last 30 Days' : 'Last ' + days + ' Days');
        var lines = [];
        lines.push('MiniBox Visit Notes — ' + periodLabel);
        lines.push(list.length + ' note' + (list.length === 1 ? '' : 's') + (filt ? ' (filtered: "' + filt + '")' : '') +
          '  ·  generated ' + new Date().toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }));
        lines.push('');
        byDay.forEach(function (day) {
          lines.push('── ' + day.label + ' ──');
          day.notes.forEach(function (n) {
            var t = new Date(n.ts).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
            lines.push('• ' + t + ' — ' + (n.account || '(no account)') + '  [' + (n.rep || '?') + ']');
            lines.push('   ' + (n.note || '').replace(/\s+/g, ' ').trim());
          });
          lines.push('');
        });
        if (!list.length) lines.push('No visit notes in this period yet — save one from the Visit Log above.');
        MN_REPORT_TEXT = lines.join('\n').replace(/\s+$/, '');

        var box = document.getElementById('mn-report');
        var ta = document.getElementById('mn-report-text');
        var title = document.getElementById('mn-report-title');
        if (title) title.textContent = periodLabel + ' — ' + list.length + ' note' + (list.length === 1 ? '' : 's');
        if (ta) ta.value = MN_REPORT_TEXT;
        if (box) { box.style.display = 'block'; box.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }
      }

      /* Quick Note — the simple path: talk or type, tap Save, it's on the team
         log instantly with a timestamp. No stop/appointment needed. */
      function mnQuickSave() {
        var ta = document.getElementById('mn-quick-text');
        var acctEl = document.getElementById('mn-quick-acct');
        var status = document.getElementById('mn-quick-status');
        var note = (ta ? ta.value : '').trim();
        if (!note) { if (status) { status.style.color = '#b45309'; status.textContent = 'Type or say something first, then tap Save.'; } return; }
        var rep = (mdRepName() || prompt('Your name (so notes are tagged to you) — saved for next time') || '').trim();
        if (!rep) return;
        try { localStorage.setItem('mbx_chat_name', rep); } catch (e) {}
        var account = (acctEl && acctEl.value.trim()) ? acctEl.value.trim() : 'Quick note';
        mnPostNote({ rep: rep, account: account, note: note, ts: Date.now() });
        if (ta) ta.value = '';
        if (acctEl) acctEl.value = '';
        if (status) { status.style.color = '#059669'; status.textContent = '✓ Saved ' + new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) + ' — it’s in the log below and in your weekly report.'; }
      }

      var MN_QMIC = null, MN_QMIC_TIMER = null;
      function mnQuickMic() {
        var status = document.getElementById('mn-quick-status');
        if (!MD_MIC_OK) { if (status) { status.style.color = '#b45309'; status.textContent = 'Voice typing isn’t supported in this browser — type your note instead (on iPhone use the keyboard mic).'; } return; }
        if (MN_QMIC) { MN_QMIC._stop = true; try { MN_QMIC.stop(); } catch (e) {} return; }  // tap again = stop
        var Rec = window.webkitSpeechRecognition || window.SpeechRecognition;
        var ta = document.getElementById('mn-quick-text');
        var btn = document.getElementById('mn-quick-mic');
        var committed = ta ? ta.value : '';
        function clearT() { if (MN_QMIC_TIMER) { clearTimeout(MN_QMIC_TIMER); MN_QMIC_TIMER = null; } }
        function armT() { clearT(); MN_QMIC_TIMER = setTimeout(function () { if (MN_QMIC) { MN_QMIC._stop = true; try { MN_QMIC.stop(); } catch (e) {} } }, 10000); }
        function startSession() {
          var rec = new Rec();
          rec.continuous = true; rec.interimResults = true; rec.lang = 'en-US';
          rec.onresult = function (ev) {
            var fin = '', any = '';
            for (var k = 0; k < ev.results.length; k++) { any += ev.results[k][0].transcript; if (ev.results[k].isFinal) fin += ev.results[k][0].transcript; }
            if (ta) ta.value = (committed + ' ' + any).trim();
            if (fin) committed = (committed + ' ' + fin).trim();
            armT();
          };
          rec.onerror = function () {};
          rec.onend = function () {
            if (!rec._stop) { if (ta) ta.value = committed; try { startSession(); return; } catch (e) {} }
            clearT(); MN_QMIC = null; if (btn) { btn.style.background = ''; btn.style.borderColor = ''; }
          };
          MN_QMIC = rec;
          if (btn) { btn.style.background = '#fee2e2'; btn.style.borderColor = '#fca5a5'; }
          try { rec.start(); armT(); } catch (e) { clearT(); MN_QMIC = null; if (btn) { btn.style.background = ''; btn.style.borderColor = ''; } }
        }
        startSession();
      }

      function mnCopyReport() {
        var ta = document.getElementById('mn-report-text');
        var st = document.getElementById('mn-log-status');
        if (!ta) return;
        var done = function () { if (st) { st.style.color = '#059669'; st.textContent = 'Report copied — paste it into Team Chat, Salesforce, or an email.'; } };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(MN_REPORT_TEXT).then(done, function () { try { ta.select(); document.execCommand('copy'); done(); } catch (e) {} });
        } else {
          try { ta.select(); document.execCommand('copy'); done(); } catch (e) {}
        }
      }

      function mnExportCsv() {
        var rows = [['Date', 'Rep', 'Account', 'Note']];
        MN_NOTES.forEach(function (n) {
          rows.push([new Date(n.ts).toLocaleString('en-US'), n.rep || '', n.account || '', (n.note || '').replace(/\s+/g, ' ')]);
        });
        var csv = rows.map(function (r) {
          return r.map(function (c) { return '"' + String(c).replace(/"/g, '""') + '"'; }).join(',');
        }).join('\r\n');
        var blob = new Blob([csv], { type: 'text/csv' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'minibox-visit-notes.csv';
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
      }

      document.addEventListener('DOMContentLoaded', function () { mdListsRender(); mdRender(); mnLoadNotes(false); });
    </script>
  </div>

