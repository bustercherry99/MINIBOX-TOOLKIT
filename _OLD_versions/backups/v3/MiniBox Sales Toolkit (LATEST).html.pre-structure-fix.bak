  },
  intro: {
    subject: 'Introducing the MiniBox+ — Complete PFTs Without a Body Box',
    body: 'Dear Dr. [Last Name],\n\nMy name is [Your Name] from PulmOne USA. I wanted to introduce you to the MiniBox+ — the only portable device that delivers complete Spirometry, Lung Volumes (plethysmography), and DLCO in 15–20 minutes, operable by any staff member, with zero maintenance fees.\n\nIt\'s been validated against the traditional body box in a published CHEST 2021 study across 700+ patients at 11 medical centers — same accuracy, same CPT codes, fraction of the footprint.\n\nWould you be open to a 15-minute demo at your convenience? I\'m happy to work around your schedule.\n\nBest regards,\n[Your Name]\nPulmOne USA\n1-844-PulmOne (785-6663)'
  },
  cardio_intro: {
    subject: 'Complete PFTs in Your Cardiology Practice — Point-of-Care in 15–20 Minutes',
    body: 'Dear Dr. [Last Name],\n\nMy name is [Your Name] from PulmOne USA. When a patient is short of breath, the heart is only half the picture — and the pulmonary half often means a referral out. The MiniBox+ performs a complete PFT (Spirometry, Lung Volumes, and DLCO) in your own office in 15–20 minutes, operable by any staff member.\n\nFor cardiology this matters clinically: spirometry is a first-line test in the dyspnea workup; COPD is found in roughly 25–50% of heart failure patients and is widely underdiagnosed; and DLCO — which a plain spirometer cannot measure — is a recognized prognostic marker in pulmonary hypertension and HFpEF. Every one of these points is drawn from peer-reviewed sources I am happy to share.\n\nWould you be open to a 15-minute demo at your convenience?\n\nBest regards,\n[Your Name]\nPulmOne USA\n1-844-PulmOne (785-6663)'
  },
  cardio_followup: {
    subject: 'MiniBox+ for Cardiology — The Clinical Case & Billing, One Page',
    body: 'Dear Dr. [Last Name],\n\nThank you for the time today. As promised, attached is a single, fully-sourced page on where complete PFTs fit in a cardiology clinic — sorting cardiac vs pulmonary dyspnea, untangling heart failure and COPD, peri-procedural risk, and why DLCO (a full PFT, not just a spirometer) carries prognostic weight in heart failure and pulmonary hypertension. It also shows the complete-PFT billing: 94010 + 94726 + 94729, about $151.45 per patient at national averages, done in-office.\n\nHappy to walk through any of the references or arrange a hands-on demo with your staff.\n\nBest regards,\n[Your Name]\nPulmOne USA'
  }
};

function emailTemplate(key) {
  var t = EMAIL_TEMPLATES[key];
  if (!t) return;
  document.getElementById('email-subject').value = t.subject;
  document.getElementById('email-body').value = t.body;
}

function openInOutlook() {
  var to = document.getElementById('email-to').value.trim();
  var cc = document.getElementById('email-cc').value.trim();
  var subj = encodeURIComponent(document.getElementById('email-subject').value.trim());
  var body = encodeURIComponent(document.getElementById('email-body').value.trim());
  var mailto = 'mailto:' + to + '?subject=' + subj + '&body=' + body;
  if (cc) mailto += '&cc=' + encodeURIComponent(cc);
  window.location.href = mailto;
}

function emailClear() {
  ['email-to','email-cc','email-subject','email-body'].forEach(function(id) {
    document.getElementById(id).value = '';
  });
}

/* ---- DAILY NOTES ---- */
(function loadNotes() {
  try {
    var saved = localStorage.getItem('pulmone_daily_notes');
    var ts = localStorage.getItem('pulmone_notes_ts');
    if (saved) document.getElementById('daily-notes').value = saved;
    if (ts) document.getElementById('notes-timestamp').textContent = 'Last saved: ' + ts;
  } catch(e) {}
})();

function saveNotes() {
  try {
    var val = document.getElementById('daily-notes').value;
    localStorage.setItem('pulmone_daily_notes', val);
    var now = new Date().toLocaleString();
    localStorage.setItem('pulmone_notes_ts', now);
    document.getElementById('notes-timestamp').textContent = 'Last saved: ' + now;
    var msg = document.getElementById('notes-saved-msg');
    msg.style.display = 'inline';
    setTimeout(function() { msg.style.display = 'none'; }, 2000);
  } catch(e) { alert('Notes saved in session only (localStorage unavailable).'); }
}

function clearNotes() {
  if (!confirm('Clear all notes?')) return;
  document.getElementById('daily-notes').value = '';
  try { localStorage.removeItem('pulmone_daily_notes'); } catch(e) {}
  document.getElementById('notes-timestamp').textContent = '';
}

/* ---- MY REFERENCES (rep-added, saved on this device) ---- */
var REF_KEY = 'pulmone_my_references';

function loadReferences() {
  try { var a = JSON.parse(localStorage.getItem(REF_KEY) || '[]'); return Array.isArray(a) ? a : []; }
  catch(e) { return []; }
}
function saveReferences(arr) {
  try { localStorage.setItem(REF_KEY, JSON.stringify(arr)); } catch(e) {}
}
function refEscape(s) {
  return String(s == null ? '' : s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}
function renderReferences() {
  var grid = document.getElementById('ref-grid');
  var empty = document.getElementById('ref-empty');
  if (!grid) return;
  var refs = loadReferences();
  grid.innerHTML = '';
  if (empty) empty.style.display = refs.length ? 'none' : 'block';
  refs.forEach(function(r, i) {
    var tel = (r.phone || '').replace(/[^0-9+]/g, '');
    var actions = '';
    if (tel) actions += '<a href="tel:' + refEscape(tel) + '" class="ct-btn ct-call">&#128222; Call</a>';
    if (r.email) actions += '<a href="mailto:' + refEscape(r.email) + '" class="ct-btn ct-email">&#9993; Email</a>';
    actions += '<button class="ct-btn ct-del" title="Remove" onclick="removeReference(' + i + ')">&#10005;</button>';
    var tile = document.createElement('div');
    tile.className = 'contact-tile';
    tile.innerHTML =
      '<div class="ct-name">' + refEscape(r.name || 'Reference') + '</div>' +
      '<div class="ct-role">' + refEscape(r.role || '') + '</div>' +
      '<div class="ct-actions">' + actions + '</div>';
    grid.appendChild(tile);
  });
}
function addReference() {
  var name  = document.getElementById('ref-name').value.trim();
  var role  = document.getElementById('ref-role').value.trim();
  var phone = document.getElementById('ref-phone').value.trim();
  var email = document.getElementById('ref-email').value.trim();
  if (!name) { alert('Please enter a name for the reference.'); return; }
  if (!phone && !email) { alert('Add a phone number or an email so you can reach this reference.'); return; }
  var refs = loadReferences();
  refs.push({ name: name, role: role, phone: phone, email: email });
  saveReferences(refs);
  document.getElementById('ref-name').value = '';
  document.getElementById('ref-role').value = '';
  document.getElementById('ref-phone').value = '';
  document.getElementById('ref-email').value = '';
  renderReferences();
}
function removeReference(i) {
  var refs = loadReferences();
  if (i < 0 || i >= refs.length) return;
  if (!confirm('Remove ' + (refs[i].name || 'this reference') + '?')) return;
  refs.splice(i, 1);
  saveReferences(refs);
  renderReferences();
}
renderReferences();

/* ---- EMBEDDED ROI BUILDER CONTROLS ---- */
function rmaFullscreen() {
  var f=document.getElementById('rma-iframe'); if(!f) return;
  var r=f.requestFullscreen||f.webkitRequestFullscreen||f.mozRequestFullScreen||f.msRequestFullscreen;
  if(r) r.call(f);
}
function roiBuilderFullscreen() {
  var iframe = document.getElementById('roi-builder-iframe');
  if (!iframe) return;
  var req = iframe.requestFullscreen || iframe.webkitRequestFullscreen || iframe.mozRequestFullScreen || iframe.msRequestFullscreen;
  if (req) {
    try { req.call(iframe); return; } catch(e) {}
  }
  // Fallback: toggle CSS fullscreen
  if (iframe.classList.contains('roi-fs-fallback')) {
    iframe.classList.remove('roi-fs-fallback');
    iframe.style.cssText = 'width:100%; border:0; height:1650px; display:block; background:#f1f5f9;';
  } else {
    iframe.classList.add('roi-fs-fallback');
    iframe.style.cssText = 'position:fixed; inset:0; width:100vw; height:100vh; z-index:10000; border:0; background:#fff;';
  }
}

function roiBuilderPrint() {
  var iframe = document.getElementById('roi-builder-iframe');
  if (!iframe) return;
  try {
    var win = iframe.contentWindow;
    if (win && typeof win.printAll === 'function') { win.printAll(); return; }
    if (win && win.document) win.print();
  } catch(e) {
    alert('Click inside the ROI proposal, then press Ctrl/Cmd+P to print.');
  }
}

function quoteBuilderFullscreen() {
  var iframe = document.getElementById('quote-builder-iframe');
  if (!iframe) return;
  var req = iframe.requestFullscreen || iframe.webkitRequestFullscreen || iframe.mozRequestFullScreen || iframe.msRequestFullscreen;
  if (req) { try { req.call(iframe); return; } catch(e) {} }
  if (iframe.classList.contains('qb-fs-fallback')) {
    iframe.classList.remove('qb-fs-fallback');
    iframe.style.cssText = 'width:100%; border:0; height:1500px; display:block; background:#f1f5f9;';
  } else {
    iframe.classList.add('qb-fs-fallback');
    iframe.style.cssText = 'position:fixed; inset:0; width:100vw; height:100vh; z-index:10000; border:0; background:#fff;';
  }
}
function quoteBuilderPrint() {
  var iframe = document.getElementById('quote-builder-iframe');
  if (!iframe) return;
  try { var win = iframe.contentWindow; if (win && win.document) win.print(); }
  catch(e) { alert('Click inside the quote, then press Ctrl/Cmd+P to print.'); }
}
document.addEventListener('keydown', function(e){
  if (e.key === 'Escape') {
    var iframe = document.getElementById('quote-builder-iframe');
    if (iframe && iframe.classList.contains('qb-fs-fallback')) {
      iframe.classList.remove('qb-fs-fallback');
      iframe.style.cssText = 'width:100%; border:0; height:1500px; display:block; background:#f1f5f9;';
    }
  }
});
// Exit fallback fullscreen on Escape
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    var iframe = document.getElementById('roi-builder-iframe');
    if (iframe && iframe.classList.contains('roi-fs-fallback')) {
      iframe.classList.remove('roi-fs-fallback');
      iframe.style.cssText = 'width:100%; border:0; height:1650px; display:block; background:#f1f5f9;';
    }
  }
});

/* ============================================================
   REP PROFILE + EMAIL LIBRARY
   ============================================================ */

/* ---- PROFILE (saved to localStorage on this device) ---- */
var REP_PROFILE = {
  name: '',
  title: 'PulmOne Sales Representative',
  email: '',
  mobile: '',
  company: 'PulmOne USA',
  emailMode: 'mailto'  // 'mailto' (Outlook desktop) or 'owa' (Outlook Web)
};

function loadProfile() {
  try {
    var raw = localStorage.getItem('pulmone_rep_profile');
    if (raw) {
      var p = JSON.parse(raw);
      if (p && typeof p === 'object') {
        for (var k in REP_PROFILE) { if (p[k] != null) REP_PROFILE[k] = p[k]; }
      }
    }
  } catch(e) {}
  renderProfileHeader();
  renderProfileCard();
}

function saveProfile() {
  REP_PROFILE.name   = document.getElementById('pm-name').value.trim();
  REP_PROFILE.title  = document.getElementById('pm-title').value.trim() || 'PulmOne Sales Representative';
  REP_PROFILE.email  = document.getElementById('pm-email').value.trim();
  REP_PROFILE.mobile = document.getElementById('pm-mobile').value.trim();
  REP_PROFILE.company= document.getElementById('pm-company').value.trim() || 'PulmOne USA';
  // emailMode is toggled via pm-toggle buttons
  try { localStorage.setItem('pulmone_rep_profile', JSON.stringify(REP_PROFILE)); } catch(e) {}
  renderProfileHeader();
  renderProfileCard();
  if (typeof easSyncProfile === 'function') easSyncProfile();
  if (currentElTmpl) selectElTemplate(currentElIdx);
  elToast('Profile saved');
  closeProfile();
}

function clearProfile() {
  if (!confirm('Clear your saved profile from this device?')) return;
  try { localStorage.removeItem('pulmone_rep_profile'); } catch(e) {}
  REP_PROFILE = { name:'', title:'PulmOne Sales Representative', email:'', mobile:'', company:'PulmOne USA', emailMode:'mailto' };
  renderProfileHeader();
  renderProfileCard();
  if (typeof easSyncProfile === 'function') easSyncProfile();
  if (currentElTmpl) selectElTemplate(currentElIdx);
  elToast('Profile cleared');
  closeProfile();
}

function openProfile() {
  document.getElementById('pm-name').value    = REP_PROFILE.name;
  document.getElementById('pm-title').value   = REP_PROFILE.title;
  document.getElementById('pm-email').value   = REP_PROFILE.email;
  document.getElementById('pm-mobile').value  = REP_PROFILE.mobile;
  document.getElementById('pm-company').value = REP_PROFILE.company;
  setEmailMode(REP_PROFILE.emailMode, true);
  document.getElementById('profile-modal').classList.add('open');
}
function closeProfile() {
  document.getElementById('profile-modal').classList.remove('open');
}

function setEmailMode(mode, skipUpdate) {
  REP_PROFILE.emailMode = mode;
  var btnMailto = document.getElementById('pm-mode-mailto');
  var btnOWA    = document.getElementById('pm-mode-owa');
  if (btnMailto) btnMailto.classList.toggle('on', mode === 'mailto');
  if (btnOWA)    btnOWA.classList.toggle('on', mode === 'owa');
  if (!skipUpdate) {
    try { localStorage.setItem('pulmone_rep_profile', JSON.stringify(REP_PROFILE)); } catch(e) {}
  }
}

function renderProfileHeader() {
  var lbl = document.getElementById('profile-name-lbl');
  var badge = document.getElementById('profile-badge');
  if (!lbl) return;
  if (REP_PROFILE.name) {
    lbl.textContent = REP_PROFILE.name;
    if (badge) badge.classList.add('set');
  } else {
    lbl.textContent = 'My Rep Profile';
    if (badge) badge.classList.remove('set');
  }
}

function renderProfileCard() {
  var nameEl = document.getElementById('el-p-name');
  if (!nameEl) return;
  if (REP_PROFILE.name) {
    nameEl.textContent = REP_PROFILE.name;
    document.getElementById('el-p-title').textContent = REP_PROFILE.title + ' &middot; ' + REP_PROFILE.company;
    document.getElementById('el-p-title').innerHTML = REP_PROFILE.title + ' &middot; ' + REP_PROFILE.company;
    var bits = [];
    if (REP_PROFILE.email)  bits.push(REP_PROFILE.email);
    if (REP_PROFILE.mobile) bits.push(REP_PROFILE.mobile);
    document.getElementById('el-p-contact').textContent = bits.join('  \u00B7  ');
  } else {
    nameEl.textContent = '(not set)';
    document.getElementById('el-p-title').textContent = 'Set your profile to auto-sign emails';
    document.getElementById('el-p-contact').textContent = '';
  }
}

/* ---- SIGNATURE BUILDER ---- */
function buildSignature() {
  var sigLines = [];
  if (REP_PROFILE.name)    sigLines.push(REP_PROFILE.name);
  if (REP_PROFILE.title)   sigLines.push(REP_PROFILE.title);
  if (REP_PROFILE.company) sigLines.push(REP_PROFILE.company);
  if (REP_PROFILE.mobile)  sigLines.push('(direct) ' + REP_PROFILE.mobile);
  if (REP_PROFILE.email)   sigLines.push(REP_PROFILE.email);
  if (sigLines.length === 0) {
    return '[Your Name]\nPulmOne USA\n1-844-PulmOne (785-6663)\nUSinfo@pulm-one.com';
  }
  return sigLines.join('\n');
}

function applyProfileMerges(text) {
  var t = text;
  t = t.replace(/\{\{YOUR_NAME\}\}/g,    REP_PROFILE.name    || '[Your Name]');
  t = t.replace(/\{\{YOUR_TITLE\}\}/g,   REP_PROFILE.title   || 'PulmOne Sales Representative');
  t = t.replace(/\{\{YOUR_EMAIL\}\}/g,   REP_PROFILE.email   || '[your.email@pulm-one.com]');
  t = t.replace(/\{\{YOUR_MOBILE\}\}/g,  REP_PROFILE.mobile  || '[your mobile]');
  t = t.replace(/\{\{YOUR_COMPANY\}\}/g, REP_PROFILE.company || 'PulmOne USA');
  t = t.replace(/\{\{SIGNATURE\}\}/g,    buildSignature());
  return t;
}

/* ---- EMAIL LIBRARY: 12 TEMPLATES ---- */
var EL_TEMPLATES = [
  { id:'intro-cold', cat:'Cold Outreach', title:'First-touch intro email',
    sub:'Never met them. You have a reason to reach out.',
    subject:'Introducing the MiniBox+ — complete PFTs without a body box',
    body:'Dear Dr. {{LAST_NAME}},\n\nMy name is {{YOUR_NAME}} from {{YOUR_COMPANY}}. Reaching out because {{SPECIFIC_REASON}}.\n\nWe make the MiniBox+ — the only portable device that delivers complete Spirometry, Lung Volumes (plethysmography), and DLCO in 15 to 20 minutes, operable by any staff member, with zero maintenance fees.\n\nIt was validated head-to-head against the traditional body box in a published CHEST 2021 study across 700+ patients at 11 medical centers. Same accuracy, same CPT codes, fraction of the footprint.\n\nWould you be open to a 15-minute demo at your convenience? I\'m happy to work around your schedule.\n\nBest regards,\n{{SIGNATURE}}',
    note:'Purpose: first touch. Replace {{SPECIFIC_REASON}} with something real (a publication, a referral from a colleague, a local market trigger). Never send a generic cold email.' },

  { id:'pre-meeting', cat:'Pre-Meeting', title:'Pre-meeting teaser — 48 hours out',
    sub:'Confirms meeting, gets intel 48 hrs in advance',
    subject:'Quick note before our {{DAY}} meeting, Dr. {{LAST_NAME}}',
    body:'Dr. {{LAST_NAME}},\n\nLooking forward to meeting you and the team on {{DAY}} at {{TIME}}.\n\nTo make sure I don\'t waste any of your time, two quick questions:\n\n  1. Roughly how many PFT-eligible patients do you see per week today?\n  2. Are there any specific clinical or financial questions you want me to be ready to answer?\n\nI\'ll bring a MiniBox+ and we can run a live test on a volunteer. Fifteen to thirty minutes is typically enough for a first meeting.\n\nSee you {{DAY}}.\n\n{{SIGNATURE}}',
    note:'Purpose: confirm the meeting + collect intel. Raises the quality of the demo enormously.' },

  { id:'demo-confirm', cat:'Logistics', title:'Day-before demo confirmation',
    sub:'Reduces no-shows, sets expectations',
    subject:'Tomorrow at {{TIME}} — MiniBox+ demo confirmation',
    body:'Dr. {{LAST_NAME}},\n\nConfirming our meeting tomorrow, {{DATE}}, at {{TIME}} at {{LOCATION}}.\n\nWhat I\'ll bring:\n  \u2022 MiniBox+ device, ready to run\n  \u2022 A 1-page summary for your records\n  \u2022 A short customized revenue projection based on the patient volume we discussed\n\nWhat I\'ll ask you to provide:\n  \u2022 One volunteer (MA, front desk, yourself) for a live test \u2014 takes under 10 minutes\n  \u2022 15 minutes of your attention; 30 if you can spare it\n\nIf anything comes up, my direct line is {{YOUR_MOBILE}}. See you tomorrow.\n\n{{SIGNATURE}}',
    note:'Purpose: reduce no-show rate. Reset expectations about what a demo actually involves.' },

  { id:'post-demo', cat:'Post-Meeting', title:'Same-day post-demo thank-you',
    sub:'Send within 2 hours of the demo',
    subject:'MiniBox+ recap — from this morning',
    body:'Dr. {{LAST_NAME}},\n\nThank you for the time this morning. I enjoyed the conversation about {{SPECIFIC_TOPIC}}.\n\nAs promised, the short version of what we covered:\n\n  \u2022 Complete PFT (spirometry, lung volumes, DLCO) in 15 minutes on a desktop device\n  \u2022 Same CPT codes as the hospital body box \u2014 up to $151.45 per complete PFT\n  \u2022 At {{PATIENTS_PER_DAY}} PFTs per day, payback in roughly {{PAYBACK_WEEKS}} weeks\n  \u2022 Published validation: CHEST 2021, 700+ patients, 11 medical centers\n\nNext step I suggested: a 30-minute follow-up with {{PM_NAME}} to walk through your specific billing history. Does {{PROPOSED_TIME_1}} or {{PROPOSED_TIME_2}} work on your side?\n\n{{SIGNATURE}}',
    note:'Purpose: anchor memory while demo is still warm. Ask for the specific next meeting, not a vague follow-up.' },

  { id:'roi-send', cat:'Financial Follow-up', title:'ROI / customized proposal send',
    sub:'After you promise the numbers',
    subject:'MiniBox+ proposal for {{PRACTICE_NAME}} — customized',
    body:'Dr. {{LAST_NAME}},\n\nAttached is the customized revenue and payback proposal we discussed, built using the patient volume numbers {{PM_NAME}} shared.\n\nHeadline:\n  \u2022 Year-1 revenue projection: {{Y1_REV}}\n  \u2022 Device breakeven: approximately {{BREAKEVEN_DATE}}\n  \u2022 Year-5 cumulative: {{Y5_REV}}\n  \u2022 Financing options included (no-interest, operating lease, and Section 179 purchase)\n\nTwo things to flag:\n\n  1. All figures are based on the National Medicare/Medicaid average. Your actual payor mix may drive this higher or lower.\n  2. Section 179 allows the full purchase price to be deducted in year one. If that applies to {{PRACTICE_NAME}}, your accountant will want to weigh in on timing.\n\nI\'d like to close the loop with a 20-minute call on {{PROPOSED_DATE}}. Fair?\n\n{{SIGNATURE}}',
    note:'Purpose: deliver the customized ROI with decision-ready framing. Always propose the next call with a specific date.' },

  { id:'peer-ref', cat:'Credibility', title:'Peer reference introduction',
    sub:'When they want to talk to a current user',
    subject:'Introducing you to Dr. {{REF_DOCTOR}} — MiniBox+ user',
    body:'Dr. {{LAST_NAME}},\n\nAs requested, connecting you with Dr. {{REF_DOCTOR}} at {{REF_PRACTICE}} — one of the practices running MiniBox+ in a setting similar to yours.\n\nDr. {{REF_DOCTOR}} has agreed to take a 15-minute phone or video call. Good topics to cover:\n\n  \u2022 Workflow reality \u2014 how does it actually fit into a patient visit?\n  \u2022 Staff training and who runs it day-to-day\n  \u2022 Billing experience \u2014 which codes, any denial patterns\n  \u2022 Anything they wish they had known before buying\n\nCc\'d both of you. Dr. {{REF_DOCTOR}} — thank you again for being willing to help.\n\n{{SIGNATURE}}',
    note:'Purpose: nothing sells equipment like a peer. Have 2-3 reference physicians warmed up in advance. Never surprise a reference.' },

  { id:'quiet-followup', cat:'Reviving a Stall', title:'Quiet-account gentle revive',
    sub:'7-10 days after no response',
    subject:'Still here when you are, Dr. {{LAST_NAME}}',
    body:'Dr. {{LAST_NAME}},\n\nI know things move fast in clinic, so wanted to surface this gently.\n\nWe last spoke about bringing MiniBox+ into {{PRACTICE_NAME}} around {{LAST_MEETING}}. No pressure — just want to make sure the ball is still in my court, not stuck in yours.\n\nThree possible paths forward. Which sounds closest?\n\n  1. "I\'m still interested, just buried." \u2014 let me know a timeline and I\'ll circle back then.\n  2. "I have specific questions that haven\'t been answered." \u2014 tell me what they are and I\'ll get you a written answer by end of week.\n  3. "We decided not to move forward." \u2014 completely fine. If you can share what tipped the decision, it helps me be better next time.\n\nWhichever it is, I\'ll respect it.\n\n{{SIGNATURE}}',
    note:'Purpose: 3-option gentle revive. Pulls response rate 3-4x higher than a standard "just following up" email.' },

  { id:'closing-nudge', cat:'Closing', title:'Decision-week closing nudge',
    sub:'When the promised close date arrives',
    subject:'Partner meeting this week — anything I can help with?',
    body:'Dr. {{LAST_NAME}},\n\n{{PM_NAME}} mentioned the partner meeting is {{DAY}}. Two quick offers:\n\n  1. If any clinical or financial question comes up, call or text me in the moment. I\'ll get you an answer in minutes, not hours.\n  2. If it helps, I can be on standby to join by phone for the MiniBox+ portion. Five minutes, just so nobody has to re-explain the ROI.\n\nEither way, rooting for you. Let me know how it lands.\n\n{{SIGNATURE}}',
    note:'Purpose: be present at the decisive moment without being pushy. Often what separates the rep who wins from the rep who waits.' },

  { id:'final-nudge', cat:'Reviving a Stall', title:'The real "final" email',
    sub:'After 3-4 unanswered follow-ups',
    subject:'Closing your file, Dr. {{LAST_NAME}}',
    body:'Dr. {{LAST_NAME}},\n\nThis is the last email I\'ll send on this unless you want me to keep going.\n\nI\'m assuming the timing just isn\'t right. I\'m going to close the file and stop crowding your inbox. That\'s the right thing to do.\n\nIf anything changes — new location, new partner, a patient that really needs in-office PFT — my number is below. No hard feelings in either direction.\n\nGood luck with everything.\n\n{{SIGNATURE}}',
    note:'Purpose: the real final email. Often triggers a response from someone who genuinely got busy. Don\'t fake it \u2014 be willing to actually close the file if they ignore this too.' },

  { id:'training-confirm', cat:'Post-Sale', title:'Training day confirmation',
    sub:'After PO signed, day before training',
    subject:'MiniBox+ training tomorrow at {{PRACTICE_NAME}}',
    body:'Hi {{PM_NAME}},\n\nTomorrow, {{DATE}} at {{TIME}}, we\'re set for the full MiniBox+ install and training at {{PRACTICE_NAME}}.\n\nPlan (approximately 2.5 hours total):\n\n  1. Install & calibration (30 min)\n  2. 6-button workflow walkthrough with the staff running it (45 min)\n  3. Live patient practice \u2014 FVC, LVM, DLCO on volunteers (45 min)\n  4. Billing office 15-minute briefing on CPT documentation\n  5. Q&A, wrap\n\nRecommended attendees: {{MA_NAMES}}, {{RT_NAME}}, {{BILLER_NAME}}.\n\nNo prep required on your side. Let me know if the room, outlet, or gas cylinder location needs last-minute coordination.\n\n{{SIGNATURE}}',
    note:'Purpose: set training day up for success. Over-communicate so the practice feels in control.' },

  { id:'post-install', cat:'Post-Sale', title:'30-day post-install check-in',
    sub:'One month after first billed patient',
    subject:'How is month one going with MiniBox+?',
    body:'Dr. {{LAST_NAME}},\n\nWe\'re at about 30 days since your first MiniBox+ patient. Quick check-in:\n\n  \u2022 How is the workflow landing with {{MA_NAME}} and the team?\n  \u2022 Any billing or reimbursement patterns we should look at together?\n  \u2022 Any patient types where you want a coaching refresher?\n  \u2022 Any features you have questions about that we didn\'t cover in training?\n\nIf it would help, I can swing by for a 20-minute tune-up visit \u2014 no charge, just part of the program. Most practices find one hour in month two accelerates utilization significantly.\n\n{{SIGNATURE}}',
    note:'Purpose: early post-sale contact is the #1 driver of referrals and second-unit purchases. Don\'t wait 90 days.' },

  { id:'referral-ask', cat:'Post-Sale', title:'Referral ask — happy customer',
    sub:'60-90 days in, after a positive experience',
    subject:'A small ask, Dr. {{LAST_NAME}}',
    body:'Dr. {{LAST_NAME}},\n\nSince MiniBox+ went live at {{PRACTICE_NAME}}, you\'ve gone from zero to {{PFT_COUNT}} PFTs per month \u2014 fantastic work by your team.\n\nA small ask if you\'re willing: are there any colleagues \u2014 former fellows, classmates, partners from prior practices \u2014 you think would benefit from a conversation?\n\nI\'m happy to take it from there; you don\'t need to do anything more than the intro. And if you\'d prefer not to \u2014 completely fine, no ask is worth the friction.\n\nThank you either way.\n\n{{SIGNATURE}}',
    note:'Purpose: turn happy customer into pipeline. Always give them an easy out.' }
];

var currentElTmpl = null;
var currentElIdx  = -1;
var currentElCustom = { subject:null, body:null }; // edited in-place values

function renderElList() {
  var list = document.getElementById('el-list');
  if (!list) return;
  list.innerHTML = '';
  EL_TEMPLATES.forEach(function(t, idx) {
    var el = document.createElement('div');
    el.className = 'email-item';
    el.onclick = function() { selectElTemplate(idx); };
    el.innerHTML =
      '<div class="email-item-cat">' + t.cat + '</div>' +
      '<div class="email-item-title">' + t.title + '</div>' +
      '<div class="email-item-sub">' + t.sub + '</div>';
    list.appendChild(el);
  });
}

function selectElTemplate(idx) {
  var t = EL_TEMPLATES[idx];
  if (!t) return;
  currentElTmpl = t;
  currentElIdx = idx;
  currentElCustom = { subject:null, body:null };
  document.querySelectorAll('#el-list .email-item').forEach(function(el, i) {
    el.classList.toggle('active', i === idx);
  });
  renderElPreview();
}

function renderElPreview() {
  if (!currentElTmpl) return;
  var t = currentElTmpl;
  var subject = currentElCustom.subject != null ? currentElCustom.subject : applyProfileMerges(t.subject);
  var body    = currentElCustom.body    != null ? currentElCustom.body    : applyProfileMerges(t.body);
  document.getElementById('el-preview-title').textContent = t.title;
  var highlight = function(s) {
    // highlight remaining merge fields
    return escapeHTML(s).replace(/\{\{([A-Z_0-9]+)\}\}/g, '<span class="merge">{{$1}}</span>');
  };
  document.getElementById('el-preview-body').innerHTML =
    '<div class="email-field email-to-row">' +
      '<div><div class="email-field-lbl">To</div><input class="email-field-input" id="el-to" name="to-email" type="email" autocomplete="email" list="mbx-emails" onchange="mbxRememberEmail(this.value)" placeholder="doctor@practice.com"></div>' +
      '<div><div class="email-field-lbl">Cc (optional)</div><input class="email-field-input" id="el-cc" name="cc-email" type="email" autocomplete="email" list="mbx-emails" onchange="mbxRememberEmail(this.value)" placeholder=""></div>' +
    '</div>' +
    '<div class="email-field">' +
      '<div class="email-field-lbl">Subject</div>' +
      '<input class="email-field-input" id="el-subject" type="text" value="' + escapeAttr(subject) + '" oninput="elSubjectEdit()">' +
    '</div>' +
    '<div class="email-field">' +
      '<div class="email-field-lbl">Body &mdash; yellow = still needs filling, tap to edit</div>' +
      '<div class="email-body-wrap" id="el-body" contenteditable="true" oninput="elBodyEdit()">' + highlight(body).replace(/\n/g,'<br>') + '</div>' +
    '</div>' +
    '<div class="email-send-row">' +
      '<button class="email-btn email-btn-owa" onclick="elSendOWA()" title="Most reliable for Microsoft 365 \u2014 opens compose window signed in as your M365 user">&#127760; Send via Outlook Web <span style="opacity:.85;font-weight:400;">(recommended)</span></button>' +
      '<button class="email-btn email-btn-copypaste" onclick="elCopyAndOpenOutlook()" title="Copies full email to clipboard and opens a blank Outlook window \u2014 paste with Ctrl+V. Bulletproof fallback.">&#128203;&#10145; Copy &amp; Open Blank Outlook</button>' +
      '<button class="email-btn email-btn-outlook" onclick="elSendMailto()" title="Uses mailto: \u2014 will open your DEFAULT Outlook account. If that\'s not you, see the Profile setup help.">&#128231; Send via Outlook Desktop</button>' +
      '<button class="email-btn email-btn-copy" onclick="elCopyBody()">&#128196; Copy Body Only</button>' +
    '</div>' +
    '<div class="email-note" style="border-left-color:var(--amber);background:#fff7e6;"><strong>&#9888; If your email body disappears:</strong> Outlook Desktop opened the draft on the wrong account and switching the From dropdown wiped it. Two fixes &mdash; (1) use the blue <em>Outlook Web</em> button above, it always composes as whoever is signed into outlook.office.com; or (2) open <em>My Rep Profile</em> in the header and follow the one-time Outlook Desktop setup to change your default account.</div>' +
    '<div class="email-note"><strong>When to use this template:</strong> ' + t.note + '</div>';
}

function escapeHTML(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function escapeAttr(s) { return escapeHTML(s); }

function elSubjectEdit() {
  currentElCustom.subject = document.getElementById('el-subject').value;
}
function elBodyEdit() {
  // pull text from contenteditable, preserve line breaks
  var el = document.getElementById('el-body');
  if (!el) return;
  var html = el.innerHTML;
  // convert <br>, <div>, <p> back to \n
  html = html.replace(/<br\s*\/?>/gi, '\n');
  html = html.replace(/<\/(div|p)>/gi, '\n').replace(/<(div|p)[^>]*>/gi, '');
  // strip remaining tags
  var tmp = document.createElement('div'); tmp.innerHTML = html;
  var text = tmp.textContent || tmp.innerText || '';
  currentElCustom.body = text;
}

function elResetTemplate() {
  currentElCustom = { subject:null, body:null };
  renderElPreview();
  elToast('Template reset');
}

function elGetCurrentTo() {
  var el = document.getElementById('el-to');
  return el ? el.value.trim() : '';
}
function elGetCurrentCc() {
  var el = document.getElementById('el-cc');
  return el ? el.value.trim() : '';
}
function elGetCurrentSubject() {
  if (currentElCustom.subject != null) return currentElCustom.subject;
  var el = document.getElementById('el-subject');
  return el ? el.value : '';
}
function elGetCurrentBody() {
  if (currentElCustom.body != null) return currentElCustom.body;
  // read from DOM in case user edited
  elBodyEdit();
  return currentElCustom.body != null ? currentElCustom.body : applyProfileMerges(currentElTmpl.body);
}

function elSendMailto() {
  if (!currentElTmpl) { elToast('Pick a template first'); return; }
  var to      = elGetCurrentTo();
  var cc      = elGetCurrentCc();
  var subject = elGetCurrentSubject();
  var body    = elGetCurrentBody();
  var url = 'mailto:' + encodeURIComponent(to)
          + '?subject=' + encodeURIComponent(subject)
          + '&body='    + encodeURIComponent(body);
  if (cc) url += '&cc=' + encodeURIComponent(cc);
  window.location.href = url;
}

function elSendOWA() {
  if (!currentElTmpl) { elToast('Pick a template first'); return; }
  var to      = elGetCurrentTo();
  var cc      = elGetCurrentCc();
  var subject = elGetCurrentSubject();
  var body    = elGetCurrentBody();
  // Outlook on the Web deeplink (Microsoft 365). Opens compose window in new tab.
  var url = 'https://outlook.office.com/mail/deeplink/compose?'
          + 'to=' + encodeURIComponent(to)
          + '&subject=' + encodeURIComponent(subject)
          + '&body='    + encodeURIComponent(body);
  if (cc) url += '&cc=' + encodeURIComponent(cc);
  window.open(url, '_blank', 'noopener');
}

function elCopyBody() {
  if (!currentElTmpl) { elToast('Pick a template first'); return; }
  elCopyToClipboard(elGetCurrentBody());
  elToast('Body copied');
}
function elCopyAll() {
  if (!currentElTmpl) { elToast('Pick a template first'); return; }
  var combined = 'Subject: ' + elGetCurrentSubject() + '\n\n' + elGetCurrentBody();
  elCopyToClipboard(combined);
  elToast('Subject + body copied');
}

/* Copy everything AND open a blank Outlook window. User pastes with Ctrl+V.
   Bulletproof against the "wrong FROM account loses body" Outlook bug. */
function elCopyAndOpenOutlook() {
  if (!currentElTmpl) { elToast('Pick a template first'); return; }
  var to      = elGetCurrentTo();
  var cc      = elGetCurrentCc();
  var subject = elGetCurrentSubject();
  var body    = elGetCurrentBody();
  // Rich clipboard format: Subject on first line, body below, To/CC notes for manual paste
  var parts = [];
  if (to)      parts.push('To: ' + to);
  if (cc)      parts.push('Cc: ' + cc);
  parts.push('Subject: ' + subject);
  parts.push('');
  parts.push(body);
  var full = parts.join('\n');
  elCopyToClipboard(full);
  elToast('Copied! Opening Outlook... press Ctrl+V to paste.');
  // Open blank Outlook compose so user can switch account first, then paste
  setTimeout(function() {
    window.location.href = 'mailto:';
  }, 400);
}

function elCopyToClipboard(text) {
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).catch(function() { elLegacyCopy(text); });
  } else {
    elLegacyCopy(text);
  }
}
function elLegacyCopy(text) {
  var ta = document.createElement('textarea');
  ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
  document.body.appendChild(ta); ta.select();
  try { document.execCommand('copy'); } catch(e) {}
  document.body.removeChild(ta);
}

function elToast(msg, ms) {
  var t = document.getElementById('el-toast');
  if (!t) return;
  t.textContent = msg || 'Done';
  t.classList.add('show');
  clearTimeout(elToast._t);
  elToast._t = setTimeout(function() { t.classList.remove('show'); }, ms || 1800);
}

/* ---- INIT REP PROFILE + LIBRARY ---- */
(function initEmailLibrary() {
  try { loadProfile(); } catch(e) {}
  try { renderElList(); selectElTemplate(0); } catch(e) {}
})();

</script>

<!-- REP PROFILE MODAL -->
<div id="profile-modal" onclick="if(event.target===this)closeProfile()">
  <div class="pm-card">
    <div class="pm-hdr">
      <div>
        <div class="pm-hdr-title">&#128100; My Rep Profile</div>
        <div class="pm-hdr-sub">Saved to this device only. Used to auto-sign email templates.</div>
      </div>
      <button class="pm-close" onclick="closeProfile()">&#10005;</button>
    </div>
    <div class="pm-body">
      <div class="pm-help">
        <strong>Why fill this in?</strong> Every email template in the Email Library will auto-sign with your name, title, email, and direct line. Saves you a minute on every send. Stored locally on this device &mdash; nothing leaves your browser.
      </div>
      <div class="pm-row pm-row-2">
        <div>
          <div class="pm-lbl">Full name</div>
          <input class="pm-inp" id="pm-name" type="text" placeholder="[Rep Name]">
        </div>
        <div>
          <div class="pm-lbl">Title</div>
          <input class="pm-inp" id="pm-title" type="text" placeholder="Territory Sales Manager">
        </div>
      </div>
      <div class="pm-row pm-row-2">
        <div>
          <div class="pm-lbl">Work email</div>
          <input class="pm-inp" id="pm-email" type="email" placeholder="_______@pulm-one.com">
        </div>
        <div>
          <div class="pm-lbl">Direct / mobile</div>
          <input class="pm-inp" id="pm-mobile" type="text" placeholder="(555) 555-5555">
        </div>
      </div>
      <div class="pm-row">
        <div class="pm-lbl">Company (shown in signature)</div>
        <input class="pm-inp" id="pm-company" type="text" value="PulmOne USA">
      </div>
      <div style="margin-top:18px; border-top:1.5px dashed var(--gray-300); padding-top:14px; font-size:12.5px; color:#374151; line-height:1.65;">
        &#127760; <strong>How sending works:</strong> every send button opens Outlook signed in as you, with the email text on your clipboard &mdash; press <strong>Ctrl+V</strong> in the message and your Outlook signature stays at the bottom. This profile fills in your name, title, and direct line wherever a template mentions you.
      </div>

    </div>
    <div class="pm-save-row">
      <button class="pm-btn pm-btn-secondary" onclick="clearProfile()">Clear</button>
      <button class="pm-btn pm-btn-secondary" onclick="closeProfile()">Cancel</button>
      <button class="pm-btn pm-btn-primary" onclick="saveProfile()">Save profile</button>
    </div>
  </div>
</div>

<div id="el-toast">Saved</div>

<!-- CUSTOM TEMPLATE EDITOR MODAL -->
<div id="tpl-modal" onclick="if(event.target===this)closeTemplateEditor()">
  <div class="tm-card">
    <div class="tm-hdr">
      <div>
        <div class="tm-hdr-title" id="tm-hdr-title">&#43; New Email Template</div>
        <div class="tm-hdr-sub">Saved to this device only. Merge fields like <code>{{LAST_NAME}}</code> and <code>{{SIGNATURE}}</code> auto-fill from your profile.</div>
      </div>
      <button class="tm-close" onclick="closeTemplateEditor()">&#10005;</button>
    </div>
    <div class="tm-body">

      <div class="tm-row">
        <div class="tm-import-zone" id="tm-import-zone" onclick="document.getElementById('tm-file').click()">
          <strong>&#128194; Import from file</strong>
          <div>Click or drag &amp; drop a <strong>.txt</strong>, <strong>.md</strong>, <strong>.eml</strong>, <strong>.html</strong>, or <strong>.docx</strong> file to load it as a template</div>
          <input type="file" id="tm-file" accept=".txt,.md,.eml,.html,.htm,.docx,text/plain,message/rfc822" style="display:none" onchange="importTemplateFile(event)">
        </div>
      </div>

      <div class="tm-row tm-row-2">
        <div>
          <div class="tm-lbl">Category</div>
          <input class="tm-inp" id="tm-cat" type="text" placeholder="e.g. My Templates">
        </div>
        <div>
          <div class="tm-lbl">Title</div>
          <input class="tm-inp" id="tm-title" type="text" placeholder="e.g. My intro email to pulmonologists">
        </div>
      </div>

      <div class="tm-row">
        <div class="tm-lbl">Short description (when to use this)</div>
        <input class="tm-inp" id="tm-sub" type="text" placeholder="e.g. First contact with a new pulm practice">
      </div>

      <div class="tm-row">
        <div class="tm-lbl">Subject line</div>
        <input class="tm-inp" id="tm-subject" type="text" placeholder="e.g. Quick note about in-office PFT, Dr. {{LAST_NAME}}">
      </div>

      <div class="tm-row">
        <div class="tm-lbl">Body (use {{MERGE_FIELDS}} for auto-fill)</div>
        <textarea class="tm-ta" id="tm-body" placeholder="Dear Dr. {{LAST_NAME}},&#10;&#10;Your email body here...&#10;&#10;{{SIGNATURE}}"></textarea>
      </div>

      <div class="tm-row">
        <div class="tm-lbl">Note (optional, your reminder to yourself)</div>
        <input class="tm-inp" id="tm-note" type="text" placeholder="e.g. Use only for first touch, never for follow-ups">
      </div>

      <div class="tm-help">
        <strong>Merge fields that auto-fill from your profile:</strong><br>
        <code>{{YOUR_NAME}}</code> &middot; <code>{{YOUR_TITLE}}</code> &middot; <code>{{YOUR_EMAIL}}</code> &middot; <code>{{YOUR_MOBILE}}</code> &middot; <code>{{YOUR_COMPANY}}</code> &middot; <code>{{SIGNATURE}}</code> (full 5-line block)<br>
        <strong>Manual fields</strong> &mdash; anything else in <code>{{CURLY_BRACES}}</code> shows up highlighted yellow for you to fill per-email (e.g. <code>{{LAST_NAME}}</code>, <code>{{PRACTICE_NAME}}</code>).
      </div>

    </div>
    <div class="tm-save-row">
      <button class="tm-btn tm-btn-danger" id="tm-delete-btn" onclick="deleteCustomTemplate()" style="display:none;">&#128465; Delete</button>
      <div style="display:flex; gap:10px; margin-left:auto;">
        <button class="tm-btn tm-btn-secondary" onclick="closeTemplateEditor()">Cancel</button>
        <button class="tm-btn tm-btn-primary" onclick="saveTemplateEdit()">Save Template</button>
      </div>
    </div>
  </div>
</div>

<script>
/* ============================================================
   CUSTOM TEMPLATES — import, create, edit, delete, bundle share
   ============================================================ */
var CUSTOM_TEMPLATES = [];
var editingTmplId = null; // null = new; else id of existing custom template

function loadCustomTemplates() {
  try {
    var raw = localStorage.getItem('pulmone_custom_templates');
    if (raw) {
      var arr = JSON.parse(raw);
      if (Array.isArray(arr)) CUSTOM_TEMPLATES = arr;
    }
  } catch(e) { CUSTOM_TEMPLATES = []; }
}
function saveCustomTemplates() {
  try { localStorage.setItem('pulmone_custom_templates', JSON.stringify(CUSTOM_TEMPLATES)); } catch(e) {}
}
function genTmplId() {
  return 'custom-' + Date.now().toString(36) + '-' + Math.random().toString(36).slice(2,7);
}

/* EDITOR MODAL */
function openTemplateEditor(id) {
  editingTmplId = id;
  var tmpl = null;
  if (id) tmpl = CUSTOM_TEMPLATES.find(function(t){ return t.id === id; });
  document.getElementById('tm-hdr-title').innerHTML = tmpl ? '&#9998; Edit Template' : '&#43; New Email Template';
  document.getElementById('tm-cat').value     = tmpl ? (tmpl.cat     || 'My Templates') : 'My Templates';
  document.getElementById('tm-title').value   = tmpl ? (tmpl.title   || '') : '';
  document.getElementById('tm-sub').value     = tmpl ? (tmpl.sub     || '') : '';
  document.getElementById('tm-subject').value = tmpl ? (tmpl.subject || '') : '';
  document.getElementById('tm-body').value    = tmpl ? (tmpl.body    || '') : '';
  document.getElementById('tm-note').value    = tmpl ? (tmpl.note    || '') : '';
  document.getElementById('tm-delete-btn').style.display = tmpl ? 'inline-block' : 'none';
  document.getElementById('tpl-modal').classList.add('open');
}
function closeTemplateEditor() {
  document.getElementById('tpl-modal').classList.remove('open');
  editingTmplId = null;
}

function saveTemplateEdit() {
  var cat     = document.getElementById('tm-cat').value.trim() || 'My Templates';
  var title   = document.getElementById('tm-title').value.trim();
  var sub     = document.getElementById('tm-sub').value.trim();
  var subject = document.getElementById('tm-subject').value.trim();
  var body    = document.getElementById('tm-body').value;
  var note    = document.getElementById('tm-note').value.trim() || 'Custom template saved to this device.';

  if (!title) { elToast('Give your template a title'); return; }
  if (!subject && !body) { elToast('Add a subject or body first'); return; }

  if (editingTmplId) {
    var idx = CUSTOM_TEMPLATES.findIndex(function(t){ return t.id === editingTmplId; });
    if (idx > -1) {
      CUSTOM_TEMPLATES[idx] = { id: editingTmplId, cat:cat, title:title, sub:sub, subject:subject, body:body, note:note, custom:true };
    }
  } else {
    CUSTOM_TEMPLATES.push({ id: genTmplId(), cat:cat, title:title, sub:sub, subject:subject, body:body, note:note, custom:true });
  }
  saveCustomTemplates();
  closeTemplateEditor();
  renderElList();
  // Keep current selection if still valid; otherwise select what was just saved
  var combined = getCombinedTemplates();
  var targetIdx = combined.findIndex(function(t){
    return editingTmplId ? t.id === editingTmplId
                         : t.title === title && t.subject === subject;
  });
  if (targetIdx > -1) selectElTemplate(targetIdx);
  elToast(editingTmplId ? 'Template updated' : 'Template saved');
}

function deleteCustomTemplate() {
  if (!editingTmplId) return;
  if (!confirm('Delete this template? This cannot be undone.')) return;
  CUSTOM_TEMPLATES = CUSTOM_TEMPLATES.filter(function(t){ return t.id !== editingTmplId; });
  saveCustomTemplates();
  closeTemplateEditor();
  renderElList();
  selectElTemplate(0);
  elToast('Template deleted');
}

/* FILE IMPORT */
function importTemplateFile(evt) {
  var file = evt.target.files && evt.target.files[0];
  if (!file) return;
  var name = file.name || '';
  var ext = name.split('.').pop().toLowerCase();
  if (ext === 'docx') {
    parseDocxFile(file);
  } else {
    var reader = new FileReader();
    reader.onload = function(e) {
      var text = e.target.result || '';
      if (ext === 'html' || ext === 'htm') {
        text = htmlToPlainText(text);
      } else if (ext === 'eml') {
        text = parseEmlText(text);
      }
      fillEditorFromText(text, name.replace(/\.[^.]+$/,''));
    };
    reader.readAsText(file);
  }
  // Reset so same file can be re-imported
  evt.target.value = '';
}

function fillEditorFromText(raw, fallbackTitle) {
  if (!raw) { elToast('File was empty'); return; }
  // Parse "Subject:" line if present at top
  var subject = '';
  var body = raw;
  var lines = raw.split(/\r?\n/);
  for (var i = 0; i < Math.min(lines.length, 5); i++) {
    var m = lines[i].match(/^\s*subject\s*:\s*(.+)$/i);
    if (m) {
      subject = m[1].trim();
      // Body = everything after that line + any blank lines
      lines.splice(0, i+1);
      while (lines.length && !lines[0].trim()) lines.shift();
      body = lines.join('\n');
      break;
    }
  }
  // If no explicit subject found, try first non-empty line as subject if short
  if (!subject) {
    var firstLine = (lines.find(function(l){ return l.trim(); }) || '').trim();
    if (firstLine && firstLine.length < 100 && lines.length > 3) {
      subject = firstLine;
    }
  }
  document.getElementById('tm-subject').value = subject;
  document.getElementById('tm-body').value = body;
  if (!document.getElementById('tm-title').value) {
    document.getElementById('tm-title').value = fallbackTitle || 'Imported template';
  }
  elToast('File loaded &mdash; review and save');
}

function htmlToPlainText(html) {
  var tmp = document.createElement('div');
  // Strip <style>, <script>
  tmp.innerHTML = html.replace(/<style[^>]*>[\s\S]*?<\/style>/gi, '')
                      .replace(/<script[^>]*>[\s\S]*?<\/script>/gi, '')
                      .replace(/<br\s*\/?>/gi, '\n')
                      .replace(/<\/(p|div|h[1-6]|li)>/gi, '\n')
                      .replace(/<[^>]+>/g, '');
  return (tmp.textContent || tmp.innerText || '').replace(/\n{3,}/g, '\n\n').trim();
}

function parseEmlText(txt) {
  // Very simple EML: headers, blank line, body
  var idx = txt.indexOf('\r\n\r\n');
  if (idx < 0) idx = txt.indexOf('\n\n');
  if (idx < 0) return txt;
  var headers = txt.slice(0, idx);
  var body = txt.slice(idx).replace(/^\s+/, '');
  var subjMatch = headers.match(/^Subject:\s*(.+)$/im);
  var out = '';
  if (subjMatch) out += 'Subject: ' + subjMatch[1].trim() + '\n\n';
  out += body;
  return out;
}

function parseDocxFile(file) {
  // Dynamically load mammoth.js from CDN to extract docx text
  if (window.mammoth) return extractDocx(file);
  var s = document.createElement('script');
  s.src = 'https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js';
  s.onload = function() { extractDocx(file); };
  s.onerror = function() {
    alert('Could not load .docx parser.\n\nWorkaround: open the file in Word, copy the text, and paste it into the Body field below.');
  };
  document.head.appendChild(s);
}
function extractDocx(file) {
  var reader = new FileReader();
  reader.onload = function(e) {
    window.mammoth.extractRawText({ arrayBuffer: e.target.result })
      .then(function(result) {
        fillEditorFromText(result.value, file.name.replace(/\.[^.]+$/,''));
      })
      .catch(function(err) {
        alert('Could not read this .docx file. Try saving it as .txt in Word first.');
      });
  };
  reader.readAsArrayBuffer(file);
}

/* DRAG & DROP for import zone */
(function initDropZone() {
  document.addEventListener('DOMContentLoaded', function(){});
  // Attach when modal opens
  setTimeout(function() {
    var zone = document.getElementById('tm-import-zone');
    if (!zone) return;
    ['dragover','dragenter'].forEach(function(ev){
      zone.addEventListener(ev, function(e){ e.preventDefault(); zone.classList.add('drag'); });
    });
    ['dragleave','drop'].forEach(function(ev){
      zone.addEventListener(ev, function(e){ e.preventDefault(); zone.classList.remove('drag'); });
    });
    zone.addEventListener('drop', function(e) {
      var f = e.dataTransfer.files && e.dataTransfer.files[0];
      if (f) {
        var fake = { target: { files: [f], value: '' } };
        importTemplateFile(fake);
      }
    });
  }, 300);
})();

/* BUNDLE EXPORT / IMPORT */
function exportMyLibrary() {
  if (!CUSTOM_TEMPLATES.length) { elToast('No custom templates to export yet'); return; }
  var blob = new Blob([JSON.stringify(CUSTOM_TEMPLATES, null, 2)], { type: 'application/json' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  var stamp = new Date().toISOString().slice(0,10);
  a.href = url; a.download = 'pulmone-email-templates-' + stamp + '.json';
  document.body.appendChild(a); a.click();
  setTimeout(function(){ document.body.removeChild(a); URL.revokeObjectURL(url); }, 1000);
  elToast('Exported ' + CUSTOM_TEMPLATES.length + ' template(s)');
}
function importMyLibrary(evt) {
  var file = evt.target.files && evt.target.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = function(e) {
    try {
      var arr = JSON.parse(e.target.result);
      if (!Array.isArray(arr)) throw new Error('Expected an array');
      var added = 0;
      arr.forEach(function(t) {
        if (!t || typeof t !== 'object') return;
        if (!t.title || !t.body) return;
        CUSTOM_TEMPLATES.push({
          id: genTmplId(),
          cat:     (t.cat     || 'Imported'),
          title:   t.title,
          sub:     (t.sub     || ''),
          subject: (t.subject || ''),
          body:    t.body,
          note:    (t.note    || 'Imported from bundle'),
          custom:  true
        });
        added++;
      });
      saveCustomTemplates();
      renderElList();
      elToast('Imported ' + added + ' template(s)');
    } catch(err) {
      alert('That file could not be parsed. Expected a JSON export from this tool.');
    }
  };
  reader.readAsText(file);
  evt.target.value = '';
}

/* INTEGRATE CUSTOM TEMPLATES INTO THE LIBRARY */
function getCombinedTemplates() {
  // Built-ins first, then custom
  return (typeof EL_TEMPLATES !== 'undefined' ? EL_TEMPLATES.slice() : []).concat(CUSTOM_TEMPLATES);
}

// Override renderElList + selectElTemplate to work off combined list
(function wrapListFunctions() {
  if (typeof renderElList !== 'function') return;
  window.renderElList = function() {
    var list = document.getElementById('el-list');
    if (!list) return;
    list.innerHTML = '';
    var all = getCombinedTemplates();
    all.forEach(function(t, idx) {
      var el = document.createElement('div');
      el.className = 'email-item' + (t.custom ? ' is-custom' : '');
      el.onclick = function(ev) {
        if (ev.target.classList && ev.target.classList.contains('email-item-action')) return;
        selectElTemplate(idx);
      };
      var titleHtml = t.title + (t.custom ? '<span class="email-item-custom-badge">My</span>' : '');
      var actions = t.custom
        ? '<div class="email-item-actions">' +
            '<button class="email-item-action" onclick="event.stopPropagation();openTemplateEditor(\'' + t.id + '\')">&#9998; Edit</button>' +
          '</div>'
        : '';
      el.innerHTML =
        '<div class="email-item-cat">' + (t.cat || '') + '</div>' +
        '<div class="email-item-title">' + titleHtml + '</div>' +
        '<div class="email-item-sub">' + (t.sub || '') + '</div>' +
        actions;
      list.appendChild(el);
    });
  };

  window.selectElTemplate = function(idx) {
    var all = getCombinedTemplates();
    var t = all[idx];
    if (!t) return;
    currentElTmpl = t;
    currentElIdx = idx;
    currentElCustom = { subject:null, body:null };
    document.querySelectorAll('#el-list .email-item').forEach(function(el, i) {
      el.classList.toggle('active', i === idx);
    });
    renderElPreview();
  };
})();


/* EMAIL ASSEMBLY STATION v2.17 */
var easEmailType = "intro";

function easToggle(wrapper) {
  var isOn = wrapper.getAttribute("data-on") === "1";
  isOn = !isOn;
  wrapper.setAttribute("data-on", isOn ? "1" : "0");
  wrapper.classList.toggle("on", isOn);
  wrapper.querySelector(".eas-toggle-dot").textContent = isOn ? "✓" : "";
}

function easToggleStudies(wrapper) {
  easToggle(wrapper);
  var isOn = wrapper.getAttribute("data-on") === "1";
  document.getElementById("eas-studies-panel").classList.toggle("open", isOn);
}

function easSetType(btn, type) {
  easEmailType = type;
  document.querySelectorAll(".eas-type-btn").forEach(function(b) { b.classList.remove("active"); });
  btn.classList.add("active");
}

function easIsOn(item) {
  var el = document.querySelector(".eas-toggle[data-item='" + item + "']");
  return el && el.getAttribute("data-on") === "1";
}

function easBuildEmail() {
  var doctor   = document.getElementById("eas-doctor").value.trim()   || "[Doctor Name]";
  var practice = document.getElementById("eas-practice").value.trim() || "[Practice Name]";
  /* v2.27: pull rep + signature from the shared Rep Profile (falls back to the typed name) */
  var profileSet = (typeof REP_PROFILE !== 'undefined' && !!REP_PROFILE.name);
  var rep      = document.getElementById("eas-rep").value.trim() || (profileSet ? REP_PROFILE.name : "") || "[Your Name]";

  var has = {
    roi:      easIsOn("roi"),
    clinical: easIsOn("clinical"),
    cpt:      easIsOn("cpt"),
    brochure: easIsOn("brochure"),
    ach:      easIsOn("ach"),
    finance:  easIsOn("finance")
  };

  if (!Object.values(has).some(Boolean)) {
    alert("Please select at least one material to include.");
    return;
  }

  var studies = [];
  ["st1","st2","st3","st4","st5"].forEach(function(id) {
    var cb = document.getElementById(id);
    if (cb && cb.checked) studies.push(cb.nextElementSibling.textContent.trim());
  });

  var subjects = {
    intro:    "MiniBox+ Resources for " + practice,
    postdemo: "Following Up on Our Meeting at " + practice,
    pricing:  "MiniBox+ Pricing and Materials for " + practice,
    checkin:  "Checking In and Sharing MiniBox+ Resources"
  };

  var greetings = {
    intro:    "I wanted to reach out and share some resources that give you a clear picture of how the MiniBox+ can benefit " + practice + ".",
    postdemo: "Thank you for the time today. It was great walking through what the MiniBox+ can do for " + practice + ". As promised, here is everything we discussed in one place.",
    pricing:  "Following up on our recent conversation. I have put together the pricing details alongside supporting materials so you have everything in one place.",
    checkin:  "I wanted to check in and make sure you have everything you need to evaluate the MiniBox+ for " + practice + "."
  };

  var closings = {
    intro:    "I would love to set up a quick call or demo at your convenience. Please let me know what works best for you and your team.",
    postdemo: "Please do not hesitate to reach out with any questions. I will follow up in a few days, but feel free to reach out directly at any time.",
    pricing:  "If you would like to discuss any of the pricing details or explore financing options, I am happy to connect at your convenience.",
    checkin:  "I am happy to answer any questions or schedule a follow-up demo. Just let me know how I can help."
  };

  var lines = [];
  var checklistItems = [];

  if (has.roi) {
    lines.push("ROI Calculator and Revenue Projection\nThis document shows how many PFT sessions per week it takes to fully offset the cost of the device based on current Medicare reimbursement rates. Most practices reach break even in under 12 months.");
    checklistItems.push("Print or export the ROI Calculator with this practice's weekly volume filled in");
  }

  if (has.clinical) {
    if (studies.length > 0) {
      lines.push("Clinical Evidence\nI have included the following peer reviewed studies for your review:\n• " + studies.join("\n• "));
      checklistItems.push("Pull PDFs for each selected clinical study");
    } else {
      lines.push("Clinical Evidence\nKey peer reviewed studies supporting in office PFT testing and COPD management.");
      checklistItems.push("Pull relevant clinical study PDFs");
    }
  }

  if (has.cpt) {
    lines.push("CPT Reimbursement Reference Sheet\nA full breakdown of CPT codes 94010, 94060, 94375, 94726, and 94729 with current average reimbursement rates so you can see the revenue potential per test.");
    checklistItems.push("Attach the CPT Reimbursement Sheet PDF");
  }

  if (has.brochure) {
    lines.push("MiniBox+ Product Brochure\nSpecs, workflow overview, connectivity options, and EHR integration details.");
    checklistItems.push("Attach the MiniBox+ product brochure");
  }

  if (has.finance) {
    lines.push("Financing and Lease Options\nFlexible payment structures including 12, 24, and 36 month plans sized to keep the monthly cost below the device revenue it generates each month.");
    checklistItems.push("Attach the current financing options sheet");
  }

  if (has.ach) {
    lines.push("ACH Authorization Form\nFor practices ready to move forward, this is the payment authorization form to get your account set up.");
    checklistItems.push("Print and pre-fill the ACH Authorization Form with practice name and address");
  }

  var numberedLines = lines.map(function(line, i) {
    return (i + 1) + ". " + line;
  }).join("\n\n");

  var body = "Dear " + doctor + ",\n\n"
    + (greetings[easEmailType] || greetings.intro)
    + "\n\nPlease find the following materials attached to this email:\n\n"
    + numberedLines
    + "\n\n"
    + (closings[easEmailType] || closings.intro)
    + "\n\nBest regards,\n"
    + (profileSet ? buildSignature() : rep + "\nPulmOne USA");

  document.getElementById("eas-out-subject").textContent = subjects[easEmailType] || subjects.intro;
  document.getElementById("eas-out-body").textContent    = body;

  var ul = document.getElementById("eas-checklist-items");
  ul.innerHTML = checklistItems.map(function(item) {
    return "<li>" + item + "</li>";
  }).join("");

  var out = document.getElementById("eas-output");
  out.classList.add("show");
  setTimeout(function() { out.scrollIntoView({ behavior: "smooth", block: "start" }); }, 50);
}

function easCopy() {
  var body = document.getElementById("eas-out-body").textContent;
  navigator.clipboard.writeText(body).then(function() {
    var btn = document.querySelector(".eas-copy-btn");
    var orig = btn.innerHTML;
    btn.textContent = "✓ Copied!";
    btn.style.background = "#27ae60";
    setTimeout(function() { btn.innerHTML = orig; btn.style.background = ""; }, 2200);
  });
}

function easGetTo() {
  var el = document.getElementById("eas-email");
  return el ? el.value.trim() : "";
}
function easOpenOutlook() {
  var to = encodeURIComponent(easGetTo());
  var s = encodeURIComponent(document.getElementById("eas-out-subject").textContent);
  var b = encodeURIComponent(document.getElementById("eas-out-body").textContent);
  window.open("https://outlook.office.com/mail/deeplink/compose?to=" + to + "&subject=" + s + "&body=" + b, "_blank", "noopener");
}
function easSendMailto() {
  var to = encodeURIComponent(easGetTo());
  var s = encodeURIComponent(document.getElementById("eas-out-subject").textContent);
  var b = encodeURIComponent(document.getElementById("eas-out-body").textContent);
  window.location.href = "mailto:" + to + "?subject=" + s + "&body=" + b;
}

/* v2.27: keep the EAS rep name + "auto-signs as" note in sync with the shared Rep Profile */
function easSyncProfile() {
  if (typeof REP_PROFILE === 'undefined') return;
  var repField = document.getElementById("eas-rep");
  if (repField && !repField.value.trim() && REP_PROFILE.name) repField.value = REP_PROFILE.name;
  var sa = document.getElementById("eas-signed-as");
  if (sa) sa.textContent = REP_PROFILE.name
    ? ("✓ Auto-signs as " + REP_PROFILE.name + (REP_PROFILE.title ? (", " + REP_PROFILE.title) : ""))
    : "No profile set — set My Rep Profile in the header to auto-sign every email.";
}

/* INIT */
(function initCustomTemplates() {
  loadCustomTemplates();
  if (typeof renderElList === 'function') { renderElList(); selectElTemplate(0); }
  try { easSyncProfile(); } catch(e) {}
})();
</script>

<script>
/* ============================================================
   v2.27 ADD-ONS: rate stamping, Save Practice, global search,
   PDF leave-behind. Lives in its own block; relies on globals
   already defined above (MINIBOX_RATES, getCalcValues, roiCalc,
   fmtShort, escapeHTML, showTab, openROIFullscreen).
   ============================================================ */

/* ---- #1 SINGLE SOURCE OF TRUTH: paint rates onto the page ---- */
function renderRates() {
  if (typeof MINIBOX_RATES === 'undefined') return;
  var money = function(n){ return '$' + Number(n).toFixed(2); };
  var maxEl = document.getElementById('rate-complete-pft');
  if (maxEl) maxEl.textContent = money(MINIBOX_RATES.completePFT);
  document.querySelectorAll('[data-cpt-rate]').forEach(function(el){
    var code = el.getAttribute('data-cpt-rate');
    if (MINIBOX_RATES.cpt[code]) el.textContent = money(MINIBOX_RATES.cpt[code].rate);
  });
  document.querySelectorAll('.rates-asof').forEach(function(el){
    el.textContent = MINIBOX_RATES.asOf;
  });
}

/* ---- #2 SAVE PRACTICE (this device only) ---- */
var SAVED_PRACTICES_KEY = 'minibox_saved_practices';
function loadSavedPractices() {
  try { var a = JSON.parse(localStorage.getItem(SAVED_PRACTICES_KEY) || '[]'); return Array.isArray(a) ? a : []; }
  catch(e) { return []; }
}
function storeSavedPractices(arr) {
  try { localStorage.setItem(SAVED_PRACTICES_KEY, JSON.stringify(arr)); } catch(e) {}
}
function savePractice() {
  var nameEl = document.getElementById('sp-name');
  var name = nameEl ? nameEl.value.trim() : '';
  if (!name) { alert('Enter a practice name first.'); if (nameEl) nameEl.focus(); return; }
  var doctor = (document.getElementById('sp-doctor') || {}).value || '';
  doctor = doctor.trim();
  var tests  = parseInt(document.getElementById('roi-slider').value) || 25;
  var device = parseFloat(document.getElementById('roi-device-cost').value) || 30000;
  var v = getCalcValues(tests, device);
  var arr = loadSavedPractices();
  arr.unshift({
    name: name, doctor: doctor, tests: tests, device: device,
    y1: v.y1, breakeven: v.dateStr, savedOn: new Date().toLocaleDateString()
  });
  storeSavedPractices(arr);
  nameEl.value = ''; if (document.getElementById('sp-doctor')) document.getElementById('sp-doctor').value = '';
  renderSavedPractices();
}
function renderSavedPractices() {
  var wrap = document.getElementById('sp-list');
  if (!wrap) return;
  var arr = loadSavedPractices();
  if (!arr.length) {
    wrap.innerHTML = '<div style="font-size:12.5px; color:var(--gray-600); padding:6px 0;">No saved practices yet. Set the numbers above, add a name, and tap Save.</div>';
    return;
  }
  wrap.innerHTML = arr.map(function(p, i) {
    var docBit = p.doctor ? (' <span style="font-weight:400; color:var(--gray-600);">&middot; ' + escapeHTML(p.doctor) + '</span>') : '';
    return '<div class="sp-item">' +
      '<div class="sp-item-main">' +
        '<div class="sp-item-name">' + escapeHTML(p.name) + docBit + '</div>' +
        '<div class="sp-item-sub">' + p.tests + ' PFTs/wk &middot; ' + fmtShort(p.y1) + ' Year 1 &middot; breakeven ' + escapeHTML(p.breakeven) + ' &middot; saved ' + escapeHTML(p.savedOn) + '</div>' +
      '</div>' +
      '<div class="sp-item-actions">' +
        '<button onclick="loadPractice(' + i + ')">Load</button>' +
        '<button class="sp-del" onclick="deletePractice(' + i + ')">Delete</button>' +
      '</div>' +
    '</div>';
  }).join('');
}
function loadPractice(i) {
  var arr = loadSavedPractices(); var p = arr[i]; if (!p) return;
  document.getElementById('roi-slider').value = p.tests;
  document.getElementById('roi-device-cost').value = p.device;
  if (document.getElementById('sp-name'))   document.getElementById('sp-name').value = p.name;
  if (document.getElementById('sp-doctor')) document.getElementById('sp-doctor').value = p.doctor || '';
  if (typeof roiCalc === 'function') roiCalc();
  var wrap = document.querySelector('.roi-calc-wrap');
  if (wrap) wrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
}
function deletePractice(i) {
  if (!confirm('Remove this saved practice?')) return;
  var arr = loadSavedPractices(); arr.splice(i, 1); storeSavedPractices(arr); renderSavedPractices();
}

/* ---- #6 PDF LEAVE-BEHIND: print the clean full-screen ROI view ---- */
function printROILeaveBehind() {
  if (typeof openROIFullscreen === 'function') openROIFullscreen();
  document.body.classList.add('printing-roi');
  setTimeout(function() {
    window.print();
    document.body.classList.remove('printing-roi');
    if (typeof closeROIFullscreen === 'function') closeROIFullscreen();
  }, 400);
}

/* ---- #3 GLOBAL SEARCH across every tab ---- */
var SEARCH_TABS = [];
function buildSearchIndex() {
  SEARCH_TABS = [];
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    var m = (btn.getAttribute('onclick') || '').match(/showTab\('([^']+)'/);
    if (m) SEARCH_TABS.push({ id: m[1], label: btn.textContent.trim() });
  });
}
function globalSearch(q) {
  var box = document.getElementById('global-search-results');
  if (!box) return;
  q = (q || '').trim();
  if (q.length < 2) { box.classList.remove('show'); box.innerHTML = ''; return; }
  if (!SEARCH_TABS.length) buildSearchIndex();
  var lcq = q.toLowerCase();

  /* --- attachments / forms first: find the actual files (W-9, ACH, brochure…) --- */
  var matHtml = '';
  try {
    if (typeof m3SearchMaterials === 'function') {
      var mats = m3SearchMaterials(q);
      if (mats.length) {
        matHtml = '<div class="gs-section-label">&#128206; Attachments &amp; forms</div>' +
          mats.map(function(m) {
            var act = (typeof m3IsViewable === 'function' && m3IsViewable(m.file)) ? '&#128065; Open' : '&#11015; Download';
            var size = (typeof m3SizeLabel === 'function') ? m3SizeLabel(m.kb) : (m.kb + ' KB');
            return '<div class="gs-result gs-mat">' +
              '<div class="gs-mat-main" onclick="m3SearchOpen(\'' + m.id + '\')">' +
                '<div class="gs-result-tab">' + escapeHTML(m.title) + '<span class="gs-count">' + size + '</span></div>' +
                '<div class="gs-result-snip">' + escapeHTML(m.sub || '') + '</div>' +
              '</div>' +
              '<div class="gs-mat-btns">' +
                '<button onclick="m3SearchOpen(\'' + m.id + '\')">' + act + '</button>' +
                (m.noembed ? '' : '<button onclick="m3SearchEmail(\'' + m.id + '\')">&#9993; Email it</button>') +
              '</div>' +
            '</div>';
          }).join('');
      }
    }
  } catch (e) {}

  var results = [];
  SEARCH_TABS.forEach(function(t) {
    var panel = document.getElementById('tab-' + t.id);
    if (!panel) return;
    var text = (panel.textContent || '').replace(/\s+/g, ' ');
    var lc = text.toLowerCase();
    var idx = lc.indexOf(lcq);
    if (idx === -1) return;
    var start = Math.max(0, idx - 40);
    var snip = (start > 0 ? '…' : '') + text.slice(start, idx + q.length + 70).trim() + '…';
    var count = 0, p = 0;
    while ((p = lc.indexOf(lcq, p)) > -1) { count++; p += lcq.length; }
    results.push({ id: t.id, label: t.label, snip: snip, count: count });
  });
  if (!results.length && !matHtml) {
    box.innerHTML = '<div class="gs-empty">No matches for &ldquo;' + escapeHTML(q) + '&rdquo;.</div>';
    box.classList.add('show');
    return;
  }
  results.sort(function(a, b) { return b.count - a.count; });
  var tabHtml = results.map(function(r) {
    return '<div class="gs-result" onclick="goToSearchResult(\'' + r.id + '\',\'' + encodeURIComponent(q) + '\')">' +
      '<div class="gs-result-tab">' + escapeHTML(r.label) + '<span class="gs-count">' + r.count + ' match' + (r.count > 1 ? 'es' : '') + '</span></div>' +
      '<div class="gs-result-snip">' + escapeHTML(r.snip) + '</div>' +
    '</div>';
  }).join('');
  var tabSection = results.length ? ('<div class="gs-section-label">&#128209; In the toolkit</div>' + tabHtml) : '';
  box.innerHTML = matHtml + tabSection;
  box.classList.add('show');
}
function goToSearchResult(id, q) {
  q = decodeURIComponent(q || '');
  var btn = null;
  document.querySelectorAll('.tab-btn').forEach(function(b) {
    if ((b.getAttribute('onclick') || '').indexOf("showTab('" + id + "'") > -1) btn = b;
  });
  if (btn && typeof showTab === 'function') showTab(id, btn);
  var box = document.getElementById('global-search-results'); if (box) box.classList.remove('show');
  var s = document.getElementById('global-search'); if (s) s.value = '';
  setTimeout(function() { highlightInPanel('tab-' + id, q); }, 70);
}
function clearHighlights() {
  document.querySelectorAll('mark.gs-mark').forEach(function(m) {
    var t = document.createTextNode(m.textContent);
    if (m.parentNode) m.parentNode.replaceChild(t, m);
  });
}
function highlightInPanel(panelId, q) {
  var panel = document.getElementById(panelId);
  if (!panel || !q) return;
  clearHighlights();
  var lcq = q.toLowerCase();
  var walker = document.createTreeWalker(panel, NodeFilter.SHOW_TEXT, null, false);
  var node, target = null;
  while ((node = walker.nextNode())) {
    var val = node.nodeValue || '';
    var i = val.toLowerCase().indexOf(lcq);
    if (i > -1 && node.parentNode && !/SCRIPT|STYLE/.test(node.parentNode.nodeName)) {
      var mark = document.createElement('mark'); mark.className = 'gs-mark'; mark.textContent = val.slice(i, i + q.length);
      var frag = document.createDocumentFragment();
      frag.appendChild(document.createTextNode(val.slice(0, i)));
      frag.appendChild(mark);
      frag.appendChild(document.createTextNode(val.slice(i + q.length)));
      node.parentNode.replaceChild(frag, node);
      target = mark; break;
    }
  }
  if (target) {
    target.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(clearHighlights, 4500);
  }
}
document.addEventListener('click', function(e) {
  var bar = document.getElementById('global-search');
  var box = document.getElementById('global-search-results');
  if (!bar || !box) return;
  if (e.target !== bar && !box.contains(e.target)) box.classList.remove('show');
});
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    var box = document.getElementById('global-search-results');
    if (box) box.classList.remove('show');
  }
});

/* ---- INIT all v2.27 add-ons ---- */
(function initV227() {
  try { renderRates(); } catch(e) {}
  try { renderSavedPractices(); } catch(e) {}
  try { buildSearchIndex(); } catch(e) {}
})();
</script>

<!-- ===================================================================
     TOOLKIT v3.0 — MATERIALS + REAL-ATTACHMENT EMAIL ENGINE
     materials-data.js holds base64 of every attachable PDF so the
     toolkit can produce genuine Outlook drafts online OR offline.
     =================================================================== -->
<style>
  .m3-cat-label { font-size:11px; font-weight:800; letter-spacing:.08em; text-transform:uppercase; color:var(--gray-600); margin:14px 0 6px; }
  .m3-cat-label:first-child { margin-top:0; }
  .m3-mat-row { display:flex; align-items:flex-start; gap:9px; padding:7px 10px; border:1px solid var(--gray-200); border-radius:8px; margin-bottom:6px; cursor:pointer; background:#fff; transition:border-color .12s, background .12s; }
  .m3-mat-row:hover { border-color:var(--blue-brand); }
  .m3-mat-row.on { border-color:var(--blue-brand); background:var(--blue-light); }
  .m3-mat-row input { margin-top:3px; accent-color:var(--blue-brand); }
  .m3-mat-title { font-size:13px; font-weight:600; color:var(--blue-dark); line-height:1.35; }
  .m3-mat-sub { font-size:11.5px; color:var(--gray-600); line-height:1.4; }
  .m3-kb { font-size:10.5px; font-weight:700; color:var(--gray-600); background:var(--gray-100); border-radius:5px; padding:1px 7px; margin-left:6px; white-space:nowrap; }
  .m3-send-help { font-size:12px; line-height:1.55; color:#1e3a5f; background:#eef4ff; border:1px solid #cfe0ff; border-radius:8px; padding:9px 12px; margin-top:10px; }
  .m3-reco { box-shadow:0 0 0 2.5px #16a34a, 0 4px 14px rgba(22,163,74,.35) !important; position:relative; }
  .m3-reco::after { content:'YOUR BEST OPTION'; position:absolute; top:-9px; right:8px; font-size:8.5px; font-weight:800; letter-spacing:.06em; background:#16a34a; color:#fff; border-radius:4px; padding:1.5px 6px; }
  .m3-lib-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(290px, 1fr)); gap:10px; }
  .m3-lib-card { border:1px solid var(--gray-200); border-radius:10px; padding:12px 14px; background:#fff; display:flex; flex-direction:column; gap:7px; }
  .m3-lib-title { font-size:13.5px; font-weight:700; color:var(--blue-dark); line-height:1.35; }
  .m3-lib-sub { font-size:11.5px; color:var(--gray-600); line-height:1.45; flex:1; }
  .m3-lib-btns { display:flex; gap:6px; flex-wrap:wrap; }
  .m3-lib-btns button { height:30px; padding:0 11px; border-radius:6px; border:1.5px solid var(--blue-brand); background:#fff; color:var(--blue-brand); font-family:'Inter',sans-serif; font-size:11.5px; font-weight:600; cursor:pointer; }
  .m3-lib-btns button:hover { background:var(--blue-light); }
  .m3-lib-btns button.m3-mail { border-color:#16a34a; color:#15803d; }
  .m3-lib-btns button.m3-mail:hover { background:#ecfdf5; }
  .m3-care { font-size:10.5px; font-weight:700; color:#b45309; background:#fff7e6; border:1px solid #fcd34d; border-radius:5px; padding:1px 7px; display:inline-block; }
  .m3-chips-row { display:flex; flex-wrap:wrap; gap:6px; align-items:center; margin:10px 0 2px; }
  .m3-chips-lbl { font-size:11.5px; font-weight:700; color:var(--gray-600); margin-right:2px; }
  .m3-chip { font-size:11.5px; font-weight:600; border:1.5px solid var(--gray-300); color:var(--gray-600); background:#fff; border-radius:999px; padding:4px 11px; cursor:pointer; user-select:none; transition:all .12s; }
  .m3-chip:hover { border-color:var(--blue-brand); color:var(--blue-brand); }
  .m3-chip.on { border-color:#16a34a; background:#ecfdf5; color:#15803d; }
  .m3-chip.on::before { content:'\2713  '; font-weight:800; }
  #m3-env-badge { cursor:default; }
  .m3-packs { display:flex; flex-wrap:wrap; gap:6px; align-items:center; margin-bottom:10px; padding:9px 10px; background:var(--gray-100); border-radius:8px; }
  .m3-pack-btn { font-size:11.5px; font-weight:700; border:1.5px solid var(--blue-brand); color:var(--blue-brand); background:#fff; border-radius:999px; padding:5px 13px; cursor:pointer; transition:all .12s; }
  .m3-pack-btn:hover { background:var(--blue-light); }
  .m3-pack-btn.m3-pack-clear { border-color:var(--gray-300); color:var(--gray-600); }
  #m3-welcome { display:none; position:fixed; inset:0; background:rgba(10,22,40,.72); z-index:10001; align-items:center; justify-content:center; padding:18px; }
  #m3-welcome.open { display:flex; }
  .m3w-card { background:#fff; border-radius:14px; max-width:480px; width:100%; padding:26px 26px 20px; box-shadow:0 24px 70px rgba(0,0,0,.4); font-family:'Inter',sans-serif; }
  .m3w-title { font-size:19px; font-weight:800; color:var(--blue-dark); margin-bottom:4px; }
  .m3w-sub { font-size:13px; color:var(--gray-600); line-height:1.55; margin-bottom:16px; }
  .m3w-lbl { font-size:11.5px; font-weight:700; color:var(--gray-600); text-transform:uppercase; letter-spacing:.05em; margin:12px 0 5px; }
  .m3w-inp { width:100%; height:40px; border:1.5px solid var(--gray-300); border-radius:8px; padding:0 12px; font-family:'Inter',sans-serif; font-size:13.5px; box-sizing:border-box; }
  .m3w-inp:focus { outline:none; border-color:var(--blue-brand); }
  .m3w-ol { display:flex; gap:6px; flex-wrap:wrap; }
  .m3w-ol button { flex:1 1 auto; height:38px; border:1.5px solid var(--gray-300); border-radius:8px; background:#fff; color:#374151; font-family:'Inter',sans-serif; font-size:12px; font-weight:600; cursor:pointer; }
  .m3w-ol button.on { border-color:var(--blue-brand); background:var(--blue-light); color:var(--blue-brand); }
  .m3w-actions { display:flex; gap:8px; justify-content:flex-end; margin-top:20px; }
  .m3w-actions .m3w-skip { background:none; border:none; color:var(--gray-600); font-size:12.5px; cursor:pointer; font-family:'Inter',sans-serif; }
  .m3w-actions .m3w-go { height:40px; padding:0 22px; border:none; border-radius:8px; background:var(--blue-brand); color:#fff; font-family:'Inter',sans-serif; font-size:13.5px; font-weight:700; cursor:pointer; }
  .m3w-actions .m3w-go:hover { filter:brightness(1.08); }
</style>
