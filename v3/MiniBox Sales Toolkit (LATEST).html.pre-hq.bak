  {id:'w9',          file:'PulmOne-W9.pdf',                       title:'PulmOne W-9',                         sub:'For vendor setup',                                        cat:'closing',  kb:609,  blurb:'PulmOne W-9 — for your vendor setup.'},
  {id:'bank',        file:'PulmOne-Bank-Information.pdf',         title:'PulmOne Bank Information',            sub:'For payment setup',                                       cat:'closing',  kb:148,  care:true, blurb:'PulmOne Bank Information — for payment setup.'},
  {id:'achpdf',      file:'ACH-Payment-Authorization.pdf',        title:'ACH Payment Authorization Form',      sub:'For practices ready to move forward',                     cat:'closing',  kb:286,  care:true, blurb:'ACH Payment Authorization Form — the payment authorization to get your account set up.'},
  // ---- Rheumatology Playbook (from Rheum Playbook.zip) ----
  {id:'rh-slick',     file:'01_Rheumatology_Play_Segment_Slick.pdf',     title:'The Rheumatology Play — Segment Slick',    sub:'2-page field guide — read before every rheum call',        cat:'rheum', kb:113,  blurb:'The Rheumatology Play (Segment Slick) — the two-page field guide: why rheumatology, the four discovery questions, the objections, the CPT bundle, and financing.'},
  {id:'rh-fieldref',  file:'02_MiniBox_Rheumatology_Field_Reference.docx',title:'MiniBox+ Rheumatology Field Reference',   sub:'Deep clinical detail — DMARDs, biologics, financing',       cat:'rheum', kb:18,   blurb:'MiniBox+ Rheumatology Field Reference — the deep version: the clinical argument, DMARDs & biologics explained, objections, and the full financing menu.'},
  {id:'rh-deck',      file:'03_PFT_Rheumatology_Clinic_Training.pptx',   title:'PFT in Rheumatology — Clinic Training Deck',sub:'19-slide staff training to send post-sale',               cat:'rheum', kb:91,   blurb:'PFT in Rheumatology — Clinic Training Deck: customer-facing training that walks the clinic staff through PFT testing for connective-tissue-disease patients.'},
  {id:'rh-guideline', file:'04_ACR_CHEST_ILD_Guideline_2023.pdf',        title:'2023 ACR/CHEST ILD Guideline',            sub:'The primary peer-reviewed source',                         cat:'rheum', kb:1294, blurb:'2023 ACR/CHEST ILD Guideline — the primary peer-reviewed source naming PFTs for ILD screening and monitoring in systemic autoimmune rheumatic diseases.'},
  {id:'rh-pico',      file:'05_ACR_CHEST_PICO_Questions_Appendix.pdf',   title:'ACR/CHEST PICO Questions (Appendix 2)',   sub:'The 24 evidence questions behind the guideline',           cat:'rheum', kb:119,  blurb:'ACR/CHEST PICO Questions — the 24 evidence questions behind the guideline recommendations, for when a rheumatologist asks how rigorous the guideline is.'},
  {id:'rh-factsheet', file:'06_RA_ILD_Patient_Fact_Sheet_PFF.pdf',       title:'RA-ILD Patient Fact Sheet (PFF)',         sub:'Plain-language patient handout',                           cat:'rheum', kb:56,   blurb:'RA-ILD Patient Fact Sheet — the Pulmonary Fibrosis Foundation’s plain-language handout on RA-ILD: symptoms, diagnosis, and prognosis.'},
  {id:'rh-emails',    file:'07_Email_Templates_Sales_Call_Guide.docx',   title:'Rheum Email Templates & Call Guide',      sub:"The post-discovery email + call prep checklist",               cat:'rheum', kb:30,   blurb:'Rheumatology Email Templates & Sales Call Guide — the actual post-discovery email, a blank template to adapt, plus a call-prep checklist and follow-up framework.'},
  {id:'cardio-onepager', file:'Cardiology-Complete-PFT-Clinical-Billing.pdf', title:'Pulmonary Function in the Cardiology Clinic', sub:'Clinical case + DLCO + billing — verified, sourced one-pager', cat:'cardio', kb:16, blurb:'Pulmonary Function in the Cardiology Clinic — a one-page, fully-sourced summary: dyspnea differentiation, heart failure vs COPD, peri-procedural risk, the DLCO / full-PFT argument, and the complete-PFT billing breakdown.'},
  {id:'al-getpaid', file:'Allergy_Will_You_Get_Paid_Reference.pdf', title:'Allergy & Asthma — Will You Get Paid?', sub:'2025 coverage, frequency & CPT/ICD-10 quick reference', cat:'allergy', kb:82, blurb:'PFTs in Allergy & Asthma — Will You Get Paid? The coverage, frequency and payment quick reference for an allergy practice: which CPT codes (94010/94060/94726/94729) insurers pay, how often, the ICD-10 pairings by asthma type and symptom, and the one charting habit (ICD-10 + rationale + modifier 25) that gets the claim paid.'},
  // ---- Interactive Calculators & Tools (self-contained HTML — the recipient opens and uses them live, works offline) ----
  {id:'calc-rheum',     file:'Rheumatology-PFT-Estimator.html',   title:'Rheumatology PFT Estimator',        sub:'Interactive — their own PFT volume & revenue by diagnosis, symptom & drug-monitoring',  cat:'calc', kb:42, blurb:'Rheumatology PFT Estimator — an interactive tool the practice opens in their browser: enter patient counts by qualifying diagnosis, weekly symptom flow, and drug-monitoring scenario, and it shows their annual PFT volume and revenue with the exact CPT/ICD codes for each.'},
  {id:'calc-interp',    file:'PFT-Interpretation-Composer.html', title:'PFT Interpretation Composer',       sub:'Interactive &mdash; the physician types the six numbers, ATS/ERS logic classifies the pattern and drafts a signature-ready interpretation', cat:'calc', kb:57, blurb:'PFT Interpretation Composer — an interactive drafting aid the practice opens in their browser: type the numbers off the MiniBox+ report, the same ATS/ERS decision tree classifies the pattern, and a signature-ready draft interpretation appears for the physician to review, edit and sign. Works offline; nothing typed into it is saved or sent anywhere.'},
  {id:'calc-pft-coding',file:'How-to-Code-a-PFT.html',            title:'How to Code a PFT (Billing Helper)',sub:'Interactive — step-by-step CPT/ICD coding for a practice new to PFT billing',            cat:'calc', kb:100, blurb:'How to Code a PFT — the interactive Billing Helper that walks a practice that has never billed PFTs before through the exact codes, step by step: which CPT codes to use, how to pair them, and what each pays.'},
  {id:'calc-roi',       file:'MiniBox-ROI-Calculator.html',       title:'ROI / Revenue Calculator',          sub:'Interactive — they plug in daily volume, see annual PFT revenue',                        cat:'calc', kb:48, blurb:'ROI / Revenue Calculator — an interactive tool the practice opens in their browser: enter daily patient volume and see the annual revenue a MiniBox+ generates through fully reimbursable CPT codes.'},
  {id:'aging-assess',   file:'MiniBox-Plus-Aging-Device-Assessment.html', title:'Aging Device Assessment',   sub:'Interactive — log a unit’s failure patterns by severity, then generate the customer outreach email', cat:'calc', kb:41, blurb:'MiniBox+ Aging Device Assessment — an interactive tool the rep opens live: record an aging unit’s condition across the DLCO gas system, occluder valve and tablet / control unit, flag issues by severity, see the device-lifetime percentage, and auto-generate a customer outreach email that opens the upgrade conversation. The working companion to the End-of-Life Letter.'},
  // ---- Training Videos (play in-app; too large to email — Play / Download only) ----
  {id:'vid-spiro-cal',  file:'Spirometry-Calibration-Check.mp4', title:'Spirometry Calibration Check', sub:'How to run the spirometry (volume) calibration check on the MiniBox+',                      cat:'video', kb:1672,  noembed:true, vgroup:'cal', blurb:''},
  {id:'vid-dlco-cal',   file:'DLCO-Calibration.mp4', title:'DLCO Calibration', sub:'How to run the DLCO calibration on the MiniBox+',                                                cat:'video', kb:2116,  noembed:true, vgroup:'cal', blurb:''},
  {id:'vid-fvc',        file:'Spirometry-FVC-Patient-Test.mp4', title:'Spirometry (FVC) — Patient Test', sub:'How to run a spirometry / FVC patient test on the MiniBox+',                              cat:'video', kb:3988,  noembed:true, blurb:''},
  {id:'vid-lvm',        file:'LVM-Lung-Volume-Measurement-Test.mp4', title:'LVM — Lung Volume Measurement Patient Test', sub:'How to run a Lung Volume Measurement test on the MiniBox+',                           cat:'video', kb:4540,  noembed:true, blurb:''},
  {id:'vid-dlco',       file:'DLCO-Diffusion-Test.mp4',           title:'DLCO (Diffusion) — Test Walkthrough', sub:'How to run a DLCO diffusion test on the MiniBox+',                                       cat:'video', kb:10296, noembed:true, blurb:''}
];
var M3_CATS = { send:'📤 Core send-pack', calc:'🧮 Calculators & Tools', training:'🎓 Training & Coaching', video:'🎬 Training Videos', clinical:'🔬 Clinical evidence', tech:'🖥 IT & technical', closing:'🤝 Closing & payment', rheum:'🦴 Rheumatology Playbook', cardio:'❤️ Cardiology', allergy:'🌿 Allergy & Asthma' };
var M3_CAT_ORDER = ['send','calc','training','video','clinical','tech','closing','rheum','cardio','allergy'];

/* ============ ATTACHMENT / MATERIALS SEARCH ============
   Lets the global search bar FIND the actual files (W-9, ACH, brochure, studies…).
   Each material carries extra keyword aliases so short, real-world searches hit —
   e.g. "w9" finds "PulmOne W-9" even though the title has a hyphen. */
var M3_MAT_ALIASES = {
  brochure:   'brochure spec specs datasheet sell sheet one pager product info',
  why:        'why minibox overview one pager onepager summary the case',
  samplereport:'sample pft report example results printout what the doctor sees',
  comparison: 'competitive comparison versus vs competitor competition body box bodybox bodyplethysmography',
  chestsum:   'chest 2021 study summary validation evidence 700 patients',
  chestfull:  'chest 2021 full article study paper peer reviewed publication',
  verona:     'verona study italy italian clinical evidence published',
  coaching:   'pft coaching sheet patient guide technician tech how to test train training coach maneuver fvc lvm dlco blast out nose clip mouthpiece breath hold green wheel tidal breaths chairside cheat sheet two sided front back',
  dlco:       'dlco gas requirements diffusion capacity on site',
  hl7:        'hl7 conformance statement interface integration ehr emr it information technology',
  mds2:       'mds2 cybersecurity security statement it information technology hipaa',
  manual:     'user manual rev 20 rev20 instructions guide documentation',
  certificate:'manufacturer certificate certification official approval',
  financing:  'financing finance application loan lease gfs payment plan monthly terms 12 24 36 month',
  w9:         'w9 w-9 w 9 tax taxpayer ein irs vendor setup form taxid tin',
  bank:       'bank banking wire routing account number payment setup remittance',
  achpdf:     'ach ach form payment authorization bank draft autopay direct debit',
  eolletter:  'eol end of life endoflife letter notice notification discontinued old minibox 2016 service ends july 2026 upgrade trade in trade-in avi lazar official',
  'aging-concerns':'aging device unit concerns end of life eol failure patterns dlco gas valve occluder tablet battery old 10 year lifetime upgrade trade in worn out breaking down',
  'rh-slick':    'rheumatology rheum play segment slick field guide discovery objections cpt',
  'rh-fieldref': 'rheumatology rheum field reference dmards biologics financing clinical',
  'rh-deck':     'rheumatology rheum training deck slides clinic staff connective tissue',
  'rh-guideline':'rheumatology rheum acr chest ild guideline 2023 screening monitoring autoimmune',
  'rh-pico':     'rheumatology rheum pico questions appendix evidence guideline',
  'rh-factsheet':'rheumatology rheum ra ild patient fact sheet handout pff fibrosis',
  'rh-emails':   'rheumatology rheum email templates call guide  followup checklist',
  'calc-rheum':     'rheumatology rheum calculator estimator interactive tool pft revenue volume ild drug monitoring cpt icd diagnosis',
  'calc-interp':    'interpretation composer interp compose draft sign signature ats ers pattern zscore z-score lln restriction obstruction dlco gates rheumatology send tool interactive',
  'calc-pft-coding':'how to code pft coding calculator billing helper cpt icd 94010 94726 94729 never coded new to billing interactive tool spirometry',
  'calc-roi':       'roi revenue calculator interactive tool return on investment volume annual money payback',
  'aging-assess':   'aging device assessment interactive tool evaluate condition failure patterns severity dlco gas valve occluder tablet battery lifetime customer email outreach upgrade trade in eol end of life old unit worn breaking',
  'vid-dlco':        'dlco diffusion video training walkthrough how to run test single breath gas transfer coaching demo watch play',
  'vid-lvm':         'lvm lung volume measurement volumes test patient video training walkthrough plethysmography how to run demo watch play',
  'vid-spiro-cal':   'spirometry calibration check calibrate volume syringe 3 liter three liter daily qc quality video training walkthrough how to demo watch play',
  'vid-fvc':         'spirometry fvc forced vital capacity patient test flow volume loop maneuver video training walkthrough how to run demo watch play',
  'vid-dlco-cal':    'dlco calibration calibrate diffusion gas check daily qc quality video training walkthrough how to run demo watch play'
};
/* collapse to bare alphanumerics so "w-9" / "W 9" / "w9" all compare equal */
function m3SearchSquish(s){ return String(s || '').toLowerCase().replace(/[^a-z0-9]+/g, ''); }
function m3SearchMaterials(q){
  var sq = m3SearchSquish(q);
  if (sq.length < 2) return [];
  var out = [];
  MATERIALS.forEach(function(m){
    var hay = m3SearchSquish([m.title, m.sub, m.blurb, m.file, M3_MAT_ALIASES[m.id] || ''].join(' '));
    if (hay.indexOf(sq) > -1) out.push(m);
  });
  return out;
}
function m3SearchCloseBox(){
  var box = document.getElementById('global-search-results'); if (box) box.classList.remove('show');
  var s = document.getElementById('global-search'); if (s) s.value = '';
}
function m3SearchOpen(id){ m3SearchCloseBox(); try { m3View(id); } catch(e) {} }
function m3SearchEmail(id){ m3SearchCloseBox(); try { m3EmailThis(id); } catch(e) {} }
var M3_STATE = { easIds:[], elIds:[], elTmplTitle:null };

function m3ById(id){ for (var i=0;i<MATERIALS.length;i++) if (MATERIALS[i].id===id) return MATERIALS[i]; return null; }
function m3HasData(id){ return (typeof MATERIALS_B64 !== 'undefined') && !!MATERIALS_B64[id]; }
function m3IsHosted(){ return location.protocol === 'http:' || location.protocol === 'https:'; }
function m3Mime(file){
  var f = String(file || '').toLowerCase();
  if (f.indexOf('.pdf') >= 0)  return 'application/pdf';
  if (f.indexOf('.docx') >= 0) return 'application/vnd.openxmlformats-officedocument.wordprocessingml.document';
  if (f.indexOf('.pptx') >= 0) return 'application/vnd.openxmlformats-officedocument.presentationml.presentation';
  if (f.indexOf('.xlsx') >= 0) return 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet';
  if (f.indexOf('.html') >= 0 || f.indexOf('.htm') >= 0) return 'text/html';
  return 'application/octet-stream';
}
function m3IsViewable(file){ return /\.(pdf|html?)$/i.test(String(file || '')); }
function m3IsVideo(file){ return /\.(mp4|webm|mov|m4v)$/i.test(String(file || '')); }

function m3Blob(id){
  var m = m3ById(id);
  var b64 = MATERIALS_B64[id];
  var bin = atob(b64), len = bin.length, bytes = new Uint8Array(len);
  for (var i=0;i<len;i++) bytes[i] = bin.charCodeAt(i);
  return new Blob([bytes], {type: m3Mime(m ? m.file : '')});
}
function m3View(id){
  var m = m3ById(id); if (!m) return;
  if (m3IsVideo(m.file)) { m3PlayVideo(id); return; }
  // Word/PowerPoint can't render in a browser tab — download instead of opening a blank tab.
  if (!m3IsViewable(m.file)) { m3Download(id); return; }
  if (m3HasData(id)) {
    var url = URL.createObjectURL(m3Blob(id));
    window.open(url, '_blank');
    setTimeout(function(){ URL.revokeObjectURL(url); }, 60000);
  } else {
    window.open('materials/' + m.file, '_blank');
  }
}
function m3Download(id){
  var m = m3ById(id); if (!m) return;
  var a = document.createElement('a');
  if (m3HasData(id)) { a.href = URL.createObjectURL(m3Blob(id)); }
  else { a.href = 'materials/' + m.file; }
  a.download = m.file; a.style.display = 'none';
  document.body.appendChild(a); a.click();
  setTimeout(function(){ document.body.removeChild(a); if (a.href.indexOf('blob:')===0) URL.revokeObjectURL(a.href); }, 4000);
}
function m3DownloadMany(ids){
  ids.forEach(function(id, i){ setTimeout(function(){ m3Download(id); }, i * 450); });
}
function m3TotalKB(ids){ var t=0; ids.forEach(function(id){ var m=m3ById(id); if (m) t+=m.kb; }); return t; }
function m3SizeLabel(kb){ return kb >= 1000 ? (kb/1024).toFixed(1) + ' MB' : kb + ' KB'; }

/* ============ IN-APP VIDEO PLAYER ============ */
function m3VideoSrc(m){ return m3HasData(m.id) ? URL.createObjectURL(m3Blob(m.id)) : 'materials/' + m.file; }
function m3PlayVideo(id){
  var m = m3ById(id); if (!m) return;
  var src = m3VideoSrc(m);
  var ov = document.getElementById('m3-video-overlay');
  if (!ov){
    ov = document.createElement('div');
    ov.id = 'm3-video-overlay';
    ov.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(8,12,20,.92);display:flex;align-items:center;justify-content:center;padding:20px;';
    ov.addEventListener('click', function(e){ if (e.target === ov) m3CloseVideo(); });
    document.body.appendChild(ov);
  }
  ov.innerHTML =
    '<div style="width:100%;max-width:960px;">'
    + '<div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:10px;">'
    +   '<div style="color:#fff;font-weight:700;font-size:15px;">' + m.title + '</div>'
    +   '<button onclick="m3CloseVideo()" style="background:#e0342f;color:#fff;border:0;border-radius:8px;padding:8px 14px;font-weight:700;cursor:pointer;">&#10005; Close</button>'
    + '</div>'
    + '<video controls autoplay playsinline style="width:100%;max-height:78vh;border-radius:12px;background:#000;box-shadow:0 20px 60px rgba(0,0,0,.5);">'
    +   '<source src="' + src + '" type="video/mp4">Your browser can&rsquo;t play this video. '
    +   '<a href="' + src + '" download="' + m.file + '" style="color:#8ab4ff;">Download it instead.</a>'
    + '</video>'
    + '<div style="margin-top:10px;text-align:right;">'
    +   '<button onclick="m3Download(\'' + m.id + '\')" style="background:#1f2937;color:#fff;border:0;border-radius:8px;padding:8px 14px;font-weight:600;cursor:pointer;">&#11015; Download</button>'
    + '</div>'
    + '</div>';
  ov.style.display = 'flex';
  document.addEventListener('keydown', m3VideoEsc);
}
function m3CloseVideo(){
  var ov = document.getElementById('m3-video-overlay'); if (!ov) return;
  var v = ov.querySelector('video'); if (v){ try { v.pause(); } catch(_){} }
  ov.style.display = 'none'; ov.innerHTML = '';
  document.removeEventListener('keydown', m3VideoEsc);
}
function m3VideoEsc(e){ if (e.key === 'Escape') m3CloseVideo(); }

/* ============ .EML BUILDER — a real Outlook draft with real attachments ============ */
function m3Chunk76(b64){ var out=''; for (var i=0;i<b64.length;i+=76) out += b64.substring(i,i+76) + '\r\n'; return out; }
function m3B64Utf8(str){ return btoa(unescape(encodeURIComponent(str))); }
function m3BuildEml(opts){
  // opts: {to, cc, subject, body, ids, fileName}
  var boundary = '----=_MBX3_' + Date.now() + '_' + Math.random().toString(36).slice(2,10);
  var eml = '';
  eml += 'MIME-Version: 1.0\r\n';
  eml += 'X-Unsent: 1\r\n';
  if (opts.to) eml += 'To: ' + opts.to + '\r\n';
  if (opts.cc) eml += 'Cc: ' + opts.cc + '\r\n';
  var subjHdr = String(opts.subject || '');
  /* Outlook needs non-ASCII subjects (curly quotes, accents) RFC-2047 encoded */
  if (!/^[\x20-\x7E]*$/.test(subjHdr)) subjHdr = '=?utf-8?B?' + m3B64Utf8(subjHdr) + '?=';
  eml += 'Subject: ' + subjHdr + '\r\n';
  eml += 'Content-Type: multipart/mixed; boundary="' + boundary + '"\r\n\r\n';
  eml += '--' + boundary + '\r\n';
  eml += 'Content-Type: text/plain; charset=utf-8\r\n';
  eml += 'Content-Transfer-Encoding: base64\r\n\r\n';
  eml += m3Chunk76(m3B64Utf8(opts.body || '')) + '\r\n';
  (opts.ids || []).forEach(function(id){
    var m = m3ById(id);
    if (!m || !m3HasData(id)) return;
    eml += '--' + boundary + '\r\n';
    eml += 'Content-Type: ' + m3Mime(m.file) + '; name="' + m.file + '"\r\n';
    eml += 'Content-Transfer-Encoding: base64\r\n';
    eml += 'Content-Disposition: attachment; filename="' + m.file + '"\r\n\r\n';
    eml += m3Chunk76(MATERIALS_B64[id]) + '\r\n';
  });
  eml += '--' + boundary + '--\r\n';
  var name = (opts.fileName || 'PulmOne-Email').replace(/[^a-zA-Z0-9 _-]/g,'').replace(/\s+/g,'-').slice(0,60) + '.eml';
  var blob = new Blob([eml], {type:'message/rfc822'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url; a.download = name; a.style.display = 'none';
  document.body.appendChild(a); a.click();
  setTimeout(function(){ document.body.removeChild(a); URL.revokeObjectURL(url); }, 4000);
  return name;
}

/* ============ v3.22 DRAFT-FIRST SEND — attachments genuinely attached ============
   Every send-with-materials now packs the whole email (To/Cc/Subject/Body) plus
   the real files into ONE .eml draft. Opening that file in Outlook gives a
   ready-to-send email — nothing to drag. Some setups open .eml drafts read-only
   (certain New Outlook / web-only configs); the steps panel has a one-tap
   "drag-in way" switch that this device remembers (m3_send_pref), reversible
   from the drag panel's own footer link. */
function m3SendPref(){ try { return localStorage.getItem('m3_send_pref') || 'draft'; } catch(e){ return 'draft'; } }
function m3SetSendPref(p){ try { localStorage.setItem('m3_send_pref', p); } catch(e) {} }
/* v3.23 iPad/iPhone FIX — the .eml draft is a dead end on iOS: Safari downloads
   it to Files and Outlook/Mail can't open it as a draft, so the rep got an
   empty email and nowhere to go. Same share sheet the RMA/Service forms already
   use: hand the real file(s) to iOS and let the rep pick Outlook or Mail with
   everything genuinely attached. Body also goes on the clipboard because the
   share sheet drops long text on some iOS builds. Desktop is unchanged. */
function m3FilesFor(ids){
  var out = [];
  (ids || []).forEach(function(id){
    var m = m3ById(id);
    if (!m || !m3HasData(id)) return;
    try { out.push(new File([m3Blob(id)], m.file, {type: m3Mime(m.file)})); } catch(e){}
  });
  return out;
}
function m3CanShareFiles(files){
  try { return !!(navigator.share && navigator.canShare && files.length && navigator.canShare({files:files})); }
  catch(e){ return false; }
}
function m3AttachSend(opts){
  /* opts: {to, cc, subject, body, ids, fileName, dragFlow}
     dragFlow = the legacy compose+download+drag flow for this composer. */
  var ids = opts.ids || [];
  if (!ids.length || !m3EmlAvailable() || m3SendPref() === 'drag') { opts.dragFlow(); return; }
  var files = m3FilesFor(ids);
  if (m3CanShareFiles(files)) {
    try { elCopyToClipboard(opts.body || ''); } catch(e){}
    navigator.share({ files:files, title:(opts.subject || ''), text:(opts.body || '') })
      .then(function(){
        m3Toast('Pick Outlook or Mail — ' + (files.length > 1 ? 'all ' + files.length + ' files are' : 'the file is')
              + ' already attached. The email text is on your clipboard if you need to paste it.', 6000);
      })
      .catch(function(err){
        if (err && err.name === 'AbortError') return;   /* rep tapped Cancel */
        var nm = m3BuildEml({ to:opts.to, cc:opts.cc, subject:opts.subject, body:opts.body, ids:ids, fileName:opts.fileName });
        m3DraftSteps(nm, ids.length, opts);
      });
    return;
  }
  var name = m3BuildEml({ to:opts.to, cc:opts.cc, subject:opts.subject, body:opts.body, ids:ids, fileName:opts.fileName });
  m3DraftSteps(name, ids.length, opts);
}
function m3DraftSteps(fileName, n, opts){
  var old = document.getElementById('m3-send-steps');
  if (old && old.parentNode) old.parentNode.removeChild(old);
  var wrap = document.createElement('div');
  wrap.id = 'm3-send-steps';
  wrap.style.cssText = 'position:fixed; inset:0; background:rgba(15,23,42,.55); z-index:99999; display:flex; align-items:center; justify-content:center; padding:18px;';
  var safeName = String(fileName || '').replace(/&/g,'&amp;').replace(/</g,'&lt;');
  var card = document.createElement('div');
  card.style.cssText = 'background:#fff; border-radius:16px; max-width:540px; width:100%; padding:22px 24px; box-shadow:0 24px 60px rgba(0,0,0,.35); font-size:15px; line-height:1.55; color:#1f2937;';
  card.innerHTML =
    '<div style="font-size:18px; font-weight:800; margin-bottom:10px;">&#128230; Your email is packed &mdash; ' + n + ' attachment' + (n>1?'s':'') + ' already inside</div>'
    + '<div style="display:flex; gap:10px; margin:10px 0;"><div style="font-weight:800; color:#1d4ed8;">1.</div><div>Open the draft that just downloaded:<br><strong style="word-break:break-all;">' + safeName + '</strong><br><span style="font-size:13px; color:#6b7280;">Look behind the ⬇ download icon at the top of this window, or in your Downloads folder.</span></div></div>'
    + '<div style="display:flex; gap:10px; margin:10px 0;"><div style="font-weight:800; color:#1d4ed8;">2.</div><div>It opens in Outlook <strong>already addressed, written, and with every file attached</strong>. Give it a once-over and hit <strong>Send</strong>.</div></div>'
    + '<div style="display:flex; gap:10px; margin-top:16px; flex-wrap:wrap;">'
    + '<button id="m3-draft-again" style="flex:1; min-width:180px; padding:11px 14px; border:0; border-radius:10px; background:#eff6ff; color:#1d4ed8; font-weight:700; font-size:14px; cursor:pointer;">&#128230; Save the draft again</button>'
    + '<button id="m3-draft-done" style="flex:1; min-width:120px; padding:11px 14px; border:0; border-radius:10px; background:#16a34a; color:#fff; font-weight:800; font-size:14px; cursor:pointer;">&#10003; Got it</button>'
    + '</div>'
    + '<div style="margin-top:14px; padding-top:12px; border-top:1px solid #e5e7eb; font-size:13px; color:#6b7280;">Draft opens read-only, or no Send button? <a href="#" id="m3-draft-fallback" style="color:#1d4ed8; font-weight:700;">Use the drag-in way instead</a> &mdash; this device will remember.</div>';
  wrap.appendChild(card);
  document.body.appendChild(wrap);
  function close(){ if (wrap.parentNode) wrap.parentNode.removeChild(wrap); }
  document.getElementById('m3-draft-done').onclick = close;
  document.getElementById('m3-draft-again').onclick = function(){
    m3BuildEml({ to:opts.to, cc:opts.cc, subject:opts.subject, body:opts.body, ids:opts.ids, fileName:opts.fileName });
  };
  document.getElementById('m3-draft-fallback').onclick = function(ev){
    ev.preventDefault();
    m3SetSendPref('drag');
    try { m3RenderSendHelp('m3-eas-send-help'); m3RenderSendHelp('m3-el-send-help'); } catch(e) {}
    close();
    opts.dragFlow();
  };
  wrap.addEventListener('click', function(ev){ if (ev.target === wrap) close(); });
}

/* ===== Pure-JS ZIP (store mode) — bundle every selected PDF into ONE file so
   it rides into ANY Outlook (New, Web, or Classic) with a single drag. No
   library, works fully offline. PDFs are already compressed, so store = fine. ===== */
var M3_CRC_TABLE = (function(){
  var t = []; for (var n=0;n<256;n++){ var c=n; for (var k=0;k<8;k++){ c=(c&1)?(0xEDB88320^(c>>>1)):(c>>>1); } t[n]=c>>>0; } return t;
})();
function m3Crc32(bytes){
  var c = 0xFFFFFFFF;
  for (var i=0;i<bytes.length;i++){ c = M3_CRC_TABLE[(c ^ bytes[i]) & 0xFF] ^ (c >>> 8); }
  return (c ^ 0xFFFFFFFF) >>> 0;
}
function m3B64ToBytes(b64){
  var bin = atob(b64), len = bin.length, bytes = new Uint8Array(len);
  for (var i=0;i<len;i++) bytes[i] = bin.charCodeAt(i);
  return bytes;
}
function m3StrBytes(s){
  var b = new Uint8Array(s.length);
  for (var i=0;i<s.length;i++) b[i] = s.charCodeAt(i) & 0xFF;
  return b;
}
function m3BuildZip(ids){
  var files = [];
  (ids || []).forEach(function(id){
    var m = m3ById(id);
    if (m && m3HasData(id)) files.push({ name: m.file, data: m3B64ToBytes(MATERIALS_B64[id]) });
  });
  if (!files.length) return null;
  function u16(n){ return new Uint8Array([n & 0xFF, (n>>>8) & 0xFF]); }
  function u32(n){ return new Uint8Array([n & 0xFF, (n>>>8) & 0xFF, (n>>>16) & 0xFF, (n>>>24) & 0xFF]); }
  var local = [], central = [], offset = 0;
  files.forEach(function(f){
    var nameB = m3StrBytes(f.name), crc = m3Crc32(f.data), size = f.data.length;
    local.push(u32(0x04034b50), u16(20), u16(0), u16(0), u16(0), u16(0), u32(crc), u32(size), u32(size), u16(nameB.length), u16(0), nameB, f.data);
    central.push(u32(0x02014b50), u16(20), u16(20), u16(0), u16(0), u16(0), u16(0), u32(crc), u32(size), u32(size), u16(nameB.length), u16(0), u16(0), u16(0), u16(0), u32(0), u32(offset), nameB);
    offset += 30 + nameB.length + size;
  });
  var localSize = offset, centralSize = 0;
  central.forEach(function(p){ centralSize += p.length; });
  var eocd = [ u32(0x06054b50), u16(0), u16(0), u16(files.length), u16(files.length), u32(centralSize), u32(localSize), u16(0) ];
  return new Blob(local.concat(central).concat(eocd), { type: 'application/zip' });
}
function m3DownloadZip(ids, zipName){
  var blob = m3BuildZip(ids);
  if (!blob) { m3Toast('No materials selected to bundle.'); return false; }
  var name = (zipName || 'PulmOne-Materials').replace(/[^a-zA-Z0-9 _-]/g,'').replace(/\s+/g,'-').slice(0,60) + '.zip';
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob); a.download = name; a.style.display = 'none';
  document.body.appendChild(a); a.click();
  setTimeout(function(){ document.body.removeChild(a); URL.revokeObjectURL(a.href); }, 4000);
  return name;
}
function m3EasDownloadZip(){
  if (!M3_STATE.easIds.length) { m3Toast('Pick at least one file above first.'); return; }
  var practice = document.getElementById('eas-practice').value.trim();
  if (m3DownloadZip(M3_STATE.easIds, 'PulmOne-' + (practice || 'Materials'))) {
    m3Toast('All ' + M3_STATE.easIds.length + ' files saved as ONE .zip in your Downloads — open a new email to your contact and drag that single file in. Works in any Outlook.');
  }
}
function m3ElZip(){
  if (!M3_STATE.elIds.length) { m3Toast('Tap a 📎 material chip first.'); return; }
  if (m3DownloadZip(M3_STATE.elIds, 'PulmOne-' + (currentElTmpl ? currentElTmpl.title : 'Materials'))) {
    m3Toast('All ' + M3_STATE.elIds.length + ' files saved as ONE .zip — drag that single file into your email. Works in any Outlook.');
  }
}
function m3EmlAvailable(){ return typeof MATERIALS_B64 !== 'undefined'; }
function m3Toast(msg, ms){ try { elToast(msg, ms); } catch(e) { alert(msg); } }

/* Friendly guard: mailto/OWA links silently cut off long bodies. */
function m3GuardedMailto(to, cc, subject, body){
  var url = 'mailto:' + encodeURIComponent(to||'') + '?subject=' + encodeURIComponent(subject||'') + '&body=' + encodeURIComponent(body||'');
  if (cc) url += '&cc=' + encodeURIComponent(cc);
  if (url.length > 1900) {
    try { elCopyToClipboard(body); } catch(e) {}
    var short = 'mailto:' + encodeURIComponent(to||'') + '?subject=' + encodeURIComponent(subject||'');
    if (cc) short += '&cc=' + encodeURIComponent(cc);
    window.location.href = short;
    m3Toast('Email body was too long for Outlook’s link limit — it’s on your clipboard. Click into the email and press Ctrl+V.');
    return;
  }
  window.location.href = url;
}
/* v3.12 SINGLE-SIGNATURE FIX: Outlook Web always injects the account's own
   auto-signature at the TOP of a link-composed email, and there is no URL
   switch to suppress it — so passing the body in the link produced TWO
   signatures (Outlook's on top, the toolkit's at the bottom). Fix: strip the
   toolkit's plain-text signature, put the body on the clipboard, and open the
   compose window with To/Cc/Subject only. Pasting drops the text ABOVE the
   auto-signature, so the rep's real Outlook signature ends the email — once.
   (Desktop mailto and .eml drafts keep the toolkit signature: those paths
   don't auto-insert one.) */
function m3StripToolkitSig(body){
  var out = String(body == null ? '' : body).replace(/\s+$/,'');
  var sigs = [];
  try { if (typeof buildSignature === 'function') sigs.push(buildSignature()); } catch(e) {}
  sigs.push('[Your Name]\nPulmOne USA\n1-844-PulmOne (785-6663)\nUSinfo@pulm-one.com');
  for (var i=0;i<sigs.length;i++){
    var sig = (sigs[i]||'').replace(/\s+$/,'');
    if (sig && out.slice(-sig.length) === sig) {
      out = out.slice(0, out.length - sig.length).replace(/\s+$/,'');
      break;
    }
  }
  /* Assembly-station fallback signature: "...\n<rep name>\nPulmOne USA" */
  out = out.replace(/\n[^\n]{0,60}\nPulmOne USA$/,'');
  return out;
}
function m3GuardedOWA(to, cc, subject, body, toastMsg){
  try { elCopyToClipboard(m3StripToolkitSig(body)); } catch(e) {}
  var url = 'https://outlook.office.com/mail/deeplink/compose?to=' + encodeURIComponent(to||'') + '&subject=' + encodeURIComponent(subject||'');
  if (cc) url += '&cc=' + encodeURIComponent(cc);
  window.open(url, '_blank', 'noopener');
  if (toastMsg !== false) m3Toast(toastMsg || 'Outlook Web is opening — click in the message and press Ctrl+V (tablet: press-and-hold, then Paste). Your email drops in and your Outlook signature stays at the bottom, just once.', 8000);
}

/* v3.16: after a send with materials, show a stay-up steps panel instead of an
   8-second toast. Reps kept missing the downloaded .zip — the installed app
   tucks downloads behind the small ⬇ icon in the title bar — and the old
   checklist line promised "no manual attaching", which no Outlook Web compose
   link can deliver (only .eml drafts or Microsoft Graph can auto-attach).
   The panel names the exact file, stays until dismissed, and can re-save it. */
function m3SendSteps(fileName, n, redownload){
  var old = document.getElementById('m3-send-steps');
  if (old && old.parentNode) old.parentNode.removeChild(old);
  var wrap = document.createElement('div');
  wrap.id = 'm3-send-steps';
  wrap.style.cssText = 'position:fixed; inset:0; background:rgba(15,23,42,.55); z-index:99999; display:flex; align-items:center; justify-content:center; padding:18px;';
  var fileLabel = n > 1 ? 'the ONE .zip (all ' + n + ' PDFs inside)' : 'the PDF';
  var safeName = String(fileName || '').replace(/&/g,'&amp;').replace(/</g,'&lt;');
  var card = document.createElement('div');
  card.style.cssText = 'background:#fff; border-radius:16px; max-width:540px; width:100%; padding:22px 24px; box-shadow:0 24px 60px rgba(0,0,0,.35); font-size:15px; line-height:1.55; color:#1f2937;';
  card.innerHTML =
    '<div style="font-size:18px; font-weight:800; margin-bottom:10px;">&#128236; Outlook is open &mdash; 2 moves to send</div>'
    + '<div style="display:flex; gap:10px; margin:10px 0;"><div style="font-weight:800; color:#1d4ed8;">1.</div><div>Click into the email and press <strong>Ctrl+V</strong> &mdash; your message drops in (your Outlook signature stays at the bottom).</div></div>'
    + '<div style="display:flex; gap:10px; margin:10px 0;"><div style="font-weight:800; color:#1d4ed8;">2.</div><div>Drag ' + fileLabel + ' into the email &mdash; that&rsquo;s your attachment' + (n > 1 ? 's' : '') + ':<br><strong style="word-break:break-all;">' + safeName + '</strong><br><span style="font-size:13px; color:#6b7280;">It just downloaded &mdash; look behind the ⬇ download icon at the top of this window, or in your Downloads folder.</span></div></div>'
    + '<div style="display:flex; gap:10px; margin-top:16px; flex-wrap:wrap;">'
    + '<button id="m3-steps-again" style="flex:1; min-width:180px; padding:11px 14px; border:0; border-radius:10px; background:#eff6ff; color:#1d4ed8; font-weight:700; font-size:14px; cursor:pointer;">&#128230; Save the file again</button>'
    + '<button id="m3-steps-done" style="flex:1; min-width:120px; padding:11px 14px; border:0; border-radius:10px; background:#16a34a; color:#fff; font-weight:800; font-size:14px; cursor:pointer;">&#10003; Got it</button>'
    + '</div>'
    + '<div style="margin-top:14px; padding-top:12px; border-top:1px solid #e5e7eb; font-size:13px; color:#6b7280;">Tired of dragging? <a href="#" id="m3-steps-draft" style="color:#1d4ed8; font-weight:700;">Switch to the one-file draft way</a> &mdash; next send, the files attach themselves.</div>';
  wrap.appendChild(card);
  document.body.appendChild(wrap);
  function close(){ if (wrap.parentNode) wrap.parentNode.removeChild(wrap); }
  document.getElementById('m3-steps-done').onclick = close;
  document.getElementById('m3-steps-again').onclick = function(){ if (redownload) redownload(); };
  var swb = document.getElementById('m3-steps-draft');
  if (swb) swb.onclick = function(ev){
    ev.preventDefault();
    m3SetSendPref('draft');
    try { m3RenderSendHelp('m3-eas-send-help'); m3RenderSendHelp('m3-el-send-help'); } catch(e) {}
    swb.parentNode.innerHTML = '&#10003; Done — from your next send on, everything packs into one ready-to-send draft with the files already attached.';
  };
  wrap.addEventListener('click', function(ev){ if (ev.target === wrap) close(); });
}

/* ============ MODE A — EMAIL ASSEMBLY STATION (v3 real materials) ============ */
var M3_PACKS = {
  intro:    { label:'⚡ Intro Pack',    ids:['brochure','why','samplereport'] },
  evidence: { label:'🔬 Evidence Pack', ids:['chestsum','chestfull','verona'] },
  it:       { label:'🖥 IT Pack',       ids:['hl7','mds2','dlco'] },
  closing:  { label:'🤝 Closing Pack',  ids:['financing','newlane-app','achpdf','w9','bank'] },
  rheum:    { label:'🦴 Rheum Pack',    ids:['rh-slick','rh-guideline','rh-factsheet'] },
  cardio:   { label:'❤️ Cardiology Pack', ids:['cardio-onepager'] }
};
function m3ApplyPack(key){
  if (key === 'clear') { M3_STATE.easIds = []; m3RenderEasMaterials(); m3Toast('Selection cleared'); return; }
  var p = M3_PACKS[key]; if (!p) return;
  M3_STATE.easIds = p.ids.slice();
  m3RenderEasMaterials();
  m3Toast(p.label.replace(/^\S+\s/,'') + ' selected — ' + p.ids.length + ' files, ' + m3SizeLabel(m3TotalKB(p.ids)));
}
function m3RenderEasMaterials(){
  var host = document.getElementById('m3-eas-materials');
  if (!host) return;
  var html = '<div class="m3-packs"><span class="m3-chips-lbl">One-tap packs:</span>';
  Object.keys(M3_PACKS).forEach(function(k){
    html += '<button type="button" class="m3-pack-btn" onclick="m3ApplyPack(\'' + k + '\')">' + M3_PACKS[k].label + '</button>';
  });
  html += '<button type="button" class="m3-pack-btn m3-pack-clear" onclick="m3ApplyPack(\'clear\')">Clear</button></div>';
  M3_CAT_ORDER.forEach(function(cat){
    var items = MATERIALS.filter(function(m){ return m.cat===cat && !m.noembed; });
    if (!items.length) return;
    html += '<div class="m3-cat-label">' + M3_CATS[cat] + '</div>';
    items.forEach(function(m){
      var on = M3_STATE.easIds.indexOf(m.id) >= 0;
      html += '<label class="m3-mat-row' + (on?' on':'') + '" id="m3-eas-row-' + m.id + '">'
            + '<input type="checkbox"' + (on?' checked':'') + ' onchange="m3EasToggle(\'' + m.id + '\', this.checked)">'
            + '<div style="flex:1;"><div class="m3-mat-title">' + m.title + '<span class="m3-kb">' + m3SizeLabel(m.kb) + '</span>'
            + (m.care ? ' <span class="m3-care">send only when closing</span>' : '') + '</div>'
            + '<div class="m3-mat-sub">' + m.sub + '</div></div></label>';
    });
  });
  host.innerHTML = html;
  m3EasSizeUpdate();
}
function m3EasToggle(id, on){
  var i = M3_STATE.easIds.indexOf(id);
  if (on && i < 0) M3_STATE.easIds.push(id);
  if (!on && i >= 0) M3_STATE.easIds.splice(i,1);
  var row = document.getElementById('m3-eas-row-' + id);
  if (row) row.classList.toggle('on', on);
  m3EasSizeUpdate();
}
function m3EasSizeUpdate(){
  var el = document.getElementById('m3-eas-size');
  if (!el) return;
  var n = M3_STATE.easIds.length;
  el.textContent = n ? ('📎 ' + n + ' file' + (n>1?'s':'') + ' selected · ' + m3SizeLabel(m3TotalKB(M3_STATE.easIds)) + ' total') : 'No materials selected yet — tap any file above to include it.';
}

/* v3 override: builds the package email from REAL selected materials. */
function easBuildEmail(){
  var doctor   = document.getElementById('eas-doctor').value.trim()   || '[Doctor Name]';
  var practice = document.getElementById('eas-practice').value.trim() || '[Practice Name]';
  var profileSet = (typeof REP_PROFILE !== 'undefined' && !!REP_PROFILE.name);
  var rep = document.getElementById('eas-rep').value.trim() || (profileSet ? REP_PROFILE.name : '') || '[Your Name]';
  var ids = M3_STATE.easIds.slice();

  var subjects = {
    intro:    'MiniBox+ Resources for ' + practice,
    postdemo: 'Following Up on Our Meeting at ' + practice,
    pricing:  'MiniBox+ Pricing and Materials for ' + practice,
    checkin:  'Checking In and Sharing MiniBox+ Resources'
  };
  var greetings = {
    intro:    'I wanted to reach out and share some resources that give you a clear picture of how the MiniBox+ can benefit ' + practice + '.',
    postdemo: 'Thank you for the time today. It was great walking through what the MiniBox+ can do for ' + practice + '. As promised, here is everything we discussed in one place.',
    pricing:  'Following up on our recent conversation. I have put together the pricing details alongside supporting materials so you have everything in one place.',
    checkin:  'I wanted to check in and make sure you have everything you need to evaluate the MiniBox+ for ' + practice + '.'
  };
  var closings = {
    intro:    'I would love to set up a quick call or demo at your convenience. Please let me know what works best for you and your team.',
    postdemo: 'Please do not hesitate to reach out with any questions. I will follow up in a few days, but feel free to reach out directly at any time.',
    pricing:  'If you would like to discuss any of the pricing details or explore financing options, I am happy to connect at your convenience.',
    checkin:  'I am happy to answer any questions or schedule a follow-up demo. Just let me know how I can help.'
  };
  var type = (typeof easEmailType !== 'undefined') ? easEmailType : 'intro';

  var body = 'Dear ' + doctor + ',\n\n' + (greetings[type] || greetings.intro);
  if (ids.length) {
    var lines = ids.map(function(id, i){ var m = m3ById(id); return (i+1) + '. ' + m.blurb; });
    body += '\n\nI have attached the following materials:\n\n' + lines.join('\n\n');
  }
  body += '\n\n' + (closings[type] || closings.intro) + '\n\nBest regards,\n'
        + (profileSet && typeof buildSignature === 'function' ? buildSignature() : rep + '\nPulmOne USA');

  document.getElementById('eas-out-subject').textContent = subjects[type] || subjects.intro;
  document.getElementById('eas-out-body').textContent = body;

  var ul = document.getElementById('eas-checklist-items');
  if (ids.length) {
    var rideNote = (m3SendPref() === 'drag')
      ? (ids.length > 1 ? ' — they save as ONE .zip when you tap Send with Outlook; drag that file into the email.' : ' — it downloads when you tap Send with Outlook; drag it into the email.')
      : ' — ' + (ids.length > 1 ? 'they ride' : 'it rides') + ' INSIDE the ready-to-send draft when you tap Send with Outlook. Already attached — nothing to drag.';
    ul.innerHTML = ids.map(function(id){ var m = m3ById(id); return '<li><strong>' + m.title + '</strong> · ' + m3SizeLabel(m.kb) + '</li>'; }).join('')
      + '<li style="list-style:none; margin-top:6px; font-weight:700;">Total: ' + m3SizeLabel(m3TotalKB(ids)) + rideNote + '</li>';
  } else {
    ul.innerHTML = '<li>No materials selected — this will be a plain email with no attachments.</li>';
  }
  m3RenderSendHelp('m3-eas-send-help');
  m3ApplyFlavor();

  var out = document.getElementById('eas-output');
  out.classList.add('show');
  setTimeout(function(){ out.scrollIntoView({behavior:'smooth', block:'start'}); }, 50);
}
function m3EasDownloadEml(){
  var subj = document.getElementById('eas-out-subject').textContent;
  if (!subj) { m3Toast('Tap “Generate Send Package Email” first'); return; }
  if (!m3EmlAvailable()) { m3Toast('Materials data file missing — keep materials-data.js next to this page. Using Outlook Web instead.'); m3EasOWA(); return; }
  var body = m3EasBody();
  var to = (typeof easGetTo === 'function') ? easGetTo() : '';
  var practice = document.getElementById('eas-practice').value.trim();
  m3BuildEml({ to:to, subject:subj, body:body, ids:M3_STATE.easIds, fileName:'PulmOne-' + (practice || 'Materials') });
  m3Toast('Draft downloaded — double-click it, review, and hit Send. (' + M3_STATE.easIds.length + ' attachment' + (M3_STATE.easIds.length===1?'':'s') + ' already inside.)');
}
function m3EasOWA(){
  var subj = document.getElementById('eas-out-subject').textContent;
  if (!subj) { m3Toast('Tap “Generate Send Package Email” first'); return; }
  var body = m3EasBody();
  var to = (typeof easGetTo === 'function') ? easGetTo() : '';
  var n = M3_STATE.easIds.length;
  var practice = (document.getElementById('eas-practice') || {value:''}).value.trim();
  /* Legacy flow: OWA compose + clipboard paste + downloaded zip drag. */
  var dragFlow = function(){
    var save = function(){
      if (n === 1) { m3DownloadMany(M3_STATE.easIds); var m = m3ById(M3_STATE.easIds[0]); return (m && m.file) || 'the downloaded PDF'; }
      var z = m3DownloadZip(M3_STATE.easIds, 'PulmOne-' + (practice || 'Materials'));
      if (!z) { m3DownloadMany(M3_STATE.easIds); return n + ' downloaded PDFs'; }
      return z;
    };
    var fname = n ? save() : null;
    m3GuardedOWA(to, '', subj, body, n ? false : null);
    if (n) m3SendSteps(fname, n, save);
  };
  /* v3.22: materials selected → one ready-to-send .eml draft, files inside. */
  m3AttachSend({ to:to, cc:'', subject:subj, body:body, ids:M3_STATE.easIds,
                 fileName:'PulmOne-' + (practice || 'Materials'), dragFlow:dragFlow });
}
function easOpenOutlook(){ m3EasOWA(); }
function easSendMailto(){
  var subj = document.getElementById('eas-out-subject').textContent;
  if (!subj) { m3Toast('Tap “Generate Send Package Email” first'); return; }
  var body = m3EasBody();
  var to = (typeof easGetTo === 'function') ? easGetTo() : '';
  m3GuardedMailto(to, '', subj, body);
  var n = M3_STATE.easIds.length;
  var practice = (document.getElementById('eas-practice') || {value:''}).value.trim();
  if (n === 1) {
    m3DownloadMany(M3_STATE.easIds);
    m3Toast('Outlook is opening — now drag the downloaded PDF from your Downloads folder into the email.', 6000);
  } else if (n > 1) {
    if (!m3DownloadZip(M3_STATE.easIds, 'PulmOne-' + (practice || 'Materials'))) m3DownloadMany(M3_STATE.easIds);
    m3Toast('Outlook is opening — now drag the ONE downloaded .zip (all ' + n + ' PDFs inside) from your Downloads folder into the email.', 6000);
  }
}

/* ============ MODE B — TEMPLATE LIBRARY: attach chips + draft send ============ */
function m3ElChipsHtml(){
  var chips = MATERIALS.filter(function(m){ return !m.noembed; }).map(function(m){
    var on = M3_STATE.elIds.indexOf(m.id) >= 0;
    return '<span class="m3-chip' + (on?' on':'') + '" onclick="m3ElToggle(\'' + m.id + '\')" title="' + m.sub.replace(/"/g,'&quot;') + ' · ' + m3SizeLabel(m.kb) + '">' + m.title + '</span>';
  }).join('');
  return '<div class="m3-chips-row"><span class="m3-chips-lbl">📎 Attach materials:</span>' + chips + '</div>';
}
function m3ElToggle(id){
  var i = M3_STATE.elIds.indexOf(id);
  if (i >= 0) M3_STATE.elIds.splice(i,1); else M3_STATE.elIds.push(id);
  renderElPreview();
}
/* v3 override of renderElPreview: same as v2.27 + attach chips + draft button.
   Preserves To/Cc the user already typed when the preview re-renders. */
function renderElPreview() {
  if (!currentElTmpl) return;
  var t = currentElTmpl;
  if (M3_STATE.elTmplTitle !== t.title) { M3_STATE.elTmplTitle = t.title; M3_STATE.elIds = []; }
  var prevTo = document.getElementById('el-to'); prevTo = prevTo ? prevTo.value : '';
  var prevCc = document.getElementById('el-cc'); prevCc = prevCc ? prevCc.value : '';
  var subject = currentElCustom.subject != null ? currentElCustom.subject : applyProfileMerges(t.subject);
  var body    = currentElCustom.body    != null ? currentElCustom.body    : applyProfileMerges(t.body);
  document.getElementById('el-preview-title').textContent = t.title;
  var highlight = function(s) {
    return escapeHTML(s).replace(/\{\{([A-Z_0-9]+)\}\}/g, '<span class="merge">{{$1}}</span>');
  };
  var nAtt = M3_STATE.elIds.length;
  document.getElementById('el-preview-body').innerHTML =
    '<div class="email-field email-to-row">' +
      '<div><div class="email-field-lbl">To</div><input class="email-field-input" id="el-to" name="to-email" type="email" autocomplete="email" list="mbx-emails" onchange="mbxRememberEmail(this.value)" placeholder="doctor@practice.com"></div>' +
      '<div><div class="email-field-lbl">Cc (optional)</div><input class="email-field-input" id="el-cc" name="cc-email" type="email" autocomplete="email" list="mbx-emails" onchange="mbxRememberEmail(this.value)" placeholder=""></div>' +
    '</div>' +
    '<div class="email-field">' +
      '<div class="email-field-lbl">Subject</div>' +
      '<input class="email-field-input" id="el-subject" type="text" value="' + escapeAttr(subject) + '" oninput="elSubjectEdit()">' +
    '</div>' +
    '<div class="email-field">' +
      '<div class="email-field-lbl">Body &mdash; yellow = still needs filling, tap to edit</div>' +
      '<div class="email-body-wrap" id="el-body" contenteditable="true" oninput="elBodyEdit()">' + highlight(body).replace(/\n/g,'<br>') + '</div>' +
    '</div>' +
    m3ElChipsHtml() +
    '<div class="email-send-row" id="m3-el-send-row">' +
      '<button class="email-btn email-btn-owa" onclick="elSendOWA()" title="' + (nAtt ? 'Packs your whole email — addresses, text, and every file — into ONE ready-to-send draft. Open it and hit Send.' : 'Opens Outlook signed in as you. Press Ctrl+V to drop your email in (your Outlook signature stays at the bottom), hit Send.') + '">&#127760; Send with Outlook' + (nAtt ? ' (+' + nAtt + ' &#128206;)' : '') + '</button>' +
      '<button class="email-btn email-btn-copy" onclick="elCopyBody()">&#128196; Copy email text</button>' +
    '</div>' +
    '<div class="m3-send-help" id="m3-el-send-help"></div>' +
    '<div class="email-note"><strong>When to use this template:</strong> ' + t.note + '</div>';
  var toEl = document.getElementById('el-to'); if (toEl && prevTo) toEl.value = prevTo;
  var ccEl = document.getElementById('el-cc'); if (ccEl && prevCc) ccEl.value = prevCc;
  m3RenderSendHelp('m3-el-send-help');
  m3ApplyFlavor();
}
function m3ElEml(){
  if (!currentElTmpl) { m3Toast('Pick a template first'); return; }
  if (!m3EmlAvailable()) { m3Toast('Materials data file missing — keep materials-data.js next to this page. Using Outlook Web instead.'); elSendOWA(); return; }
  var name = m3BuildEml({
    to: elGetCurrentTo(), cc: elGetCurrentCc(),
    subject: elGetCurrentSubject(), body: elGetCurrentBody(),
    ids: M3_STATE.elIds, fileName: 'PulmOne-' + currentElTmpl.title
  });
  var n = M3_STATE.elIds.length;
  m3Toast('Draft downloaded — double-click it, review, and hit Send.' + (n ? ' (' + n + ' attachment' + (n===1?'':'s') + ' already inside.)' : ''));
}
/* v3 overrides: same behavior + length guard + companion file downloads */
function elSendOWA(){
  if (!currentElTmpl) { m3Toast('Pick a template first'); return; }
  var n = M3_STATE.elIds.length;
  /* Legacy flow (v3.13): OWA compose + paste + ONE auto-zipped drag. */
  var dragFlow = function(){
    var save = function(){
      if (n === 1) { m3DownloadMany(M3_STATE.elIds); var m = m3ById(M3_STATE.elIds[0]); return (m && m.file) || 'the downloaded PDF'; }
      var z = m3DownloadZip(M3_STATE.elIds, 'PulmOne-' + (currentElTmpl ? currentElTmpl.title : 'Materials'));
      if (!z) { m3DownloadMany(M3_STATE.elIds); return n + ' downloaded PDFs'; }
      return z;
    };
    var fname = n ? save() : null;
    m3GuardedOWA(elGetCurrentTo(), elGetCurrentCc(), elGetCurrentSubject(), elGetCurrentBody(), n ? false : null);
    if (n) m3SendSteps(fname, n, save);
  };
  /* v3.22: attach chips picked → one ready-to-send .eml draft, files inside. */
  m3AttachSend({ to:elGetCurrentTo(), cc:elGetCurrentCc(), subject:elGetCurrentSubject(), body:elGetCurrentBody(),
                 ids:M3_STATE.elIds, fileName:'PulmOne-' + (currentElTmpl ? currentElTmpl.title : 'Materials'), dragFlow:dragFlow });
}
function elSendMailto(){
  if (!currentElTmpl) { m3Toast('Pick a template first'); return; }
  m3GuardedMailto(elGetCurrentTo(), elGetCurrentCc(), elGetCurrentSubject(), elGetCurrentBody());
  var n = M3_STATE.elIds.length;
  if (n === 1) {
    m3DownloadMany(M3_STATE.elIds);
    m3Toast('Outlook is opening — drag the downloaded PDF into the email.', 6000);
  } else if (n > 1) {
    if (!m3DownloadZip(M3_STATE.elIds, 'PulmOne-' + (currentElTmpl ? currentElTmpl.title : 'Materials'))) m3DownloadMany(M3_STATE.elIds);
    m3Toast('Outlook is opening — drag the ONE downloaded .zip (all ' + n + ' PDFs inside) into the email.', 6000);
  }
}

/* ============ MATERIALS LIBRARY (Forms tab) ============ */
function m3EmailThis(id){
  M3_STATE.easIds = [id];
  showTab('emaillib', document.querySelector('.tab-btn[onclick*="emaillib"]'));
  m3RenderEasMaterials();
  setTimeout(function(){
    var eas = document.querySelector('.eas-wrap');
    if (eas) eas.scrollIntoView({behavior:'smooth', block:'start'});
    m3Toast('Material selected — fill in the doctor’s info and generate the email.');
  }, 120);
}
function m3RenderLibrary(){
  var host = document.getElementById('m3-library');
  if (!host) return;
  var html = '';
  M3_CAT_ORDER.forEach(function(cat){
    var items = MATERIALS.filter(function(m){ return m.cat===cat; });
    if (!items.length) return;
    html += '<div class="m3-cat-label">' + M3_CATS[cat] + '</div><div class="m3-lib-grid">';
    items.forEach(function(m){
      html += '<div class="m3-lib-card">'
        + '<div class="m3-lib-title">' + m.title + ' <span class="m3-kb">' + m3SizeLabel(m.kb) + '</span></div>'
        + '<div class="m3-lib-sub">' + m.sub + (m.care ? ' &nbsp;<span class="m3-care">send only when closing</span>' : '') + '</div>'
        + '<div class="m3-lib-btns">'
        + (m3IsVideo(m.file)
            ? '<button onclick="m3PlayVideo(\'' + m.id + '\')">&#9654; Play</button>'
            : '<button onclick="m3View(\'' + m.id + '\')">&#128065; View</button>')
        + '<button onclick="m3Download(\'' + m.id + '\')">&#11015; Download</button>'
        + (m.noembed ? '' : '<button class="m3-mail" onclick="m3EmailThis(\'' + m.id + '\')">&#9993; Email it</button>')
        + '</div></div>';
    });
    html += '</div>';
  });
  if (!m3EmlAvailable()) {
    html = '<div class="m3-send-help" style="margin-bottom:12px; border-color:#fcd34d; background:#fff7e6;"><strong>&#9888; materials-data.js not found.</strong> Keep that file (and the materials folder) in the same folder as this page — without it, View/Download still work but emails can’t carry attachments automatically.</div>' + html;
  }
  host.innerHTML = html;
}

/* ============ CARDIOLOGY TAB — sub-view switch + playbook iframe height ============ */
function cardioShowView(view, btn){
  ['playbook','evidence'].forEach(function(v){
    var el = document.getElementById('cardio-view-' + v);
    if (el) el.style.display = (v === view) ? '' : 'none';
    var b = document.getElementById('cxsub-' + v);
    if (b) b.classList.toggle('on', v === view);
  });
}
window.addEventListener('message', function(e){
  if (e.data && e.data.cardioPbHeight){
    var f = document.getElementById('cardio-playbook-iframe');
    if (f) f.style.height = (Math.max(900, e.data.cardioPbHeight) + 30) + 'px';
  }
});

/* ============ INTERNAL MEDICINE TAB — sub-view switch ============
   Same shape as cardioShowView. Name must end in "ShowView" so the
   training-videos wiring can find it and bolt its own pill on. */
function intmedShowView(view, btn){
  ['playbook','evidence'].forEach(function(v){
    var el = document.getElementById('intmed-view-' + v);
    if (el) el.style.display = (v === view) ? '' : 'none';
    var b = document.getElementById('imsub-' + v);
    if (b) b.classList.toggle('on', v === view);
  });
}

/* ============ RHEUMATOLOGY TAB — sub-view switch + files ============ */
/* ============================================================
   v2.20 — Rheumatology Interpretation Composer
   Mirrors the ATS/ERS decision chart printed on the MiniBox+
   report: Gate 1 airflow -> Gate 2 size -> Gate 3 gas exchange.
   z-score is authoritative; %pred is the fallback when z is blank.
   ============================================================ */
var RHC_Z_LLN = -1.645;          /* 5th percentile — ATS/ERS 2022 */
var RHC_PCT_LLN = 80;            /* fallback only, when no z given */
var RHC_RATIO_PCT_LLN = 70;      /* fallback only — fixed ratio */

function rhcNum(id){
  var el = document.getElementById(id);
  if (!el || el.value === '' || el.value === null) return null;
  var v = parseFloat(el.value);
  return isNaN(v) ? null : v;
}
/* Returns true (normal), false (below LLN), or null (unknown). */
function rhcNormal(zId, pId, pctLLN){
  var z = rhcNum(zId);
  if (z !== null) return z >= RHC_Z_LLN;
  var p = rhcNum(pId);
  /* A value like 0.78 in the % box is the raw ratio, not % predicted — refuse to classify on it. */
  if (p !== null && !(pId === 'rhc-ratio-p' && rhcRatioLooksRaw(p))) return p >= pctLLN;
  return null;
}
function rhcRatioLooksRaw(p){ return p > 0 && p <= 1.5; }
function rhcGateText(zId, pId, ok){
  var z = rhcNum(zId), p = rhcNum(pId), bits = [];
  if (pId === 'rhc-ratio-p' && p !== null && rhcRatioLooksRaw(p)) p = null;
  if (z !== null) bits.push('z ' + (z > 0 ? '+' : '') + z.toFixed(2));
  if (p !== null) bits.push(p.toFixed(0) + '% pred');
  if (!bits.length) return '&mdash;';
  var verdict = ok === null ? '' : (ok ? ' &rarr; <b>normal</b>' : ' &rarr; <b>below LLN</b>');
  return bits.join(' &middot; ') + verdict;
}
function rhcSeverity(){
  var z = rhcNum('rhc-fev1-z'), p = rhcNum('rhc-fev1-p');
  if (p === null && z === null) return null;
  if (p !== null){
    if (p >= 70) return 'Mild';
    if (p >= 60) return 'Moderate';
    if (p >= 50) return 'Moderately severe';
    if (p >= 35) return 'Severe';
    return 'Very severe';
  }
  if (z >= -2) return 'Mild';
  if (z >= -2.5) return 'Moderate';
  if (z >= -3) return 'Moderately severe';
  if (z >= -4) return 'Severe';
  return 'Very severe';
}

function rhcClassify(){
  var airflow = rhcNormal('rhc-ratio-z','rhc-ratio-p', RHC_RATIO_PCT_LLN);
  var size    = rhcNormal('rhc-tlc-z','rhc-tlc-p', RHC_PCT_LLN);
  var gas     = rhcNormal('rhc-dlco-z','rhc-dlco-p', RHC_PCT_LLN);
  if (airflow === null || size === null) return { key:'incomplete', airflow:airflow, size:size, gas:gas };
  var key;
  if (airflow && size)        key = (gas === false) ? 'normal-lowdlco' : 'normal';
  else if (airflow && !size)  key = (gas === false) ? 'restrict-ild'   : 'restrict-extra';
  else if (!airflow && size)  key = (gas === false) ? 'obstruct-emph'  : 'obstruct';
  else                        key = 'mixed';
  return { key:key, airflow:airflow, size:size, gas:gas };
}

var RHC_PATTERNS = {
  'normal':          { label:'Normal spirometry, lung volumes and gas exchange', ild:false },
  'normal-lowdlco':  { label:'Isolated reduction in DLCO', ild:true },
  'restrict-ild':    { label:'Restriction with reduced DLCO — consistent with ILD', ild:true },
  'restrict-extra':  { label:'Restriction with preserved DLCO', ild:false },
  'obstruct':        { label:'Obstructive ventilatory defect', ild:false },
  'obstruct-emph':   { label:'Obstruction with reduced DLCO', ild:false },
  'mixed':           { label:'Mixed obstructive and restrictive defect', ild:true }
};

function rhcRun(){
  rhcDemoDriftCheck();
  var r = rhcClassify();
  var vEl = document.getElementById('rhc-verdict-v');
  var wrap = document.getElementById('rhc-verdict');
  var sevRow = document.getElementById('rhc-verdict-sev');
  if (!vEl) return;

  /* Catch the natural mistake: typing the ratio itself (0.78) instead of its % predicted. */
  var rw = document.getElementById('rhc-ratio-warn');
  if (rw){
    var rp = rhcNum('rhc-ratio-p');
    if (rp !== null && rhcRatioLooksRaw(rp)){
      rw.innerHTML = 'That looks like the ratio itself (' + rp + ') &mdash; this box wants the <b>% Predicted</b> number from the report (usually near 100). Or type the ratio&rsquo;s <b>Z-score</b> in the z box instead.';
      rw.style.display = 'block';
    } else {
      rw.style.display = 'none';
    }
  }

  document.getElementById('rhc-g1a').innerHTML = rhcGateText('rhc-ratio-z','rhc-ratio-p', r.airflow);
  document.getElementById('rhc-g2a').innerHTML = rhcGateText('rhc-tlc-z','rhc-tlc-p', r.size);
  document.getElementById('rhc-g3a').innerHTML = rhcGateText('rhc-dlco-z','rhc-dlco-p', r.gas);
  document.getElementById('rhc-g1').classList.toggle('live', r.airflow !== null);
  document.getElementById('rhc-g2').classList.toggle('live', r.size !== null);
  document.getElementById('rhc-g3').classList.toggle('live', r.gas !== null);

  if (r.key === 'incomplete'){
    vEl.textContent = 'Enter FEV₁/FVC and TLC to classify';
    wrap.classList.remove('hit');
    sevRow.style.display = 'none';
    document.getElementById('rhc-flags').innerHTML = '';
    return;
  }
  var pat = RHC_PATTERNS[r.key];
  vEl.textContent = pat.label;
  wrap.classList.toggle('hit', !!pat.ild);

  if (r.key === 'normal'){
    sevRow.style.display = 'none';
  } else {
    var sev = rhcSeverity();
    sevRow.style.display = '';
    if (sev) document.getElementById('rhc-sev').value = sev;
  }
  rhcFlags(r);
  rhcCompose();
}

function rhcFlags(r){
  var host = document.getElementById('rhc-flags');
  if (!host) return;
  var out = '', bmi = rhcNum('rhc-bmi');
  var dz = rhcNum('rhc-dlco-z'), dp = rhcNum('rhc-dlco-p');

  /* The objection a rheumatologist will raise first. */
  if (bmi !== null && bmi >= 30 && r.size === false){
    if (r.gas === false){
      out += '<div class="rhc-flag"><div class="rhc-flag-i">&#9878;&#65039;</div><div>'
        + '<div class="rhc-flag-t">Expect: &ldquo;that&rsquo;s the obesity, not ILD.&rdquo;</div>'
        + '<div class="rhc-flag-d">BMI ' + bmi.toFixed(1) + ' does restrict lung volumes &mdash; but obesity typically <strong>preserves or raises</strong> DLCO. '
        + 'A reduced DLCO' + (dz !== null ? ' (z ' + dz.toFixed(2) + ')' : (dp !== null ? ' (' + dp.toFixed(0) + '% pred)' : ''))
        + ' alongside the restriction is a genuine gas-exchange defect and is not explained by body habitus. That is the answer to the objection.</div></div></div>';
    } else {
      out += '<div class="rhc-flag"><div class="rhc-flag-i">&#9878;&#65039;</div><div>'
        + '<div class="rhc-flag-t">Body habitus may explain this restriction</div>'
        + '<div class="rhc-flag-d">BMI ' + bmi.toFixed(1) + ' with restriction but a preserved DLCO fits an extrapulmonary/obesity pattern rather than ILD. Say so in the interpretation rather than leaving it open.</div></div></div>';
    }
  }
  if (RHC_PATTERNS[r.key] && RHC_PATTERNS[r.key].ild){
    out += '<div class="rhc-flag"><div class="rhc-flag-i">&#129504;</div><div>'
      + '<div class="rhc-flag-t">This is the CTD-ILD pattern</div>'
      + '<div class="rhc-flag-d">In a patient with a known connective-tissue disease, this result is what the ACR/CHEST ILD guidance is asking you to catch. Tie the interpretation to their rheumatologic diagnosis &mdash; that is what makes it clinically and administratively defensible.</div></div></div>';
  }
  if (r.gas === null){
    out += '<div class="rhc-flag"><div class="rhc-flag-i">&#9888;&#65039;</div><div>'
      + '<div class="rhc-flag-t">No DLCO entered</div>'
      + '<div class="rhc-flag-d">DLCO is often the earliest abnormality in CTD-ILD. Without it the pattern can be described but ILD cannot be assessed &mdash; the third gate is where this diagnosis usually declares itself.</div></div></div>';
  }
  host.innerHTML = out;
}

function rhcVal(zId, pId, name){
  var z = rhcNum(zId), p = rhcNum(pId), bits = [];
  if (pId === 'rhc-ratio-p' && p !== null && rhcRatioLooksRaw(p)) p = null;
  if (p !== null) bits.push(p.toFixed(0) + '% predicted');
  if (z !== null) bits.push('z-score ' + (z > 0 ? '+' : '') + z.toFixed(2));
  if (!bits.length) return '';
  return name + ' ' + bits.join(', ');
}

function rhcCompose(){
  var out = document.getElementById('rhc-out');
  if (!out) return;
  var r = rhcClassify();
  if (r.key === 'incomplete'){ out.value = ''; return; }

  var sevEl = document.getElementById('rhc-sev');
  var sev = (document.getElementById('rhc-verdict-sev').style.display === 'none') ? null : (sevEl ? sevEl.value : null);

  var measured = [];
  ['rhc-fvc-z|rhc-fvc-p|FVC','rhc-fev1-z|rhc-fev1-p|FEV₁','rhc-ratio-z|rhc-ratio-p|FEV₁/FVC','rhc-tlc-z|rhc-tlc-p|TLC','rhc-dlco-z|rhc-dlco-p|DLCO']
    .forEach(function(spec){
      var s = spec.split('|'), t = rhcVal(s[0], s[1], s[2]);
      if (t) measured.push(t);
    });

  var body = {
    'normal': 'Spirometry, lung volumes and diffusing capacity are all within normal limits. There is no evidence of an obstructive or restrictive ventilatory defect, and gas exchange is preserved.',
    'normal-lowdlco': 'Spirometry and lung volumes are within normal limits, but the diffusing capacity is reduced in isolation. An isolated reduction in DLCO may precede any volume loss in connective-tissue-disease-associated interstitial lung disease, and may also be seen in pulmonary vascular disease or anaemia.',
    'restrict-ild': 'There is a restrictive ventilatory defect with a reduced diffusing capacity. The FEV₁/FVC ratio is preserved, which argues against airflow obstruction as the cause of the reduced volumes. The combination of reduced lung volumes and impaired gas exchange is consistent with an interstitial process.',
    'restrict-extra': 'There is a restrictive ventilatory defect with a preserved diffusing capacity. This combination more often reflects an extrapulmonary cause of reduced volumes — chest wall restriction, neuromuscular weakness, or body habitus — than an interstitial process.',
    'obstruct': 'There is an obstructive ventilatory defect. Lung volumes are preserved and the diffusing capacity is normal.',
    'obstruct-emph': 'There is an obstructive ventilatory defect accompanied by a reduced diffusing capacity, a combination that suggests emphysematous change rather than airways disease alone.',
    'mixed': 'There is a mixed defect, with both a reduced FEV₁/FVC ratio and reduced lung volumes. Each component should be considered separately.'
  }[r.key];

  var impression = {
    'normal': 'Normal pulmonary function study.',
    'normal-lowdlco': 'Isolated reduction in diffusing capacity.',
    'restrict-ild': (sev ? sev + ' restrictive' : 'Restrictive') + ' ventilatory defect with reduced DLCO, consistent with an interstitial lung process.',
    'restrict-extra': (sev ? sev + ' restrictive' : 'Restrictive') + ' ventilatory defect with preserved DLCO.',
    'obstruct': (sev ? sev + ' obstructive' : 'Obstructive') + ' ventilatory defect.',
    'obstruct-emph': (sev ? sev + ' obstructive' : 'Obstructive') + ' ventilatory defect with reduced DLCO.',
    'mixed': (sev ? sev + ' mixed' : 'Mixed') + ' obstructive and restrictive defect.'
  }[r.key];

  var recs = {
    'normal': 'Given the patient’s underlying rheumatologic diagnosis, continue surveillance at the interval appropriate to their disease and therapy.',
    'normal-lowdlco': 'Recommend correlation with HRCT and consideration of pulmonary vascular disease. Repeat testing to establish the trajectory.',
    'restrict-ild': 'Recommend correlation with high-resolution CT of the chest. Serial pulmonary function testing at [3–6 month] intervals will establish whether the process is stable or progressive, which is the measurement that drives treatment decisions.',
    'restrict-extra': 'Correlate clinically. If an interstitial process remains a concern, HRCT and serial testing are recommended.',
    'obstruct': 'Correlate clinically; consider bronchodilator response testing if not already performed.',
    'obstruct-emph': 'Correlate clinically and with chest imaging.',
    'mixed': 'Recommend correlation with high-resolution CT of the chest and serial pulmonary function testing.'
  }[r.key];

  var txt = 'INTERPRETATION\n\n';
  if (measured.length) txt += 'Measured values: ' + measured.join('; ') + '.\n\n';
  txt += body + '\n\n';
  txt += 'Clinical context: [' + (RHC_PATTERNS[r.key].ild
      ? 'state the patient’s connective-tissue disease, disease duration, current immunosuppressive therapy, and any respiratory symptoms'
      : 'state the patient’s rheumatologic diagnosis, current therapy, and any respiratory symptoms') + '].\n\n';
  txt += 'IMPRESSION: ' + impression + '\n\n';
  txt += recs + '\n\n';
  txt += rhcSignBlock();

  out.value = txt;
}

/* Name and date each get their OWN line. The old single-line
   "Interpreted by: ____  Date: ____" wrapped the moment anyone typed into it,
   which shoved the date onto the next line and looked broken. */
function rhcSignBlock(){
  var nameEl = document.getElementById('rhc-signer');
  var dateEl = document.getElementById('rhc-signdate');
  var name = nameEl ? nameEl.value.trim() : '';
  var date = rhcDateText(dateEl ? dateEl.value : '');
  /* Short rules on purpose: a longer underscore run wraps on a phone-width textarea,
     which is the wrapping that made this block look broken in the first place. */
  return 'Interpreted by: ' + (name || '__________________') + '\n'
       + 'Date: ' + (date || '__________');
}

/* yyyy-mm-dd from the date input → the m/d/yyyy a US chart expects. */
function rhcDateText(v){
  if (!v) return '';
  var p = v.split('-');
  if (p.length !== 3) return v;
  return (+p[1]) + '/' + (+p[2]) + '/' + p[0];
}

/* Date defaults to today, but only once — so clearing it on purpose sticks. */
var rhcSignSeeded = false;
function rhcInitSign(){
  if (rhcSignSeeded) return;
  var d = document.getElementById('rhc-signdate');
  if (!d) return;
  rhcSignSeeded = true;
  if (!d.value){
    var n = new Date(), pad = function(x){ return (x < 10 ? '0' : '') + x; };
    d.value = n.getFullYear() + '-' + pad(n.getMonth() + 1) + '-' + pad(n.getDate());
  }
  rhcCompose();
}

/* The other way out of the tool: a clean signed page for the chart.
   Uses a hidden iframe rather than window.open so pop-up blockers can't eat it. */
function rhcPrint(){
  var out = document.getElementById('rhc-out');
  if (!out || !out.value.trim()){ rhcToast('Nothing to print yet — enter the numbers first'); return; }
  var esc = function(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); };
  var old = document.getElementById('rhc-printframe');
  if (old && old.parentNode) old.parentNode.removeChild(old);
  var f = document.createElement('iframe');
  f.id = 'rhc-printframe';
  f.setAttribute('aria-hidden','true');
  f.style.cssText = 'position:fixed;right:0;bottom:0;width:0;height:0;border:0;opacity:0;';
  document.body.appendChild(f);
  var d = f.contentWindow.document;
  d.open();
  d.write('<!doctype html><html><head><meta charset="utf-8"><title>Pulmonary Function Interpretation</title>'
    + '<style>@page{margin:0.75in;}'
    + 'body{font-family:Georgia,"Times New Roman",serif;font-size:11.5pt;line-height:1.55;color:#111;margin:0;}'
    + 'h1{font-family:Arial,Helvetica,sans-serif;font-size:12pt;letter-spacing:.09em;text-transform:uppercase;'
    + 'border-bottom:1.5px solid #111;padding-bottom:7px;margin:0 0 16px;}'
    + 'pre{font-family:inherit;font-size:inherit;white-space:pre-wrap;word-wrap:break-word;margin:0;}'
    + '.foot{margin-top:26px;padding-top:9px;border-top:1px solid #bbb;'
    + 'font-family:Arial,Helvetica,sans-serif;font-size:8.5pt;color:#555;}'
    + '</style></head><body><h1>Pulmonary Function Interpretation</h1><pre>'
    + esc(out.value)
    + '</pre><div class="foot">Physician review and signature required. Drafted with the MiniBox+ interpretation composer '
    + '(ATS/ERS pattern logic); not a diagnosis.</div></body></html>');
  d.close();
  try { f.contentWindow.focus(); } catch(e){}
  setTimeout(function(){
    try { f.contentWindow.print(); } catch(e){ rhcToast('Your browser blocked printing'); }
  }, 150);
  rhcTimerStop();
  rhcToast('Print sheet ready — pick "Save as PDF" to file it');
}

/* PulmOne MiniBox+ demonstration report — restriction with reduced DLCO. */
var RHC_DEMO = { 'rhc-ratio-z':0.38, 'rhc-ratio-p':103, 'rhc-tlc-z':-3.78, 'rhc-tlc-p':54,
                 'rhc-dlco-z':-3.61, 'rhc-dlco-p':54, 'rhc-fvc-z':-4.55, 'rhc-fvc-p':48,
                 'rhc-fev1-z':-4.18, 'rhc-fev1-p':50, 'rhc-bmi':41.8 };

/* ---- "See the report" — the source document behind the six boxes.
        Every value shown in the overlay is read from RHC_DEMO, so the report
        and the demo case can never drift apart. ---- */
function rhRepOpen(){
  var o = document.getElementById('rhrep-overlay');
  if (!o) return;
  o.classList.add('on');
  document.body.style.overflow = 'hidden';
}
function rhRepClose(){
  var o = document.getElementById('rhrep-overlay');
  if (!o) return;
  o.classList.remove('on');
  document.body.style.overflow = '';
}
/* Tapping a row on the report drops that one number into its box — the point
   being to SHOW which number lands where, not just to save typing. */
function rhRepPick(param){
  var zEl = document.getElementById('rhc-' + param + '-z');
  var pEl = document.getElementById('rhc-' + param + '-p');
  if (zEl) zEl.value = RHC_DEMO['rhc-' + param + '-z'];
  if (pEl) pEl.value = RHC_DEMO['rhc-' + param + '-p'];
  rhcRun();
  rhcToast(({ratio:'Gate 1 · FEV₁/FVC', tlc:'Gate 2 · TLC', dlco:'Gate 3 · DLCO',
             fvc:'FVC', fev1:'FEV₁'})[param] + ' filled in');
  if (zEl) rhRepFlash(zEl);
  if (pEl) rhRepFlash(pEl);
}
function rhRepFlash(el){
  el.style.transition = 'background-color .25s';
  el.style.backgroundColor = '#d8f0f7';
  setTimeout(function(){ el.style.backgroundColor = ''; }, 900);
}
function rhRepFillAll(){
  rhRepClose();
  rhcLoadCase();
}
document.addEventListener('keydown', function(e){
  if (e.key === 'Escape'){
    var o = document.getElementById('rhrep-overlay');
    if (o && o.classList.contains('on')) rhRepClose();
  }
});
function rhcLoadCase(){
  var set = RHC_DEMO;
  Object.keys(set).forEach(function(k){ var el = document.getElementById(k); if (el) el.value = set[k]; });
  rhcDemoChrome(true);
  rhcRun();
  rhcToast('Demo case loaded — restriction with reduced DLCO');
}
/* Same button loads the demo and takes it back out, so it's always reversible. */
function rhcDemoToggle(){
  var card = document.getElementById('rhc-demo-card');
  if (card && card.classList.contains('on')) { rhcClear(); rhcToast('Demo case removed'); }
  else { rhcLoadCase(); }
}
/* Once the rep starts typing over the demo numbers, it stops being the demo. */
function rhcDemoDriftCheck(){
  var card = document.getElementById('rhc-demo-card');
  if (!card || !card.classList.contains('on')) return;
  var same = Object.keys(RHC_DEMO).every(function(k){
    var el = document.getElementById(k);
    return el && el.value !== '' && Number(el.value) === RHC_DEMO[k];
  });
  if (!same) rhcDemoChrome(false);
}
function rhcDemoChrome(on){
  var card = document.getElementById('rhc-demo-card');
  var btn  = document.getElementById('rhc-demo-btn');
  if (card) card.classList.toggle('on', !!on);
  if (btn)  btn.innerHTML = on ? '✕ Remove the demo case' : '📋 Load the ILD demo case';
}
function rhcClear(){
  ['rhc-ratio-z','rhc-ratio-p','rhc-tlc-z','rhc-tlc-p','rhc-dlco-z','rhc-dlco-p',
   'rhc-fvc-z','rhc-fvc-p','rhc-fev1-z','rhc-fev1-p','rhc-bmi'].forEach(function(k){
    var el = document.getElementById(k); if (el) el.value = '';
  });
  rhcDemoChrome(false);
  rhcRun();
}
function rhcCopy(){
  var out = document.getElementById('rhc-out');
  if (!out || !out.value.trim()) { rhcToast('Nothing to copy yet'); return; }
  var done = function(){ rhcToast('Copied — now paste it into the chart with Ctrl+V'); rhcTimerStop(); };
  if (navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(out.value).then(done, function(){ out.select(); document.execCommand('copy'); done(); });
  } else { out.select(); document.execCommand('copy'); done(); }
}
function rhcToast(msg){
  var t = document.getElementById('rhc-toast');
  if (!t) return;
  t.textContent = msg;
  t.classList.add('on');
  clearTimeout(t._h);
  t._h = setTimeout(function(){ t.classList.remove('on'); }, 1900);
}

/* ---- the clock: the whole "3 minutes to signature" claim, made visible ---- */
var rhcT0 = null, rhcTick = null;
function rhcTimerToggle(){ rhcTick ? rhcTimerStop() : rhcTimerStart(); }
function rhcTimerStart(){
  rhcT0 = new Date().getTime();
  document.getElementById('rhc-timer').classList.add('run');
  document.getElementById('rhc-timer-btn').innerHTML = '&#9724; Stop';
  document.getElementById('rhc-timer-lbl').textContent = 'running';
  rhcTick = setInterval(function(){
    var s = Math.floor((new Date().getTime() - rhcT0) / 1000);
    document.getElementById('rhc-timer').textContent = Math.floor(s/60) + ':' + ('0' + (s%60)).slice(-2);
  }, 250);
}
function rhcTimerStop(){
  if (!rhcTick) return;
  clearInterval(rhcTick); rhcTick = null;
  document.getElementById('rhc-timer').classList.remove('run');
  document.getElementById('rhc-timer-btn').innerHTML = 'Start timer';
  document.getElementById('rhc-timer-lbl').textContent = 'time to signature';
}

/* ---- The chain: three questions, three tools. Rendered in one place
        so the wording can never drift between the two views. ---- */
var RHX_STEPS = [
  { id:'estimator', who:'The practice owner asks', q:'Is this worth money to us?',
    tool:'PFT Estimator &mdash; their own patient counts &times; their own rate.', go:'Open the estimator' },
  { id:'billing',   who:'The biller asks', q:'How do I code it for our payer, in our state?',
    tool:'Billing Helper &mdash; MAC by state, payer policy, bundling rules, denial fixes.', go:'Open the billing helper' },
  { id:'composer',  who:'The physician asks', q:'What am I signing?',
    tool:'Interp Composer &mdash; insurance only pays for a PFT when a physician signs an interpretation report. This tool writes that report, signature-ready.', go:'Open the composer' }
];
function rhxHtml(here){
  var h = '<div class="rhx-h"><h4>The three questions &mdash; and the tool that answers each one</h4>'
    + '<p>A rheumatology practice does not have one objection, it has three, and they come from three different people. Each one has a tool behind it.</p></div>'
    + '<div class="rhx-grid">';
  RHX_STEPS.forEach(function(s){
    var isHere = (s.id === here);
    var onclick = isHere ? '' :
      (s.id === 'billing' ? 'mbxOpenTab(\'billing\')'
                          : 'rheumShowView(\'' + s.id + '\', document.getElementById(\'rhsub-' + s.id + '\'))');
    h += '<div class="rhx-step">'
      + '<div class="rhx-who">' + s.who + '</div>'
      + '<div class="rhx-q">&ldquo;' + s.q + '&rdquo;</div>'
      + '<div class="rhx-tool">' + s.tool + '</div>'
      + '<button type="button" class="rhx-go' + (isHere ? ' here' : '') + '"'
      + (onclick ? ' onclick="' + onclick + '"' : ' disabled')
      + '>' + (isHere ? 'You&rsquo;re in this tool now' : s.go + ' &rarr;') + '</button>'
      + '</div>';
  });
  h += '</div>'
    + '<div class="rhx-foot"><strong>Why they interlock:</strong> the Billing Helper&rsquo;s own documentation checklist requires &ldquo;a signed interpretation &amp; report &mdash; numeric values, the graphic record, and the provider&rsquo;s reading.&rdquo; '
    + 'The Composer is what produces that. The money case is only collectable if the interpretation exists, and the interpretation only gets written if it takes minutes rather than an afternoon.</div>';
  return h;
}
function rhxRender(here){
  var el = document.getElementById('rhx-' + here);
  if (el) el.innerHTML = rhxHtml(here);
}

/* ---- Rehearse the Room: the three-person act. Same cast and wording
        as RHX_STEPS — the act is the preview, the chain is the wayfinding. ---- */
var RHACT_SCENES = [
  { k:'intro', tag:'The set-up',
    title:'A rheumatology sale is never one conversation.',
    body:'It&rsquo;s three &mdash; with three different people, and each one holds a veto. The owner can kill it on money, the biller can kill it on coding, and the physician can kill it on paperwork. Walk in ready for all three and there&rsquo;s nothing left to say no to.' },
  { k:'owner', av:'', who:'Act I &mdash; The Practice Owner', q:'Is this worth money to us?',
    real:'&ldquo;Show me <em>our</em> number, not your brochure&rsquo;s.&rdquo; National averages bounce off. The owner only trusts math built from their own patient counts and their own payer rate.',
    move:'Don&rsquo;t answer &mdash; calculate. Open the PFT Estimator and build the number together: their ILD-risk patients, their weekly symptom volume, their rate. When the annual figure lands on the screen, it&rsquo;s their number, not your pitch.',
    openLbl:'Open the PFT Estimator' },
  { k:'biller', av:'', who:'Act II &mdash; The Biller', q:'How do I code it for our payer, in our state?',
    real:'&ldquo;When this denies, it lands on <em>my</em> desk.&rdquo; The biller has been burned before. They need the exact codes, their state&rsquo;s Medicare rules, and a fix for when a claim bounces.',
    move:'Open the Billing Helper on their state: the 94010 + 94726 + 94729 bundle, the payer policies, the bundling traps, the denial fixes. Hand the biller the answers and the blocker becomes your inside champion.',
    openLbl:'Open the Billing Helper' },
  { k:'phys', av:'', who:'Act III &mdash; The Physician', q:'What am I signing?',
    real:'&ldquo;Does this machine mean homework for <em>me</em>?&rdquo; Insurance only pays when a physician signs a written interpretation report on every test. The doctor hears: an afternoon of paperwork I don&rsquo;t have.',
    move:'Open the Interp Composer: pattern classified, report drafted, signature-ready. The doctor reviews and signs in minutes &mdash; the paperwork objection dies on the spot.',
    openLbl:'Open the Interp Composer' },
  { k:'close', tag:'Curtain',
    title:'One machine. Three yeses. No objection left standing.',
    body:'The three answers interlock: the money is only collectable if the signed report exists, and the report only gets written because it takes minutes instead of an afternoon. Win the owner, the biller, and the physician &mdash; then close on financing. Start where every conversation starts: the money.' }
];
var rhActI = 0;
function rhActOpen(){
  rhActI = 0;
  document.getElementById('rhact-overlay').style.display = 'flex';
  document.body.style.overflow = 'hidden';
  rhActRender();
}
function rhActClose(){
  document.getElementById('rhact-overlay').style.display = 'none';
  document.body.style.overflow = '';
}
function rhActGo(d){
  rhActI = Math.max(0, Math.min(RHACT_SCENES.length - 1, rhActI + d));
  rhActRender();
}
function rhActTool(k){
  rhActClose();
  if (k === 'biller') { mbxOpenTab('billing'); }
  else if (k === 'owner') { rheumShowView('estimator', document.getElementById('rhsub-estimator')); }
  else { rheumShowView('composer', document.getElementById('rhsub-composer')); }
}
function rhActRender(){
  var s = RHACT_SCENES[rhActI], h = '';
  h += '<div class="rhact-top"><div class="rhact-steps">';
  RHACT_SCENES.forEach(function(sc, i){
    h += '<span class="rhact-dot' + (i === rhActI ? ' on' : '') + '"></span>';
  });
  h += '</div><button type="button" class="rhact-x" onclick="rhActClose()" title="Close">&#10005;</button></div>';
  h += '<div class="rhact-body">';
  if (s.av) {
    h += '<div class="rhact-cast1"><span class="rhact-av">' + s.av + '</span><span class="rhact-who">' + s.who + '</span></div>'
      + '<div class="rhact-bubble">&ldquo;' + s.q + '&rdquo;</div>'
      + '<div class="rhact-lbl gold">What they&rsquo;re really saying</div><p class="rhact-p">' + s.real + '</p>'
      + '<div class="rhact-lbl teal">Your move</div><p class="rhact-p">' + s.move + '</p>'
      + '<button type="button" class="rhact-open" onclick="rhActTool(\'' + s.k + '\')">' + s.openLbl + ' &rarr;</button>';
  } else {
    h += '<div class="rhact-tag">' + s.tag + '</div><h3 class="rhact-title">' + s.title + '</h3><p class="rhact-p">' + s.body + '</p>';
    if (s.k === 'intro') {
      h += '<div class="rhact-cast">'
        + '<span class="rhact-chip"> The Owner &mdash; the money</span>'
        + '<span class="rhact-chip"> The Biller &mdash; the codes</span>'
        + '<span class="rhact-chip"> The Physician &mdash; the signature</span></div>';
    } else {
      h += '<button type="button" class="rhact-open" onclick="rhActTool(\'owner\')">Start with the owner &mdash; open the Estimator &rarr;</button>';
    }
  }
  h += '</div><div class="rhact-foot">';
  h += '<button type="button" class="rhact-nav"' + (rhActI === 0 ? ' style="visibility:hidden;"' : '') + ' onclick="rhActGo(-1)">&larr; Back</button>';
  if (rhActI === RHACT_SCENES.length - 1) {
    h += '<button type="button" class="rhact-nav done" onclick="rhActClose()">Done</button>';
  } else {
    var nextLbl = ['Meet the owner', 'Next: the biller', 'Next: the physician', 'The close'][rhActI];
    h += '<button type="button" class="rhact-nav next" onclick="rhActGo(1)">' + nextLbl + ' &rarr;</button>';
  }
  h += '</div>';
  document.getElementById('rhact-card').innerHTML = h;
}
document.addEventListener('keydown', function(e){
  var ov = document.getElementById('rhact-overlay');
  if (!ov || ov.style.display !== 'flex') return;
  if (e.key === 'Escape') rhActClose();
  else if (e.key === 'ArrowRight') rhActGo(1);
  else if (e.key === 'ArrowLeft') rhActGo(-1);
});

/* =====================================================================
   DRILL IT — flashcards off the rheumatology playbook
   ---------------------------------------------------------------------
   Every deck below is the SAME content that's rendered on the playbook
   page above it. If a playbook line changes, change the card too — the
   whole point is that the rep is quizzed on exactly what they just read.
   Coding cards follow the corrected ruling: 94010 + 94726 + 94729,
   never 94060 (NCCI pair, modifier indicator 0 — nothing unbundles it).
   ===================================================================== */
var RHFC_DECKS = {
  moves: {
    title:'The play, in five moves', sub:'Move by move. Can you name it before you flip?',
    cards:[
      {q:'Move 1 &mdash; what do you anchor on?', a:'<b>The guideline.</b> The 2023 ACR/CHEST guideline names PFTs &mdash; spirometry, lung volumes and DLCO &mdash; as recommended for ILD screening and monitoring in RA, scleroderma, Sj&ouml;gren&rsquo;s, MCTD and inflammatory myopathies. That&rsquo;s the door.', hint:'It&rsquo;s not the device.'},
      {q:'Move 2 &mdash; where is the volume?', a:'<b>Already in the chart.</b> A rheumatologist with high RA and SSc volume is sending PFTs out the door today. The population exists &mdash; they&rsquo;re just referring it out.'},
      {q:'Move 3 &mdash; what do you do on the first call?', a:'<b>Discover, don&rsquo;t pitch.</b> Ask the four discovery questions and let the rheumatologist do the math on owning their own DLCO data.'},
      {q:'Move 4 &mdash; what has to be handled cleanly?', a:'<b>The three objections:</b> staff training, reimbursement, and upfront cost. Memorize the answers &mdash; don&rsquo;t look them up in the room.'},
      {q:'Move 5 &mdash; what do you close on?', a:'<b>The financing that fits.</b> Lease-to-own with $0 down removes the capital objection. The clinical case carries the rest.'}
    ]
  },
  numbers: {
    title:'The patient math', sub:'The three numbers that make the case in one breath.',
    cards:[
      {q:'What share of scleroderma (SSc) patients develop ILD?', a:'<span class="rhfc-hi">50%+</span> &mdash; more than half. This is why SSc is the sharpest opening in rheumatology.'},
      {q:'What share of RA patients develop ILD?', a:'<span class="rhfc-hi">10&ndash;30%</span>. RA is the volume play &mdash; a lower rate against a far bigger panel.'},
      {q:'Which measurement is the most sensitive early marker for ILD?', a:'<b>DLCO</b> &mdash; and MiniBox+ runs it as part of a complete PFT, not as a bolt-on module.'}
    ]
  },
  cpt: {
    title:'The CPT bundle', sub:'Get these wrong in the room and you lose the biller. Six cards.',
    cards:[
      {q:'Name the three codes in the ILD panel.', a:'<span class="rhfc-hi">94010</span> spirometry &middot; <span class="rhfc-hi">94726</span> plethysmography for lung volumes (TLC) &middot; <span class="rhfc-hi">94729</span> diffusing capacity (DLCO).', hint:'Spirometry, volumes, diffusion.'},
      {q:'Why <em>not</em> 94060 for ILD screening?', a:'94060 is spirometry <b>with</b> bronchodilator and already <b>includes 94010</b> &mdash; bill both and it denies as bundled. Bronchodilator response is an asthma/COPD question, not an ILD one.'},
      {q:'Can a modifier unbundle 94060 and 94010?', a:'<b>No.</b> The NCCI pair carries <b>modifier indicator 0</b> &mdash; no modifier ever splits them. That rule lives in the PTP edit table, not the narrative chapter.'},
      {q:'What supervision level does the ILD panel need?', a:'<b>General supervision</b> for 94010 / 94726 / 94729. (94060 would need <b>direct</b>.) The correct panel is also the easier one to staff &mdash; that&rsquo;s a selling point, not a footnote.'},
      {q:'Roughly what does the panel pay, national CY2026?', a:'<span class="rhfc-hi">~$157</span> &mdash; 94010 $29.73 + 94726 $63.80 + 94729 $63.46 = <b>$156.99</b>. The estimator&rsquo;s $150 default is deliberately conservative.'},
      {q:'Screening vs. monitoring &mdash; what&rsquo;s the trap?', a:'Medicare excludes <b>routine screening of asymptomatic patients</b>, but ACR/CHEST recommends screening at-risk patients. Documented lung involvement or symptoms = monitoring = payable. Asymptomatic = screening = patient-liable, get an <b>ABN</b>. Never sell asymptomatic surveillance as recurring volume.', hint:'The one that can burn a practice.'}
    ]
  },
  cadence: {
    title:'Monitoring cadence (PFTs)', sub:'Recurring PFTs are recurring utilization &mdash; know the table cold.',
    cards:[
      {q:'SSc-ILD &mdash; how often in the first year, and once stable?', a:'First year: <b>every 3&ndash;6 months</b>. Once stable: <b>every 6&ndash;12 months</b>.'},
      {q:'IIM-ILD (inflammatory myopathies) &mdash; first year, and once stable?', a:'First year: <b>every 3&ndash;6 months</b>. Once stable: <b>every 6&ndash;12 months</b>. Same as SSc.'},
      {q:'RA-ILD &mdash; first year, and once stable?', a:'First year: <b>every 3&ndash;12 months</b>. Once stable: <b>every 6&ndash;12 months</b>.'},
      {q:'Sj&ouml;gren&rsquo;s / MCTD-ILD &mdash; first year, and once stable?', a:'First year: <b>every 3&ndash;12 months</b>. Once stable: <b>every 6&ndash;12 months</b>. Same as RA.'},
      {q:'What pushes testing more frequent than the table?', a:'<b>Progressive fibrotic phenotypes, treatment changes, or clinical deterioration.</b> That&rsquo;s the sentence that turns a cadence table into recurring utilization.'}
    ]
  },
  objections: {
    title:'The three objections', sub:'Say the answer out loud before you flip. That&rsquo;s the drill.',
    cards:[
      {q:'&ldquo;My staff isn&rsquo;t trained on PFTs.&rdquo;', a:'<b>No RT required.</b> We train the MA, RN or NP &mdash; plus training, support and return visits.'},
      {q:'&ldquo;Will I get reimbursed? I&rsquo;m a rheumatologist.&rdquo;', a:'<b>Yes.</b> The ACR/CHEST guideline gives clean medical-necessity documentation. Bundle: <span class="rhfc-hi">94010 + 94726 + 94729</span>.'},
      {q:'&ldquo;$15K upfront is a stretch.&rdquo;', a:'<b>Lease-to-own, zero upfront</b> &mdash; 12/24/36/60-month terms, optional 90-day deferral, $1 buyout. Or 0% financing, or a subscription.'}
    ]
  },
  discovery: {
    title:'The four discovery questions', sub:'Don&rsquo;t pitch on the discovery call. Ask. Recall them word-for-word.',
    cards:[
      {q:'Discovery question 1 &mdash; on treatment monitoring?', a:'&ldquo;What percentage of your patients are on <b>DMARDs or biologics</b>, and how do you currently monitor them for <b>pulmonary toxicity</b>?&rdquo;'},
      {q:'Discovery question 2 &mdash; on the referral path?', a:'&ldquo;For your <b>RA and scleroderma</b> patients, where are you sending PFTs today &mdash; and <b>how long</b> until you get the results back?&rdquo;'},
      {q:'Discovery question 3 &mdash; on the workflow?', a:'&ldquo;When a patient&rsquo;s <b>DLCO trends down</b>, what does your workflow look like to catch it?&rdquo;'},
      {q:'The closer &mdash; what&rsquo;s the last question you ask?', a:'&ldquo;How would your <b>treatment cadence</b> change if you <b>owned the PFT data</b> inside your practice?&rdquo;', hint:'It makes them picture owning it.'}
    ]
  }
};
var RHFC_ORDER = ['moves','numbers','cpt','cadence','objections','discovery'];

var rhfcQueue = [], rhfcI = 0, rhfcFlipped = false, rhfcDeckId = '',
    rhfcRight = 0, rhfcSeen = 0, rhfcMissed = [], rhfcMode = 'menu';

/* Scores persist so a rep can see they've actually improved. Silently
   no-ops if storage is blocked (file:// in some browsers). */
function rhfcScores(){
  try { return JSON.parse(localStorage.getItem('rhfc-scores') || '{}'); } catch(e){ return {}; }
}
function rhfcSaveScore(id, pct){
  try {
    var s = rhfcScores(); var prev = s[id] || {};
    s[id] = { last: pct, best: Math.max(pct, prev.best || 0) };
    localStorage.setItem('rhfc-scores', JSON.stringify(s));
  } catch(e){}
}

/* The drill is a track, not a shelf of decks. These three decide what the
   rep is pushed toward when a round ends, so the overlay never dead-ends. */
function rhfcNextDeck(id){
  if (id === 'all') return '';
  var i = RHFC_ORDER.indexOf(id);
  return (i < 0 || i >= RHFC_ORDER.length - 1) ? '' : RHFC_ORDER[i + 1];
}
function rhfcClearedCount(){
  var s = rhfcScores(), n = 0;
  RHFC_ORDER.forEach(function(k){ if (s[k] && s[k].best >= 80) n++; });
  return n;
}
/* Mirrors the overlay's deck track onto the Training card, so progress is
   visible before you open anything. */
function rhtrRenderTrack(){
  var el = document.getElementById('rhtr-track');
  if (!el) return;
  var sc = rhfcScores(), h = '<div class="pips">';
  RHFC_ORDER.forEach(function(k){
    h += '<i class="' + (sc[k] && sc[k].best >= 80 ? 'on' : '') + '"></i>';
  });
  h += '</div><span>' + rhfcClearedCount() + ' of ' + RHFC_ORDER.length + ' decks cleared</span>';
  el.innerHTML = h;
}

/* Terminal move: close the cards, open the live room. */
function rhfcToRehearse(){
  rhfcClose();
  if (typeof rhActOpen === 'function') rhActOpen();
}

function rhfcOpen(){
  rhfcMode = 'menu';
  var o = document.getElementById('rhfc-overlay');
  if (!o) return;
  o.classList.add('on');
  document.body.style.overflow = 'hidden';
  rhfcRender();
}
function rhfcClose(){
  var o = document.getElementById('rhfc-overlay');
  if (!o) return;
  o.classList.remove('on');
  document.body.style.overflow = '';
}
function rhfcShuffle(a){
  for (var i = a.length - 1; i > 0; i--){ var j = Math.floor(Math.random() * (i + 1)); var t = a[i]; a[i] = a[j]; a[j] = t; }
  return a;
}
/* Start one deck, or 'all' for the mixed run. */
function rhfcStart(id){
  rhfcDeckId = id;
  var cards;
  if (id === 'all'){
    cards = [];
    RHFC_ORDER.forEach(function(k){
      RHFC_DECKS[k].cards.forEach(function(c){ cards.push({ q:c.q, a:c.a, hint:c.hint, from:RHFC_DECKS[k].title }); });
    });
    rhfcShuffle(cards);
  } else {
    if (!RHFC_DECKS[id]) return;
    cards = RHFC_DECKS[id].cards.slice();
  }
  rhfcQueue = cards; rhfcI = 0; rhfcFlipped = false;
  rhfcRight = 0; rhfcSeen = 0; rhfcMissed = [];
  rhfcMode = 'card';
  var o = document.getElementById('rhfc-overlay');
  if (o && !o.classList.contains('on')){ o.classList.add('on'); document.body.style.overflow = 'hidden'; }
  rhfcRender();
}
function rhfcFlip(){
  if (rhfcMode !== 'card') return;
  rhfcFlipped = !rhfcFlipped;
  rhfcRender();
}
/* "Again" doesn't punish twice: a card is scored once, the first time it's
   seen, then requeued at the back so the rep leaves having said it right. */
function rhfcGrade(got){
  if (rhfcMode !== 'card') return;
  var card = rhfcQueue[rhfcI];
  if (!card) return;
  if (!card._scored){
    card._scored = true; rhfcSeen++;
    if (got) rhfcRight++; else rhfcMissed.push(card);
  }
  if (!got){ var again = rhfcQueue.splice(rhfcI, 1)[0]; rhfcQueue.push(again); }
  else { rhfcI++; }
  rhfcFlipped = false;
  if (rhfcI >= rhfcQueue.length){
    rhfcMode = 'done';
    var pct = rhfcSeen ? Math.round((rhfcRight / rhfcSeen) * 100) : 0;
    rhfcSaveScore(rhfcDeckId, pct);
  }
  rhfcRender();
}
function rhfcRetryMissed(){
  if (!rhfcMissed.length) return;
  rhfcQueue = rhfcMissed.map(function(c){ return { q:c.q, a:c.a, hint:c.hint, from:c.from }; });
  rhfcI = 0; rhfcFlipped = false; rhfcRight = 0; rhfcSeen = 0; rhfcMissed = [];
  rhfcMode = 'card';
  rhfcRender();
}

function rhfcRender(){
  var host = document.getElementById('rhfc-body');
  if (!host) return;
  var h = '';

  if (rhfcMode === 'menu'){
    var sc = rhfcScores(), total = 0;
    RHFC_ORDER.forEach(function(k){ total += RHFC_DECKS[k].cards.length; });
    h += '<div class="rhfc-top"><div>' +
         '<div class="rhfc-tag">The Whetstone</div>' +
         '<div class="rhfc-title">Rheumatology recall</div>' +
         '<div class="rhfc-sub">Pick a deck, or run all ' + total + ' cards mixed. Say the answer out loud, then flip &mdash; that&rsquo;s the whole method.</div>' +
         '</div><button type="button" class="rhfc-x" onclick="rhfcClose()" aria-label="Close">&#10005;</button></div>';
    h += '<div class="rhfc-decks">';
    RHFC_ORDER.forEach(function(k){
      var d = RHFC_DECKS[k], s = sc[k];
      h += '<button type="button" class="rhfc-deck" onclick="rhfcStart(\'' + k + '\')">' +
           '<div class="rhfc-deck-h">' + d.title + '</div>' +
           '<div class="rhfc-deck-n">' + d.cards.length + ' cards</div>' +
           (s ? '<div class="rhfc-deck-score' + (s.best === 100 ? ' gold' : '') + '">' + (s.best === 100 ? ' 100% ' : '') + 'Last ' + s.last + '% &middot; Best ' + s.best + '%</div>' : '') +
           '</button>';
    });
    h += '</div>';
    h += '<button type="button" class="rhfc-all" onclick="rhfcStart(\'all\')">Drill all ' + total + ' &mdash; shuffled</button>';
    /* The track: six pips + the exit. Makes it obvious the drill ends somewhere. */
    var cl = rhfcClearedCount();
    h += '<div class="rhfc-track"><div class="rhfc-track-pips">';
    RHFC_ORDER.forEach(function(k){
      var cleared2 = sc[k] && sc[k].best >= 80;
      h += '<i class="' + (cleared2 ? 'on' : '') + '" title="' + RHFC_DECKS[k].title + (cleared2 ? ' - cleared' : '') + '"></i>';
    });
    h += '</div><div class="rhfc-track-lbl">' + cl + ' of ' + RHFC_ORDER.length + ' decks cleared' +
         (cl >= RHFC_ORDER.length ? ' &mdash; you know the words' : '') + '</div></div>';
    h += '<button type="button" class="rhfc-exit" onclick="rhfcToRehearse()">' +
         (cl >= RHFC_ORDER.length ? ' You&rsquo;re ready &mdash; rehearse the room' : 'Skip the cards &mdash; rehearse the room ') +
         '</button>';
    h += '<div class="rhfc-howto" data-mbx-tip="rh-flashcards-howto"><b>How it works:</b> read the front, answer it out loud, flip it. Hit <b>Again</b> and the card goes to the back of the pile &mdash; you don&rsquo;t finish until you&rsquo;ve said every one right. Keyboard: <b>Space</b> flips, <b>1</b> = Again, <b>2</b> = Got it.</div>';
    host.innerHTML = h;
    return;
  }

  if (rhfcMode === 'done'){
    var pct = rhfcSeen ? Math.round((rhfcRight / rhfcSeen) * 100) : 0;
    var note = pct === 100 ? 'Clean run. You can hold this section of the playbook without the page in front of you.'
             : pct >= 80  ? 'Close. The misses below are the ones that&rsquo;ll cost you in the room &mdash; run them again.'
             : 'That&rsquo;s the honest number. Run the missed cards, then take the whole deck again.';
    h += '<div class="rhfc-top"><div>' +
         '<div class="rhfc-tag">Round complete</div>' +
         '<div class="rhfc-title">' + (rhfcDeckId === 'all' ? 'All decks, shuffled' : RHFC_DECKS[rhfcDeckId].title) + '</div>' +
         '</div><button type="button" class="rhfc-x" onclick="rhfcClose()" aria-label="Close">&#10005;</button></div>';
    h += '<div class="rhfc-score"><div class="rhfc-score-big">' + pct + '%</div>' +
         '<div class="rhfc-score-lbl">' + rhfcRight + ' of ' + rhfcSeen + ' first-time right</div>' +
         '<div class="rhfc-score-note">' + note + '</div></div>';
    if (rhfcMissed.length){
      h += '<div class="rhfc-missed"><h5>Needed a second look</h5><ul>';
      rhfcMissed.forEach(function(c){ h += '<li>' + c.q + '</li>'; });
      h += '</ul></div>';
    }
    /* What's next. A finished round always points somewhere: the misses,
       the next deck, or out of the cards and into the room. */
    var nxt = rhfcNextDeck(rhfcDeckId), cleared = rhfcClearedCount();
    var handoff = '';
    if (rhfcMissed.length){
      handoff = '<b>Next:</b> clean up the ' + rhfcMissed.length + ' below, then move on. Nothing gets learned by re-reading it &mdash; say them out loud.';
    } else if (nxt){
      handoff = '<b>Next:</b> ' + RHFC_DECKS[nxt].title + ' &mdash; ' + RHFC_DECKS[nxt].cards.length + ' cards. ' + cleared + ' of ' + RHFC_ORDER.length + ' decks cleared.';
    } else if (cleared >= RHFC_ORDER.length){
      handoff = '<b>All six decks cleared.</b> You know the words. The only thing left is saying them to somebody who pushes back &mdash; go rehearse the room.';
    } else {
      handoff = '<b>Next:</b> ' + (RHFC_ORDER.length - cleared) + ' deck' + (RHFC_ORDER.length - cleared === 1 ? '' : 's') + ' still unclaimed, or take it into the room.';
    }
    h += '<div class="rhfc-next">' + handoff + '</div>';

    h += '<div class="rhfc-again-btns">';
    if (rhfcMissed.length){
      h += '<button type="button" class="primary" onclick="rhfcRetryMissed()">Drill the ' + rhfcMissed.length + ' I missed</button>';
      h += '<button type="button" onclick="rhfcStart(\'' + rhfcDeckId + '\')">Run the deck again</button>';
    } else if (nxt){
      h += '<button type="button" class="primary" onclick="rhfcStart(\'' + nxt + '\')">' + RHFC_DECKS[nxt].title + ' &rarr;</button>';
      h += '<button type="button" onclick="rhfcStart(\'' + rhfcDeckId + '\')">Run this deck again</button>';
    } else {
      h += '<button type="button" class="primary" onclick="rhfcToRehearse()"> Rehearse the room</button>';
      h += '<button type="button" onclick="rhfcStart(\'' + rhfcDeckId + '\')">Run the deck again</button>';
    }
    h += '<button type="button" onclick="rhfcOpen()">All decks</button>';
    h += '</div>';
    /* Always an exit into the live act, even mid-track. */
    if (nxt || rhfcMissed.length){
      h += '<button type="button" class="rhfc-exit" onclick="rhfcToRehearse()">Done drilling &mdash; take it into the room</button>';
    }
    host.innerHTML = h;
    return;
  }

  /* card view */
  var card = rhfcQueue[rhfcI] || {};
  var done = rhfcI, total2 = rhfcQueue.length;
  var pctBar = total2 ? Math.round((done / total2) * 100) : 0;
  h += '<div class="rhfc-top"><div>' +
       '<div class="rhfc-tag">' + (rhfcDeckId === 'all' ? 'All decks &middot; shuffled' : 'The Whetstone') + '</div>' +
       '<div class="rhfc-title">' + (rhfcDeckId === 'all' ? (card.from || 'Rheumatology') : RHFC_DECKS[rhfcDeckId].title) + '</div>' +
       '</div><button type="button" class="rhfc-x" onclick="rhfcClose()" aria-label="Close">&#10005;</button></div>';
  h += '<div class="rhfc-prog"><i style="width:' + pctBar + '%"></i></div>';
  h += '<div class="rhfc-meta"><span>Card ' + Math.min(done + 1, total2) + ' of ' + total2 + '</span><span>' + rhfcRight + ' right</span></div>';

  h += '<div class="rhfc-face' + (rhfcFlipped ? ' flipped' : '') + ' rhfc-anim" onclick="rhfcFlip()">';
  if (!rhfcFlipped){
    h += '<div class="rhfc-side">Front</div><div class="rhfc-q">' + (card.q || '') + '</div>';
    if (card.hint) h += '<div class="rhfc-hint">Hint: ' + card.hint + '</div>';
    h += '<div class="rhfc-flipnote">Tap to flip</div>';
  } else {
    h += '<div class="rhfc-side">Answer</div><div class="rhfc-qsmall">' + (card.q || '') + '</div><div class="rhfc-a">' + (card.a || '') + '</div>';
    h += '<div class="rhfc-flipnote">Tap to go back</div>';
  }
  h += '</div>';

  if (!rhfcFlipped){
    h += '<button type="button" class="rhfc-reveal" onclick="rhfcFlip()">Show the answer</button>';
  } else {
    h += '<div class="rhfc-grade">' +
         '<button type="button" class="rhfc-g again" onclick="rhfcGrade(false)">&#8635; Again<small>Back of the pile</small></button>' +
         '<button type="button" class="rhfc-g got" onclick="rhfcGrade(true)">&#10003; Got it<small>Next card</small></button>' +
         '</div>';
  }
  h += '<div class="rhfc-foot">' +
       '<button type="button" class="rhfc-link" onclick="rhfcOpen()">&larr; All decks</button>' +
       '<span class="rhfc-keys"><kbd>Space</kbd> flip &middot; <kbd>1</kbd> again &middot; <kbd>2</kbd> got it &middot; <kbd>Esc</kbd> close</span>' +
       '</div>';
  host.innerHTML = h;
}

document.addEventListener('keydown', function(e){
  var o = document.getElementById('rhfc-overlay');
  if (!o || !o.classList.contains('on')) return;
  if (e.key === 'Escape'){ rhfcClose(); return; }
  if (rhfcMode !== 'card') return;
  if (e.key === ' ' || e.key === 'Enter'){ e.preventDefault(); rhfcFlip(); }
  else if (e.key === '1'){ if (rhfcFlipped) rhfcGrade(false); }
  else if (e.key === '2'){ if (rhfcFlipped) rhfcGrade(true); }
});

function rheumShowView(view, btn){
  ['playbook','training','pftsuite','estimator','composer','files'].forEach(function(v){
    var el = document.getElementById('rheum-view-' + v);
    if (el) el.style.display = (v === view) ? '' : 'none';
    var b = document.getElementById('rhsub-' + v);
    if (b) b.classList.toggle('on', v === view);
  });
  if (btn && btn.classList) { /* explicit button click already handled above */ }
  if (view === 'pftsuite') rhpsLoad();
  if (view === 'training') rhtrRenderTrack();
  if (view === 'files') m3RenderRheumFiles();
  if (view === 'composer') rhcInitSign();
  if (view === 'estimator' || view === 'composer') rhxRender(view);
}
/* ---- PFT Suite, folded in ----
   All 8 Suite pages are base64'd into PFTSUITE_FILES near the bottom of this file by
   _tools/build-pft-suite-inline.mjs. Nothing is fetched: each page is decoded to a
   Blob URL on demand, so the Suite works with the wifi off and inside the offline zip.
   The Suite's own pages link to each other with plain relative hrefs, so we inject a
   click-catcher into every page and swap the frame ourselves. Never edit the inlined
   block by hand — edit _deploy_pft_suite/ and re-run the build script. */
var RHPS_TITLES = {
  'index.html': 'The Trainer and all six pattern pages, built into this toolkit.',
  'MiniBox_PFT_Report_Studio_v1.0.html': 'PFT Report Studio &mdash; the live trainer.',
  'MiniBox_PFT_Training_Normal_v1.0.html': 'Pattern library &mdash; Normal.',
  'MiniBox_PFT_Training_Asthma_v1.0.html': 'Pattern library &mdash; Asthma.',
  'MiniBox_PFT_Training_COPD_v1.0.html': 'Pattern library &mdash; COPD / Emphysema.',
  'MiniBox_PFT_Training_ILD_v1.0.html': 'Pattern library &mdash; ILD / Pneumonitis.',
  'MiniBox_PFT_Training_ChestWall-Neuromuscular_v1.0.html': 'Pattern library &mdash; Chest-wall / Neuromuscular.',
  'MiniBox_PFT_Training_Mixed_v1.0.html': 'Pattern library &mdash; Mixed.'
};
var RHPS_STATE = { file:'', html:{} };
// The Suite pages are plain HTML with no back link of their own — standalone they rely
// on the browser's Back button, which an iframe doesn't give the rep. This shim hands
// navigation back to us so the "Suite menu" button can do that job instead.
var RHPS_SHIM = '<script>(function(){document.addEventListener("click",function(e){'
  + 'var n=e.target; while(n&&n.nodeName!=="A") n=n.parentNode;'
  + 'if(!n) return; var h=n.getAttribute("href")||"";'
  + 'if(!/\\.html$/i.test(h)||/^(https?:|\\/\\/)/i.test(h)) return;'
  + 'e.preventDefault(); parent.postMessage({__pftsuite:1,file:h},"*");'
  + '},true);})();<\/script>';
/* srcdoc, not a Blob URL: the offline zip is opened by double-clicking index.html,
   which makes the page a file:// origin where blob: iframes are unreliable. srcdoc
   behaves identically on file://, http:// and https://. */
function rhpsHtml(file){
  if (RHPS_STATE.html[file]) return RHPS_STATE.html[file];
  var b64 = (window.PFTSUITE_FILES || {})[file];
  if (!b64) return '';
  var bin = atob(b64), u8 = new Uint8Array(bin.length);
  for (var i = 0; i < bin.length; i++) u8[i] = bin.charCodeAt(i);
  var html = new TextDecoder('utf-8').decode(u8);
  html = html.replace(/<\/body>/i, RHPS_SHIM + '</body>');
  RHPS_STATE.html[file] = html;
  return html;
}
function rhpsOpen(file){
  var f = document.getElementById('rhps-iframe');
  if (!f) return;
  var html = rhpsHtml(file);
  if (!html) return;
  RHPS_STATE.file = file;
  f.srcdoc = html;
  var crumb = document.getElementById('rhps-crumb');
  if (crumb) crumb.innerHTML = RHPS_TITLES[file] || file;
  var back = document.getElementById('rhps-back');
  if (back) back.style.display = (file === 'index.html') ? 'none' : '';
}
function rhpsLoad(){
  if (!RHPS_STATE.file) rhpsOpen('index.html');
  // Reached from the Composer's "Teach them to read it" button we can be halfway
  // down the page, so put the Suite's top edge back under the rep's eyes.
  var w = document.querySelector('#tab-rheum .rhps-wrap');
  if (w) w.scrollIntoView({behavior:'smooth', block:'start'});
}
function rhpsPopOut(){
  // Pops the inlined copy, not the Vercel deploy, so full screen works offline too.
  var html = rhpsHtml(RHPS_STATE.file || 'index.html');
  if (!html) return;
  var w = window.open('', '_blank');
  if (!w) return;
  w.document.open(); w.document.write(html); w.document.close();
}
window.addEventListener('message', function(e){
  if (e.data && e.data.__pftsuite && e.data.file) rhpsOpen(String(e.data.file).replace(/^.*\//, ''));
});
var RHEUM_TOOL_IDS = ['calc-rheum', 'calc-pft-coding', 'calc-interp'];
function m3RenderRheumFiles(){
  var host = document.getElementById('rheum-files-grid');
  if (!host) return;
  var items = MATERIALS.filter(function(m){ return m.cat === 'rheum'; });
  var html = '<div class="m3-lib-grid">';
  items.forEach(function(m){
    html += '<div class="m3-lib-card">'
      + '<div class="m3-lib-title">' + m.title + ' <span class="m3-kb">' + m3SizeLabel(m.kb) + '</span></div>'
      + '<div class="m3-lib-sub">' + m.sub + '</div>'
      + '<div class="m3-lib-btns">'
      + (m3IsViewable(m.file) ? '<button onclick="m3View(\'' + m.id + '\')">&#128065; View</button>' : '')
      + '<button onclick="m3Download(\'' + m.id + '\')">&#11015; Download</button>'
      + '<button class="m3-mail" onclick="m3EmailThis(\'' + m.id + '\')">&#9993; Email it</button>'
      + '</div></div>';
  });
  html += '</div>';
  html += '<div style="margin:24px 0 4px;font-size:12px;font-weight:800;letter-spacing:.09em;text-transform:uppercase;color:#0a6075;">The three interactive tools &mdash; send a working copy</div>'
    + '<div style="font-size:12.5px;color:#3a5567;line-height:1.55;margin:0 0 12px;">The Estimator, the Billing Helper and the Interp Composer are each a single self-contained file. Email one and the practice opens it in any browser and uses it live &mdash; their own numbers, no internet needed, nothing installed.</div>'
    + m3RenderMatCards(RHEUM_TOOL_IDS);
  host.innerHTML = html;
}
function rheumEmailAll(){
  M3_STATE.easIds = MATERIALS.filter(function(m){ return m.cat === 'rheum'; }).map(function(m){ return m.id; }).concat(RHEUM_TOOL_IDS);
  showTab('emaillib', document.querySelector('.tab-btn[onclick*="emaillib"]'));
  m3RenderEasMaterials();
  setTimeout(function(){
    var eas = document.querySelector('.eas-wrap');
    if (eas) eas.scrollIntoView({behavior:'smooth', block:'start'});
    m3Toast('The whole rheum pack is loaded — 7 documents + 3 interactive tools. Fill in the doctor’s info and generate the email.');
  }, 120);
}

function cardioEmailAll(){
  M3_STATE.easIds = MATERIALS.filter(function(m){ return m.cat === 'cardio'; }).map(function(m){ return m.id; });
  showTab('emaillib', document.querySelector('.tab-btn[onclick*="emaillib"]'));
  m3RenderEasMaterials();
  setTimeout(function(){
    var eas = document.querySelector('.eas-wrap');
    if (eas) eas.scrollIntoView({behavior:'smooth', block:'start'});
    m3Toast('Cardiology one-pager loaded - fill in the doctor info and generate the email.');
  }, 120);
}

/* ============ PULMONOLOGY TAB — sub-view switch, files, calculators ============ */
/* Pulmonology is the core specialty: its materials live across the send/clinical/tech/calc
   categories rather than one 'pulmo' cat, so we surface them by explicit id list. */
var PULMO_DOC_IDS  = ['brochure','why','samplereport','comparison','chestsum','chestfull','verona','coaching','dlco','hl7','mds2','manual'];
var PULMO_CALC_IDS = ['calc-roi','calc-pft-coding'];
var PULMO_EMAIL_PACK = ['brochure','why','samplereport','comparison','chestsum'];

function pulmoShowView(view, btn){
  ['playbook','calcs','files'].forEach(function(v){
    var el = document.getElementById('pulmo-view-' + v);
    if (el) el.style.display = (v === view) ? '' : 'none';
    var b = document.getElementById('plsub-' + v);
    if (b) b.classList.toggle('on', v === view);
  });
  if (view === 'files') m3RenderPulmoFiles();
  if (view === 'calcs') m3RenderPulmoCalcs();
}
function m3RenderMatCards(ids){
  var html = '<div class="m3-lib-grid">';
  ids.forEach(function(id){
    var m = MATERIALS.filter(function(x){ return x.id === id; })[0];
    if (!m) return;
    var isHtml = /\.html?$/i.test(m.file);
    html += '<div class="m3-lib-card">'
      + '<div class="m3-lib-title">' + m.title + ' <span class="m3-kb">' + m3SizeLabel(m.kb) + '</span></div>'
      + '<div class="m3-lib-sub">' + m.sub + '</div>'
      + '<div class="m3-lib-btns">'
      + (m3IsViewable(m.file) ? '<button onclick="m3View(\'' + m.id + '\')">&#128065; ' + (isHtml ? 'Open' : 'View') + '</button>' : '')
      + '<button onclick="m3Download(\'' + m.id + '\')">&#11015; Download</button>'
      + (m.noembed ? '' : '<button class="m3-mail" onclick="m3EmailThis(\'' + m.id + '\')">&#9993; Email it</button>')
      + '</div></div>';
  });
  html += '</div>';
  return html;
}
function m3RenderPulmoFiles(){
  var host = document.getElementById('pulmo-files-grid');
  if (host) host.innerHTML = m3RenderMatCards(PULMO_DOC_IDS);
}
function m3RenderPulmoCalcs(){
  var host = document.getElementById('pulmo-calcs-grid');
  if (host) host.innerHTML = m3RenderMatCards(PULMO_CALC_IDS);
}
function pulmoEmailAll(){
  M3_STATE.easIds = PULMO_EMAIL_PACK.slice();
  showTab('emaillib', document.querySelector('.tab-btn[onclick*="emaillib"]'));
  m3RenderEasMaterials();
  setTimeout(function(){
    var eas = document.querySelector('.eas-wrap');
    if (eas) eas.scrollIntoView({behavior:'smooth', block:'start'});
    m3Toast('Core pulmonology pack loaded — fill in the doctor’s info and generate the email.');
  }, 120);
}

