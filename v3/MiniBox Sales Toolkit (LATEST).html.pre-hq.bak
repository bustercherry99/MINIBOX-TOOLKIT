<script id="mbx-qc-videos">
/* TRAINING VIDEOS IN THE QUICK COMPOSER — the videos were hidden from the attach list
   because they carry noembed (a size guard). Unlike every other material they are real
   files under materials/ rather than bytes baked into the page, so simply un-hiding them
   would have produced an email that said "video attached" with nothing attached. This
   block lists them, fetches the bytes at send time, and falls back to a download + drag
   when the fetch cannot happen (the offline copy). Self-contained + append-only. */
(function(){
  var WARN_MB = 20;                                  /* typical mailbox attachment cap */
  function isVid(m){ return !!m && m.cat === 'video'; }

  /* correct MIME so Outlook shows a video, not a generic file */
  if (typeof window.m3Mime === 'function'){
    var origMime = window.m3Mime;
    window.m3Mime = function(file){
      var f = String(file || '').toLowerCase();
      if (/\.mp4$/.test(f))  return 'video/mp4';
      if (/\.webm$/.test(f)) return 'video/webm';
      if (/\.(mov|m4v)$/.test(f)) return 'video/quicktime';
      return origMime(file);
    };
  }

  /* 1) list the videos in the attach picker */
  window.qcBuildAttachList = function(){
    var host = document.getElementById('qc-attach-list');
    if (!host || typeof MATERIALS === 'undefined') return;
    var html = '';
    M3_CAT_ORDER.forEach(function(cat){
      var items = MATERIALS.filter(function(m){ return m.cat === cat && (!m.noembed || isVid(m)); });
      if (!items.length) return;
      html += '<div class="qc-cat">' + (M3_CATS[cat] || cat) + '</div>';
      items.forEach(function(m){
        html += '<label class="qc-item">'
          + '<input type="checkbox" onchange="qcToggle(&#39;' + m.id + '&#39;, this.checked)"' + (QC_SEL[m.id] ? ' checked' : '') + '>'
          + '<span class="qc-item-t">' + m.title + '</span>'
          + '<span class="qc-item-kb">' + m3SizeLabel(m.kb) + '</span>'
          + '</label>';
      });
    });
    host.innerHTML = html;
  };

  /* 2) say something when the pack gets big enough to bounce */
  var origCount = window.qcUpdateCount;
  window.qcUpdateCount = function(){
    if (typeof origCount === 'function') origCount();
    var el = document.getElementById('qc-attach-count');
    if (!el) return;
    var ids = qcSelIds();
    if (ids.length && m3TotalKB(ids) / 1024 > WARN_MB){
      el.textContent += ' — large, some inboxes cap around ' + WARN_MB + ' MB';
    }
  };

  /* 3) load the real video bytes before the draft is built */
  function loadBytes(id){
    var m = m3ById(id);
    if (!m) return Promise.reject();
    return fetch('materials/' + encodeURI(m.file)).then(function(r){
      if (!r.ok) throw new Error('http ' + r.status);
      return r.blob();
    }).then(function(b){
      return new Promise(function(res, rej){
        var fr = new FileReader();
        fr.onload = function(){ var d = String(fr.result); MATERIALS_B64[id] = d.slice(d.indexOf(',') + 1); res(id); };
        fr.onerror = rej;
        fr.readAsDataURL(b);
      });
    });
  }

  var origOpen = window.openInOutlook;
  window.openInOutlook = function(){
    var missing = qcSelIds().filter(function(id){ return !m3HasData(id); });
    if (!missing.length || typeof MATERIALS_B64 === 'undefined'){ origOpen(); return; }
    m3Toast('Packing the video into your draft — one moment.', 4000);
    Promise.all(missing.map(function(id){
      return loadBytes(id).then(function(){ return null; }, function(){ return id; });
    })).then(function(failed){
      var bad = failed.filter(Boolean);
      if (!bad.length){ origOpen(); return; }
      /* could not pack them (offline copy): download those separately, draft the rest */
      var held = [];
      bad.forEach(function(id){ held.push(id); delete QC_SEL[id]; m3Download(id); });
      qcUpdateCount();
      origOpen();
      held.forEach(function(id){ QC_SEL[id] = true; });
      qcUpdateCount();
      m3Toast('The video saved to your device separately — drag it into the email before you send.', 9000);
    });
  };
})();
</script>
<script id="mbx-roi-autoheight">
/* Grow the ROI Proposal Builder iframes to fit their content. iOS Safari can't
   scroll inside a fixed-height iframe, so on a phone the bottom of the builder
   was unreachable once Finance/Lease sections expanded past the hard 1650px.
   The builder posts its real height; we match it here so the PAGE scrolls. */
(function(){
  function fit(sourceWin, h){
    var frames = document.querySelectorAll('#roi-builder-iframe, #roi-builder-forms-iframe');
    for (var i = 0; i < frames.length; i++){
      var f = frames[i];
      if (f.contentWindow === sourceWin){
        f.style.height = (h + 4) + 'px';
        return;
      }
    }
  }
  window.addEventListener('message', function(e){
    var d = e && e.data;
    if (d && typeof d === 'object' && typeof d.mbxRoiHeight === 'number' && d.mbxRoiHeight > 200){
      fit(e.source, d.mbxRoiHeight);
    }
  });
})();
</script>
<script id="mbx-hidden-admin">
/* HIDDEN ADMIN DOOR (2026-07-21)
   The Command Center tab is invisible by default — nothing in the nav hints it
   exists. Three silent ways in, for the few people who are told:
       - tap the PulmOne logo 5 times within 3 seconds   (phone / iPad)
       - Ctrl+Shift+9                                    (desktop)
       - open the app with  ?vault=1                     (a link you hand out)
   Repeating the tap or the chord puts it back into hiding. The reveal is
   remembered per device, so someone who knows the gesture only does it once.

   This hides the DOOR, not the DATA. reports.html still demands the second
   password and the SERVER checks it (api/admin.js), so anyone who stumbles on
   the gesture still lands on a lock screen. Two walls, not one. */
(function () {
  var KEY      = 'mbx_cc_unhidden';
  var NEEDED   = 5;         // taps
  var WINDOW   = 3000;      // ms they must land inside
  var taps     = [];

  function btn()  { return document.getElementById('mbx-cc-tabbtn'); }
  function on()   { try { return localStorage.getItem(KEY) === '1'; } catch (e) { return false; } }
  function paint(v) { var b = btn(); if (b) b.style.display = v ? '' : 'none'; }

  function say(msg) {
    var t = document.getElementById('mbx-vault-toast');
    if (!t) {
      t = document.createElement('div');
      t.id = 'mbx-vault-toast';
      t.style.cssText = 'position:fixed;left:50%;bottom:26px;transform:translateX(-50%);' +
        'z-index:99999;background:#12161b;color:#dfe6ec;border:1px solid #2a323b;' +
        'border-radius:8px;padding:10px 16px;font-size:12.5px;letter-spacing:.02em;' +
        'font-family:var(--mono,ui-monospace,monospace);box-shadow:0 6px 24px rgba(0,0,0,.45);' +
        'opacity:0;transition:opacity .18s;pointer-events:none;';
      document.body.appendChild(t);
    }
    t.textContent = msg;
    t.style.opacity = '1';
    clearTimeout(t._h);
    t._h = setTimeout(function () { t.style.opacity = '0'; }, 2200);
  }

  /* Reveal and walk straight into it — the gesture IS the request to open it. */
  function reveal(quiet) {
    try { localStorage.setItem(KEY, '1'); } catch (e) {}
    paint(true);
    if (!quiet) {
      say('Command Center unlocked');
      var b = btn();
      if (b) setTimeout(function () { b.click(); }, 120);
    }
  }
  function conceal() {
    try { localStorage.removeItem(KEY); } catch (e) {}
    paint(false);
    say('Command Center hidden');
  }
  function toggle() { on() ? conceal() : reveal(); }

  /* --- trigger 1: five taps on the logo --- */
  document.addEventListener('DOMContentLoaded', function () {
    if (on()) paint(true);
    var logo = document.querySelector('.tk-logo');
    if (!logo) return;
    logo.style.cursor = 'default';            // gives nothing away
    logo.addEventListener('click', function () {
      var now = new Date().getTime();
      taps.push(now);
      taps = taps.filter(function (t) { return now - t < WINDOW; });
      if (taps.length >= NEEDED) { taps = []; toggle(); }
    });
  });

  /* --- trigger 2: Ctrl+Shift+9 --- */
  document.addEventListener('keydown', function (e) {
    if (!e.ctrlKey || !e.shiftKey) return;
    if (e.key !== '9' && e.code !== 'Digit9') return;
    e.preventDefault();
    toggle();
  });

  /* --- trigger 3: ?vault=1, then scrub it out of the address bar so it does
         not survive in history, a screenshot, or a shared link. --- */
  (function () {
    var qs;
    try { qs = new URLSearchParams(location.search); } catch (e) { return; }
    if (qs.get('vault') !== '1') return;
    reveal(true);
    qs.delete('vault');
    if (history.replaceState) {
      history.replaceState(null, '',
        location.pathname + (qs.toString() ? '?' + qs.toString() : '') + location.hash);
    }
    document.addEventListener('DOMContentLoaded', function () {
      setTimeout(function () { var b = btn(); if (b) b.click(); }, 200);
    });
  })();

  /* --- and shut the generic deep-link door: ?tab=command must not work for
         anyone who has not been let in. --- */
  if (typeof window.mbxOpenTab === 'function') {
    var orig = window.mbxOpenTab;
    window.mbxOpenTab = function (id) {
      if (String(id).toLowerCase() === 'command' && !on()) return false;
      return orig.apply(this, arguments);
    };
  }
})();
</script>
